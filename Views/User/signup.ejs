<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>ShopEasy · Secure Signup | Premium Account</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    :root {
      --primary: #ff6b6b;
      --secondary: #4ecdc4;
      --accent: #ffe66d;
      --dark: #2c3e50;
      --light: #f7f9fc;
      --white: #ffffff;
      --gradient-1: linear-gradient(135deg, #ff6b6b, #ee5a24);
      --gradient-2: linear-gradient(135deg, #4ecdc4, #44bd32);
      --gradient-3: linear-gradient(135deg, #a55eea, #8854d0);
      --shadow-soft: 0 10px 40px rgba(0, 0, 0, 0.08);
      --shadow-hover: 0 20px 50px rgba(0, 0, 0, 0.15);
      --transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    }

    body {
      background: #f0f3f8;
      color: var(--dark);
      overflow-x: hidden;
    }

    .particles-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -1;
    }

    .particle {
      position: absolute;
      border-radius: 50%;
      animation: particleFloat 15s infinite ease-in-out;
      opacity: 0.3;
    }

    @keyframes particleFloat {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      25% { transform: translate(80px, -60px) rotate(90deg); }
      50% { transform: translate(-40px, 40px) rotate(180deg); }
      75% { transform: translate(-70px, -30px) rotate(270deg); }
    }

    .header-premium {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      padding: 12px 0;
      position: sticky;
      top: 0;
      z-index: 1030;
      transition: var(--transition);
    }

    .header-premium.scrolled {
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
      padding: 8px 0;
    }

    .brand-premium {
      font-size: 2.2rem;
      font-weight: 900;
      background: var(--gradient-1);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      letter-spacing: -1px;
      transition: var(--transition);
      text-decoration: none;
    }

    .nav-icon-premium {
      position: relative;
      color: #666;
      font-size: 1.4rem;
      margin-left: 22px;
      transition: var(--transition);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
    }

    .nav-icon-premium:hover {
      color: var(--primary);
      transform: translateY(-2px);
    }

    .cart-badge-premium {
      position: absolute;
      top: -10px;
      right: -14px;
      background: var(--gradient-1);
      color: white;
      border-radius: 50%;
      width: 24px;
      height: 24px;
      font-size: 0.7rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    .signup-section {
      min-height: calc(100vh - 200px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 20px;
    }

    .signup-card-premium {
      background: white;
      border-radius: 40px;
      box-shadow: var(--shadow-soft);
      overflow: hidden;
      transition: var(--transition);
      max-width: 550px;
      width: 100%;
      border: none;
      animation: fadeInUp 0.8s ease-out;
    }

    .signup-card-premium:hover {
      box-shadow: var(--shadow-hover);
      transform: translateY(-8px);
    }

    .signup-header-premium {
      background: var(--gradient-2);
      padding: 35px 30px;
      text-align: center;
      color: white;
    }

    .signup-header-premium i {
      font-size: 4rem;
      background: rgba(255, 255, 255, 0.2);
      padding: 20px;
      border-radius: 80px;
      margin-bottom: 20px;
      backdrop-filter: blur(10px);
      animation: iconPulse 2s infinite;
    }

    @keyframes iconPulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    .signup-header-premium h3 {
      font-weight: 800;
      font-size: 1.8rem;
      margin-bottom: 8px;
    }

    .signup-header-premium p {
      opacity: 0.9;
      font-size: 0.9rem;
    }

    .signup-body-premium {
      padding: 40px 35px;
    }

    .input-group-premium {
      margin-bottom: 22px;
      position: relative;
    }

    .input-group-premium label {
      font-weight: 700;
      font-size: 0.85rem;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--dark);
    }

    .input-group-premium label i { color: var(--primary); }

    .input-group-premium input {
      width: 100%;
      padding: 14px 48px 14px 20px;
      border: 2px solid #e8ecf1;
      border-radius: 60px;
      font-size: 0.95rem;
      transition: var(--transition);
      outline: none;
      background: white;
    }

    .input-group-premium input:focus {
      border-color: var(--primary);
      box-shadow: 0 5px 20px rgba(255, 107, 107, 0.15);
      transform: scale(1.02);
    }

    .input-group-premium input:disabled {
      background: #f8f9fc;
      cursor: not-allowed;
      opacity: 0.7;
    }

    .verified-badge {
      position: absolute;
      right: 20px;
      top: 50%;
      transform: translateY(-50%);
      color: #2ed573;
      font-size: 1.1rem;
      pointer-events: none;
    }

    .password-wrapper { position: relative; }

    .toggle-password {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #999;
      font-size: 1.2rem;
      transition: var(--transition);
      z-index: 10;
      background: none;
      border: none;
      padding: 4px;
      line-height: 1;
    }

    .toggle-password:hover { color: var(--primary); }

    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 25px;
    }

    .checkbox-group input { width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary); }
    .checkbox-group label { font-size: 0.85rem; color: #666; cursor: pointer; }
    .checkbox-group a { color: var(--primary); text-decoration: none; font-weight: 600; }
    .checkbox-group a:hover { text-decoration: underline; }

    .btn-signup-premium {
      background: var(--gradient-2);
      border: none;
      padding: 14px;
      border-radius: 60px;
      font-weight: 800;
      font-size: 1.1rem;
      width: 100%;
      color: white;
      transition: var(--transition);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .btn-signup-premium:hover:not(:disabled) {
      transform: translateY(-3px);
      filter: brightness(1.05);
      box-shadow: 0 15px 30px rgba(78, 205, 196, 0.3);
    }

    .btn-signup-premium:disabled { opacity: 0.6; cursor: not-allowed; }

    .divider-premium {
      display: flex;
      align-items: center;
      text-align: center;
      margin: 25px 0;
      color: #aaa;
      font-size: 0.85rem;
    }

    .divider-premium::before,
    .divider-premium::after {
      content: '';
      flex: 1;
      border-bottom: 1px solid #e0e4e9;
    }
    .divider-premium::before { margin-right: 15px; }
    .divider-premium::after { margin-left: 15px; }

    .social-signup {
      display: flex;
      justify-content: center;
      gap: 15px;
      margin-bottom: 25px;
    }

    .social-btn {
      width: 52px;
      height: 52px;
      border-radius: 60px;
      background: #f8f9fc;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #555;
      font-size: 1.4rem;
      transition: var(--transition);
      cursor: pointer;
      text-decoration: none;
      border: 1px solid #e8ecf1;
    }

    .social-btn:hover {
      background: var(--gradient-2);
      color: white;
      transform: translateY(-5px);
      border-color: transparent;
      box-shadow: 0 10px 25px rgba(78, 205, 196, 0.2);
    }

    .login-link {
      text-align: center;
      font-size: 0.9rem;
    }

    .login-link a { color: var(--primary); font-weight: 700; text-decoration: none; }
    .login-link a:hover { text-decoration: underline; }

    /* ---------- SUCCESS OVERLAY ---------- */
    .success-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(10px);
      z-index: 3000;
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
    }

    .success-overlay.show { display: flex; }

    .animation-container {
      position: relative;
      width: 220px;
      height: 220px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .success-message {
      color: white;
      font-size: 1.4rem;
      font-weight: 700;
      text-align: center;
      animation: fadeInUp 0.5s ease forwards;
      opacity: 0;
    }

    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* signup success animation */
    .signup-animation .circle-check {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: var(--gradient-2);
      position: absolute;
      animation: popIn 0.5s ease forwards;
    }

    .signup-animation .checkmark {
      position: absolute;
      color: white;
      font-size: 50px;
      animation: drawCheck 0.6s 0.4s ease forwards;
      opacity: 0;
    }

    @keyframes popIn {
      0% { transform: scale(0); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes drawCheck {
      0% { opacity: 0; transform: scale(0.5); }
      100% { opacity: 1; transform: scale(1); }
    }

    /* ---------- NOTIFICATION MODAL ---------- */
    .modal-premium { z-index: 3500 !important; }
    .modal-premium + .modal-backdrop { z-index: 3499 !important; }
    .modal-premium .modal-content {
      border-radius: 28px;
      border: none;
      box-shadow: 0 30px 80px rgba(0,0,0,0.25);
      animation: modalBounceIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
    }
    @keyframes modalBounceIn {
      from { opacity: 0; transform: scale(0.85) translateY(-30px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .modal-premium .modal-header {
      border-bottom: none;
      padding: 25px 24px 5px;
      text-align: center;
      display: block;
    }
    .modal-icon-circle {
      width: 65px;
      height: 65px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 12px;
      color: white;
    }
    .modal-icon-circle.success { background: var(--gradient-2); }
    .modal-icon-circle.error { background: var(--gradient-1); }
    .modal-icon-circle.warning { background: linear-gradient(135deg, #f39c12, #e67e22); }
    .modal-icon-circle.info { background: linear-gradient(135deg, #667eea, #764ba2); }
    .modal-premium .modal-body {
      padding: 5px 24px 18px;
      text-align: center;
      font-size: 0.95rem;
      color: #555;
    }
    .modal-message-title {
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--dark);
      margin-bottom: 5px;
    }
    .modal-premium .modal-footer {
      border-top: none;
      padding: 0 24px 22px;
      justify-content: center;
      gap: 10px;
    }
    .btn-modal-action {
      padding: 10px 26px;
      border-radius: 50px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      font-size: 0.9rem;
      transition: all 0.2s;
    }
    .btn-modal-primary { background: var(--gradient-1); color: white; }
    .btn-modal-primary:hover { filter: brightness(1.1); }
    .btn-modal-secondary { background: #f0f0f0; color: #333; }
    .btn-modal-secondary:hover { background: #e0e0e0; }

    .footer-premium {
      background: #1a1a2e;
      color: #aab;
      padding: 60px 0 25px;
    }
    .footer-premium h6 { color: white; font-weight: 800; margin-bottom: 20px; }
    .footer-premium a { color: #889; text-decoration: none; display: block; margin-bottom: 12px; transition: var(--transition); font-size: 0.9rem; }
    .footer-premium a:hover { color: var(--primary); padding-left: 8px; }
    .social-circle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 45px;
      height: 45px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
      margin-right: 12px;
      color: white;
      text-decoration: none;
      transition: var(--transition);
    }
    .social-circle:hover {
      background: var(--gradient-1);
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(255,107,107,0.4);
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
    .shake-animation { animation: shake 0.3s ease-in-out; }

    @media (max-width: 576px) {
      .brand-premium { font-size: 1.8rem; }
      .nav-icon-premium { font-size: 1.2rem; margin-left: 12px; }
      .signup-body-premium { padding: 30px 20px; }
      .signup-header-premium { padding: 25px 20px; }
      .signup-header-premium i { font-size: 3rem; padding: 15px; }
      .signup-header-premium h3 { font-size: 1.4rem; }
    }
  </style>
</head>

<body>
  <div class="particles-container" id="particlesContainer"></div>

  <!-- SUCCESS ANIMATION OVERLAY -->
  <div class="success-overlay" id="successOverlay">
    <div class="animation-container" id="animationContainer"></div>
    <div class="success-message" id="successMessage">Success!</div>
  </div>

  <!-- NOTIFICATION MODAL -->
  <div class="modal fade modal-premium" id="notificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <div class="modal-icon-circle" id="modalIconCircle"></div>
        </div>
        <div class="modal-body">
          <div class="modal-message-title" id="modalTitle"></div>
          <p class="mb-0" id="modalMessage"></p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-modal-action btn-modal-primary" id="modalPrimaryBtn" data-bs-dismiss="modal">OK</button>
          <button type="button" class="btn-modal-action btn-modal-secondary" id="modalSecondaryBtn" style="display:none;" data-bs-dismiss="modal">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <header class="header-premium" id="header">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center">
        <a href="#" class="brand-premium">ShopEasy</a>
        <div class="d-flex align-items-center">
          <a href="#" class="nav-icon-premium"><i class="fas fa-user-circle"></i></a>
          <a href="#" class="nav-icon-premium"><i class="fas fa-heart"></i></a>
          <a href="#" class="nav-icon-premium position-relative">
            <i class="fas fa-shopping-bag"></i>
            <span class="cart-badge-premium" id="cartCount">0</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <div class="container">
    <div class="signup-section">
      <div class="signup-card-premium">
        <div class="signup-header-premium">
          <i class="fas fa-user-plus"></i>
          <h3>Create Account</h3>
          <p>Join ShopEasy and start shopping</p>
        </div>
        <div class="signup-body-premium">
          <form id="signupForm">
            <div class="input-group-premium">
              <label><i class="fas fa-user"></i> Full Name *</label>
              <input type="text" id="fullName" name="fullName" placeholder="John Doe" required autocomplete="name">
            </div>
            <div class="input-group-premium" id="emailGroup">
              <label><i class="fas fa-envelope"></i> Email Address *</label>
              <input type="email" id="email" name="email" placeholder="hello@shopeasy.com" required autocomplete="email">
              <span class="verified-badge" id="verifiedBadge" style="display: none;"><i class="fas fa-check-circle"></i></span>
            </div>
            <div class="input-group-premium">
              <label><i class="fas fa-phone"></i> Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="+1 234 567 8900" autocomplete="tel" minlength="10" maxlength="12">
              <small class="text-muted" style="font-size:0.7rem; margin-left:15px;">Optional but recommended</small>
            </div>
            <div class="input-group-premium">
              <label><i class="fas fa-lock"></i> Password *</label>
              <div class="password-wrapper">
                <input type="password" id="password" name="password" placeholder="Min. 6 chars, 1 uppercase, 1 number" required autocomplete="new-password">
                <i class="fas fa-eye toggle-password" data-target="password" title="Show password"></i>
              </div>
              <div id="passwordStrength" class="strength-meter"></div>
            </div>
            <div class="input-group-premium">
              <label><i class="fas fa-check-circle"></i> Confirm Password *</label>
              <div class="password-wrapper">
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm your password" required autocomplete="off">
                <i class="fas fa-eye toggle-password" data-target="confirmPassword" title="Show password"></i>
              </div>
            </div>
            <div class="checkbox-group">
              <input type="checkbox" id="termsCheckbox">
              <label>I agree to the <a href="#" id="termsLink">Terms of Service</a> and <a href="#" id="privacyLink">Privacy Policy</a> *</label>
            </div>
            <button type="submit" class="btn-signup-premium" id="signupBtn">
              <i class="fas fa-arrow-right-to-bracket"></i> Sign Up
            </button>
          </form>
          <div class="divider-premium">OR SIGN UP WITH</div>
          <div class="social-signup">
            <a href="#" class="social-btn" id="googleSignup"><i class="fab fa-google"></i></a>
            <a href="#" class="social-btn" id="facebookSignup"><i class="fab fa-facebook-f"></i></a>
            <a href="#" class="social-btn" id="appleSignup"><i class="fab fa-apple"></i></a>
          </div>
          <div class="login-link">
            Already have an account? <a href="#" id="loginLink">Sign In</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer-premium">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-3 col-6">
          <h6>ShopEasy</h6><a href="#">Our Story</a><a href="#">Careers</a><a href="#">Press</a>
        </div>
        <div class="col-md-3 col-6">
          <h6>Support</h6><a href="#">Help Center</a><a href="#">Shipping Info</a><a href="#">Returns</a>
        </div>
        <div class="col-md-3 col-6">
          <h6>Account</h6><a href="#">My Orders</a><a href="#">Wishlist</a><a href="#">Profile</a>
        </div>
        <div class="col-md-3 col-6">
          <h6>Connect</h6>
          <div>
            <a href="#" class="social-circle"><i class="fab fa-facebook-f"></i></a>
            <a href="#" class="social-circle"><i class="fab fa-instagram"></i></a>
            <a href="#" class="social-circle"><i class="fab fa-pinterest"></i></a>
          </div>
        </div>
      </div>
      <div class="text-center mt-5 pt-4 border-top border-secondary">© 2025 ShopEasy Premium. All rights reserved.</div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function () {
      const API_BASE_URL = window.location.origin; // or 'http://localhost:3000'

      // ---------- PREMIUM POP-UP MODAL ----------
      const notifModal = document.getElementById('notificationModal');
      const bsNotifModal = notifModal ? new bootstrap.Modal(notifModal, { backdrop: 'static' }) : null;
      function showModal(type, title, msg, opts = {}) {
        if (!bsNotifModal) return;
        const map = {
          success: { cls: 'success', icon: 'fa-check-circle' },
          error: { cls: 'error', icon: 'fa-times-circle' },
          warning: { cls: 'warning', icon: 'fa-exclamation-triangle' },
          info: { cls: 'info', icon: 'fa-info-circle' }
        };
        const cfg = map[type] || map.info;
        document.getElementById('modalIconCircle').className = 'modal-icon-circle ' + cfg.cls;
        document.getElementById('modalIconCircle').innerHTML = `<i class="fas ${cfg.icon}"></i>`;
        document.getElementById('modalTitle').textContent = title;
        document.getElementById('modalMessage').textContent = msg;

        const pri = document.getElementById('modalPrimaryBtn');
        pri.textContent = opts.primaryText || 'OK';
        pri.style.display = 'inline-block';
        pri.onclick = () => { opts.onPrimary?.(); bsNotifModal.hide(); };

        const sec = document.getElementById('modalSecondaryBtn');
        let secondaryText = opts.secondaryText;
        if (secondaryText === undefined) secondaryText = 'Cancel';
        if (secondaryText) {
          sec.textContent = secondaryText;
          sec.style.display = 'inline-block';
          sec.onclick = () => { opts.onSecondary?.(); bsNotifModal.hide(); };
        } else {
          sec.style.display = 'none';
        }
        bsNotifModal.show();
        if (opts.autoHide) setTimeout(() => bsNotifModal.hide(), opts.autoHide);
      }

      // ---------- SUCCESS ANIMATION OVERLAY ----------
      function showSuccessAnimation() {
        const overlay = document.getElementById('successOverlay');
        const container = document.getElementById('animationContainer');
        const msgEl = document.getElementById('successMessage');
        container.innerHTML = `
          <div class="signup-animation" style="position:relative;width:100%;height:100%">
            <div class="circle-check"></div>
            <div class="checkmark"><i class="fas fa-check"></i></div>
          </div>`;
        msgEl.textContent = 'Account Created Successfully!';
        overlay.classList.add('show');
        setTimeout(() => {
          window.location.href = '/';
        }, 2500);
      }

      // ---------- PARTICLES ----------
      const particlesContainer = document.getElementById('particlesContainer');
      for (let i = 0; i < 25; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        const size = Math.random() * 30 + 10;
        p.style.width = size + 'px'; p.style.height = size + 'px';
        p.style.background = ['#ff6b6b', '#4ecdc4', '#ffe66d', '#a55eea'][Math.floor(Math.random() * 4)];
        p.style.left = Math.random() * 100 + '%'; p.style.top = Math.random() * 100 + '%';
        p.style.animationDelay = Math.random() * 10 + 's';
        p.style.animationDuration = (Math.random() * 10 + 15) + 's';
        particlesContainer.appendChild(p);
      }

      // header scroll
      const header = document.getElementById('header');
      window.addEventListener('scroll', () => header.classList.toggle('scrolled', window.scrollY > 50));

      // ---------- FETCH VERIFIED EMAIL ----------
      async function fetchVerifiedEmail() {
        try {
          const response = await fetch(`${API_BASE_URL}/verified-email`, {
            method: 'GET',
            credentials: 'include'
          });
          const data = await response.json();
          if (data.success && data.data && data.data.email) {
            const emailInput = document.getElementById('email');
            const verifiedBadge = document.getElementById('verifiedBadge');
            emailInput.value = data.data.email;
            emailInput.readOnly = true;
            verifiedBadge.style.display = 'inline';
            showModal('success', 'Email Verified', `Your email ${data.data.email} is verified.`);
            return true;
          } else {
            // Not verified – show warning and redirect to verification page
            showModal('warning', 'Email Verification Required', 'Please verify your email first. Redirecting to verification page...', {
              autoHide: 2500,
              onPrimary: () => { window.location.href = '/verify-otp'; }
            });
            setTimeout(() => {
              window.location.href = '/verify-otp';
            }, 3000);
            return false;
          }
        } catch (error) {
          showModal('error', 'Server Error', 'Could not check email verification status. Please try again later.');
          return false;
        }
      }

      // Call on page load
      window.addEventListener('DOMContentLoaded', () => {
        fetchVerifiedEmail();
      });

      // ---------- PASSWORD TOGGLE ----------
      document.querySelectorAll('.toggle-password').forEach(icon => {
        icon.addEventListener('click', function () {
          const targetId = this.getAttribute('data-target');
          const input = document.getElementById(targetId);
          if (input) {
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            this.classList.toggle('fa-eye', !isPassword);
            this.classList.toggle('fa-eye-slash', isPassword);
          }
        });
      });

      // ---------- VALIDATION ----------
      function validateFullName(name) { return name && name.trim().length >= 2 && name.trim().length <= 50; }
      function validateEmail(email) { return /^\S+@\S+\.\S+$/.test(email); }
      function validatePhone(phone) { if (!phone) return true; return /^[0-9+\-\s]{10,15}$/.test(phone); }
      function validatePassword(pwd) { return pwd.length >= 6 && /[A-Z]/.test(pwd) && /[a-z]/.test(pwd) && /\d/.test(pwd); }
      function validateConfirm(pwd, confirm) { return pwd === confirm; }

      function shakeElement(el) { el.classList.add('shake-animation'); setTimeout(() => el.classList.remove('shake-animation'), 300); }

      // password strength
      const passwordInput = document.getElementById('password');
      const strengthDiv = document.getElementById('passwordStrength');
      if (passwordInput && strengthDiv) {
        passwordInput.addEventListener('input', () => {
          const val = passwordInput.value;
          if (!val) { strengthDiv.innerHTML = ''; return; }
          let score = 0;
          if (val.length >= 6) score++;
          if (val.length >= 8) score++;
          if (/[A-Z]/.test(val)) score++;
          if (/[a-z]/.test(val)) score++;
          if (/[0-9]/.test(val)) score++;
          let text = 'Weak', color = '#ff4757';
          if (score >= 4) { text = 'Medium'; color = '#ffa502'; }
          if (score >= 5) { text = 'Strong'; color = '#2ed573'; }
          strengthDiv.innerHTML = `<span style="color:${color};">●</span><span style="color:#666;font-weight:500;"> Password Strength: ${text}</span>`;
        });
      }

      // ---------- FORM SUBMISSION ----------
      const signupForm = document.getElementById('signupForm');
      const fullNameInput = document.getElementById('fullName');
      const emailInput = document.getElementById('email');
      const phoneInput = document.getElementById('phone');
      const confirmPasswordInput = document.getElementById('confirmPassword');
      const termsCheckbox = document.getElementById('termsCheckbox');
      const signupBtn = document.getElementById('signupBtn');

      signupForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fullName = fullNameInput.value.trim();
        const email = emailInput.value.trim();
        const phone = phoneInput.value.trim() || null;
        const password = passwordInput.value;
        const confirm = confirmPasswordInput.value;
        const terms = termsCheckbox.checked;

        if (!validateFullName(fullName)) { showModal('warning', 'Invalid Name', 'Full name must be 2-50 characters.'); shakeElement(fullNameInput); return; }
        if (!validateEmail(email)) { showModal('warning', 'Invalid Email', 'Enter a valid email address.'); shakeElement(emailInput); return; }
        if (phone && !validatePhone(phone)) { showModal('warning', 'Invalid Phone', 'Phone must be 10-15 digits.'); shakeElement(phoneInput); return; }
        if (!validatePassword(password)) { showModal('warning', 'Weak Password', 'Password must be at least 6 chars with uppercase, lowercase, number.'); shakeElement(passwordInput); return; }
        if (!validateConfirm(password, confirm)) { showModal('warning', 'Mismatch', 'Passwords do not match.'); shakeElement(confirmPasswordInput); return; }
        if (!terms) { showModal('warning', 'Terms Required', 'You must accept the Terms of Service.'); shakeElement(termsCheckbox); return; }

        signupBtn.disabled = true;
        const originalHtml = signupBtn.innerHTML;
        signupBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Creating account...';

        try {
          const response = await fetch(`${API_BASE_URL}/signup`, {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fullName, email, phone, password, confirmPassword: confirm, termsAccepted: true })
          });
          const data = await response.json();
          if (data.success) {
            showSuccessAnimation();
          } else {
            showModal('error', 'Signup Failed', data.message || 'Could not create account.');
          }
        } catch (err) {
          showModal('error', 'Network Error', 'Please check your connection.');
        } finally {
          signupBtn.disabled = false;
          signupBtn.innerHTML = originalHtml;
        }
      });

      // social / link handlers
      document.getElementById('googleSignup')?.addEventListener('click', e => { e.preventDefault(); showModal('info', 'Google Signup', 'Premium integration ready.'); });
      document.getElementById('facebookSignup')?.addEventListener('click', e => { e.preventDefault(); showModal('info', 'Facebook Signup', 'Premium integration ready.'); });
      document.getElementById('appleSignup')?.addEventListener('click', e => { e.preventDefault(); showModal('info', 'Apple Signup', 'Premium integration ready.'); });
      document.getElementById('loginLink')?.addEventListener('click', e => { e.preventDefault(); showModal('info', 'Login', 'Redirecting to login...'); });
      document.getElementById('termsLink')?.addEventListener('click', e => { e.preventDefault(); showModal('info', 'Terms', 'Full terms of service.'); });
      document.getElementById('privacyLink')?.addEventListener('click', e => { e.preventDefault(); showModal('info', 'Privacy', 'Privacy policy details.'); });
    })();
  </script>
</body>

</html>