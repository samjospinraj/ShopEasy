                        <div class="activity-item"><div class="activity-icon"><i class="fas fa-user"></i></div><div class="activity-desc"><strong>Updated customer details</strong> for Linda Zhao · <span class="activity-time">3 days ago</span></div></div>
                        <div class="activity-item"><div class="activity-icon"><i class="fas fa-cog"></i></div><div class="activity-desc"><strong>Changed store settings</strong> (tax rules) · <span class="activity-time">Mar 12</span></div></div>
                        <div class="activity-item"><div class="activity-icon"><i class="fas fa-file-alt"></i></div><div class="activity-desc"><strong>Generated sales report</strong> Q1 2025 · <span class="activity-time">Mar 10</span></div></div>
                    </div>
