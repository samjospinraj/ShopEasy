                    <div class="filter-input-group date-range-group"><i class="fas fa-calendar"></i><input type="date" id="dateFrom"><span class="date-separator">to</span><input type="date" id="dateTo"></div>
                    <div class="active-filter-tag" id="activeFilterTag">All orders <span class="clear-filter" id="clearFilter"><i class="fas fa-times-circle"></i></span></div>
