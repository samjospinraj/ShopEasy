<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>ShopEasy · Curated Premium Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5a24;
            --secondary: #4ecdc4;
            --accent: #ffe66d;
            --dark: #1e2a3e;
            --light: #f8fafd;
            --white: #ffffff;
            --gradient-1: linear-gradient(135deg, #ff6b6b, #ee5a24);
            --gradient-2: linear-gradient(135deg, #4ecdc4, #44bd32);
            --gradient-3: linear-gradient(135deg, #a55eea, #8854d0);
            --shadow-soft: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
            --shadow-hover: 0 35px 60px -15px rgba(0, 0, 0, 0.25);
            --transition: all 0.4s cubic-bezier(0.2, 0.95, 0.4, 1.05);
            --neon-glow: 0 0 40px rgba(78, 205, 196, 0.5), 0 0 80px rgba(255, 107, 107, 0.25);
            --glass-border: rgba(255, 255, 255, 0.35);
        }

        body {
            background: linear-gradient(145deg, #eef2f7 0%, #e2e8f0 100%);
            color: var(--dark);
            overflow-x: hidden;
            position: relative;
        }

        .mesh-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background: radial-gradient(circle at 20% 30%, rgba(255, 107, 107, 0.08) 0%, rgba(78, 205, 196, 0.05) 50%, rgba(255, 230, 109, 0.03) 100%);
        }

        .animated-blob {
            position: fixed;
            width: 50vw;
            height: 50vw;
            background: radial-gradient(circle, rgba(255, 107, 107, 0.2), rgba(78, 205, 196, 0.05));
            border-radius: 62% 38% 72% 28% / 44% 56% 44% 56%;
            filter: blur(80px);
            z-index: -1;
            animation: blobMove 25s infinite alternate ease-in-out;
        }

        @keyframes blobMove {
            0% { transform: translate(-10%, -10%) rotate(0deg); }
            100% { transform: translate(10%, 15%) rotate(10deg); }
        }

        .header-premium {
            background: rgba(255, 255, 255, 0.72);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.5);
            padding: 16px 0;
            position: sticky;
            top: 0;
            z-index: 1030;
            transition: all 0.3s ease;
        }

        .header-premium.scrolled {
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
            padding: 10px 0;
        }

        .brand-premium {
            font-size: 2rem;
            font-weight: 800;
            background: var(--gradient-1);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.5px;
            transition: transform 0.2s;
            text-decoration: none;
        }

        .brand-premium:hover { transform: scale(1.02); filter: brightness(1.05); }

        .nav-icon-premium {
            position: relative;
            color: #2d3e50;
            font-size: 1.4rem;
            margin-left: 28px;
            transition: var(--transition);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            text-decoration: none;
        }

        .nav-icon-premium:hover { color: var(--primary); transform: translateY(-3px); }

        .cart-badge-premium {
            position: absolute;
            top: -10px; right: -14px;
            background: var(--gradient-1);
            color: white;
            border-radius: 40px;
            width: 22px; height: 22px;
            font-size: 0.7rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            box-shadow: 0 4px 10px rgba(255,107,107,0.4);
        }

        .login-section {
            min-height: calc(100vh - 180px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 50px 20px;
        }

        .login-card-premium {
            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(2px);
            border-radius: 56px;
            box-shadow: var(--shadow-soft);
            overflow: hidden;
            transition: var(--transition);
            max-width: 520px;
            width: 100%;
            border: 1px solid rgba(255,255,255,0.8);
        }

        .login-card-premium:hover { transform: translateY(-10px); box-shadow: var(--shadow-hover); }

        .login-header-premium {
            background: var(--gradient-1);
            padding: 40px 30px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .login-header-premium::after {
            content: '';
            position: absolute;
            top: -30%; left: -20%;
            width: 140%; height: 140%;
            background: radial-gradient(circle, rgba(255,255,255,0.25), transparent);
            transform: rotate(12deg);
            pointer-events: none;
        }

        .login-header-premium i {
            font-size: 4rem;
            background: rgba(255,255,255,0.2);
            padding: 20px;
            border-radius: 80px;
            margin-bottom: 20px;
            backdrop-filter: blur(12px);
            transition: transform 0.3s;
        }

        .login-header-premium h3 { font-weight: 800; font-size: 2rem; letter-spacing: -0.3px; }

        .login-body-premium { padding: 44px 40px; }

        .input-group-premium {
            margin-bottom: 28px;
            position: relative;
        }

        .input-group-premium label {
            font-weight: 700;
            font-size: 0.85rem;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--dark);
            letter-spacing: -0.2px;
        }

        .input-group-premium label i { color: var(--primary); }

        .input-group-premium input {
            width: 100%;
            padding: 14px 20px;
            border: 2px solid #eef2f6;
            border-radius: 44px;
            font-size: 0.95rem;
            transition: all 0.25s;
            outline: none;
            background: #fff;
        }

        .input-group-premium input:focus {
            border-color: var(--primary);
            box-shadow: 0 8px 22px rgba(255,107,107,0.12);
            transform: scale(1.01);
        }

        .toggle-password {
            position: absolute;
            right: 20px; bottom: 16px;
            cursor: pointer;
            color: #aaa;
            transition: color 0.2s;
            z-index: 2;
        }

        .toggle-password:hover { color: var(--primary); }

        .checkbox-group {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }

        .checkbox-group label { font-size: 0.85rem; font-weight: 500; }

        .forgot-link {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            transition: 0.2s;
        }

        .forgot-link:hover { color: var(--primary-dark); text-decoration: underline; }

        .btn-login-premium {
            background: var(--gradient-1);
            border: none;
            padding: 15px;
            border-radius: 60px;
            font-weight: 800;
            font-size: 1rem;
            width: 100%;
            color: white;
            transition: all 0.3s;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            letter-spacing: 0.5px;
        }

        .btn-login-premium:disabled { opacity: 0.65; transform: none; }
        .btn-login-premium:hover:not(:disabled) {
            transform: translateY(-3px);
            filter: brightness(1.02);
            box-shadow: 0 20px 32px -12px rgba(255,107,107,0.5);
        }

        .divider-premium {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 28px 0;
            font-size: 0.8rem;
            color: #8a99aa;
        }

        .divider-premium::before, .divider-premium::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e2e8f0;
        }
        .divider-premium::before { margin-right: 18px; }
        .divider-premium::after { margin-left: 18px; }

        .social-login {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 28px;
        }

        .social-btn {
            width: 54px; height: 54px;
            border-radius: 60px;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #334155;
            font-size: 1.5rem;
            transition: all 0.3s;
            cursor: pointer;
            text-decoration: none;
            border: 1px solid #e9edf2;
        }

        .social-btn:hover {
            background: var(--gradient-1);
            color: white;
            transform: translateY(-6px);
            border-color: transparent;
            box-shadow: 0 12px 22px -8px rgba(255,107,107,0.4);
        }

        .register-link { text-align: center; font-weight: 500; font-size: 0.9rem; }
        .register-link a { color: var(--primary); font-weight: 700; text-decoration: none; }

        /* ---------- ALERT / ERROR MODAL ---------- */
        .alert-modal-overlay {
            position: fixed; inset: 0; z-index: 2100;
            background: rgba(10,16,28,0.6);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0; pointer-events: none;
            transition: opacity 0.35s ease;
        }
        .alert-modal-overlay.active { opacity: 1; pointer-events: auto; }

        .alert-modal-card {
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 40px;
            padding: 40px 36px 36px;
            max-width: 420px; width: 90%;
            text-align: center;
            border: 1px solid var(--glass-border);
            box-shadow: 0 35px 70px -25px rgba(0,0,0,0.35);
            transform: scale(0.85) translateY(20px);
            transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
        }
        .alert-modal-overlay.active .alert-modal-card { transform: scale(1) translateY(0); }

        .alert-icon-circle {
            width: 75px; height: 75px;
            margin: 0 auto 22px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.2rem;
            background: rgba(255,71,87,0.12);
            color: #ff4757;
            border: 2px solid rgba(255,71,87,0.25);
            box-shadow: 0 12px 25px rgba(255,71,87,0.2);
        }

        .alert-icon-circle.warning {
            background: rgba(241,196,15,0.12);
            color: #f39c12;
            border-color: rgba(241,196,15,0.25);
            box-shadow: 0 12px 25px rgba(241,196,15,0.2);
        }

        .alert-title { font-weight: 800; font-size: 1.5rem; margin-bottom: 10px; color: #1e2a3e; }
        .alert-message { color: #4b5b6b; font-weight: 500; margin-bottom: 26px; line-height: 1.5; }

        .btn-alert-ok {
            background: var(--gradient-1);
            border: none;
            padding: 13px 42px;
            border-radius: 50px;
            font-weight: 700;
            color: white;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.25s;
            box-shadow: 0 10px 22px -8px rgba(255,107,107,0.4);
        }
        .btn-alert-ok:hover { transform: translateY(-3px); filter: brightness(1.03); box-shadow: 0 18px 30px -12px rgba(255,107,107,0.55); }

        /* ---------- 2026 SUCCESS MODAL ---------- */
        .modal-2026-overlay {
            position: fixed; inset: 0; z-index: 2000;
            background: rgba(10,16,28,0.55);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none;
            transition: opacity 0.45s ease;
        }
        .modal-2026-overlay.active { opacity: 1; pointer-events: auto; }

        .modal-2026-card {
            background: rgba(255,255,255,0.82);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border-radius: 48px;
            padding: 50px 38px 42px;
            max-width: 480px; width: 92%;
            text-align: center;
            position: relative;
            border: 1.5px solid var(--glass-border);
            box-shadow: var(--neon-glow), 0 40px 80px -30px rgba(0,0,0,0.35);
            transform: scale(0.8) translateY(30px);
            transition: transform 0.5s cubic-bezier(0.22,1,0.36,1);
        }
        .modal-2026-overlay.active .modal-2026-card { transform: scale(1) translateY(0); }

        .success-ring-container { position: relative; width: 110px; height: 110px; margin: 0 auto 24px; }
        .success-ring { position: absolute; inset: 0; border-radius: 50%; border: 3px solid transparent; }
        .success-ring.ring-1 { border-top-color: var(--primary); border-right-color: var(--secondary); animation: ringSpin 2.2s linear infinite; }
        .success-ring.ring-2 { inset: 10px; border-bottom-color: var(--secondary); border-left-color: #a55eea; animation: ringSpin 1.8s linear infinite reverse; }
        .success-ring.ring-3 { inset: 22px; border-top-color: #ffe66d; border-right-color: var(--primary); animation: ringSpin 2.6s linear infinite; }
        @keyframes ringSpin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .success-icon-inner {
            position: absolute; inset: 28px;
            background: var(--gradient-2);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            z-index: 2;
            box-shadow: 0 12px 35px rgba(78,205,196,0.45);
            animation: iconPulse 1.6s ease-in-out infinite;
        }
        @keyframes iconPulse {
            0%,100% { box-shadow: 0 12px 35px rgba(78,205,196,0.45); }
            50% { box-shadow: 0 20px 50px rgba(78,205,196,0.7), 0 0 70px rgba(255,107,107,0.3); }
        }
        .success-icon-inner i { font-size: 2.6rem; color: #fff; animation: checkBounce 0.7s cubic-bezier(0.34,1.56,0.64,1) forwards; }
        @keyframes checkBounce { 0% { transform: scale(0); opacity:0; } 60% { transform: scale(1.3); opacity:1; } 100% { transform: scale(1); opacity:1; } }

        .modal-2026-title {
            font-size: 2rem; font-weight: 800;
            background: var(--gradient-1);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 8px;
        }

        .modal-2026-subtitle { color: #5a6d80; font-weight: 500; margin-bottom: 22px; }

        .modal-2026-user-email {
            background: #f0f4f9;
            border-radius: 40px;
            padding: 10px 24px;
            display: inline-block;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--dark);
            margin-bottom: 26px;
        }

        .btn-2026-continue {
            background: var(--gradient-1);
            border: none;
            padding: 14px 40px;
            border-radius: 60px;
            font-weight: 700;
            color: white;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 0.3px;
            box-shadow: 0 12px 28px -10px rgba(255,107,107,0.4);
        }
        .btn-2026-continue:hover { transform: translateY(-4px); box-shadow: 0 20px 38px -12px rgba(255,107,107,0.6); }

        .particle-burst { position: absolute; pointer-events: none; z-index: 0; }
        .particle-dot {
            position: absolute;
            width: 8px; height: 8px;
            border-radius: 50%;
            animation: particleFly 1.4s ease-out forwards;
            opacity: 0;
        }
        @keyframes particleFly {
            0% { transform: translate(0,0) scale(1); opacity:1; }
            100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity:0; }
        }

        .footer-premium {
            background: #0f1722;
            color: #9aaebb;
            padding: 50px 0 20px;
            margin-top: 20px;
        }
        .footer-premium h6 { color: white; font-weight: 700; margin-bottom: 22px; }
        .footer-premium a { color: #8d9bb0; text-decoration: none; display: block; margin-bottom: 12px; transition: 0.2s; font-size: 0.85rem; }
        .footer-premium a:hover { color: var(--primary); padding-left: 6px; }

        .social-circle {
            display: inline-flex; width: 42px; height: 42px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
            align-items: center; justify-content: center;
            margin-right: 12px;
            transition: all 0.2s;
        }
        .social-circle:hover { background: var(--gradient-1); transform: translateY(-5px); }

        .toast-notify {
            position: fixed; bottom: 25px; right: 25px;
            background: white;
            border-radius: 50px;
            padding: 12px 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border-left: 5px solid var(--primary);
            display: flex; align-items: center; gap: 10px;
            font-weight: 600;
            transform: translateX(400px);
            transition: transform 0.4s ease;
            z-index: 1150;
            max-width: 90vw;
        }
        .toast-notify.show { transform: translateX(0); }

        @media (max-width: 576px) {
            .login-body-premium { padding: 30px 25px; }
            .login-header-premium { padding: 30px 20px; }
            .brand-premium { font-size: 1.7rem; }
            .nav-icon-premium { margin-left: 16px; font-size: 1.2rem; }
            .modal-2026-card { padding: 36px 22px 32px; border-radius: 36px; }
            .alert-modal-card { padding: 32px 24px 28px; border-radius: 32px; }
            .success-ring-container { width: 90px; height: 90px; }
            .success-icon-inner { inset: 22px; }
            .success-icon-inner i { font-size: 2rem; }
            .modal-2026-title { font-size: 1.6rem; }
            .cart-badge-premium { width: 18px; height: 18px; font-size: 0.6rem; top: -8px; right: -10px; }
            .login-card-premium { border-radius: 40px; }
            .header-premium { padding: 12px 0; }
        }

        @media (max-width: 360px) {
            .login-body-premium { padding: 24px 18px; }
            .input-group-premium input { padding: 12px 16px; font-size: 0.9rem; }
            .btn-login-premium { padding: 12px; font-size: 0.9rem; }
            .social-btn { width: 46px; height: 46px; font-size: 1.3rem; }
            .social-login { gap: 12px; }
            .checkbox-group { flex-direction: column; align-items: flex-start; gap: 8px; }
            .alert-modal-card, .modal-2026-card { padding: 26px 16px 24px; }
        }
    </style>
</head>

<body>
    <div class="mesh-bg"></div>
    <div class="animated-blob" style="top: -15%; left: -10%;"></div>
    <div class="animated-blob" style="bottom: -20%; right: -10%; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(78,205,196,0.2), rgba(255,230,109,0.05)); animation-duration: 30s;"></div>

    <header class="header-premium" id="header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <a href="#" class="brand-premium">ShopEasy</a>
                <div class="d-flex align-items-center">
                    <a href="#" class="nav-icon-premium"><i class="fas fa-user-circle"></i></a>
                    <a href="#" class="nav-icon-premium"><i class="fas fa-heart"></i></a>
                    <a href="#" class="nav-icon-premium position-relative">
                        <i class="fas fa-shopping-bag"></i>
                        <span class="cart-badge-premium" id="cartCount">0</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="login-section">
            <div class="login-card-premium" id="loginCard">
                <div class="login-header-premium">
                    <i class="fas fa-sparkle"></i>
                    <h3>Welcome Back</h3>
                    <p>Rediscover your style · secure sign in</p>
                </div>
                <div class="login-body-premium">
                    <form id="loginForm" novalidate>
                        <div class="input-group-premium">
                            <label><i class="fas fa-envelope"></i> Email address</label>
                            <input type="email" id="loginEmail" placeholder="hello@shopeasy.com" required autocomplete="email">
                        </div>
                        <div class="input-group-premium">
                            <label><i class="fas fa-key"></i> Password</label>
                            <input type="password" id="loginPassword" placeholder="••••••••" required autocomplete="current-password">
                            <i class="fas fa-eye-slash toggle-password" id="togglePassIcon"></i>
                        </div>
                        <div class="checkbox-group">
                            <label class="d-flex align-items-center gap-2">
                                <input type="checkbox" id="rememberMe"> <span>Keep me signed in</span>
                            </label>
                            <a href="#" class="forgot-link" id="forgotPasswordBtn">Forgot password?</a>
                        </div>
                        <button type="submit" class="btn-login-premium" id="loginSubmitBtn">
                            <i class="fas fa-arrow-right-to-bracket"></i> Sign In
                        </button>
                    </form>
                    <div class="divider-premium">or continue with</div>
                    <div class="social-login">
                        <a href="#" class="social-btn google-btn"><i class="fab fa-google"></i></a>
                        <a href="#" class="social-btn fb-btn"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-btn apple-btn"><i class="fab fa-apple"></i></a>
                    </div>
                    <div class="register-link">
                        New to ShopEasy? <a href="#" id="signupLink">Create account →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ALERT / ERROR MODAL -->
    <div class="alert-modal-overlay" id="alertModalOverlay">
        <div class="alert-modal-card">
            <div class="alert-icon-circle" id="alertIconCircle">
                <i class="fas fa-exclamation-circle"></i>
            </div>
            <h3 class="alert-title" id="alertTitle">Notice</h3>
            <p class="alert-message" id="alertMessage">Something went wrong.</p>
            <button class="btn-alert-ok" id="btnAlertOk">Got it</button>
        </div>
    </div>

    <!-- 2026 SUCCESS MODAL -->
    <div class="modal-2026-overlay" id="modal2026Overlay">
        <div class="modal-2026-card" id="modal2026Card">
            <div class="particle-burst" id="particleBurst"></div>
            <div class="success-ring-container">
                <div class="success-ring ring-1"></div>
                <div class="success-ring ring-2"></div>
                <div class="success-ring ring-3"></div>
                <div class="success-icon-inner">
                    <i class="fas fa-check"></i>
                </div>
            </div>
            <h2 class="modal-2026-title">You're In! ✨</h2>
            <p class="modal-2026-subtitle" id="modalSubtitle">Login successful · Heading to your destination…</p>
            <div class="modal-2026-user-email" id="modalUserEmail">hello@shopeasy.com</div>
            <br>
            <button class="btn-2026-continue" id="btn2026Continue">
                <i class="fas fa-location-arrow"></i> &nbsp;<span id="btn2026Label">Go now</span>
            </button>
        </div>
    </div>

    <!-- Toast (minor info only) -->
    <div id="toastMsg" class="toast-notify" style="display: none;">
        <i class="fas fa-check-circle"></i>
        <span id="toastText"></span>
    </div>

    <footer class="footer-premium">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3"><h6>ShopEasy</h6><a href="#">Our Story</a><a href="#">Sustainability</a><a href="#">Press</a></div>
                <div class="col-md-3"><h6>Support</h6><a href="#">Help Center</a><a href="#">Returns & Exchanges</a><a href="#">Shipping</a></div>
                <div class="col-md-3"><h6>Account</h6><a href="#">Orders</a><a href="#">Wishlist</a><a href="#">Profile</a></div>
                <div class="col-md-3"><h6>Connect</h6>
                    <div><a href="#" class="social-circle"><i class="fab fa-instagram"></i></a><a href="#" class="social-circle"><i class="fab fa-twitter"></i></a><a href="#" class="social-circle"><i class="fab fa-pinterest"></i></a></div>
                </div>
            </div>
            <div class="text-center mt-5 pt-3 border-top border-secondary">© 2025 ShopEasy — Curated living. All rights reserved.</div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // GSAP entrance
            gsap.from(".login-card-premium", { duration: 0.8, y: 60, opacity: 0, ease: "back.out(0.6)" });
            gsap.from(".login-header-premium i", { duration: 0.6, scale: 0.5, opacity: 0, delay: 0.2, ease: "elastic.out(1,0.5)" });
            gsap.from(".brand-premium", { duration: 0.7, x: -20, opacity: 0, stagger: 0.1 });

            const header = document.getElementById('header');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 40) header.classList.add('scrolled');
                else header.classList.remove('scrolled');
            });

            // ──────── ALERT MODAL (popup for validation / errors) ────────
            const alertOverlay = document.getElementById('alertModalOverlay');
            const alertIconCircle = document.getElementById('alertIconCircle');
            const alertTitle = document.getElementById('alertTitle');
            const alertMessage = document.getElementById('alertMessage');
            const btnAlertOk = document.getElementById('btnAlertOk');

            function openAlertModal(message, title = 'Notice', icon = 'fa-exclamation-circle', type = 'error') {
                if (alertTitle) alertTitle.textContent = title;
                if (alertMessage) alertMessage.textContent = message;
                const iconEl = alertIconCircle?.querySelector('i');
                if (iconEl) { iconEl.className = `fas ${icon}`; }
                if (alertIconCircle) {
                    alertIconCircle.classList.remove('warning');
                    if (type === 'warning') alertIconCircle.classList.add('warning');
                }
                if (alertOverlay) {
                    alertOverlay.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
            }

            function closeAlertModal() {
                if (alertOverlay) { alertOverlay.classList.remove('active'); document.body.style.overflow = ''; }
            }
            if (btnAlertOk) btnAlertOk.addEventListener('click', closeAlertModal);
            if (alertOverlay) alertOverlay.addEventListener('click', (e) => { if (e.target === alertOverlay) closeAlertModal(); });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && alertOverlay?.classList.contains('active')) closeAlertModal(); });

            // ──────── TOAST (minor info) ────────
            let toastTimer;
            const toastEl = document.getElementById('toastMsg');
            function showToast(message, isError = false) {
                if (!toastEl) return;
                toastEl.style.display = 'flex';
                const icon = toastEl.querySelector('i');
                const text = document.getElementById('toastText');
                if (toastTimer) clearTimeout(toastTimer);
                text.innerText = message;
                if (isError) {
                    icon.className = "fas fa-exclamation-triangle";
                    toastEl.style.borderLeftColor = "#ff4757";
                    icon.style.color = "#ff4757";
                } else {
                    icon.className = "fas fa-check-circle";
                    toastEl.style.borderLeftColor = "var(--primary)";
                    icon.style.color = "var(--primary)";
                }
                toastEl.classList.add('show');
                toastTimer = setTimeout(() => {
                    toastEl.classList.remove('show');
                    setTimeout(() => { if (toastEl) toastEl.style.display = 'none'; }, 400);
                }, 3500);
            }

            // ──────── 2026 SUCCESS MODAL (now uses redirectUrl) ────────
            const modalOverlay = document.getElementById('modal2026Overlay');
            const modalUserEmail = document.getElementById('modalUserEmail');
            const modalSubtitle = document.getElementById('modalSubtitle');
            const btn2026Label = document.getElementById('btn2026Label');
            const particleBurst = document.getElementById('particleBurst');
            const btn2026Continue = document.getElementById('btn2026Continue');
            let redirectTimer = null;
            let currentRedirectUrl = '/cart'; // fallback

            function spawnParticles() {
                if (!particleBurst) return;
                particleBurst.innerHTML = '';
                const colors = ['#ff6b6b','#4ecdc4','#ffe66d','#a55eea','#ff9f43','#54a0ff','#ff6ec7','#00d2d3'];
                const count = 44;
                const fragment = document.createDocumentFragment();
                for (let i=0; i<count; i++) {
                    const dot = document.createElement('div');
                    dot.classList.add('particle-dot');
                    const angle = (Math.PI*2*i)/count;
                    const distance = 70 + Math.random()*100;
                    dot.style.setProperty('--dx', Math.cos(angle)*distance+'px');
                    dot.style.setProperty('--dy', Math.sin(angle)*distance+'px');
                    dot.style.background = colors[Math.floor(Math.random()*colors.length)];
                    dot.style.width = (5+Math.random()*9)+'px';
                    dot.style.height = dot.style.width;
                    dot.style.animationDuration = (1+Math.random()*1.8)+'s';
                    dot.style.animationDelay = Math.random()*0.25+'s';
                    dot.style.left = '50%';
                    dot.style.top = '50%';
                    fragment.appendChild(dot);
                }
                particleBurst.appendChild(fragment);
            }

            function redirectNow() {
                window.location.href = currentRedirectUrl;
            }

            function open2026Modal(userEmail, redirectUrl = '/cart') {
                currentRedirectUrl = redirectUrl;
                if (modalUserEmail) modalUserEmail.textContent = userEmail || 'hello@shopeasy.com';

                // Customize the subtitle and button label based on redirectUrl
                let destinationLabel = 'your destination';
                let buttonLabel = 'Go now';
                if (redirectUrl === '/cart') {
                    destinationLabel = 'your cart';
                    buttonLabel = 'Go to Cart';
                } else if (redirectUrl === '/wishlist') {
                    destinationLabel = 'your wishlist';
                    buttonLabel = 'Go to Wishlist';
                } else if (redirectUrl === '/') {
                    destinationLabel = 'the homepage';
                    buttonLabel = 'Go Home';
                }
                if (modalSubtitle) modalSubtitle.textContent = `Login successful · Heading to ${destinationLabel}…`;
                if (btn2026Label) btn2026Label.textContent = buttonLabel;

                if (modalOverlay) {
                    modalOverlay.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
                const checkIcon = document.querySelector('.success-icon-inner i');
                if (checkIcon) {
                    checkIcon.style.animation = 'none';
                    checkIcon.offsetHeight;
                    checkIcon.style.animation = 'checkBounce 0.7s cubic-bezier(0.34,1.56,0.64,1) forwards';
                }
                spawnParticles();
                gsap.fromTo(".modal-2026-title", {y:18,opacity:0},{y:0,opacity:1,duration:0.5,delay:0.15,ease:"back.out(0.5)"});
                gsap.fromTo(".modal-2026-subtitle", {y:10,opacity:0},{y:0,opacity:1,duration:0.4,delay:0.25});
                gsap.fromTo(".modal-2026-user-email", {scale:0.85,opacity:0},{scale:1,opacity:1,duration:0.4,delay:0.35,ease:"elastic.out(1,0.4)"});
                gsap.fromTo(".btn-2026-continue", {y:16,opacity:0},{y:0,opacity:1,duration:0.45,delay:0.45,ease:"back.out(0.55)"});

                if (redirectTimer) clearTimeout(redirectTimer);
                redirectTimer = setTimeout(redirectNow, 4000);
            }

            function close2026Modal() {
                if (modalOverlay) { modalOverlay.classList.remove('active'); document.body.style.overflow = ''; }
                if (particleBurst) particleBurst.innerHTML = '';
                if (redirectTimer) { clearTimeout(redirectTimer); redirectTimer = null; }
            }

            if (btn2026Continue) {
                btn2026Continue.addEventListener('click', () => {
                    if (redirectTimer) clearTimeout(redirectTimer);
                    redirectNow();
                });
            }

            if (modalOverlay) modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) close2026Modal(); });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modalOverlay?.classList.contains('active')) close2026Modal(); });

            // ──────── LOGIN / API CALL (uses redirectUrl from backend) ────────
            const API_BASE = window.location.origin;
            const LOGIN_URL = `${API_BASE}/login`;
            const emailInput = document.getElementById('loginEmail');
            const passInput = document.getElementById('loginPassword');
            const rememberCheck = document.getElementById('rememberMe');

            if (localStorage.getItem('rememberedEmail') && localStorage.getItem('rememberFlag') === 'true') {
                emailInput.value = localStorage.getItem('rememberedEmail');
                rememberCheck.checked = true;
            }

            const toggleEye = document.getElementById('togglePassIcon');
            if (toggleEye) {
                toggleEye.addEventListener('click', () => {
                    const type = passInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passInput.setAttribute('type', type);
                    toggleEye.classList.toggle('fa-eye-slash');
                    toggleEye.classList.toggle('fa-eye');
                });
            }

            async function performLogin(email, password) {
                const submitBtn = document.getElementById('loginSubmitBtn');
                const originalHtml = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Authenticating...';
                submitBtn.disabled = true;

                try {
                    const cleanEmail = email.toLowerCase().trim();
                    const response = await fetch(LOGIN_URL, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ email: cleanEmail, password: password })
                    });
                    const data = await response.json();
                    if (!response.ok) {
                        if (data.message === 'Invalid email') {
                            window.location.replace('/signup');
                            return;
                        }
                        throw new Error(data.message || 'Invalid credentials or server error');
                    }
                    if (data.success === true) {
                        if (rememberCheck.checked) {
                            localStorage.setItem('rememberedEmail', cleanEmail);
                            localStorage.setItem('rememberFlag', 'true');
                        } else {
                            localStorage.removeItem('rememberedEmail');
                            localStorage.removeItem('rememberFlag');
                        }
                        // Use the redirectUrl from the server response
                        const redirectTo = data.redirectUrl || '/';
                        setTimeout(() => {
                            open2026Modal(cleanEmail, redirectTo);
                            submitBtn.innerHTML = originalHtml;
                            submitBtn.disabled = false;
                        }, 600);
                    } else {
                        throw new Error(data.message || 'Login failed');
                    }
                } catch (err) {
                    console.error('[LOGIN ERROR]', err);
                    openAlertModal(err.message || 'Connection error. Please try again.', 'Login Error', 'fa-exclamation-triangle');
                    submitBtn.innerHTML = originalHtml;
                    submitBtn.disabled = false;
                }
            }

            const loginForm = document.getElementById('loginForm');
            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const email = emailInput.value.trim();
                const password = passInput.value.trim();

                if (!email || !password) {
                    openAlertModal('Please fill in both email and password.', 'Missing fields', 'fa-exclamation-circle');
                    return;
                }
                if (!email.includes('@') || !email.includes('.')) {
                    openAlertModal('Enter a valid email address.', 'Invalid email', 'fa-exclamation-circle');
                    return;
                }
                if (password.length < 4) {
                    openAlertModal('Password must be at least 4 characters.', 'Weak password', 'fa-exclamation-circle');
                    return;
                }
                await performLogin(email, password);
            });

            // Social / links
            const socialDemo = (provider) => showToast(`🔐 ${provider} OAuth — ready for production integration`, false);
            document.querySelector('.google-btn')?.addEventListener('click', (e) => { e.preventDefault(); socialDemo('Google'); });
            document.querySelector('.fb-btn')?.addEventListener('click', (e) => { e.preventDefault(); socialDemo('Facebook'); });
            document.querySelector('.apple-btn')?.addEventListener('click', (e) => { e.preventDefault(); socialDemo('Apple'); });

            document.getElementById('forgotPasswordBtn')?.addEventListener('click', (e) => {
                e.preventDefault();
                showToast('📧 Reset link sent to your email (demo flow)', false);
            });

            document.getElementById('signupLink')?.addEventListener('click', (e) => {
                e.preventDefault();
                showToast('🌟 Let’s create your amazing account! (Signup ready)', false);
                setTimeout(() => { window.location.replace(`${API_BASE}/signup`); }, 600);
            });

            // micro‑interactions
            document.querySelectorAll('.input-group-premium input').forEach(inp => {
                inp.addEventListener('focus', () => gsap.to(inp, { scale:1.01, duration:0.2, borderColor:"#ff6b6b" }));
                inp.addEventListener('blur', () => gsap.to(inp, { scale:1, borderColor:"#eef2f6", duration:0.2 }));
            });

            const loginCard = document.querySelector('.login-card-premium');
            loginCard?.addEventListener('mouseenter', () => gsap.to(loginCard, { y:-8, boxShadow:"0 30px 50px -20px rgba(0,0,0,0.25)", duration:0.4 }));
            loginCard?.addEventListener('mouseleave', () => gsap.to(loginCard, { y:0, boxShadow:"var(--shadow-soft)", duration:0.4 }));
        })();
    </script>
</body>
</html>