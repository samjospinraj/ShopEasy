    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>
    <script>
        (function() {
            const API_BASE = 'http://localhost:3000';
            const RETURN_WINDOW_MS = 7 * 24 * 60 * 60 * 1000;

            let isAuthenticated = false;
            let allOrders = [];
            let currentFilter = 'all';
            let currentReviewOrderId = null;
            let currentReturnOrderId = null;
            let currentReturnCompleteOrderId = null;
            let currentOtpOrderId = null;
            let selectedRating = 0;
            let activeTimers = {};
            let returnModalTimerId = null;

            // ============ Premium Modal Pop-up (Replaces toast for alerts) ============
            const notifModal = document.getElementById('notificationModal');
            const bsNotifModal = notifModal ? new bootstrap.Modal(notifModal, {
                backdrop: 'static'
            }) : null;

            function showModal(type, title, msg, opts = {}) {
                if (!bsNotifModal) return;
                const map = {
                    success: { cls: 'success', icon: 'fa-check-circle' },
                    error: { cls: 'error', icon: 'fa-times-circle' },
                    warning: { cls: 'warning', icon: 'fa-exclamation-triangle' },
                    info: { cls: 'info', icon: 'fa-info-circle' }
                };
                const cfg = map[type] || map.info;
                document.getElementById('modalIconCircle').className = 'modal-icon-circle ' + cfg.cls;
                document.getElementById('modalIconCircle').innerHTML = `<i class="fas ${cfg.icon}"></i>`;
                document.getElementById('modalTitle').textContent = title;
                document.getElementById('modalMessage').textContent = msg;

                const pri = document.getElementById('modalPrimaryBtn');
                pri.textContent = opts.primaryText || 'OK';
                pri.style.display = 'inline-block';
                pri.onclick = () => {
                    opts.onPrimary?.();
                    bsNotifModal.hide();
                };

                const sec = document.getElementById('modalSecondaryBtn');
                let secondaryText = opts.secondaryText;
                if (secondaryText === undefined) secondaryText = 'Cancel';
                if (secondaryText) {
                    sec.textContent = secondaryText;
                    sec.style.display = 'inline-block';
                    sec.onclick = () => {
                        if (opts.onSecondary) opts.onSecondary();
                        bsNotifModal.hide();
                    };
                } else {
                    sec.style.display = 'none';
                }

                bsNotifModal.show();
                if (opts.autoHide) setTimeout(() => bsNotifModal.hide(), opts.autoHide);
            }

            // Show custom success animation overlay (used for major successes)
            function showSuccessAnimation(type, message = 'Success!') {
                const overlay = document.getElementById('successOverlay');
                const container = document.getElementById('animationContainer');
                const msgEl = document.getElementById('successMessage');
                container.innerHTML = '';
                let animationHtml = '';
                switch (type) {
                    case 'review':
                        animationHtml =
                            `<div class="review-animation" style="position:relative;width:100%;height:100%">
                            <div class="paper"></div>
                            <span class="star-burst star1">⭐</span>
                            <span class="star-burst star2">✨</span>
                            <span class="star-burst star3">🌟</span>
                            <div class="pen"></div>
                        </div>`;
                        break;
                    case 'cancel':
                        animationHtml =
                            `<div class="cancel-animation" style="position:relative;width:100%;height:100%">
                            <div class="circle"></div>
                            <div class="cross"></div>
                        </div>`;
                        break;
                    case 'return':
                        animationHtml =
                            `<div class="return-animation" style="position:relative;width:100%;height:100%">
                            <div class="box"></div>
                            <div class="arrow">↩️</div>
                        </div>`;
                        break;
                    case 'refund':
                        animationHtml =
                            `<div class="refund-animation" style="position:relative;width:100%;height:100%">
                            <div class="coin"></div>
                            <div class="coin coin2"></div>
                            <div class="coin coin3"></div>
                        </div>`;
                        break;
                    case 'otp':
                        animationHtml =
                            `<div class="otp-animation" style="position:relative;width:100%;height:100%">
                            <div class="shield"></div>
                            <div class="lock">🔒</div>
                        </div>`;
                        break;
                    default:
                        animationHtml = `<div style="font-size:50px;">✅</div>`;
                }
                container.innerHTML = animationHtml;
                msgEl.textContent = message;
                overlay.classList.add('show');
                setTimeout(() => {
                    window.location.reload();
                }, 2500);
            }

            function parseCustomDate(str) {
                if (!str) return null;
                const stdDate = new Date(str);
                if (!isNaN(stdDate.getTime()) && str.includes('-')) return stdDate;
                const parts = str.match(
                    /(\d{1,2})\/(\d{1,2})\/(\d{4}), (\d{1,2}):(\d{2}):(\d{2}) (am|pm)/i);
                if (!parts) return null;
                const day = parseInt(parts[1], 10);
                const month = parseInt(parts[2], 10) - 1;
                const year = parseInt(parts[3], 10);
                let hour = parseInt(parts[4], 10);
                const minute = parseInt(parts[5], 10);
                const second = parseInt(parts[6], 10);
                const ampm = parts[7].toLowerCase();
                if (ampm === 'pm' && hour < 12) hour += 12;
                if (ampm === 'am' && hour === 12) hour = 0;
                return new Date(year, month, day, hour, minute, second);
            }

            function formatExpiryDate(expiryTimeMs) {
                const date = new Date(expiryTimeMs);
                if (isNaN(date.getTime())) return '--';
                return date.toLocaleString('en-IN', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: true
                });
            }

            (function() {
                const pc = document.getElementById('particles');
                for (let i = 0; i < 30; i++) {
                    const p = document.createElement('div');
                    p.className = 'particle';
                    const s = Math.random() * 25 + 5;
                    p.style.cssText =
                        `width:${s}px;height:${s}px;background:hsl(${Math.random() * 360},70%,65%);left:${Math.random() * 100}%;top:${Math.random() * 100}%;animation-delay:${Math.random() * 15}s;`;
                    pc.appendChild(p);
                }
            })();

            window.addEventListener('scroll', () => document.getElementById('header').classList.toggle(
                'scrolled', window.scrollY > 50));

            function initStarRating() {
                const stars = document.querySelectorAll('#starRating .star');
                stars.forEach(star => {
                    star.addEventListener('click', function() {
                        selectedRating = parseInt(this.dataset.rating);
                        document.getElementById('reviewRating').value = selectedRating;
                        updateStars(selectedRating);
                    });
                    star.addEventListener('mouseenter', function() {
                        updateStars(parseInt(this.dataset.rating));
                    });
                });
                document.getElementById('starRating').addEventListener('mouseleave', function() {
                    updateStars(selectedRating);
                });
            }

            function updateStars(rating) {
                const stars = document.querySelectorAll('#starRating .star');
                stars.forEach(star => {
                    if (parseInt(star.dataset.rating) <= rating) {
                        star.textContent = '★';
                        star.style.color = '#f59e0b';
                    } else {
                        star.textContent = '☆';
                        star.style.color = '#d1d5db';
                    }
                });
            }

            function toast(msg) {
                const t = document.getElementById('toastMsg');
                document.getElementById('toastText').innerText = msg;
                t.classList.add('show');
                setTimeout(() => t.classList.remove('show'), 2800);
            }

            function updateCartBadge(count = 0) {
                document.getElementById('cartCount').innerText = count;
            }

            function redirectToLogin() {
                window.location.href = `/login?returnTo=${encodeURIComponent(window.location.href)}`;
            }

            async function checkAuth() {
                try {
                    const res = await fetch(`${API_BASE}/api/check-auth`, {
                        credentials: 'include'
                    });
                    if (res.ok) {
                        const json = await res.json();
                        isAuthenticated = json.loggedIn === true;
                    } else isAuthenticated = false;
                } catch (e) {
                    isAuthenticated = false;
                }
                updateLoginUI();
                if (!isAuthenticated) {
                    redirectToLogin();
                    return false;
                }
                return true;
            }

            function updateLoginUI() {
                const menuLogout = document.getElementById('menuLogout');
                const userIconBtn = document.getElementById('userIconBtn');
                if (menuLogout) menuLogout.style.display = isAuthenticated ? 'flex' : 'none';
                if (userIconBtn) userIconBtn.style.color = isAuthenticated ? '#4ecdc4' : '#666';
            }

            async function fetchCartCount() {
                if (!isAuthenticated) {
                    updateCartBadge(0);
                    return 0;
                }
                try {
                    const res = await fetch(`${API_BASE}/carts`, {
                        credentials: 'include'
                    });
                    if (res.ok) {
                        const json = await res.json();
                        if (json.success) {
                            const count = json.count || (json.data ? json.data.length : 0);
                            updateCartBadge(count);
                            return count;
                        }
                    }
                } catch (e) {}
                return 0;
            }

            function getTimeRemaining(deadline) {
                const now = Date.now();
                const total = deadline.getTime() - now;
                if (total <= 0) return {
                    expired: true,
                    days: 0,
                    hours: 0,
                    minutes: 0,
                    seconds: 0,
                    total: 0
                };
                const seconds = Math.floor((total / 1000) % 60);
                const minutes = Math.floor((total / 1000 / 60) % 60);
                const hours = Math.floor((total / (1000 * 60 * 60)) % 24);
                const days = Math.floor(total / (1000 * 60 * 60 * 24));
                return {
                    expired: false,
                    days,
                    hours,
                    minutes,
                    seconds,
                    total
                };
            }

            function formatTimerDisplay(timeObj) {
                if (timeObj.expired) return 'EXPIRED';
                let parts = [];
                if (timeObj.days > 0) parts.push(`${timeObj.days}d`);
                parts.push(`${String(timeObj.hours).padStart(2, '0')}h`);
                parts.push(`${String(timeObj.minutes).padStart(2, '0')}m`);
                parts.push(`${String(timeObj.seconds).padStart(2, '0')}s`);
                return parts.join(' : ');
            }

            function startTimer(timerId, deadline, onExpiry) {
                if (activeTimers[timerId]) clearInterval(activeTimers[timerId]);
                const timerElement = document.getElementById(timerId);
                if (!timerElement) return;

                function update() {
                    const remaining = getTimeRemaining(deadline);
                    timerElement.textContent = formatTimerDisplay(remaining);
                    timerElement.classList.toggle('expired', remaining.expired);
                    if (remaining.expired) {
                        if (activeTimers[timerId]) {
                            clearInterval(activeTimers[timerId]);
                            delete activeTimers[timerId];
                        }
                        if (typeof onExpiry === 'function') onExpiry();
                    }
                }
                update();
                activeTimers[timerId] = setInterval(update, 1000);
            }

            async function checkReturnWindowAndStartTimer(orderId) {
                const returnBtn = document.getElementById(`return-btn-${orderId}`);
                const bannerEl = document.getElementById(`return-banner-${orderId}`);
                const timerEl = document.getElementById(`return-window-${orderId}`);
                const expiryEl = document.getElementById(`return-expiry-${orderId}`);

                if (activeTimers[`return-window-${orderId}`]) {
                    clearInterval(activeTimers[`return-window-${orderId}`]);
                    delete activeTimers[`return-window-${orderId}`];
                }

                try {
                    const res = await fetch(`${API_BASE}/order/return-time/${orderId}`, {
                        credentials: 'include'
                    });
                    if (!res.ok) return;
                    const result = await res.json();
                    if (!result.success || !result.data) return;

                    const {
                        isExpired,
                        remainingTime,
                        expiryTime,
                        readableRemainingTime
                    } = result.data;

                    if (isExpired) {
                        if (returnBtn) returnBtn.style.display = 'none';
                        if (bannerEl) bannerEl.innerHTML =
                            '<i class="fas fa-hourglass-end"></i><div><strong>Return Window Expired</strong></div>';
                        if (timerEl) timerEl.textContent = 'EXPIRED';
                        if (expiryEl && expiryTime) expiryEl.textContent = 'Expired on: ' +
                            formatExpiryDate(expiryTime);
                        return;
                    }

                    if (returnBtn) returnBtn.style.display = '';

                    if (expiryEl && expiryTime) {
                        expiryEl.textContent = 'Expires: ' + formatExpiryDate(expiryTime);
                    }

                    const deadline = new Date(Date.now() + remainingTime);
                    startTimer(`return-window-${orderId}`, deadline, () => {
                        if (returnBtn) returnBtn.style.display = 'none';
                        if (bannerEl) bannerEl.innerHTML =
                            '<i class="fas fa-hourglass-end"></i><div><strong>Return Window Expired</strong></div>';
                        if (expiryEl && expiryTime) expiryEl.textContent = 'Expired on: ' +
                            formatExpiryDate(expiryTime);
                    });
                } catch (e) {
                    const order = allOrders.find(o => o._id === orderId);
                    if (order && order.orderTimeline?.deliveryCompletedAt) {
                        const completedDate = parseCustomDate(order.orderTimeline.deliveryCompletedAt);
                        if (completedDate && !isNaN(completedDate)) {
                            const deadline = new Date(completedDate.getTime() + RETURN_WINDOW_MS);
                            if (expiryEl) expiryEl.textContent = 'Expires: ' + formatExpiryDate(deadline
                                .getTime());
                            startTimer(`return-window-${orderId}`, deadline, () => {
                                if (returnBtn) returnBtn.style.display = 'none';
                                if (bannerEl) bannerEl.innerHTML =
                                    '<i class="fas fa-hourglass-end"></i><div><strong>Return Window Expired</strong></div>';
                                if (expiryEl) expiryEl.textContent = 'Expired on: ' +
                                    formatExpiryDate(deadline.getTime());
                            });
                        }
                    }
                }
            }

            async function fetchOrders() {
                const ordersContainer = document.getElementById('ordersContainer');
                const loadingDiv = document.getElementById('ordersLoading');
                const emptyState = document.getElementById('emptyState');
                clearAllTimers();
                if (loadingDiv) loadingDiv.style.display = 'block';
                emptyState.style.display = 'none';
                while (ordersContainer.firstChild) {
                    if (ordersContainer.firstChild !== loadingDiv) ordersContainer.removeChild(ordersContainer
                        .firstChild);
                    else break;
                }
                try {
                    const res = await fetch(`${API_BASE}/orders`, {
                        credentials: 'include'
                    });
                    const result = await res.json();
                    if (res.ok && result.success) {
                        allOrders = (result.orders || []).map(order => ({
                            ...order,
                            orderStatus: order.orderStatus || 'pending',
                            returnStatus: order.returnStatus || 'none',
                            orderTimeline: order.orderTimeline || {},
                            returnTimeline: order.returnTimeline || {},
                            totals: order.totals || {},
                            items: order.items || [],
                            paymentMethod: order.paymentMethod || 'N/A',
                            shippingAddress: order.shippingAddress || {},
                            hasReviewed: order.hasReviewed || false
                        }));
                        updateStats();
                        if (allOrders.length === 0) {
                            loadingDiv.style.display = 'none';
                            emptyState.style.display = 'block';
                        } else {
                            filterOrders(currentFilter);
                        }
                    } else throw new Error(result.message || 'Failed');
                } catch (error) {
                    allOrders = [];
                    updateStats();
                    loadingDiv.style.display = 'none';
                    emptyState.style.display = 'block';
                    showModal('error', 'Error', 'Error loading orders: ' + error.message);
                }
            }

            function clearAllTimers() {
                Object.values(activeTimers).forEach(timerId => clearInterval(timerId));
                activeTimers = {};
                if (returnModalTimerId) {
                    clearInterval(returnModalTimerId);
                    returnModalTimerId = null;
                }
            }

            function updateStats() {
                const counts = {
                    all: allOrders.length,
                    pending: 0,
                    confirmed: 0,
                    processing: 0,
                    packed: 0,
                    shipped: 0,
                    out_for_delivery: 0,
                    delivered: 0,
                    delivery_completed: 0,
                    delivery_failed: 0,
                    cancelled: 0,
                    returned: 0,
                    return_requested: 0,
                    return_approved: 0,
                    return_rejected: 0,
                    return_expired: 0
                };
                allOrders.forEach(order => {
                    const s = (order.orderStatus || '').toLowerCase();
                    if (counts.hasOwnProperty(s)) counts[s]++;
                    const rs = (order.returnStatus || 'none').toLowerCase();
                    const returnKeys = ['return_requested', 'return_approved', 'return_rejected',
                        'return_expired', 'returned'
                    ];
                    if (returnKeys.includes(rs)) counts[rs] = (counts[rs] || 0) + 1;
                });
                Object.keys(counts).forEach(k => {
                    const el = document.getElementById('stat' + k.charAt(0).toUpperCase() + k.slice(1)
                        .replace(/_./g, x => x[1].toUpperCase()));
                    if (el) el.textContent = counts[k];
                });
            }

            window.filterOrders = function(filter) {
                currentFilter = filter;
                document.querySelectorAll('.stat-card').forEach(c => c.classList.remove('active'));
                const statCard = document.querySelector(`.stat-card[data-filter="${filter}"]`);
                if (statCard) statCard.classList.add('active');
                document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
                const tab = document.querySelector(`.filter-tab[data-filter="${filter}"]`);
                if (tab) tab.classList.add('active');
                let filtered = allOrders;
                const returnFilters = ['return_requested', 'return_approved', 'return_rejected',
                    'return_expired', 'returned'
                ];
                if (returnFilters.includes(filter)) {
                    filtered = allOrders.filter(o => (o.returnStatus || 'none').toLowerCase() === filter);
                } else if (filter !== 'all') {
                    filtered = allOrders.filter(o => (o.orderStatus || '').toLowerCase() === filter);
                }
                renderOrders(filtered);
            };

            function renderOrders(orders) {
                const ordersContainer = document.getElementById('ordersContainer');
                const loadingDiv = document.getElementById('ordersLoading');
                const emptyState = document.getElementById('emptyState');
                clearAllTimers();
                if (loadingDiv) loadingDiv.style.display = 'none';
                if (!orders.length) {
                    while (ordersContainer.firstChild) ordersContainer.removeChild(ordersContainer.firstChild);
                    emptyState.style.display = 'block';
                    document.getElementById('emptyStateMessage').textContent = allOrders.length > 0 ?
                        'No orders match the selected filter.' :
                        'You haven\'t placed any orders yet. Start shopping now!';
                    return;
                }
                emptyState.style.display = 'none';
                let html = '';
                orders.forEach((order, i) => html += createOrderCard(order, i));
                while (ordersContainer.firstChild) {
                    if (ordersContainer.firstChild !== loadingDiv) ordersContainer.removeChild(ordersContainer
                        .firstChild);
                    else break;
                }
                const temp = document.createElement('div');
                temp.innerHTML = html;
                while (temp.firstChild) ordersContainer.appendChild(temp.firstChild);

                orders.forEach(order => {
                    const status = (order.orderStatus || '').toLowerCase();
                    const minAt = order.orderTimeline?.deliveredMinAt;
                    const maxAt = order.orderTimeline?.deliveredMaxAt;
                    if (['pending', 'confirmed', 'processing', 'packed', 'shipped', 'out_for_delivery']
                        .includes(status) && minAt && maxAt) {
                        const minDate = parseCustomDate(minAt),
                            maxDate = parseCustomDate(maxAt);
                        if (minDate && !isNaN(minDate)) startTimer(`delivery-min-${order._id}`,
                    minDate);
                        if (maxDate && !isNaN(maxDate)) startTimer(`delivery-max-${order._id}`,
                    maxDate);
                    }
                    if (status === 'delivery_completed' && (order.returnStatus || 'none').toLowerCase() ===
                        'none') {
                        checkReturnWindowAndStartTimer(order._id);
                    }
                });
                initStarRating();
            }

            function createOrderCard(order, index) {
                const orderId = order._id,
                    shortId = orderId.toString().slice(-8);
                const orderedAtDate = parseCustomDate(order.orderTimeline?.orderedAt);
                const orderDate = orderedAtDate ? orderedAtDate.toLocaleDateString('en-IN', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                }) : 'N/A';
                const orderStatus = (order.orderStatus || 'pending').toLowerCase();
                const returnStatus = (order.returnStatus || 'none').toLowerCase();
                const totals = order.totals || {},
                    totalAmount = totals.totalAmount || 0;
                const paymentMethod = order.paymentMethod || 'N/A';
                const paymentDisplay = paymentMethod === 'cashOnDelivery' ? 'Cash on Delivery' : paymentMethod ===
                    'onlinePayment' ? 'Online Payment' : paymentMethod;
                const isCOD = paymentMethod === 'cashOnDelivery';
                let displayStatus = orderStatus,
                    statusLabel = orderStatus.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                let statusClass = `status-${orderStatus.replace(/_/g, '')}`,
                    statusDotClass = `dot-${orderStatus.replace(/_/g, '')}`;
                const returnMap = {
                    'requested': {
                        label: 'Return Requested',
                        class: 'status-returnrequested',
                        dot: 'dot-returnrequested'
                    },
                    'approved': {
                        label: 'Return Approved',
                        class: 'status-returnapproved',
                        dot: 'dot-returnapproved'
                    },
                    'rejected': {
                        label: 'Return Rejected',
                        class: 'status-returnrejected',
                        dot: 'dot-returnrejected'
                    },
                    'expired': {
                        label: 'Return Expired',
                        class: 'status-returnexpired',
                        dot: 'dot-returnexpired'
                    },
                    'returned': {
                        label: 'Returned',
                        class: 'status-returned',
                        dot: 'dot-returned'
                    }
                };
                if (returnMap[returnStatus]) {
                    displayStatus = returnStatus;
                    statusLabel = returnMap[returnStatus].label;
                    statusClass = returnMap[returnStatus].class;
                    statusDotClass = returnMap[returnStatus].dot;
                }
                const items = order.items || [];
                let itemsHTML = '';
                items.slice(0, 4).forEach(item => {
                    const product = item.productId || {};
                    let imgUrl =
                        'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=40&h=40&fit=crop';
                    const mainImg = product.image || product.mainImage;
                    if (mainImg) {
                        if (typeof mainImg === 'string') imgUrl = mainImg.startsWith('http') ? mainImg :
                            `${API_BASE}${mainImg}`;
                        else if (mainImg.path) imgUrl = mainImg.path.startsWith('http') ? mainImg.path :
                            `${API_BASE}${mainImg.path}`;
                        else if (mainImg.url) imgUrl = mainImg.url.startsWith('http') ? mainImg.url :
                            `${API_BASE}${mainImg.url}`;
                    }
                    itemsHTML +=
                        `<div class="order-item-chip"><img src="${imgUrl}" alt="${product.name || 'Product'}" class="order-item-img" onerror="this.src='https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=40&h=40&fit=crop'"><div class="order-item-info"><div class="order-item-name">${item.productName || product.name || 'Product'}</div><div class="order-item-qty">Qty: ${item.quantity || 1}</div></div></div>`;
                });
                if (items.length > 4) itemsHTML +=
                    `<div class="more-items-badge">+${items.length - 4} more</div>`;
                const progressHTML = buildProgressHTML(orderStatus, returnStatus);
                const shipping = order.shippingAddress || {};
                const city = shipping.city || 'N/A',
                    state = shipping.state || '',
                    country = shipping.country || 'India';
                let deliveryHTML = '';
                if (['pending', 'confirmed', 'processing', 'packed', 'shipped', 'out_for_delivery'].includes(
                        orderStatus) && order.orderTimeline?.deliveredMinAt && order.orderTimeline
                    ?.deliveredMaxAt) {
                    deliveryHTML =
                        `<div class="delivery-estimate"><span><i class="fas fa-box-open"></i> Earliest: <span id="delivery-min-${orderId}">--</span></span><span><i class="fas fa-truck"></i> Latest: <span id="delivery-max-${orderId}">--</span></span></div>`;
                }
                const returnBannerHTML = buildReturnBanner(order);
                let cardClass = '';
                if (returnStatus === 'approved') cardClass = ' return-approved-card';
                else if (returnStatus === 'rejected') cardClass = ' return-rejected-card';
                else if (returnStatus === 'requested') cardClass = ' return-requested-card';
                else if (returnStatus === 'expired') cardClass = ' return-expired-card';
                else if (returnStatus === 'returned') cardClass = ' returned-card';
                const actionButtons = buildActionButtons(orderStatus, returnStatus, isCOD, orderId, order);

                return `<div class="order-card${cardClass}" style="animation-delay:${index * 0.1}s">
            <div class="order-header">
                <div>
                    <div class="order-id-section"><span class="order-id">#${shortId}</span><span class="order-date"><i class="far fa-calendar-alt me-1"></i>${orderDate}</span></div>
                    <div class="delivery-info-row mt-2"><i class="fas fa-map-marker-alt"></i><span>${city}${state ? ', ' + state : ''}, ${country} 🇮🇳</span></div>
                </div>
                <div class="order-status-badge ${statusClass}"><span class="status-dot ${statusDotClass}"></span>${statusLabel}</div>
            </div>
            ${deliveryHTML}
            <div id="return-banner-${orderId}">${returnBannerHTML}</div>
            ${progressHTML}
            <div class="order-items">${itemsHTML || '<span class="text-muted small">No items</span>'}</div>
            <div class="order-footer">
                <div><small class="text-muted d-block">Total Amount</small><span class="order-total">₹${Number(totalAmount).toFixed(2)}</span><small class="text-muted d-block mt-1"><i class="fas fa-credit-card me-1"></i>${paymentDisplay}</small></div>
                <div class="order-actions">${actionButtons}</div>
            </div>
        </div>`;
            }

            function buildProgressHTML(orderStatus, returnStatus) {
                const steps = ['pending', 'confirmed', 'processing', 'packed', 'shipped', 'out_for_delivery',
                    'delivered', 'delivery_completed'
                ];
                if (orderStatus === 'cancelled') return `<div class="order-progress"><div class="progress-step cancelled-step"><div class="progress-dot" style="background:#ef4444;box-shadow:0 0 0 2px #ef4444;"></div><span class="progress-label" style="color:#ef4444;">Cancelled</span></div></div>`;
                if (orderStatus === 'delivery_failed')
                    return `<div class="order-progress"><div class="progress-step cancelled-step"><div class="progress-dot" style="background:#ef4444;box-shadow:0 0 0 2px #ef4444;"></div><span class="progress-label" style="color:#ef4444;">Delivery Failed</span></div></div>`;
                const idx = steps.indexOf(orderStatus);
                if (idx === -1) return '';
                let html = '';
                steps.forEach((s, i) => {
                    let stepClass = i <= idx ? 'completed' : '';
                    if (i === idx && orderStatus !== 'delivery_completed' && orderStatus !== 'delivered')
                        stepClass = 'active';
                    let lineClass = i < idx ? 'fill' : '';
                    if (i < idx && (orderStatus === 'delivery_completed' || orderStatus === 'delivered'))
                        lineClass = 'fill-green';
                    html += `<div class="progress-step ${stepClass}">
                ${i < steps.length - 1 ? `<div class="progress-line ${lineClass}"></div>` : ''}
                <div class="progress-dot"></div><span class="progress-label">${formatStepLabel(s)}</span></div>`;
                });
                if (returnStatus === 'returned') html +=
                    `<div class="progress-step returned-step"><div class="progress-dot" style="background:#10b981;box-shadow:0 0 0 2px #10b981;"></div><span class="progress-label" style="color:#10b981;">Returned</span></div>`;
                else if (returnStatus === 'approved') html +=
                    `<div class="progress-step return-approved-step"><div class="progress-dot" style="background:#10b981;box-shadow:0 0 0 2px #10b981;animation:pulseGreen 1.5s infinite;"></div><span class="progress-label" style="color:#10b981;">Return Approved</span></div>`;
                else if (returnStatus === 'requested') html +=
                    `<div class="progress-step return-step"><div class="progress-dot"></div><span class="progress-label" style="color:#f59e0b;">Return Requested</span></div>`;
                else if (returnStatus === 'rejected') html +=
                    `<div class="progress-step return-rejected-step"><div class="progress-dot" style="background:#ef4444;box-shadow:0 0 0 2px #ef4444;"></div><span class="progress-label" style="color:#ef4444;">Return Rejected</span></div>`;
                else if (returnStatus === 'expired') html +=
                    `<div class="progress-step return-expired-step"><div class="progress-dot" style="background:#f59e0b;box-shadow:0 0 0 2px #f59e0b;"></div><span class="progress-label" style="color:#f59e0b;">Expired</span></div>`;
                return `<div class="order-progress">${html}</div>`;
            }

            function formatStepLabel(step) {
                const map = {
                    pending: 'Pending',
                    confirmed: 'Confirmed',
                    processing: 'Processing',
                    packed: 'Packed',
                    shipped: 'Shipped',
                    out_for_delivery: 'Out for Delivery',
                    delivered: 'Delivered',
                    delivery_completed: 'Completed'
                };
                return map[step] || step;
            }

            function buildReturnBanner(order) {
                const rs = (order.returnStatus || 'none').toLowerCase();
                if (rs === 'approved') {
                    const appDate = order.returnTimeline?.returnApprovedAt ? parseCustomDate(order.returnTimeline
                        .returnApprovedAt)?.toLocaleString('en-IN') : 'N/A';
                    let html =
                        `<div class="return-approved-banner"><i class="fas fa-check-circle"></i><div><strong>Return Approved ✓</strong><br><small>Approved: ${appDate}</small>`;
                    if (order.returnrejectReason) html +=
                        `<br><small>Note: ${order.returnrejectReason}</small>`;
                    html += `</div></div>`;
                    return html;
                }
                if (rs === 'rejected') {
                    let html =
                        `<div class="return-rejected-banner"><i class="fas fa-times-circle"></i><div><strong>Return Rejected ✗</strong>`;
                    if (order.returnrejectReason) html +=
                        `<br><small>Reason: ${order.returnrejectReason}</small>`;
                    if (order.returnrejectComment) html +=
                        `<br><small>Comment: ${order.returnrejectComment}</small>`;
                    html += `</div></div>`;
                    return html;
                }
                if (rs === 'requested') {
                    const reqDate = order.returnTimeline?.returnRequestedAt ? parseCustomDate(order.returnTimeline
                        .returnRequestedAt)?.toLocaleString('en-IN') : 'Just now';
                    return `<div class="return-info-banner"><i class="fas fa-info-circle"></i><div><strong>Return Requested</strong><br><small>Requested: ${reqDate}</small><br><small>Reason: ${order.returnReason || 'N/A'}</small></div></div>`;
                }
                if (rs === 'expired') {
                    return `<div class="return-expired-banner"><i class="fas fa-hourglass-end"></i><div><strong>Return Expired</strong><br><small>Reason: ${order.returnReason || 'N/A'}</small></div></div>`;
                }
                if (rs === 'returned') {
                    return `<div class="returned-banner"><i class="fas fa-box"></i><div><strong>Return Completed ✓</strong><br><small>Reason: ${order.returnReason || 'N/A'}</small></div></div>`;
                }
                if ((order.orderStatus || '').toLowerCase() === 'delivery_completed') {
                    if (rs === 'none' && order.orderTimeline?.deliveryCompletedAt) {
                        return `<div class="return-info-banner"><i class="fas fa-clock"></i><div><strong>Return Window Active</strong><br><small>Return by: <span id="return-window-${order._id}" class="return-timer">--</span></small><br><span class="expiry-date-display" id="return-expiry-${order._id}"><i class="fas fa-calendar-alt"></i> Loading expiry...</span></div></div>`;
                    }
                }
                return '';
            }

            function buildActionButtons(orderStatus, returnStatus, isCOD, orderId, order) {
                let btns =
                    `<button class="btn-order-action primary" onclick="viewOrderDetails('${orderId}')"><i class="fas fa-eye"></i> View</button>`;

                if (orderStatus === 'delivered' && returnStatus === 'none') {
                    btns +=
                        `<button class="btn-order-action green" onclick="openOtpModal('${orderId}')"><i class="fas fa-check-circle"></i> Order Confirm</button>`;
                }

                if (orderStatus === 'delivery_completed' && returnStatus === 'none') {
                    if (!order.hasReviewed) btns +=
                        `<button class="btn-order-action purple" onclick="openReviewModal('${orderId}')"><i class="fas fa-star"></i> Review</button>`;
                    btns +=
                        `<button class="btn-order-action warning" onclick="openReturnModal('${orderId}')" id="return-btn-${orderId}"><i class="fas fa-undo-alt"></i> Return</button>`;
                    btns +=
                        `<button class="btn-order-action" onclick="buyAgain('${orderId}')"><i class="fas fa-redo"></i> Buy Again</button>`;
                }

                if (returnStatus === 'approved') btns +=
                    `<button class="btn-order-action success" onclick="openReturnCompleteModal('${orderId}')"><i class="fas fa-check-circle"></i> Mark Returned</button>`;
                if (returnStatus === 'requested') btns +=
                    `<button class="btn-order-action warning" disabled><i class="fas fa-undo-alt"></i> Return Pending</button>`;
                if (returnStatus === 'rejected') btns +=
                    `<button class="btn-order-action danger" disabled><i class="fas fa-times-circle"></i> Return Rejected</button>`;
                if (returnStatus === 'expired') btns +=
                    `<button class="btn-order-action orange" disabled><i class="fas fa-hourglass-end"></i> Return Expired</button>`;
                if (returnStatus === 'returned') btns +=
                    `<button class="btn-order-action success" disabled><i class="fas fa-box"></i> Returned</button>`;

                if (!['shipped', 'out_for_delivery', 'delivered', 'delivery_completed', 'delivery_failed',
                        'cancelled'
                    ].includes(orderStatus) && !['requested', 'approved', 'returned', 'rejected', 'expired']
                    .includes(returnStatus)) {
                    btns +=
                        `<button class="btn-order-action danger" onclick="cancelOrder('${orderId}')"><i class="fas fa-times"></i> Cancel</button>`;
                }
                if (orderStatus === 'cancelled' && !isCOD && returnStatus === 'none') btns +=
                    `<button class="btn-order-action info" onclick="openRefundModal('${orderId}')"><i class="fas fa-money-bill-wave"></i> Refund</button>`;
                return btns;
            }

            window.openOtpModal = function(orderId) {
                currentOtpOrderId = orderId;
                document.getElementById('otpModal').classList.add('show');
                document.getElementById('deliveryOtpInput').value = '';
            };
            window.closeOtpModal = function() {
                document.getElementById('otpModal').classList.remove('show');
                currentOtpOrderId = null;
            };
            window.submitOtpConfirmation = async function() {
                const otp = document.getElementById('deliveryOtpInput').value.trim();
                if (!otp) {
                    showModal('warning', 'OTP Required', '⚠️ Enter OTP');
                    return;
                }
                try {
                    const res = await fetch(`${API_BASE}/order/confirm-delivery/${currentOtpOrderId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ otp })
                    });
                    const data = await res.json();
                    if (data.success) {
                        closeOtpModal();
                        showSuccessAnimation('otp', 'OTP Confirmed!');
                    } else showModal('error', 'Invalid OTP', data.message || 'Invalid OTP');
                } catch (e) {
                    showModal('error', 'Network Error', 'Network error');
                }
            };

            window.viewOrderDetails = (id) => window.location.href = `/myOrder/${id}`;
            window.buyAgain = (id) => {
                toast('🛒 Adding items...');
                setTimeout(() => window.location.href = '/cart', 1000);
            };
            window.cancelOrder = async (id) => {
                if (!confirm('Cancel order?')) return;
                try {
                    const res = await fetch(`${API_BASE}/orders/cancel/${id}`, {
                        method: 'PUT',
                        credentials: 'include'
                    });
                    const data = await res.json();
                    if (data.success) showSuccessAnimation('cancel', 'Order Cancelled');
                    else showModal('error', 'Cancellation Failed', data.message || 'Failed');
                } catch (e) {
                    showModal('error', 'Network Error', 'Network error');
                }
            };

            window.openReviewModal = function(orderId) {
                currentReviewOrderId = orderId;
                document.getElementById('reviewModal').classList.add('show');
                selectedRating = 0;
                updateStars(0);
                document.getElementById('reviewTitle').value = '';
                document.getElementById('reviewComments').value = '';
                document.getElementById('reviewImages').value = '';
                document.getElementById('reviewVideos').value = '';
                const btn = document.getElementById('submitReviewBtn');
                btn.classList.remove('btn-loading');
                btn.querySelector('.btn-text').style.visibility = 'visible';
            };
            window.closeReviewModal = () => {
                document.getElementById('reviewModal').classList.remove('show');
                const btn = document.getElementById('submitReviewBtn');
                btn.classList.remove('btn-loading');
                btn.querySelector('.btn-text').style.visibility = 'visible';
            };
            window.submitReview = async () => {
                const rating = parseInt(document.getElementById('reviewRating').value);
                const comment = document.getElementById('reviewComments').value.trim();
                if (!rating || rating < 1) {
                    showModal('warning', 'Rating Required', '⚠️ Select rating');
                    return;
                }
                if (comment.length < 10) {
                    showModal('warning', 'Review Too Short', '⚠️ Review too short');
                    return;
                }

                const order = allOrders.find(o => o._id === currentReviewOrderId);
                if (!order || !order.items || order.items.length === 0) {
                    showModal('error', 'No Products', '⚠️ No products found');
                    return;
                }
                const productId = order.items[0].productId?._id || order.items[0].productId;
                if (!productId) {
                    showModal('error', 'Product Missing', '⚠️ Product ID missing');
                    return;
                }

                const btn = document.getElementById('submitReviewBtn');
                btn.classList.add('btn-loading');
                btn.querySelector('.btn-text').style.visibility = 'hidden';

                const formData = new FormData();
                formData.append('productId', productId);
                formData.append('rating', rating);
                formData.append('comment', comment);
                const imageFiles = document.getElementById('reviewImages').files;
                for (let i = 0; i < imageFiles.length; i++) formData.append('reviewImages', imageFiles[i]);
                const videoFiles = document.getElementById('reviewVideos').files;
                for (let i = 0; i < videoFiles.length; i++) formData.append('reviewVideos', videoFiles[i]);

                try {
                    const res = await fetch(`${API_BASE}/review`, {
                        method: 'POST',
                        credentials: 'include',
                        body: formData
                    });
                    const data = await res.json();
                    if (data.success) {
                        closeReviewModal();
                        showSuccessAnimation('review', 'Review Submitted!');
                        const orderIndex = allOrders.findIndex(o => o._id === currentReviewOrderId);
                        if (orderIndex !== -1) allOrders[orderIndex].hasReviewed = true;
                        filterOrders(currentFilter);
                    } else {
                        btn.classList.remove('btn-loading');
                        btn.querySelector('.btn-text').style.visibility = 'visible';
                        showModal('error', 'Review Failed', data.message || 'Failed');
                    }
                } catch (e) {
                    btn.classList.remove('btn-loading');
                    btn.querySelector('.btn-text').style.visibility = 'visible';
                    showModal('error', 'Network Error', 'Network error');
                }
            };

            window.openReturnModal = function(orderId) {
                currentReturnOrderId = orderId;
                document.getElementById('returnModal').classList.add('show');
                document.getElementById('returnReason').value = '';
                document.getElementById('returnComments').value = '';
                document.getElementById('returnModalTimer').textContent = '--';
                document.getElementById('returnModalExpiry').textContent = '--';
                document.getElementById('returnModalReadable').textContent = '--';
                document.getElementById('returnWindowInfo').style.display = 'none';
                const submitBtn = document.getElementById('submitReturnBtn');
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
                submitBtn.textContent = 'Submit Return';
                fetch(`${API_BASE}/order/return-time/${orderId}`, { credentials: 'include' })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success && data.data && data.data.isExpired) {
                            document.getElementById('returnWindowInfo').style.display = 'flex';
                            document.getElementById('returnModalTimer').textContent = 'EXPIRED';
                            document.getElementById('returnModalExpiry').textContent = data.data
                                .expiryTime ? formatExpiryDate(data.data.expiryTime) : '--';
                            document.getElementById('returnModalReadable').textContent = data.data
                                .readableRemainingTime || 'EXPIRED';
                            submitBtn.disabled = true;
                            submitBtn.style.opacity = '0.5';
                            submitBtn.textContent = 'Return Window Expired';
                            showModal('warning', 'Return Expired', '⏰ Return window expired');
                        } else if (data.success && data.data && data.data.remainingTime) {
                            startReturnModalTimerFromApi(data.data.remainingTime, data.data.expiryTime,
                                data.data.readableRemainingTime);
                        } else {
                            startReturnModalTimerFallback(orderId);
                        }
                    })
                    .catch(() => startReturnModalTimerFallback(orderId));
            };
            window.closeReturnModal = function() {
                document.getElementById('returnModal').classList.remove('show');
                currentReturnOrderId = null;
                if (returnModalTimerId) {
                    clearInterval(returnModalTimerId);
                    returnModalTimerId = null;
                }
                document.getElementById('returnWindowInfo').style.display = 'none';
            };
            window.submitReturn = async function() {
                const reason = document.getElementById('returnReason').value;
                const comments = document.getElementById('returnComments').value.trim();
                if (!reason) {
                    showModal('warning', 'Reason Required', '⚠️ Select reason');
                    return;
                }
                try {
                    const check = await fetch(`${API_BASE}/order/return-time/${currentReturnOrderId}`, {
                        credentials: 'include'
                    });
                    const checkData = await check.json();
                    if (checkData.success && checkData.data && checkData.data.isExpired) {
                        showModal('warning', 'Return Expired', '⏰ Return window expired');
                        closeReturnModal();
                        await fetchOrders();
                        return;
                    }
                } catch (e) {}
                try {
                    const res = await fetch(`${API_BASE}/order/return-request/${currentReturnOrderId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({
                            returnReason: reason,
                            returnComments: comments || undefined
                        })
                    });
                    const data = await res.json();
                    if (data.success) {
                        closeReturnModal();
                        showSuccessAnimation('return', 'Return Requested!');
                    } else showModal('error', 'Return Failed', data.message || 'Failed');
                } catch (e) {
                    showModal('error', 'Network Error', 'Network error');
                }
            };

            function startReturnModalTimerFromApi(remainingTime, expiryTime, readableRemainingTime) {
                if (returnModalTimerId) clearInterval(returnModalTimerId);
                const deadline = new Date(Date.now() + remainingTime);
                document.getElementById('returnWindowInfo').style.display = 'flex';
                document.getElementById('returnModalExpiry').textContent = formatExpiryDate(expiryTime);
                document.getElementById('returnModalReadable').textContent = readableRemainingTime || '';

                function update() {
                    const remaining = getTimeRemaining(deadline);
                    const timerEl = document.getElementById('returnModalTimer');
                    const submitBtn = document.getElementById('submitReturnBtn');
                    if (timerEl) timerEl.textContent = formatTimerDisplay(remaining);
                    if (remaining.expired) {
                        if (submitBtn) {
                            submitBtn.disabled = true;
                            submitBtn.style.opacity = '0.5';
                            submitBtn.textContent = 'Return Window Expired';
                        }
                        if (returnModalTimerId) {
                            clearInterval(returnModalTimerId);
                            returnModalTimerId = null;
                        }
                        showModal('warning', 'Return Expired', '⏰ Return window expired');
                    }
                }
                update();
                returnModalTimerId = setInterval(update, 1000);
            }

            function startReturnModalTimerFallback(orderId) {
                if (returnModalTimerId) clearInterval(returnModalTimerId);
                const order = allOrders.find(o => o._id === orderId);
                if (!order || !order.orderTimeline?.deliveryCompletedAt) return;
                const completedDate = parseCustomDate(order.orderTimeline.deliveryCompletedAt);
                if (!completedDate || isNaN(completedDate)) return;
                const returnDeadline = new Date(completedDate.getTime() + RETURN_WINDOW_MS);
                document.getElementById('returnWindowInfo').style.display = 'flex';
                document.getElementById('returnModalExpiry').textContent = formatExpiryDate(returnDeadline.getTime());
                document.getElementById('returnModalReadable').textContent = '';

                function update() {
                    const remaining = getTimeRemaining(returnDeadline);
                    const timerEl = document.getElementById('returnModalTimer');
                    const submitBtn = document.getElementById('submitReturnBtn');
                    if (timerEl) timerEl.textContent = formatTimerDisplay(remaining);
                    if (remaining.expired) {
                        if (submitBtn) {
                            submitBtn.disabled = true;
                            submitBtn.style.opacity = '0.5';
                            submitBtn.textContent = 'Return Window Expired';
                        }
                        if (returnModalTimerId) {
                            clearInterval(returnModalTimerId);
                            returnModalTimerId = null;
                        }
                        showModal('warning', 'Return Expired', '⏰ Return window expired');
                    }
                }
                update();
                returnModalTimerId = setInterval(update, 1000);
            }

            window.openRefundModal = (id) => {
                currentReviewOrderId = id;
                document.getElementById('refundModal').classList.add('show');
            };
            window.closeRefundModal = () => document.getElementById('refundModal').classList.remove('show');
            window.submitRefund = async () => {
                const reason = document.getElementById('refundReason').value;
                const comments = document.getElementById('refundComments').value.trim();
                if (!reason) {
                    showModal('warning', 'Reason Required', '⚠️ Select reason');
                    return;
                }
                try {
                    const res = await fetch(`${API_BASE}/refund-request`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({
                            orderId: currentReviewOrderId,
                            refundReason: reason,
                            refundComments: comments || undefined
                        })
                    });
                    const data = await res.json();
                    if (data.success) {
                        closeRefundModal();
                        showSuccessAnimation('refund', 'Refund Requested!');
                    } else showModal('error', 'Refund Failed', data.message || 'Failed');
                } catch (e) {
                    showModal('error', 'Network Error', 'Network error');
                }
            };

            window.openReturnCompleteModal = (id) => {
                currentReturnCompleteOrderId = id;
                document.getElementById('returnCompleteModal').classList.add('show');
            };
            window.closeReturnCompleteModal = () => document.getElementById('returnCompleteModal').classList.remove('show');
            window.confirmReturnComplete = async () => {
                try {
                    const res = await fetch(`${API_BASE}/admin/order/return-complete/${currentReturnCompleteOrderId}`, {
                        method: 'PUT',
                        credentials: 'include'
                    });
                    const data = await res.json();
                    if (data.success) {
                        closeReturnCompleteModal();
                        showSuccessAnimation('return', 'Return Completed!');
                    } else showModal('error', 'Return Completion Failed', data.message || 'Failed');
                } catch (e) {
                    showModal('error', 'Network Error', 'Network error');
                }
            };

            document.querySelectorAll('.modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) {
                        this.classList.remove('show');
                        if (this.id === 'returnModal') closeReturnModal();
                        if (this.id === 'otpModal') closeOtpModal();
                    }
                });
            });

            document.getElementById('userIconBtn').addEventListener('click', (e) => {
                e.stopPropagation();
                if (!isAuthenticated) {
                    redirectToLogin();
                    return;
                }
                document.getElementById('userDropdownMenu').classList.toggle('show');
            });
            document.addEventListener('click', (e) => {
                if (!e.target.closest('#userDropdown')) document.getElementById('userDropdownMenu').classList
                    .remove('show');
            });
            document.getElementById('menuLogout').addEventListener('click', async (e) => {
                e.preventDefault();
                try { await fetch('/logout', { method: 'GET', credentials: 'include' }); } catch (e) {}
                isAuthenticated = false;
                updateLoginUI();
                updateCartBadge(0);
                showModal('info', 'Logged Out', 'Logged out successfully', {
                    autoHide: 2000,
                    onPrimary: () => redirectToLogin()
                });
            });

            (async () => {
                if (await checkAuth()) {
                    await fetchCartCount();
                    await fetchOrders();
                }
            })();
        })();
    </script>
</body>
</html>
