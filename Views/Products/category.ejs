    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>
    <script>
        (function () {
            // ========== PARTICLES ANIMATION ==========
            const particlesContainer = document.getElementById('particlesContainer');
            for (let i = 0; i < 30; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                const size = Math.random() * 40 + 5;
                p.style.width = size + 'px';
                p.style.height = size + 'px';
                p.style.background = ['#ff6b6b', '#4ecdc4', '#ffe66d', '#a55eea', '#667eea'][Math.floor(Math.random() * 5)];
                p.style.left = Math.random() * 100 + '%';
                p.style.top = Math.random() * 100 + '%';
                p.style.animationDelay = Math.random() * 12 + 's';
                p.style.animationDuration = (Math.random() * 18 + 8) + 's';
                p.style.opacity = Math.random() * 0.3 + 0.1;
                particlesContainer.appendChild(p);
            }

            // ========== HEADER SCROLL EFFECT ==========
            const header = document.getElementById('header');
            window.addEventListener('scroll', () => {
                header.classList.toggle('scrolled', window.scrollY > 50);
            });

            // ========== DATA & STATE ==========
            let allProducts = [];
            let filteredProducts = [];
            let cartItemIds = new Set();
            let wishlistItemIds = new Set();
            let isSearchActive = false;
            let isLoggedIn = false;

            // Reviews state
            let allReviews = [];
            let ratingCounts = {};
            let productRatingsMap = {};

            // ========== DOM ELEMENTS ==========
            const productsGrid = document.getElementById('productsGrid');
            const loadingStateDiv = document.getElementById('loadingState');
            const brandFilterDiv = document.getElementById('brandFilter');
            const minPriceInput = document.getElementById('minPrice');
            const maxPriceInput = document.getElementById('maxPrice');
            const priceSlider = document.getElementById('priceRange');
            const applyBtn = document.getElementById('applyFiltersBtn');
            const resetBtn = document.getElementById('resetFiltersBtn');
            const sortSelect = document.getElementById('sortSelect');
            const cartCountSpan = document.getElementById('cartCount');
            const searchInput = document.getElementById('searchInput');
            const searchBtn = document.getElementById('searchBtn');
            const filtersSidebar = document.getElementById('filtersSidebar');
            const filterToggleBtn = document.getElementById('filterToggleBtn');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            const closeFiltersBtn = document.getElementById('closeFiltersBtn');
            const productCountSpan = document.getElementById('productCount');

            // ========== USER DROPDOWN & AUTHENTICATION ==========
            const userIconBtn = document.getElementById('userIconBtn');
            const userDropdownMenu = document.getElementById('userDropdownMenu');
            const menuLogout = document.getElementById('menuLogout');

            // ========== MODAL SYSTEM ==========
            const notificationModal = document.getElementById('notificationModal');
            const modalIconCircle = document.getElementById('modalIconCircle');
            const modalTitle = document.getElementById('modalTitle');
            const modalMessage = document.getElementById('modalMessage');
            const modalPrimaryBtn = document.getElementById('modalPrimaryBtn');
            const modalSecondaryBtn = document.getElementById('modalSecondaryBtn');
            let bsModalInstance = null;
            let modalAutoHideTimer = null;

            if (notificationModal) {
                bsModalInstance = new bootstrap.Modal(notificationModal, {
                    backdrop: 'static',
                    keyboard: true
                });
            }

            function showModal(type = 'success', title = 'Success!', message = '', options = {}) {
                if (!bsModalInstance) return;
                if (modalAutoHideTimer) {
                    clearTimeout(modalAutoHideTimer);
                    modalAutoHideTimer = null;
                }

                modalIconCircle.className = 'modal-icon-circle';
                modalIconCircle.innerHTML = '';

                switch (type) {
                    case 'success':
                        modalIconCircle.classList.add('success');
                        modalIconCircle.innerHTML = '<i class="fas fa-check-circle"></i>';
                        break;
                    case 'error':
                        modalIconCircle.classList.add('error');
                        modalIconCircle.innerHTML = '<i class="fas fa-times-circle"></i>';
                        break;
                    case 'warning':
                        modalIconCircle.classList.add('warning');
                        modalIconCircle.innerHTML = '<i class="fas fa-exclamation-triangle"></i>';
                        break;
                    case 'info':
                    default:
                        modalIconCircle.classList.add('info');
                        modalIconCircle.innerHTML = '<i class="fas fa-info-circle"></i>';
                        break;
                }

                modalTitle.textContent = title;
                modalMessage.textContent = message;

                modalPrimaryBtn.textContent = options.primaryText || 'OK';
                modalPrimaryBtn.style.display = 'inline-block';
                modalPrimaryBtn.onclick = function() {
                    if (options.onPrimary && typeof options.onPrimary === 'function') {
                        options.onPrimary();
                    }
                    bsModalInstance.hide();
                };

                if (options.secondaryText) {
                    modalSecondaryBtn.textContent = options.secondaryText;
                    modalSecondaryBtn.style.display = 'inline-block';
                    modalSecondaryBtn.onclick = function() {
                        if (options.onSecondary && typeof options.onSecondary === 'function') {
                            options.onSecondary();
                        }
                        bsModalInstance.hide();
                    };
                } else {
                    modalSecondaryBtn.style.display = 'none';
                }

                bsModalInstance.show();

                const autoHideDelay = options.autoHide || (type === 'success' ? 2500 : (type === 'info' ? 3000 : 0));
                if (autoHideDelay > 0) {
                    modalAutoHideTimer = setTimeout(() => {
                        if (bsModalInstance && notificationModal.classList.contains('show')) {
                            bsModalInstance.hide();
                        }
                    }, autoHideDelay);
                }
            }

            // ========== AUTHENTICATION ==========
            async function checkAuth() {
                try {
                    const response = await fetch('/api/check-auth', {
                        method: 'GET',
                        credentials: 'include'
                    });
                    if (!response.ok) throw new Error('Auth check failed');
                    const data = await response.json();
                    isLoggedIn = data.loggedIn;
                    updateLoginUI();
                    if (isLoggedIn) {
                        await Promise.all([fetchCart(), fetchWishlist()]);
                        renderProducts();
                    }
                } catch (error) {
                    console.error('Auth check failed:', error);
                    isLoggedIn = false;
                    updateLoginUI();
                }
            }

            function updateLoginUI() {
                if (menuLogout) {
                    menuLogout.style.display = isLoggedIn ? 'flex' : 'none';
                }
                if (userIconBtn) {
                    userIconBtn.style.color = isLoggedIn ? '#4ecdc4' : '#666';
                }
            }

            userIconBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                if (!isLoggedIn) {
                    window.location.href = '/login';
                    return;
                }
                userDropdownMenu.classList.toggle('show');
            });

            document.addEventListener('click', (e) => {
                if (!e.target.closest('#userDropdown')) {
                    userDropdownMenu.classList.remove('show');
                }
            });

            menuLogout.addEventListener('click', async (e) => {
                e.preventDefault();
                e.stopPropagation();
                try {
                    const response = await fetch('/logout', {
                        method: 'GET',
                        credentials: 'include'
                    });
                    if (response.ok || response.redirected) {
                        isLoggedIn = false;
                        updateLoginUI();
                        userDropdownMenu.classList.remove('show');
                        cartItemIds.clear();
                        wishlistItemIds.clear();
                        updateCartCountUI(0);
                        renderProducts();
                        showModal('info', 'Logged Out', 'You have been logged out successfully.', {
                            autoHide: 2000,
                            onPrimary: () => { window.location.href = '/login'; }
                        });
                        setTimeout(() => { window.location.href = '/login'; }, 2200);
                    }
                } catch (error) {
                    console.error('Logout failed:', error);
                    showModal('error', 'Error', 'Logout failed. Please try again.');
                }
            });

            // ========== UTILITY FUNCTIONS ==========
            function updateCartCountUI(count) {
                cartCountSpan.textContent = count || 0;
            }

            function escapeHtml(str) {
                if (!str) return '';
                const div = document.createElement('div');
                div.appendChild(document.createTextNode(str));
                return div.innerHTML;
            }

            // Helper to generate star HTML
            function generateStarsHTML(rating, emptyClass = 'empty-inline') {
                const fullStars = Math.floor(rating);
                const halfStar = rating % 1 >= 0.5;
                const emptyStars = 5 - fullStars - (halfStar ? 1 : 0);
                let html = '';
                for (let i = 0; i < fullStars; i++) html += '<i class="fas fa-star"></i>';
                if (halfStar) html += '<i class="fas fa-star-half-alt"></i>';
                for (let i = 0; i < emptyStars; i++) html += `<i class="far fa-star ${emptyClass}"></i>`;
                return html;
            }

            // ========== MOBILE FILTERS ==========
            function openFilters() {
                filtersSidebar.classList.add('open');
                sidebarOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
            function closeFilters() {
                filtersSidebar.classList.remove('open');
                sidebarOverlay.classList.remove('active');
                document.body.style.overflow = '';
            }
            filterToggleBtn.addEventListener('click', openFilters);
            closeFiltersBtn.addEventListener('click', closeFilters);
            sidebarOverlay.addEventListener('click', closeFilters);

            // ========== FALLBACK PRODUCTS ==========
            const fallbackProducts = [
                { id: 1, name: "Slim Fit Jeans", brand: "URBANSTYLE", price: 29.99, comparePrice: 49.99, image: "https://images.unsplash.com/photo-1542272604-787c3835535d?w=300&fit=crop", stock: 25, discountPercent: 40 },
                { id: 2, name: "Premium Cotton T-Shirt", brand: "COMFORTWEAR", price: 59.99, comparePrice: 89.99, image: "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=300&fit=crop", stock: 40, discountPercent: 33 },
                { id: 3, name: "Classic Leather Jacket", brand: "MOTOGEAR", price: 149.99, comparePrice: 249.99, image: "https://images.unsplash.com/photo-1551028719-00167b16eac5?w=300&fit=crop", stock: 15, discountPercent: 40 },
                { id: 4, name: "Wireless Earbuds Pro", brand: "SOUNDX", price: 79.99, comparePrice: 129.99, image: "https://images.unsplash.com/photo-1590658268037-6bf12f032f55?w=300&fit=crop", stock: 30, discountPercent: 38 },
                { id: 5, name: "Running Shoes", brand: "STRIDELAB", price: 99.99, comparePrice: 159.99, image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=300&fit=crop", stock: 22, discountPercent: 37 },
                { id: 6, name: "Minimalist Watch", brand: "TIMEWEAR", price: 189.99, comparePrice: 299.99, image: "https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=300&fit=crop", stock: 8, discountPercent: 36 },
                { id: 7, name: "Canvas Backpack", brand: "URBANSTYLE", price: 49.99, comparePrice: 79.99, image: "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=300&fit=crop", stock: 18, discountPercent: 37 },
                { id: 8, name: "Oversized Hoodie", brand: "COMFORTWEAR", price: 69.99, comparePrice: 109.99, image: "https://images.unsplash.com/photo-1556821840-3a63f95609a7?w=300&fit=crop", stock: 35, discountPercent: 36 }
            ];

            // ========== FETCH CART ==========
            async function fetchCart() {
                if (!isLoggedIn) { updateCartCountUI(0); return; }
                try {
                    const res = await fetch('/carts', { credentials: 'include' });
                    if (res.ok) {
                        const data = await res.json();
                        if (data.success && data.data) {
                            cartItemIds.clear();
                            data.data.forEach(item => cartItemIds.add(item.productId.toString()));
                            updateCartCountUI(data.count || data.data.length);
                        }
                    } else if (res.status === 401) {
                        isLoggedIn = false; updateLoginUI(); updateCartCountUI(0);
                    } else { updateCartCountUI(0); }
                } catch (err) { console.error('Error fetching cart:', err); updateCartCountUI(0); }
            }

            // ========== FETCH WISHLIST ==========
            async function fetchWishlist() {
                if (!isLoggedIn) return;
                try {
                    const res = await fetch('/wishlists', { credentials: 'include' });
                    if (res.ok) {
                        const data = await res.json();
                        if (data.success && data.data) {
                            wishlistItemIds.clear();
                            data.data.forEach(item => wishlistItemIds.add(item.productId.toString()));
                        }
                    }
                } catch (err) { console.error('Error fetching wishlist:', err); }
            }

            // ========== FETCH REVIEWS DATA ==========
            async function fetchReviewsData() {
                try {
                    const [reviewsRes, ratingCountRes] = await Promise.all([
                        fetch('/reviews'),
                        fetch('/reviews/ratings/count')
                    ]);

                    if (reviewsRes.ok) {
                        const data = await reviewsRes.json();
                        if (data.success && data.reviews) {
                            allReviews = data.reviews;
                        }
                    } else {
                        console.warn('Reviews fetch failed, using empty reviews');
                        allReviews = [];
                    }

                    if (ratingCountRes.ok) {
                        const data = await ratingCountRes.json();
                        if (data.success && data.ratingCounts) {
                            ratingCounts = data.ratingCounts;
                        }
                    } else {
                        ratingCounts = {};
                    }
                } catch (err) {
                    console.warn('Reviews data fetch error:', err.message);
                    allReviews = [];
                    ratingCounts = {};
                }
                computeProductRatingsMap();
                renderProducts();
            }

            function computeProductRatingsMap() {
                productRatingsMap = {};
                if (!allReviews.length) return;

                const productRatingAccum = {};

                allReviews.forEach(review => {
                    const reviewItems = review.reviewItems || [];
                    reviewItems.forEach(item => {
                        const productId = item.productId?._id || item.productId?.id || item.productId;
                        if (!productId) return;
                        const productIdStr = productId.toString();
                        if (!productRatingAccum[productIdStr]) {
                            productRatingAccum[productIdStr] = { totalRating: 0, count: 0 };
                        }
                        productRatingAccum[productIdStr].totalRating += (item.rating || 0);
                        productRatingAccum[productIdStr].count += 1;
                    });
                });

                Object.keys(productRatingAccum).forEach(pid => {
                    const { totalRating, count } = productRatingAccum[pid];
                    productRatingsMap[pid] = {
                        averageRating: Math.round((totalRating / count) * 10) / 10,
                        totalReviews: count
                    };
                });
            }

            // ========== FETCH PRODUCTS ==========
            function getCategoryId() {
                const parts = window.location.pathname.split("/").filter(p => p);
                const last = parts[parts.length - 1];
                return (last === "productForm" || last === "browse" || !last) ? "pro-x1" : last;
            }

            async function fetchProducts() {
                const categoryId = getCategoryId();
                loadingStateDiv.style.display = 'flex';
                productsGrid.innerHTML = '';
                try {
                    const res = await fetch(`/categorie/${categoryId}`);
                    if (!res.ok) throw new Error('API failed');
                    const data = await res.json();
                    if (data.products && Array.isArray(data.products)) {
                        allProducts = data.products.map(p => ({
                            id: p.id || p._id,
                            name: p.productName || 'Product',
                            brand: p.brand || 'Premium',
                            price: parseFloat(p.price) || 0,
                            comparePrice: parseFloat(p.comparePrice) || 0,
                            image: p.mainImage?.path ? `${p.mainImage.path}` : 'https://placehold.co/300x300?text=ShopEasy',
                            stock: parseInt(p.stockQuantity || p.stock) ?? 10,
                            discountPercent: p.offerPercent || (p.comparePrice > 0 ? Math.round(((p.comparePrice - p.price) / p.comparePrice) * 100) : 0)
                        }));
                    } else throw new Error('Invalid format');
                } catch (err) {
                    console.warn('Using fallback products:', err.message);
                    allProducts = [...fallbackProducts];
                } finally {
                    loadingStateDiv.style.display = 'none';
                    initFiltersAndRender();
                }
            }

            function initFiltersAndRender() {
                populateBrands();
                setPriceLimits();
                applyFiltersAndRender();
            }

            function populateBrands() {
                const brands = [...new Set(allProducts.map(p => p.brand))];
                brandFilterDiv.innerHTML = brands.map(b =>
                    `<label class="brand-check-premium">
                        <input type="checkbox" value="${escapeHtml(b)}" class="brand-checkbox" checked />
                        <span>${escapeHtml(b)}</span>
                    </label>`
                ).join('');
            }

            function setPriceLimits() {
                const prices = allProducts.map(p => p.price);
                if (!prices.length) return;
                const min = Math.floor(Math.min(...prices) / 5) * 5;
                const max = Math.ceil(Math.max(...prices) / 10) * 10;
                priceSlider.min = min;
                priceSlider.max = max;
                priceSlider.value = max;
                minPriceInput.value = min;
                maxPriceInput.value = max;
            }

            function getSelectedBrands() {
                return Array.from(document.querySelectorAll('.brand-checkbox:checked')).map(cb => cb.value);
            }
            function getOfferFilter() {
                const sel = document.querySelector('input[name="offerType"]:checked');
                return sel ? sel.value : 'all';
            }

            function applyFiltersAndRender() {
                const searchQuery = searchInput.value.trim().toLowerCase();
                let temp = [...allProducts];

                if (searchQuery) {
                    temp = temp.filter(p => p.name.toLowerCase().includes(searchQuery) || p.brand.toLowerCase().includes(searchQuery));
                }

                const brands = getSelectedBrands();
                if (brands.length > 0 && brands.length < [...new Set(allProducts.map(p => p.brand))].length) {
                    temp = temp.filter(p => brands.includes(p.brand));
                }

                const minP = parseFloat(minPriceInput.value) || 0;
                const maxP = parseFloat(maxPriceInput.value) || Infinity;
                temp = temp.filter(p => p.price >= minP && p.price <= maxP);

                const offer = getOfferFilter();
                if (offer !== 'all') {
                    temp = temp.filter(p => {
                        const disc = p.discountPercent || 0;
                        switch (offer) {
                            case 'with-discount': return disc > 0;
                            case 'discount-20+': return disc >= 20;
                            case 'discount-40+': return disc >= 40;
                            default: return true;
                        }
                    });
                }

                const sortVal = sortSelect.value;
                switch (sortVal) {
                    case 'price-asc': temp.sort((a, b) => a.price - b.price); break;
                    case 'price-desc': temp.sort((a, b) => b.price - a.price); break;
                    case 'name': temp.sort((a, b) => a.name.localeCompare(b.name)); break;
                    case 'discount': temp.sort((a, b) => (b.discountPercent || 0) - (a.discountPercent || 0)); break;
                }

                filteredProducts = temp;
                productCountSpan.textContent = `All Products (${filteredProducts.length})`;
                renderProducts();
                if (window.innerWidth <= 992) closeFilters();
            }

            // ========== RENDER PRODUCTS (WITH RATINGS) ==========
            function renderProducts() {
                if (!filteredProducts.length) {
                    productsGrid.innerHTML = `<div class="empty-state-premium">
                        <i class="fas fa-box-open fa-3x"></i>
                        <h5>No products match</h5>
                        <p class="text-muted">Try different filters or search terms</p>
                    </div>`;
                    return;
                }

                productsGrid.innerHTML = filteredProducts.map((p, idx) => {
                    const productIdStr = p.id.toString();
                    const inWishlist = wishlistItemIds.has(productIdStr);
                    const inCart = cartItemIds.has(productIdStr);
                    const outStock = p.stock <= 0;
                    const lowStock = p.stock > 0 && p.stock <= 5;
                    const discount = p.discountPercent || 0;

                    // Product rating
                    const prodRating = productRatingsMap[productIdStr];
                    let ratingRowHTML = '';
                    if (prodRating && prodRating.totalReviews > 0) {
                        ratingRowHTML = `
                        <div class="product-rating-row">
                            <span class="stars-inline">${generateStarsHTML(prodRating.averageRating, 'empty-inline')}</span>
                            <span class="rating-count-text">(${prodRating.totalReviews})</span>
                        </div>`;
                    }

                    // Stock badge
                    let stockBadgeHTML = '';
                    if (outStock) {
                        stockBadgeHTML = '<span class="stock-badge out-of-stock"><i class="fas fa-times-circle"></i> Out of Stock</span>';
                    } else if (lowStock) {
                        stockBadgeHTML = `<span class="stock-badge low-stock"><i class="fas fa-exclamation-circle"></i> Only ${p.stock} left</span>`;
                    } else {
                        stockBadgeHTML = `<span class="stock-badge in-stock"><i class="fas fa-check-circle"></i> ${p.stock} in stock</span>`;
                    }

                    // Stock info row
                    let stockInfoRow = '';
                    if (outStock) {
                        stockInfoRow = '<div class="stock-info-row text-danger"><span class="stock-dot red"></span> Out of Stock</div>';
                    } else if (lowStock) {
                        stockInfoRow = `<div class="stock-info-row text-warning"><span class="stock-dot orange"></span> Only ${p.stock} left — Hurry!</div>`;
                    } else {
                        stockInfoRow = `<div class="stock-info-row text-success"><span class="stock-dot green"></span> In Stock (${p.stock} available)</div>`;
                    }

                    return `
                        <div class="product-card-premium" style="animation-delay: ${idx * 0.08}s;" data-product-id="${p.id}">
                            <div class="product-img-wrap-premium">
                                <img src="${p.image}" alt="${escapeHtml(p.name)}" onerror="this.src='https://placehold.co/300x300?text=ShopEasy'" loading="lazy" />
                                ${discount > 0 ? `<div class="discount-badge-premium">-${discount}%</div>` : ''}
                                ${stockBadgeHTML}
                                <button class="wishlist-btn-card ${inWishlist ? 'active-wishlist' : ''}" data-wishlist="${p.id}" aria-label="${inWishlist ? 'Remove from wishlist' : 'Add to wishlist'}">
                                    <i class="fa${inWishlist ? 's' : 'r'} fa-heart"></i>
                                </button>
                            </div>
                            <div class="product-details-premium">
                                <div class="product-brand-premium">${escapeHtml(p.brand)}</div>
                                <div class="product-title-premium">${escapeHtml(p.name)}</div>
                                ${ratingRowHTML}
                                ${stockInfoRow}
                                <div class="price-row-premium">
                                    <span class="current-price-premium">₹${p.price.toFixed(2)}</span>
                                    ${p.comparePrice > p.price ? `<span class="old-price-premium">₹${p.comparePrice.toFixed(2)}</span>` : ''}
                                </div>
                                <div class="product-actions-premium">
                                    <button class="btn-add-cart-premium ${inCart ? 'in-cart' : ''}" ${outStock ? 'disabled' : ''} data-addcart="${p.id}">
                                        ${outStock ? 'Out of Stock' : (inCart ? '<i class="fas fa-shopping-cart me-1"></i> Go to Cart' : '<i class="fas fa-cart-plus me-1"></i> Add to Cart')}
                                    </button>
                                </div>
                            </div>
                        </div>`;
                }).join('');

                attachEventListeners();
            }

            function attachEventListeners() {
                document.querySelectorAll('.product-card-premium').forEach(card => {
                    card.addEventListener('click', function(e) {
                        if (e.target.closest('button')) return;
                        const productId = this.dataset.productId;
                        if (productId) window.location.href = `/singleproduct/${productId}`;
                    });
                });

                document.querySelectorAll('[data-addcart]').forEach(btn => {
                    btn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        if (!isLoggedIn) {
                            showModal('warning', 'Login Required', 'Please login to add items to your cart.', {
                                primaryText: 'Login Now',
                                onPrimary: () => { window.location.href = '/login'; },
                                secondaryText: 'Later',
                                autoHide: 0
                            });
                            return;
                        }
                        const id = this.dataset.addcart;
                        handleCartClick(id, this);
                    });
                });

                document.querySelectorAll('[data-wishlist]').forEach(btn => {
                    btn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        if (!isLoggedIn) {
                            showModal('warning', 'Login Required', 'Please login to manage your wishlist.', {
                                primaryText: 'Login Now',
                                onPrimary: () => { window.location.href = '/login'; },
                                secondaryText: 'Later',
                                autoHide: 0
                            });
                            return;
                        }
                        const id = this.dataset.wishlist;
                        toggleWishlist(id, this);
                    });
                });
            }

            function handleCartClick(productId, buttonElement) {
                if (cartItemIds.has(productId.toString())) {
                    window.location.href = '/cart';
                    return;
                }
                addToCart(productId, buttonElement);
            }

            async function addToCart(productId, buttonElement) {
                try {
                    buttonElement.disabled = true;
                    const originalHTML = buttonElement.innerHTML;
                    buttonElement.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding...';
                    const res = await fetch('/cart', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ productId, quantity: 1 })
                    });
                    const data = await res.json();
                    if (data.success) {
                        cartItemIds.add(productId.toString());
                        showModal('success', 'Added to Cart!', 'Item added to your cart successfully.', {
                            autoHide: 2200,
                            primaryText: 'Continue Shopping',
                            secondaryText: 'View Cart',
                            onSecondary: () => { window.location.href = '/cart'; }
                        });
                        await fetchCart();
                        renderProducts();
                    } else if (res.status === 401) {
                        showModal('warning', 'Login Required', 'Please login to add items to your cart.', {
                            primaryText: 'Login Now',
                            onPrimary: () => { window.location.href = '/login'; },
                            autoHide: 0
                        });
                        buttonElement.disabled = false;
                        buttonElement.innerHTML = originalHTML;
                    } else {
                        showModal('error', 'Oops!', data.message || 'Failed to add to cart');
                        buttonElement.disabled = false;
                        buttonElement.innerHTML = originalHTML;
                    }
                } catch (err) {
                    console.error('Add to cart error:', err);
                    showModal('warning', 'Network Error', 'Unable to connect. Please try again.');
                    buttonElement.disabled = false;
                    buttonElement.innerHTML = '<i class="fas fa-cart-plus me-1"></i> Add to Cart';
                }
            }

            async function toggleWishlist(productId, buttonElement) {
                const isCurrentlyActive = buttonElement.classList.contains('active-wishlist');
                try {
                    buttonElement.disabled = true;
                    if (isCurrentlyActive) {
                        const res = await fetch('/wishlist', {
                            method: 'DELETE',
                            headers: { 'Content-Type': 'application/json' },
                            credentials: 'include',
                            body: JSON.stringify({ productId })
                        });
                        const data = await res.json();
                        if (data.success) {
                            wishlistItemIds.delete(productId.toString());
                            showModal('info', 'Removed', 'Item removed from your wishlist.', { autoHide: 2000 });
                            renderProducts();
                        } else if (res.status === 401) {
                            showModal('warning', 'Login Required', 'Please login to manage your wishlist.', {
                                primaryText: 'Login Now',
                                onPrimary: () => { window.location.href = '/login'; },
                                autoHide: 0
                            });
                            buttonElement.disabled = false;
                        } else {
                            showModal('error', 'Error', data.message || 'Failed to remove');
                            buttonElement.disabled = false;
                        }
                    } else {
                        const res = await fetch('/wishlist', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            credentials: 'include',
                            body: JSON.stringify({ productId })
                        });
                        const data = await res.json();
                        if (data.success) {
                            wishlistItemIds.add(productId.toString());
                            showModal('success', 'Wishlisted!', 'Item added to your wishlist! ❤️', { autoHide: 2000 });
                            renderProducts();
                        } else if (res.status === 401) {
                            showModal('warning', 'Login Required', 'Please login to manage your wishlist.', {
                                primaryText: 'Login Now',
                                onPrimary: () => { window.location.href = '/login'; },
                                autoHide: 0
                            });
                            buttonElement.disabled = false;
                        } else {
                            showModal('error', 'Error', data.message || 'Failed to add');
                            buttonElement.disabled = false;
                        }
                    }
                } catch (err) {
                    console.error('Wishlist error:', err);
                    showModal('warning', 'Network Error', 'Unable to connect. Please try again.');
                    buttonElement.disabled = false;
                }
            }

            // ========== EVENT LISTENERS ==========
            priceSlider.addEventListener('input', (e) => { maxPriceInput.value = e.target.value; });
            priceSlider.addEventListener('change', () => applyFiltersAndRender());
            minPriceInput.addEventListener('change', () => applyFiltersAndRender());
            maxPriceInput.addEventListener('change', () => {
                priceSlider.value = maxPriceInput.value;
                applyFiltersAndRender();
            });
            applyBtn.addEventListener('click', () => applyFiltersAndRender());
            resetBtn.addEventListener('click', () => {
                document.querySelectorAll('.brand-checkbox').forEach(cb => cb.checked = true);
                const allRadio = document.querySelector('input[name="offerType"][value="all"]');
                if (allRadio) allRadio.checked = true;
                setPriceLimits();
                sortSelect.value = 'default';
                searchInput.value = '';
                applyFiltersAndRender();
                showModal('info', 'Filters Reset', 'All filters have been cleared.', { autoHide: 2000 });
            });
            sortSelect.addEventListener('change', () => applyFiltersAndRender());
            document.getElementById('offerFilterGroup').addEventListener('change', (e) => {
                if (e.target.name === 'offerType') applyFiltersAndRender();
            });
            searchBtn.addEventListener('click', () => applyFiltersAndRender());
            searchInput.addEventListener('keyup', (e) => {
                if (e.key === 'Enter') applyFiltersAndRender();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && filtersSidebar.classList.contains('open')) closeFilters();
            });

            // ========== INIT ==========
            async function init() {
                await checkAuth();
                fetchReviewsData();
                await fetchProducts();
                // Re-render after reviews load (fetchReviewsData will call renderProducts again)
            }
            init();
        })();
    </script>
</body>

</html>