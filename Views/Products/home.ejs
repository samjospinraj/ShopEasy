            // ========== Fetch Reviews & Rating Counts ==========
            async function fetchReviewsData() {
                try {
                    const [reviewsRes, ratingCountRes] = await Promise.all([
                        fetch(REVIEWS_API),
                        fetch(RATING_COUNT_API)
                    ]);

                    if (reviewsRes.ok) {
                        const reviewsData = await reviewsRes.json();
                        if (reviewsData.success && reviewsData.reviews) {
                            allReviews = reviewsData.reviews;
                        }
                    } else {
                        console.warn("Reviews fetch failed, status:", reviewsRes.status);
                        allReviews = [];
                    }

                    if (ratingCountRes.ok) {
                        const ratingData = await ratingCountRes.json();
                        if (ratingData.success && ratingData.ratingCounts) {
                            ratingCounts = ratingData.ratingCounts;
                        }
                    } else {
                        console.warn("Rating counts fetch failed, status:", ratingCountRes.status);
                        ratingCounts = {};
                    }
                } catch (err) {
                    console.warn("Reviews data fetch failed:", err.message);
                    allReviews = [];
                    ratingCounts = {};
                }

                computeProductRatingsMap();
                renderReviewsSection();
                renderProductSections();
            }

            function computeProductRatingsMap() {
                productRatingsMap = {};
                if (!allReviews.length) return;

                const productRatingAccum = {};

                allReviews.forEach(review => {
                    const reviewItems = review.reviewItems || [];
                    reviewItems.forEach(item => {
                        const productId = item.productId?._id || item.productId?.id || item.productId;
                        if (!productId) return;
                        const productIdStr = productId.toString();
                        if (!productRatingAccum[productIdStr]) {
                            productRatingAccum[productIdStr] = { totalRating: 0, count: 0 };
                        }
                        productRatingAccum[productIdStr].totalRating += (item.rating || 0);
                        productRatingAccum[productIdStr].count += 1;
                    });
                });

                Object.keys(productRatingAccum).forEach(pid => {
                    const { totalRating, count } = productRatingAccum[pid];
                    productRatingsMap[pid] = {
                        averageRating: Math.round((totalRating / count) * 10) / 10,
                        totalReviews: count
                    };
                });
            }

            function renderReviewsSection() {
                if (!ratingSummaryCard || !reviewCardsGrid) return;

                // Compute from ratingCounts
                const count5 = ratingCounts[5] || ratingCounts["5"] || 0;
                const count4 = ratingCounts[4] || ratingCounts["4"] || 0;
                const count3 = ratingCounts[3] || ratingCounts["3"] || 0;
                const count2 = ratingCounts[2] || ratingCounts["2"] || 0;
                const count1 = ratingCounts[1] || ratingCounts["1"] || 0;
                const totalCount = count5 + count4 + count3 + count2 + count1;

                if (totalCount === 0) {
                    avgRatingBig.textContent = "--";
                    avgStarsBig.innerHTML = '<i class="far fa-star empty-big"></i><i class="far fa-star empty-big"></i><i class="far fa-star empty-big"></i><i class="far fa-star empty-big"></i><i class="far fa-star empty-big"></i>';
                    totalReviewsText.textContent = "No reviews yet";
                    ratingBarsContainer.innerHTML =
                        '<p class="text-muted small text-center mt-2">Be the first to review!</p>';
                } else {
                    const avgRating = (count5 * 5 + count4 * 4 + count3 * 3 + count2 * 2 + count1 * 1) / totalCount;
                    avgRatingBig.textContent = avgRating.toFixed(1);
                    avgStarsBig.innerHTML = generateBigStarsHTML(avgRating);
                    totalReviewsText.textContent = `Based on ${totalCount} review${totalCount !== 1 ? 's' : ''}`;

                    const maxCount = Math.max(count5, count4, count3, count2, count1, 1);
                    const bars = [
                        { star: 5, count: count5 },
                        { star: 4, count: count4 },
                        { star: 3, count: count3 },
                        { star: 2, count: count2 },
                        { star: 1, count: count1 }
                    ];
                    ratingBarsContainer.innerHTML = bars.map(b => `
                        <div class="rating-bar-row">
                            <span class="rating-bar-label">${b.star} <i class="fas fa-star"></i></span>
                            <div class="rating-bar-track">
                                <div class="rating-bar-fill" style="width: ${(b.count / maxCount) * 100}%;"></div>
                            </div>
                            <span class="rating-bar-count">${b.count}</span>
                        </div>
                    `).join("");
                }

                // Flatten review items for display
                const allReviewItems = [];
                allReviews.forEach((review, reviewIdx) => {
                    const reviewItems = review.reviewItems || [];
                    reviewItems.forEach((item, itemIdx) => {
                        allReviewItems.push({
                            reviewId: review._id || review.id,
                            userId: review.userId,
                            orderId: review.orderId,
                            item: item,
                            globalIndex: allReviewItems.length,
                            reviewIdx: reviewIdx,
                            itemIdx: itemIdx
                        });
                    });
                });

                // Sort by most recent first
                allReviewItems.sort((a, b) => {
                    const dateA = new Date(a.item.createdAt || 0);
                    const dateB = new Date(b.item.createdAt || 0);
                    return dateB - dateA;
                });

                if (allReviewItems.length === 0) {
                    reviewCardsGrid.innerHTML = `
                        <div class="empty-state col-12">
                            <i class="fas fa-comment-dots fa-3x mb-3"></i>
                            <h5>No reviews yet</h5>
                            <p class="text-muted">Customer reviews will appear here once available.</p>
                        </div>`;
                } else {
                    reviewCardsGrid.innerHTML = allReviewItems.slice(0, 12).map(ri => {
                        const item = ri.item;
                        const product = item.productId || {};
                        const user = ri.userId || {};
                        const userName = user.fullName || user.name || "Anonymous";
                        const userInitial = userName.charAt(0).toUpperCase();
                        const productName = product.productName || product.name || "Product";
                        const productImage = product.mainImage?.path ?
                            `${BASE_URL}${product.mainImage.path}` :
                            "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=60&fit=crop";
                        const productId = product._id || product.id || "";
                        const rating = item.rating || 0;
                        const reviewTitle = item.title || "";
                        const reviewText = item.reviewText || item.review || "";
                        const createdAt = item.createdAt ? new Date(item.createdAt)
                            .toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) :
                            "";
                        const reviewImages = item.images || [];
                        const avatarClass = getAvatarClass(ri.globalIndex);

                        return `
                        <div class="review-card-premium" style="animation-delay:${ri.globalIndex * 0.08}s;">
                            <div class="review-card-header">
                                <div class="review-user-avatar ${avatarClass}">${userInitial}</div>
                                <div class="review-user-info">
                                    <div class="review-user-name">
                                        ${escapeHtml(userName)}
                                        <span class="verified-badge"><i class="fas fa-check-circle"></i> Verified</span>
                                    </div>
                                    <div class="review-date">${createdAt}</div>
                                </div>
                            </div>
                            <div class="review-stars-row">${generateReviewStarsHTML(rating)}</div>
                            ${reviewTitle ? `<div class="review-title-text">${escapeHtml(reviewTitle)}</div>` : ''}
                            ${reviewText ? `<div class="review-body-text">${escapeHtml(reviewText)}</div>` : ''}
                            ${reviewImages.length > 0 ? `
                            <div class="review-images-row">
                                ${reviewImages.map(img => {
                                    const imgPath = img.path || img;
                                    const imgUrl = imgPath.startsWith('http') ? imgPath : `${BASE_URL}${imgPath}`;
                                    return `<img src="${imgUrl}" class="review-image-thumb" alt="Review image" loading="lazy" onerror="this.style.display='none'">`;
                                }).join("")}
                            </div>` : ''}
                            <a href="/singleproduct/${productId}" class="review-product-link">
                                <img src="${productImage}" alt="${escapeHtml(productName)}" onerror="this.src='https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=60&fit=crop'">
                                <span>${escapeHtml(productName)}</span>
                                <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>`;
                    }).join("");

                    if (allReviewItems.length > 12) {
                        reviewCardsGrid.innerHTML += `
                        <div class="text-center w-100 mt-2" style="grid-column: 1 / -1;">
                            <p class="text-muted small">Showing 12 of ${allReviewItems.length} reviews</p>
                        </div>`;
                    }
                }
            }

            // ========== Render Product Card ==========
            function renderProductCard(p, idx) {
                const discount = p.comparePrice > p.price ? Math.round(((p.comparePrice - p.price) / p.comparePrice) *
                    100) : 0;
                const outOfStock = p.stock <= 0;
                const lowStock = p.stock > 0 && p.stock <= 5;
                const inWishlist = wishlistItemIds.has(p.id.toString());
                const inCart = cartItemIds.has(p.id.toString());

                // Product rating
                const prodRating = productRatingsMap[p.id.toString()];
                let ratingRowHTML = '';
                if (prodRating && prodRating.totalReviews > 0) {
                    ratingRowHTML = `
                    <div class="product-rating-row">
                        <span class="stars-inline">${generateStarsHTML(prodRating.averageRating, 'empty-inline')}</span>
                        <span class="rating-count-text">(${prodRating.totalReviews})</span>
                    </div>`;
                }

                // Stock badge
                let stockBadgeHTML = '';
                if (outOfStock) {
                    stockBadgeHTML =
                        '<span class="stock-badge out-of-stock"><i class="fas fa-times-circle"></i> Out of Stock</span>';
                } else if (lowStock) {
                    stockBadgeHTML =
                        `<span class="stock-badge low-stock"><i class="fas fa-exclamation-circle"></i> Only ${p.stock} left</span>`;
                } else {
                    stockBadgeHTML =
                        `<span class="stock-badge in-stock"><i class="fas fa-check-circle"></i> ${p.stock} in stock</span>`;
                }

                // Stock info row
                let stockInfoRow = '';
                if (outOfStock) {
                    stockInfoRow =
                        '<div class="stock-info-row text-danger"><span class="stock-dot red"></span> Out of Stock</div>';
                } else if (lowStock) {
                    stockInfoRow =
                        `<div class="stock-info-row text-warning"><span class="stock-dot orange"></span> Only ${p.stock} left — Hurry!</div>`;
                } else {
                    stockInfoRow =
                        `<div class="stock-info-row text-success"><span class="stock-dot green"></span> In Stock (${p.stock} available)</div>`;
                }

                return `
                <div class="product-card" style="animation-delay:${idx * 0.1}s;" data-id="${p.id}">
                    ${discount > 0 ? `<div class="discount-badge">-${discount}%</div>` : ""}
                    <div class="product-img-wrap">
                        <img src="${p.image}" loading="lazy" alt="${escapeHtml(p.name)}" onerror="this.src='https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=300&fit=crop'">
                        ${stockBadgeHTML}
                        <button class="wishlist-btn ${inWishlist ? 'active' : ''}" data-wishlist="${p.id}">
                            <i class="${inWishlist ? 'fas' : 'far'} fa-heart"></i>
                        </button>
                    </div>
                    <div class="product-details">
                        <div class="product-brand">${escapeHtml(p.brand)}</div>
                        <div class="product-title">${escapeHtml(p.name)}</div>
                        ${ratingRowHTML}
                        ${stockInfoRow}
                        <div class="price-row">
                            <span class="current-price">₹${p.price.toFixed(2)}</span>
                            ${p.comparePrice > p.price ? `<span class="old-price">₹${p.comparePrice.toFixed(2)}</span>` : ""}
                        </div>
                        <button class="btn-add-cart ${inCart ? 'in-cart' : ''}" data-addcart="${p.id}" ${outOfStock && !inCart ? 'disabled' : ''}>
                            ${outOfStock ? '<i class="fas fa-ban me-1"></i> Out of Stock' : (inCart ? '<i class="fas fa-shopping-cart me-1"></i> Go to Cart' : '<i class="fas fa-cart-plus me-1"></i> Add to Cart')}
                        </button>
                    </div>
                </div>`;
            }

            // ========== Render Product Sections ==========
            function renderProductSections() {
                if (isSearchActive) return;
                const featured = allProducts.slice(0, 12);
                const more = allProducts.slice(12, 20);
                const sale = allProducts.filter(p => p.comparePrice > p.price).slice(20, 28);

                featuredGrid.innerHTML = featured.length ? featured.map((p, i) => renderProductCard(p, i)).join("") :
                    '<div class="empty-state col-12"><i class="fas fa-box-open fa-3x mb-3"></i><h5>No featured products</h5><p class="text-muted">Check back soon for new arrivals</p></div>';
                moreGrid.innerHTML = more.length ? more.map((p, i) => renderProductCard(p, i)).join("") :
                    '<div class="empty-state col-12"><i class="fas fa-clock fa-3x mb-3"></i><h5>No new arrivals yet</h5><p class="text-muted">Fresh products coming soon</p></div>';
                saleGrid.innerHTML = sale.length ? sale.map((p, i) => renderProductCard(p, i)).join("") :
                    '<div class="empty-state col-12"><i class="fas fa-tag fa-3x mb-3"></i><h5>No deals available</h5><p class="text-muted">Exclusive deals will appear here</p></div>';

                attachCardListeners();
            }

            function attachCardListeners() {
                document.querySelectorAll(".product-card").forEach(card => {
                    card.addEventListener("click", function(e) {
                        if (e.target.closest("button")) return;
                        const id = this.dataset.id;
                        if (id) window.location.href = `/singleproduct/${id}`;
                    });
                });
                document.querySelectorAll("[data-addcart]").forEach(btn => {
                    btn.addEventListener("click", function(e) {
                        e.stopPropagation();
                        if (!isLoggedIn) {
                            showModal('warning', 'Login Required',
                                'Please login to add items to your cart.', {
                                    autoHide: 2500,
                                    primaryText: 'Login Now',
                                    onPrimary: () => { window.location.href = "/login"; },
                                    secondaryText: 'Later'
                                });
                            return;
                        }
                        const id = this.dataset.addcart;
                        const product = allProducts.find(p => p.id.toString() === id);
                        addToCart(id, product?.name, this);
                    });
                });
                document.querySelectorAll("[data-wishlist]").forEach(btn => {
                    btn.addEventListener("click", function(e) {
                        e.stopPropagation();
                        if (!isLoggedIn) {
                            showModal('warning', 'Login Required',
                                'Please login to manage your wishlist.', {
                                    autoHide: 2500,
                                    primaryText: 'Login Now',
                                    onPrimary: () => { window.location.href = "/login"; },
                                    secondaryText: 'Later'
                                });
                            return;
                        }
                        const id = this.dataset.wishlist;
                        toggleWishlist(id, this);
                    });
                });
            }

            // ========== Particles ==========
            const particlesContainer = document.getElementById("particlesContainer");
            for (let i = 0; i < 35; i++) {
                const p = document.createElement("div");
                p.className = "particle";
                const size = Math.random() * 40 + 5;
                p.style.width = size + "px";
                p.style.height = size + "px";
                p.style.background = ["#ff6b6b", "#4ecdc4", "#ffe66d", "#a55eea", "#667eea"][Math.floor(Math.random() *
                    5)];
                p.style.left = Math.random() * 100 + "%";
                p.style.top = Math.random() * 100 + "%";
                p.style.animationDelay = Math.random() * 12 + "s";
                p.style.animationDuration = (Math.random() * 18 + 8) + "s";
                p.style.opacity = Math.random() * 0.3 + 0.1;
                particlesContainer.appendChild(p);
            }

            // ========== Header scroll ==========
            const header = document.getElementById("header");
            window.addEventListener("scroll", () => header.classList.toggle("scrolled", window.scrollY > 50));

            // ========== Init ==========
            async function init() {
                await checkAuth();
                fetchCategorySystem();
                fetchProducts();
                fetchReviewsData();
            }
            init();
        })();
    </script>
</body>

</html>