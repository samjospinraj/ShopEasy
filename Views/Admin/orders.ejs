                        <div class="filter-menu" id="paymentFilterMenu">
                            <div class="filter-menu-item" data-payment="all"><i class="fas fa-list-ul"></i> All payments</div>
                            <div class="filter-menu-item" data-payment="onlinePayment"><i class="fas fa-credit-card"></i> Online Payment</div>
