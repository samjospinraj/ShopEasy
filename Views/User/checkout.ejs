            function updateCartBadge(count = 0) { document.getElementById('cartCount').innerText = count; }
            function redirectToLogin() { window.location.href = `/login?returnTo=${encodeURIComponent(window.location.href)}`; }

            // ============ AUTH ============
            async function checkAuth() {
                try {
                    const res = await fetch(`${API_BASE}/api/check-auth`, { credentials: 'include' });
                    if (res.ok) { const json = await res.json(); isAuthenticated = json.loggedIn === true; }
                    else { isAuthenticated = false; }
                } catch (e) { isAuthenticated = false; }
                updateLoginUI();
                if (!isAuthenticated) { redirectToLogin(); return false; }
                return true;
            }

            function updateLoginUI() {
                const menuLogout = document.getElementById('menuLogout');
                const userIconBtn = document.getElementById('userIconBtn');
                if (menuLogout) menuLogout.style.display = isAuthenticated ? 'flex' : 'none';
                if (userIconBtn) userIconBtn.style.color = isAuthenticated ? '#4ecdc4' : '#666';
            }

            async function fetchCartCount() {
                if (!isAuthenticated) { updateCartBadge(0); return 0; }
                try {
                    const res = await fetch(`${API_BASE}/carts`, { credentials: 'include' });
                    if (res.ok) {
                        const json = await res.json();
                        if (json.success) {
                            const count = json.count || (json.data ? json.data.length : 0);
                            updateCartBadge(count);
                            return count;
                        }
                    }
                } catch (e) {}
                return 0;
            }

            async function fetchCheckoutData() {
                try {
                    let endpoint = `${API_BASE}/checkout-data`;
                    if (checkoutType === 'single' && singleProductId) endpoint = `${API_BASE}/checkout-data/${singleProductId}`;
                    const response = await fetch(endpoint, { credentials: 'include', headers: { 'Accept': 'application/json' } });
                    if (!response.ok) throw new Error((await response.json()).message || 'Failed to fetch checkout data');
                    const result = await response.json();
                    if (result.success) {
                        checkoutData = result.data;
                        populateUserProfile(result.data.userProfile);
                        deliveryTimeline = { minTime: null, maxTime: null, minDays: null, maxDays: null };
                        shippingCost = 0;
                        if (checkoutType === 'single') populateSingleProduct(result.data.product);
                        else populateCartItems(result.data.products);
                        updateDeliveryTimelineDisplay();
                        await fetchCartCount();
                    } else {
                        showModal('error', 'Error', 'Failed to load checkout data: ' + (result.message || 'Unknown error'));
                    }
                } catch (error) {
                    showModal('error', 'Error', 'Error loading checkout data: ' + error.message);
                }
            }

            function populateUserProfile(userProfile) {
                if (!userProfile) return;
                if (userProfile.fullName) document.getElementById('customerName').value = userProfile.fullName;
                else if (userProfile.name) document.getElementById('customerName').value = userProfile.name;
                if (userProfile.phone) document.getElementById('customerPhone').value = userProfile.phone;
                if (userProfile.address) {
                    if (typeof userProfile.address === 'string') document.getElementById('deliveryAddress').value = userProfile.address;
                    else if (typeof userProfile.address === 'object') {
                        document.getElementById('deliveryAddress').value = userProfile.address.street || userProfile.address.full || '';
                        document.getElementById('city').value = userProfile.address.city || '';
                        document.getElementById('postalCode').value = userProfile.address.postalCode || userProfile.address.zip || '';
                        document.getElementById('state').value = userProfile.address.state || '';
                    }
                } else if (userProfile.shippingAddress) {
                    document.getElementById('deliveryAddress').value = userProfile.shippingAddress.address || '';
                    document.getElementById('city').value = userProfile.shippingAddress.city || '';
                    document.getElementById('postalCode').value = userProfile.shippingAddress.postalCode || '';
                    document.getElementById('state').value = userProfile.shippingAddress.state || '';
                }
                const countrySelect = document.getElementById('country');
                let country = 'India';
                if (userProfile.address?.country) country = userProfile.address.country;
                else if (userProfile.shippingAddress?.country) country = userProfile.shippingAddress.country;
                for (let i = 0; i < countrySelect.options.length; i++) {
                    if (countrySelect.options[i].value === country) { countrySelect.selectedIndex = i; break; }
                }
                ['customerName', 'customerPhone', 'deliveryAddress', 'city', 'postalCode', 'state'].forEach(fieldId => {
                    const input = document.getElementById(fieldId);
                    if (input && input.value.trim()) validateField(input);
                });
            }

            function populateSingleProduct(product) {
                const orderItemsContainer = document.getElementById('orderItems');
                const loadingDiv = document.getElementById('orderItemsLoading');
                if (!product || !product.productId) {
                    orderItemsContainer.innerHTML = '<div class="text-center py-3"><p class="text-muted">Product not found</p></div>';
                    return;
                }
                if (loadingDiv) loadingDiv.remove();
                const item = product.productId;
                const quantity = product.quantity || 1;
                const price = item.price || 0;
                const itemTotal = price * quantity;
                cartItems = [{ productId: item._id || singleProductId, quantity: quantity }];
                extractDeliveryTimeline(product);
                const productName = item.productName || item.name || 'Product';
                let imageUrl = 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=150&h=150&fit=crop';
                if (item.mainImage) {
                    if (typeof item.mainImage === 'string') imageUrl = item.mainImage;
                    else if (item.mainImage.path || item.mainImage.url || item.mainImage.secure_url) {
                        imageUrl = item.mainImage.path || item.mainImage.url || item.mainImage.secure_url;
                    }
                }
                orderItemsContainer.innerHTML = `
                <div class="product-summary-item">
                    <img src="${imageUrl}" alt="${productName}" class="product-summary-img" onerror="this.src='https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=150&h=150&fit=crop'">
                    <div class="flex-fill">
                        <h6 class="mb-0 fw-bold">${productName}</h6>
                        <small class="text-muted">Qty: ${quantity} | Unit Price: ₹${price.toFixed(2)}</small>
                    </div>
                    <span class="fw-bold">₹${itemTotal.toFixed(2)}</span>
                </div>`;
                document.getElementById('shippingAmount').innerText = shippingCost === 0 ? 'Free' : `₹${shippingCost.toFixed(2)}`;
                const tax = itemTotal * 0.08;
                window.cartTotals = { subtotal: itemTotal, tax: tax };
                document.getElementById('subtotalAmount').textContent = `₹${itemTotal.toFixed(2)}`;
                document.getElementById('taxAmount').textContent = `₹${tax.toFixed(2)}`;
                updateTotalAmount();
                updateDeliveryTimelineDisplay();
            }

            function populateCartItems(products) {
                const orderItemsContainer = document.getElementById('orderItems');
                const loadingDiv = document.getElementById('orderItemsLoading');
                if (!products || products.length === 0) {
                    orderItemsContainer.innerHTML = '<div class="text-center py-3"><p class="text-muted">No items in cart</p></div>';
                    shippingCost = 0;
                    document.getElementById('shippingAmount').innerText = 'Free';
                    return;
                }
                if (loadingDiv) loadingDiv.remove();
                let subtotal = 0;
                let itemsHTML = '';
                cartItems = [];
                shippingCost = 0;
                const allProducts = [];
                products.forEach(cartItem => {
                    if (cartItem.productId) {
                        const product = cartItem.productId;
                        const quantity = cartItem.quantity || 1;
                        const price = product.price || 0;
                        const itemTotal = price * quantity;
                        subtotal += itemTotal;
                        cartItems.push({ productId: product._id || cartItem.productId._id, quantity: quantity });
                        allProducts.push(product);
                        if (product.dimensions && product.dimensions.shippingCost) shippingCost += Number(product.dimensions.shippingCost || 0);
                        const productName = product.productName || product.name || 'Product';
                        let imageUrl = 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=150&h=150&fit=crop';
                        if (product.mainImage) {
                            if (typeof product.mainImage === 'string') imageUrl = product.mainImage;
                            else if (product.mainImage.path || product.mainImage.url || product.mainImage.secure_url) imageUrl = product.mainImage.path || product.mainImage.url || product.mainImage.secure_url;
                        }
                        itemsHTML += `
                        <div class="product-summary-item">
                            <img src="${imageUrl}" alt="${productName}" class="product-summary-img" onerror="this.src='https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=150&h=150&fit=crop'">
                            <div class="flex-fill">
                                <h6 class="mb-0 fw-bold">${productName}</h6>
                                <small class="text-muted">Qty: ${quantity} | Price: ₹${price.toFixed(2)}</small>
                            </div>
                            <span class="fw-bold">₹${itemTotal.toFixed(2)}</span>
                        </div>`;
                    }
                });
                consolidateDeliveryTimelines(allProducts);
                orderItemsContainer.innerHTML = itemsHTML || '<div class="text-center py-3"><p class="text-muted">No items found in cart</p></div>';
                document.getElementById('shippingAmount').innerText = shippingCost === 0 ? 'Free' : `₹${shippingCost.toFixed(2)}`;
                const tax = subtotal * 0.08;
                window.cartTotals = { subtotal: subtotal, tax: tax };
                document.getElementById('subtotalAmount').textContent = `₹${subtotal.toFixed(2)}`;
                document.getElementById('taxAmount').textContent = `₹${tax.toFixed(2)}`;
                updateTotalAmount();
                updateDeliveryTimelineDisplay();
            }

