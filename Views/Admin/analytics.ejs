    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr">
    </script>
    <script>
        (() => {
            const API_BASE = "http://localhost:3000/admin";
            const sidebar = document.getElementById('sidebar');
            const menuToggle = document.getElementById('menuToggle');
            const popupModal = new bootstrap.Modal(document.getElementById('popupModal'));

            // ──────── MOUSE TRACKING ────────
            let mouseX = window.innerWidth / 2;
            let mouseY = window.innerHeight / 2;
            let targetMouseX = mouseX;
            let targetMouseY = mouseY;

            document.addEventListener('mousemove', (e) => {
                targetMouseX = e.clientX;
                targetMouseY = e.clientY;
            });
            document.addEventListener('touchmove', (e) => {
                if (e.touches.length > 0) {
                    targetMouseX = e.touches[0].clientX;
                    targetMouseY = e.touches[0].clientY;
                }
            }, { passive: true });

            // Smooth mouse follow for glow
            function updateMouseGlow() {
                mouseX += (targetMouseX - mouseX) * 0.12;
                mouseY += (targetMouseY - mouseY) * 0.12;
                const glow = document.getElementById('mouseGlow');
                if (glow) {
                    glow.style.left = mouseX + 'px';
                    glow.style.top = mouseY + 'px';
                }
                // Update CSS vars for orb shifting
                const rx = mouseX / window.innerWidth;
                const ry = mouseY / window.innerHeight;
                document.documentElement.style.setProperty('--mouse-x', rx.toFixed(3));
                document.documentElement.style.setProperty('--mouse-y', ry.toFixed(3));

                // Subtle orb shift toward mouse
                const orb1 = document.getElementById('orb1');
                const orb2 = document.getElementById('orb2');
                const orb3 = document.getElementById('orb3');
                if (orb1) orb1.style.transform = `translate(${(rx-0.5)*40}px, ${(ry-0.5)*30}px)`;
                if (orb2) orb2.style.transform = `translate(${(rx-0.5)*-35}px, ${(ry-0.5)*-25}px)`;
                if (orb3) orb3.style.transform = `translate(${(rx-0.5)*25}px, ${(ry-0.5)*-35}px)`;
            }

            // ──────── CANVAS PARTICLES (mouse-reactive) ────────
            const canvas = document.getElementById('particleCanvas');
            const ctx = canvas.getContext('2d');
            let canvasParticles = [];
            const MAX_CANVAS_PARTICLES = 60;

            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resizeCanvas();
            window.addEventListener('resize', resizeCanvas);

            class CanvasParticle {
                constructor() {
                    this.reset(true);
                }
                reset(initial = false) {
                    this.x = Math.random() * canvas.width;
                    this.y = initial ? Math.random() * canvas.height : canvas.height + 30;
                    this.size = 0.8 + Math.random() * 3.5;
                    this.speedY = -0.3 - Math.random() * 1.4;
                    this.speedX = (Math.random() - 0.5) * 0.6;
                    this.opacity = 0.15 + Math.random() * 0.55;
                    this.life = 1;
                    this.decay = 0.0004 + Math.random() * 0.0012;
                    this.color = ['#4d8fff', '#9b6dff', '#3ce4d4', '#fbbf24', '#34d399', '#f472b6'][Math.floor(Math
                        .random() * 6)];
                }
                update(mx, my) {
                    this.y += this.speedY;
                    this.x += this.speedX;
                    this.life -= this.decay;

                    // Mouse repulsion
                    const dx = this.x - mx;
                    const dy = this.y - my;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    const repelRadius = 140;
                    if (dist < repelRadius && dist > 0) {
                        const force = (1 - dist / repelRadius) * 4.5;
                        this.x += (dx / dist) * force;
                        this.y += (dy / dist) * force;
                        this.opacity = Math.min(1, this.opacity + 0.03);
                        this.size = Math.min(6, this.size + 0.15);
                    }

                    if (this.y < -20 || this.life <= 0 || this.x < -30 || this.x > canvas.width + 30) {
                        this.reset();
                    }
                }
                draw(ctx) {
                    ctx.save();
                    ctx.globalAlpha = this.opacity * this.life;
                    ctx.fillStyle = this.color;
                    ctx.shadowColor = this.color;
                    ctx.shadowBlur = this.size * 5;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.restore();
                }
            }

            for (let i = 0; i < MAX_CANVAS_PARTICLES; i++) {
                canvasParticles.push(new CanvasParticle());
            }

            function animateCanvas() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                canvasParticles.forEach(p => {
                    p.update(mouseX, mouseY);
                    p.draw(ctx);
                });
                // Draw subtle connection lines between nearby particles near mouse
                for (let i = 0; i < canvasParticles.length; i++) {
                    for (let j = i + 1; j < canvasParticles.length; j++) {
                        const a = canvasParticles[i];
                        const b = canvasParticles[j];
                        const dx = a.x - b.x;
                        const dy = a.y - b.y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < 70) {
                            const alpha = (1 - dist / 70) * 0.18 * a.life * b.life;
                            ctx.save();
                            ctx.globalAlpha = alpha;
                            ctx.strokeStyle = '#4d8fff';
                            ctx.lineWidth = 0.4;
                            ctx.beginPath();
                            ctx.moveTo(a.x, a.y);
                            ctx.lineTo(b.x, b.y);
                            ctx.stroke();
                            ctx.restore();
                        }
                    }
                }
                requestAnimationFrame(animateCanvas);
            }
            animateCanvas();

            // ──────── CSS PARTICLES ────────
            function spawnParticles() {
                const container = document.getElementById('particlesContainer');
                if (!container) return;
                for (let i = 0; i < 35; i++) {
                    const particle = document.createElement('div');
                    particle.className = 'particle';
                    particle.style.left = Math.random() * 100 + '%';
                    particle.style.animationDelay = Math.random() * 10 + 's';
                    particle.style.animationDuration = (6 + Math.random() * 14) + 's';
                    particle.style.width = (1 + Math.random() * 3) + 'px';
                    particle.style.height = particle.style.width;
                    const colors = ['#4d8fff', '#9b6dff', '#3ce4d4', '#fbbf24', '#34d399', '#f472b6'];
                    particle.style.background = colors[Math.floor(Math.random() * colors.length)];
                    container.appendChild(particle);
                }
            }
            spawnParticles();

            // ──────── SIDEBAR ────────
            function toggleSidebar(e) {
                e?.stopPropagation();
                sidebar.classList.toggle('active');
            }
            menuToggle?.addEventListener('click', toggleSidebar);
            document.getElementById('toggleSidebar')?.addEventListener('click', toggleSidebar);
            document.addEventListener('click', e => {
                if (window.innerWidth <= 992 && !sidebar.contains(e.target) && !menuToggle.contains(
                        e.target) && sidebar.classList.contains('active'))
                    sidebar.classList.remove('active');
            });
            new MutationObserver(() => {
                const chev = document.querySelector('#toggleSidebar i');
                if (sidebar.classList.contains('active')) chev?.classList.replace('fa-chevron-left',
                    'fa-chevron-right');
                else chev?.classList.replace('fa-chevron-right', 'fa-chevron-left');
            }).observe(sidebar, { attributes: true, attributeFilter: ['class'] });

            // ──────── DATA ────────
            let allProducts = [],
                allCategories = [],
                allSubcategories = [],
                allSubSubcategories = [],
                allOrders = [],
                allCustomers = [],
                revenueTimeData = [],
                customerBlockData = null,
                customerCountData = null;
            const productMap = new Map();
            let revenueChart = null,
                revenueTimeChart = null,
                revenueDetailChart = null;
            let currentView = 'all';
            let revenuePanelVisible = false;

            async function fetchJSON(url) {
                const r = await fetch(url);
                if (!r.ok) throw new Error(`HTTP ${r.status}`);
                return r.json();
            }

            async function fetchAll() {
                showLoading(true);
                try {
                    const [p, c, s, ss, o, cu, rev, custBlocks, custCounts] = await Promise.all([
                        fetchJSON(`${API_BASE}/allproduct`),
                        fetchJSON(`${API_BASE}/allCategory`),
                        fetchJSON(`${API_BASE}/allsubCategory`),
                        fetchJSON(`${API_BASE}/allsub_subCategory`),
                        fetchJSON(`${API_BASE}/orders`),
                        fetchJSON(`${API_BASE}/customers`),
                        fetchJSON(`${API_BASE}/orders/revenue`),
                        fetchJSON(`${API_BASE}/customers/blocks`).catch(() => null),
                        fetchJSON(`${API_BASE}/customers/count`).catch(() => null),
                    ]);
                    allProducts = p.data || [];
                    allCategories = c.data || [];
                    allSubcategories = s.data || [];
                    allSubSubcategories = ss.data || [];
                    allOrders = o.orderData || [];
                    allCustomers = cu.customers || [];
                    revenueTimeData = rev.revenueData || [];
                    customerBlockData = custBlocks?.data || null;
                    customerCountData = custCounts?.data || null;
                    productMap.clear();
                    allProducts.forEach(pr => productMap.set(pr._id?.toString(), pr));
                    populateFilters();
                    applyAll();
                    updateNotifBadge();
                    updateRevenueTimeChart();
                    if (customerBlockData) updateCustomerBlockSummary();
                } catch (err) {
                    console.error(err);
                    showToast('⚠️ Failed to load data', 'triangle-exclamation');
                    showModal('Connection Error', 'Ensure API runs on <b>' + API_BASE + '</b>');
                } finally {
                    showLoading(false);
                }
            }

            function showLoading(show) {
                let ov = document.getElementById('loadingOverlay');
                if (show) {
                    if (!ov) {
                        ov = document.createElement('div');
                        ov.id = 'loadingOverlay';
                        ov.className = 'loading-overlay';
                        ov.innerHTML = '<div class="spinner-lg"></div>';
                        document.body.appendChild(ov);
                    }
                    ov.style.display = 'flex';
                } else if (ov) ov.style.display = 'none';
            }

            function showToast(msg, icon = 'chart-line') {
                const old = document.querySelector('.notification-toast');
                if (old) old.remove();
                const t = document.createElement('div');
                t.className = 'notification-toast';
                t.innerHTML =
                    `<i class="fas fa-${icon}" style="color:var(--accent-blue);"></i><span>${msg}</span>`;
                document.body.appendChild(t);
                setTimeout(() => {
                    t.style.opacity = '0';
                    t.style.transform = 'translateX(50px)';
                    setTimeout(() => t.remove(), 350);
                }, 2400);
            }

            function showModal(title, msg) {
                document.getElementById('popupModalLabel').textContent = title;
                document.getElementById('popupModalBody').innerHTML = msg;
                popupModal.show();
            }

            function updateNotifBadge() {
                document.getElementById('notifBadge').textContent = allOrders.length || '0';
            }

            function updateCustomerBlockSummary() {
                if (!customerBlockData) return;
                document.getElementById('blockedCustomersCount').textContent = customerBlockData.blocked || 0;
                document.getElementById('totalCustomersCount').textContent = customerBlockData.totalCustomers || 0;
            }

            function populateFilters() {
                const cat = document.getElementById('catFilterSelect'),
                    sub = document.getElementById('subcatFilterSelect'),
                    ssub = document.getElementById('subsubFilterSelect');
                cat.innerHTML = '<option value="all">All Categories</option>';
                allCategories.forEach(c => cat.innerHTML +=
                    `<option value="${escapeHTML(c.name)}">${escapeHTML(c.name)}</option>`);
                sub.innerHTML = '<option value="all">All Subcategories</option>';
                allSubcategories.forEach(s => sub.innerHTML +=
                    `<option value="${escapeHTML(s.name)}" data-parent="${escapeHTML(s.parentName||'')}">${escapeHTML(s.name)}</option>`
                    );
                ssub.innerHTML = '<option value="all">All Sub‑Sub</option>';
                allSubSubcategories.forEach(ss => ssub.innerHTML +=
                    `<option value="${escapeHTML(ss.name)}" data-parent="${escapeHTML(ss.parentName||'')}" data-subparent="${escapeHTML(ss.subParentName||'')}">${escapeHTML(ss.name)}</option>`
                    );
            }

            function escapeHTML(s) {
                const d = document.createElement('div');
                d.textContent = s || '';
                return d.innerHTML;
            }

            function cascade() {
                const catV = document.getElementById('catFilterSelect').value,
                    sub = document.getElementById('subcatFilterSelect'),
                    ssub = document.getElementById('subsubFilterSelect');
                [...sub.options].forEach(o => {
                    if (o.value === 'all') return;
                    o.style.display = (catV === 'all' || o.dataset.parent === catV) ? '' : 'none';
                });
                if (sub.options[sub.selectedIndex]?.style.display === 'none') sub.value = 'all';
                const subV = sub.value;
                [...ssub.options].forEach(o => {
                    if (o.value === 'all') return;
                    let show = true;
                    if (catV !== 'all' && o.dataset.parent !== catV) show = false;
                    if (subV !== 'all' && o.dataset.subparent !== subV) show = false;
                    o.style.display = show ? '' : 'none';
                });
                if (ssub.options[ssub.selectedIndex]?.style.display === 'none') ssub.value = 'all';
            }

            function getFiltered() {
                const catV = document.getElementById('catFilterSelect').value,
                    subV = document.getElementById('subcatFilterSelect').value,
                    ssubV = document.getElementById('subsubFilterSelect').value;
                let fProd = [...allProducts];
                if (catV !== 'all') fProd = fProd.filter(p => p.category?.categoryName === catV);
                if (subV !== 'all') fProd = fProd.filter(p => p.subcategory?.subcategoryName === subV);
                if (ssubV !== 'all') fProd = fProd.filter(p => p.sub_subcategory?.subSubName === ssubV);
                const prodIds = new Set(fProd.map(p => p._id?.toString()));
                let fOrd = allOrders.filter(o => o.items?.some(i => prodIds.has(i.productId?._id?.toString() || i
                    .productId?.toString?.() || '')));
                const dCal = document.getElementById('dateRangeCalendar')._flatpickr;
                if (dCal?.selectedDates.length === 2) {
                    const [s, e] = dCal.selectedDates;
                    fOrd = fOrd.filter(o => { const d = extractDate(o); return d ? d >= s && d <= e : true; });
                }
                let fCust = [...allCustomers];
                const cCal = document.getElementById('customerDateCalendar')._flatpickr;
                if (cCal?.selectedDates.length === 1) {
                    const cd = cCal.selectedDates[0];
                    fCust = fCust.filter(c => c.joinedAt ? new Date(c.joinedAt) >= cd : true);
                }
                const custIds = new Set(fOrd.map(o => o.userId?._id?.toString() || o.userId?.toString?.() || '')
                    .filter(Boolean));
                fCust = fCust.filter(c => custIds.has(c._id?.toString()) || custIds.size === 0);
                return { fProd, fOrd, fCust, prodIds };
            }

            function extractDate(o) {
                if (o.createdAt) return new Date(o.createdAt);
                if (o.orderTimeline) {
                    const v = Object.values(o.orderTimeline).filter(d => d && !isNaN(new Date(d)));
                    if (v.length) return new Date(v[0]);
                }
                return null;
            }

            function applyAll() {
                cascade();
                const { fProd, fOrd, fCust } = getFiltered();
                updatePrice(fProd);
                updateOrderStatus(fOrd);
                updateCustomerStatus(fCust);
                updateProductStatus(fProd);
                updateMargin(fOrd, fProd);
                updateSellThrough(fProd, fOrd);
                updateRevenueChart(fOrd, fProd);
                updateExtra(fOrd, fCust);
                updateAOV(fOrd);
                updateRevenueTimeChart();
                if (revenuePanelVisible) updateRevenueDetailPanel(fOrd);
            }

            function updatePrice(prod) {
                const prices = prod.map(p => p.price || p.productPrice || p.sellingPrice || 0).filter(p => p > 0);
                const total = prices.length || 1;
                const b = { low: 0, mid: 0, high: 0, premium: 0 };
                prices.forEach(p => {
                    if (p <= 25) b.low++;
                    else if (p <= 80) b.mid++;
                    else if (p <= 200) b.high++;
                    else b.premium++;
                });
                const pcts = { low: Math.round(b.low / total * 100), mid: Math.round(b.mid / total * 100),
                    high: Math.round(b.high / total * 100), premium: Math.round(b.premium / total * 100) };
                const fills = document.querySelectorAll('#priceRangeContainer .price-bar-fill'),
                    spans = document.querySelectorAll('#priceRangeContainer .price-pct'),
                    keys = ['low', 'mid', 'high', 'premium'],
                    cols = ['#4d8fff', '#34d399', '#fbbf24', '#f87171'];
                keys.forEach((k, i) => {
                    if (fills[i]) {
                        fills[i].style.width = pcts[k] + '%';
                        fills[i].style.background = cols[i];
                        spans[i].textContent = pcts[k] + '%';
                    }
                });
            }

            function updateAOV(ord) {
                const t = ord.map(o => o.totals?.totalAmount || 0).filter(v => v > 0);
                const aov = t.reduce((a, b) => a + b, 0) / (t.length || 1);
                document.getElementById('aovDisplay').textContent = `🔼 AOV $${aov.toFixed(2)}`;
                document.getElementById('aovChange').textContent = aov > 50 ? '+5.2%' : '+2.1%';
            }

            function updateOrderStatus(ord) {
                const cnt = { pending: 0, shipped: 0, delivered: 0, cancelled: 0 };
                ord.forEach(o => {
                    const s = (o.orderStatus || '').toLowerCase();
                    if (s.includes('pending')) cnt.pending++;
                    else if (s.includes('ship')) cnt.shipped++;
                    else if (s.includes('deliver')) cnt.delivered++;
                    else if (s.includes('cancel')) cnt.cancelled++;
                    else cnt.pending++;
                });
                const total = ord.length || 1,
                    pcts = {
                        pending: Math.round(cnt.pending / total * 100),
                        shipped: Math.round(cnt.shipped / total * 100),
                        delivered: Math.round(cnt.delivered / total * 100),
                        cancelled: Math.round(cnt.cancelled / total * 100)
                    };
                const labels = ['pending', 'shipped', 'delivered', 'cancelled'],
                    disp = ['Pending', 'Shipped', 'Delivered', 'Cancelled'];
                document.querySelectorAll('#orderStatusRing .status-dot').forEach((d, i) => {
                    d.innerHTML =
                        `<span class="dot ${labels[i]}"></span> ${disp[i]} <span class="os-pct">${pcts[labels[i]]}%</span>`;
                });
                const bars = document.querySelectorAll('#orderStatusBars span'),
                    w = [pcts.pending, pcts.shipped, pcts.delivered, pcts.cancelled],
                    h = [Math.max(pcts.pending * 0.6, 8), Math.max(pcts.shipped * 1.2, 8), Math.max(pcts
                        .delivered * 1.3, 8), Math.max(pcts.cancelled * 0.5, 4)];
                bars.forEach((b, i) => { b.style.width = w[i] + '%';
                    b.style.height = h[i] + 'px'; });
            }

            function updateCustomerStatus(cust) {
                let active = 0,
                    inactive = 0,
                    blocked = 0;
                const now = new Date();
                const newMonth = cust.filter(c => c.joinedAt && new Date(c.joinedAt).getMonth() === now.getMonth() &&
                    new Date(c.joinedAt).getFullYear() === now.getFullYear()).length;
                cust.forEach(c => {
                    if (c.isBlocked === true) { inactive++;
                        blocked++; } else active++;
                });
                const total = cust.length || 1,
                    aP = Math.round(active / total * 100),
                    iP = Math.round(inactive / total * 100);
                const pie = document.getElementById('customerPie');
                if (pie) pie.style.background =
                    `radial-gradient(var(--bg-card) 60%,transparent 61%), conic-gradient(#34d399 0deg ${aP*3.6}deg, #f87171 ${aP*3.6}deg 360deg)`;
                const leg = document.querySelectorAll('#customerPieLegend span');
                if (leg.length >= 2) {
                    leg[0].innerHTML =
                        `<span style="color:#34d399;">●</span> Active <span class="cs-pct">${aP}%</span>`;
                    leg[1].innerHTML =
                        `<span style="color:#f87171;">●</span> Inactive <span class="cs-pct">${iP}%</span>`;
                }
                document.getElementById('newCustomersCount').textContent = newMonth;
                if (!customerBlockData) {
                    document.getElementById('totalCustomersCount').textContent = cust.length;
                    document.getElementById('blockedCustomersCount').textContent = blocked;
                }
            }

            function updateProductStatus(prod) {
                let inS = 0,
                    low = 0,
                    out = 0,
                    disc = 0;
                prod.forEach(p => {
                    const stock = p.stock ?? p.stockQuantity ?? p.inventory ?? p.quantity ?? 0;
                    const st = (p.status || '').toLowerCase();
                    if (st.includes('discontinued') || st.includes('inactive')) disc++;
                    else if (stock === 0 || st.includes('out')) out++;
                    else if (stock <= 10) low++;
                    else inS++;
                });
                const total = prod.length || 1,
                    activeCnt = inS + low + out;
                document.getElementById('inStockCount').textContent = inS;
                document.getElementById('lowStockCount').textContent = low;
                document.getElementById('outStockCount').textContent = out;
                document.getElementById('activeProductBar').style.width = Math.round(activeCnt / total * 100) + '%';
                document.getElementById('activeProductPct').textContent = Math.round(activeCnt / total * 100) + '%';
                document.getElementById('discontinuedBar').style.width = Math.round(disc / total * 100) + '%';
                document.getElementById('discontinuedPct').textContent = Math.round(disc / total * 100) + '%';
            }

            function updateMargin(ord, prod) {
                const rev = {};
                const catMap = new Map();
                prod.forEach(p => catMap.set(p._id?.toString(), p.category?.categoryName || 'Unknown'));
                ord.forEach(o => (o.items || []).forEach(i => {
                    const pid = i.productId?._id?.toString() || i.productId?.toString?.() || '';
                    const cat = catMap.get(pid) || 'Unknown';
                    rev[cat] = (rev[cat] || 0) + ((i.quantity || 1) * (i.price || o.totals?.subtotal / (o
                        .items?.length || 1) || 0));
                }));
                const total = Object.values(rev).reduce((a, b) => a + b, 0) || 1;
                const sorted = Object.entries(rev).sort((a, b) => b[1] - a[1]);
                const cont = document.getElementById('marginRingContainer');
                if (!cont) return;
                const cols = ['#4d8fff', '#fbbf24', '#34d399', '#9b6dff', '#f87171', '#3ce4d4'];
                cont.innerHTML = sorted.map(([cat, val], i) => {
                    const pct = Math.round(val / total * 100);
                    return `<div class="ring-item"><span class="ring-label">${escapeHTML(cat.substring(0,10))}</span><div class="ring-bg"><div class="ring-fill" style="width:${pct}%; background:${cols[i%6]};"></div></div><span style="font-size:0.75rem;font-weight:600;">${pct}%</span></div>`;
                }).join('') || '<p style="color:var(--text-muted);">No data</p>';
            }

            function updateSellThrough(prod, ord) {
                const sold = new Set();
                ord.forEach(o => (o.items || []).forEach(i => {
                    const pid = i.productId?._id?.toString() || i.productId?.toString?.() || '';
                    if (pid) sold.add(pid);
                }));
                const sell = Math.round(sold.size / (prod.length || 1) * 100);
                document.getElementById('sellThroughPct').textContent = sell + '%';
                const donut = document.getElementById('sellThroughDonut');
                if (donut) donut.style.background =
                    `radial-gradient(var(--bg-card) 55%,transparent 56%), conic-gradient(#4d8fff 0deg ${sell*3.6}deg, rgba(255,255,255,0.06) ${sell*3.6}deg 360deg)`;
            }

            function updateRevenueChart(ord, prod) {
                const rev = {};
                const ssMap = new Map();
                prod.forEach(p => ssMap.set(p._id?.toString(), p.sub_subcategory?.subSubName || 'Other'));
                ord.forEach(o => (o.items || []).forEach(i => {
                    const pid = i.productId?._id?.toString() || i.productId?.toString?.() || '';
                    const name = ssMap.get(pid) || 'Other';
                    rev[name] = (rev[name] || 0) + ((i.quantity || 1) * (i.price || o.totals?.totalAmount / (o
                        .items?.length || 1) || 0));
                }));
                const sorted = Object.entries(rev).sort((a, b) => b[1] - a[1]).slice(0, 8);
                const labels = sorted.map(([n]) => n.substring(0, 15)),
                    data = sorted.map(([, v]) => Math.round(v));
                document.getElementById('chartAvgPrice').textContent = '$' + (prod.map(p => p.price || p
                    .productPrice || p.sellingPrice || 0).filter(v => v > 0).reduce((a, b) => a + b, 0) / (prod
                    .length || 1)).toFixed(2);
                document.getElementById('chartTotalOrders').textContent = ord.length;
                document.getElementById('chartInStockPct').textContent = Math.round(prod.filter(p => (p.stock ?? p
                    .stockQuantity ?? 0) > 0).length / (prod.length || 1) * 100) + '%';
                const ctx = document.getElementById('revenueBarChart')?.getContext('2d');
                if (!ctx) return;
                if (revenueChart) revenueChart.destroy();
                revenueChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels.length ? labels : ['No Data'],
                        datasets: [{
                            label: 'Revenue ($)',
                            data: data.length ? data : [0],
                            backgroundColor: ['rgba(77,143,255,0.85)',
                                'rgba(52,211,153,0.85)', 'rgba(251,191,36,0.85)',
                                'rgba(155,109,255,0.85)', 'rgba(248,113,113,0.85)',
                                'rgba(60,228,212,0.85)'
                            ],
                            borderRadius: 12,
                            borderSkipped: false,
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' },
                                ticks: { color: '#a0aec0' } },
                            x: { grid: { display: false }, ticks: { color: '#a0aec0' } }
                        },
                        plugins: { legend: { labels: { color: '#a0aec0' } } }
                    }
                });
            }

            function updateRevenueTimeChart() {
                const ctx = document.getElementById('revenueTimeChart')?.getContext('2d');
                if (!ctx || !revenueTimeData.length) return;
                const labels = revenueTimeData.map(d =>
                    `${d._id.year}-${String(d._id.month).padStart(2,'0')}-${String(d._id.day).padStart(2,'0')}`);
                const revs = revenueTimeData.map(d => d.totalRevenue || 0);
                if (revenueTimeChart) revenueTimeChart.destroy();
                revenueTimeChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [{
                            label: 'Daily Revenue ($)',
                            data: revs,
                            borderColor: '#4d8fff',
                            backgroundColor: 'rgba(77,143,255,0.08)',
                            fill: true,
                            tension: 0.35,
                            pointRadius: 3,
                            pointBackgroundColor: '#4d8fff',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 1,
                            borderWidth: 2,
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' },
                                ticks: { color: '#a0aec0' } },
                            x: { grid: { display: false }, ticks: { color: '#a0aec0' } }
                        },
                        plugins: { legend: { labels: { color: '#a0aec0' } } }
                    }
                });
            }

            function updateExtra(ord, cust) {
                const cnt = { pending: 0, shipped: 0, delivered: 0 };
                ord.forEach(o => {
                    const s = (o.orderStatus || '').toLowerCase();
                    if (s.includes('pending')) cnt.pending++;
                    else if (s.includes('ship')) cnt.shipped++;
                    else if (s.includes('deliver')) cnt.delivered++;
                });
                const max = Math.max(...Object.values(cnt), 1);
                const bars = document.querySelectorAll('#orderPriceStatusBars span');
                const h = [Math.max(cnt.pending / max * 70, 10), Math.max(cnt.shipped / max * 70, 10), Math.max(cnt
                    .delivered / max * 70, 10), Math.max((cnt.pending + cnt.shipped) / (max * 2) * 70, 8), Math
                    .max(cnt.delivered / max * 70, 10)
                ];
                bars.forEach((b, i) => { if (b) b.style.height = h[i] + 'px'; });

                let active = 0,
                    inactive = 0;
                cust.forEach(c => {
                    if (c.isBlocked === true) inactive++;
                    else active++;
                });
                const total = cust.length || 1;
                const mcBars = document.querySelectorAll('#marginCustomerBars .mc-bar');
                [Math.round(active / total * 100), Math.round(inactive / total * 100)].forEach((p, i) => {
                    if (mcBars[i]) mcBars[i].style.width = p + '%';
                });
            }

            // ──────── REVENUE DETAIL PANEL ────────
            function openRevenueDetailPanel() {
                const panel = document.getElementById('revenueDetailPanel');
                panel.classList.remove('d-none-soft');
                revenuePanelVisible = true;
                const { fOrd } = getFiltered();
                updateRevenueDetailPanel(fOrd);
                showToast('📊 Revenue details expanded', 'chart-line');
                // Scroll to panel
                panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            function closeRevenueDetailPanel() {
                const panel = document.getElementById('revenueDetailPanel');
                panel.classList.add('d-none-soft');
                revenuePanelVisible = false;
                if (revenueDetailChart) { revenueDetailChart.destroy();
                    revenueDetailChart = null; }
            }

            function updateRevenueDetailPanel(ord) {
                if (!revenuePanelVisible) return;
                // Aggregate revenue by day from orders
                const dailyMap = {};
                ord.forEach(o => {
                    const d = extractDate(o);
                    if (!d) return;
                    const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
                    if (!dailyMap[key]) dailyMap[key] = { revenue: 0, orders: 0 };
                    dailyMap[key].revenue += o.totals?.totalAmount || 0;
                    dailyMap[key].orders += 1;
                });
                const sorted = Object.entries(dailyMap).sort((a, b) => a[0].localeCompare(b[0]));
                const totalRevenue = sorted.reduce((s, [, v]) => s + v.revenue, 0);
                const totalOrders = sorted.reduce((s, [, v]) => s + v.orders, 0);
                const avgDaily = sorted.length ? totalRevenue / sorted.length : 0;
                const bestDay = sorted.reduce((best, [k, v]) => v.revenue > (best.revenue || 0) ? { date: k,
                    revenue: v.revenue } : best, { date: '—', revenue: 0 });

                document.getElementById('revTotalRevenue').textContent = '$' + totalRevenue.toLocaleString(
                'en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('revAvgDaily').textContent = '$' + avgDaily.toLocaleString('en-US', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
                document.getElementById('revBestDay').textContent = bestDay.date;
                document.getElementById('revTotalOrders').textContent = totalOrders;

                // Table
                const tbody = document.getElementById('revTableBody');
                const recent = sorted.slice(-20).reverse();
                tbody.innerHTML = recent.map(([date, v]) => `
                    <tr>
                        <td>${date}</td>
                        <td><strong>$${v.revenue.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}</strong></td>
                        <td>${v.orders}</td>
                        <td>$${(v.revenue/(v.orders||1)).toFixed(2)}</td>
                    </tr>
                `).join('') || '<tr><td colspan="4" style="text-align:center;color:var(--text-muted);">No data</td></tr>';

                // Mini chart
                const ctx = document.getElementById('revenueDetailChart')?.getContext('2d');
                if (!ctx) return;
                if (revenueDetailChart) revenueDetailChart.destroy();
                const chartLabels = sorted.map(([k]) => k);
                const chartData = sorted.map(([, v]) => v.revenue);
                revenueDetailChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: chartLabels.length ? chartLabels : ['No Data'],
                        datasets: [{
                            label: 'Daily Revenue ($)',
                            data: chartData.length ? chartData : [0],
                            backgroundColor: 'rgba(60,228,212,0.7)',
                            borderColor: '#3ce4d4',
                            borderWidth: 1,
                            borderRadius: 8,
                            borderSkipped: false,
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' },
                                ticks: { color: '#a0aec0' } },
                            x: { grid: { display: false }, ticks: { color: '#a0aec0',
                                    maxTicksLimit: 15 } }
                        },
                        plugins: { legend: { labels: { color: '#a0aec0' } } }
                    }
                });
            }

            // ──────── VIEW SWITCHING ────────
            function setView(view) {
                currentView = view;
                document.querySelectorAll('.type-tab').forEach(tab => tab.classList.remove('active'));
                const targetTab = document.querySelector(`.type-tab[data-type="${view}"]`);
                if (targetTab) targetTab.classList.add('active');
                document.querySelectorAll('[data-view]').forEach(el => {
                    const views = el.getAttribute('data-view').split(',');
                    el.classList.toggle('d-none-soft', !views.includes(view));
                });
                if (view === 'orders' || view === 'all') {
                    updateRevenueTimeChart();
                    updateOrderStatus(getFiltered().fOrd);
                }
                if (view === 'products' || view === 'all') {
                    updateSellThrough(getFiltered().fProd, getFiltered().fOrd);
                }
                if (view === 'subsubcategories' || view === 'all') {
                    updateRevenueChart(getFiltered().fOrd, getFiltered().fProd);
                }
            }

            // ──────── EVENT LISTENERS ────────
            function setupListeners() {
                const cat = document.getElementById('catFilterSelect'),
                    sub = document.getElementById('subcatFilterSelect'),
                    ssub = document.getElementById('subsubFilterSelect');
                cat.addEventListener('change', () => { cascade();
                    applyAll(); });
                sub.addEventListener('change', () => { cascade();
                    applyAll(); });
                ssub.addEventListener('change', applyAll);
                const dCal = flatpickr('#dateRangeCalendar', { mode: 'range', dateFormat: 'Y-m-d',
                    onChange: applyAll });
                const cCal = flatpickr('#customerDateCalendar', { mode: 'single', dateFormat: 'Y-m-d',
                    onChange: applyAll });
                document.getElementById('dateRangeCalendar')._flatpickr = dCal;
                document.getElementById('customerDateCalendar')._flatpickr = cCal;
                document.getElementById('clearFilterBtn').addEventListener('click', () => {
                    cat.value = 'all';
                    sub.value = 'all';
                    ssub.value = 'all';
                    dCal.clear();
                    cCal.clear();
                    cascade();
                    applyAll();
                    showToast('🔄 Filters reset', 'undo-alt');
                });

                document.querySelectorAll('.type-tab').forEach(tab => {
                    tab.addEventListener('click', () => setView(tab.getAttribute('data-type')));
                });

                // Revenue click handlers
                document.getElementById('revenueTimeCard')?.addEventListener('click', (e) => {
                    if (e.target.closest('canvas') && !e.target.closest('.revenue-detail-panel')) {
                        openRevenueDetailPanel();
                    } else if (!e.target.closest('.revenue-detail-panel') && !e.target.closest('.close-panel')) {
                        openRevenueDetailPanel();
                    }
                });
                document.getElementById('revenueBarCard')?.addEventListener('click', (e) => {
                    if (!e.target.closest('.revenue-detail-panel') && !e.target.closest('.close-panel')) {
                        openRevenueDetailPanel();
                    }
                });
                document.getElementById('closeRevenuePanel')?.addEventListener('click', closeRevenueDetailPanel);

                // Quick action buttons
                document.getElementById('generateReport')?.addEventListener('click', () => showModal(
                    '📊 Generate Report', 'Report generation started.'));
                document.getElementById('viewMargin')?.addEventListener('click', () => showModal(
                    '🔍 Margin Deep Dive', 'Margin analysis loaded.'));
                document.getElementById('comparePeriod')?.addEventListener('click', () => showModal(
                    '📅 Compare Periods', 'Comparison active.'));
                document.getElementById('exportAnalytics')?.addEventListener('click', () => showModal(
                    '⬇️ Export Graphics', 'PNG export prepared.'));
                document.getElementById('searchInput')?.addEventListener('keydown', e => {
                    if (e.key === 'Enter') showToast('🔎 Searching...', 'search');
                });

                // Keyboard shortcut for revenue panel
                document.addEventListener('keydown', e => {
                    if (e.key === 'Escape' && revenuePanelVisible) {
                        closeRevenueDetailPanel();
                    }
                    if (e.ctrlKey && e.key === 'r') {
                        e.preventDefault();
                        if (revenuePanelVisible) closeRevenueDetailPanel();
                        else openRevenueDetailPanel();
                    }
                });
            }

            setupListeners();
            fetchAll();
            setView('all');

            // ──────── ANIMATION LOOP ────────
            function animationLoop() {
                updateMouseGlow();
                requestAnimationFrame(animationLoop);
            }
            animationLoop();
        })();
    </script>
</body>
</html>