                <div class="card-detail positive" id="customersTrend"><i class="fas fa-user-plus"></i> —</div>
                <button class="btn btn-outline" id="btnCustomersView"><i class="fas fa-user-friends"></i> view</button>
            </div>
        </div>

        <!-- ANALYTICS + TOP CATEGORIES -->
        <div class="analytics-container">
            <div class="chart-container">
                <div class="chart-header">
                    <h3>📈 Sales analytics</h3>
                    <select id="chartPeriodSelect">
                        <option value="7">Last 7 days</option>
                        <option value="30" selected>Last 30 days</option>
                        <option value="90">Quarter</option>
                    </select>
                </div>
                <div class="analytics-summary-row" id="analyticsSummaryRow">
                    <div class="analytics-mini-card"><div class="mini-icon"><i class="fas fa-calendar-day"></i></div><div class="mini-value" id="todayRevenue">₹0</div><div class="mini-label">Today</div></div>
                    <div class="analytics-mini-card"><div class="mini-icon"><i class="fas fa-calendar-week"></i></div><div class="mini-value" id="weekRevenue">₹0</div><div class="mini-label">This Week</div></div>
                    <div class="analytics-mini-card"><div class="mini-icon"><i class="fas fa-chart-line"></i></div><div class="mini-value" id="growthPercent">—%</div><div class="mini-label">vs Last Week</div></div>
                </div>
                <div class="chart-canvas-wrap"><canvas id="revenueChart"></canvas></div>
            </div>
            <div class="summary-container">
                <div class="chart-header"><h3>🏷️ Top categories</h3></div>
                <div class="stats-summary" id="topCategoriesContainer">
                    <div class="stat-item" style="color:var(--text-muted);">Loading categories...</div>
                </div>
                <div class="view-all-btn-small">
                    <button class="btn btn-outline" id="btnViewAllCategories"><i class="fas fa-arrow-right"></i> View All Categories</button>
                </div>
            </div>
        </div>

        <!-- TABLES: Recent orders + Top products -->
        <div class="tables-container">
            <div class="table-card">
                <h3>📦 Recent orders <a href="/Admin/order" class="view-all-link"><i class="fas fa-external-link-alt"></i> View all</a></h3>
                <table>
                    <thead><tr><th>Order ID</th><th>Customer</th><th>Date</th><th>Amount</th><th>Status</th></tr></thead>
                    <tbody id="recentOrdersBody">
                        <tr><td colspan="5" style="text-align:center;color:var(--text-muted);">Loading orders...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="table-card">
                <h3>🔥 Top products <a href="/Admin/product" class="view-all-link"><i class="fas fa-external-link-alt"></i> View all</a></h3>
                <table>
                    <thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Sold</th></tr></thead>
                    <tbody id="topProductsBody">
                        <tr><td colspan="5" style="text-align:center;color:var(--text-muted);">Loading products...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // ═══════════ NURAN PARTICLE BACKGROUND (FULL) ═══════════
            const canvas = document.getElementById('nuranCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouseX = -999, mouseY = -999, targetMouseX = -999, targetMouseY = -999;
            const SPLATTER_RADIUS = 190, CONNECTION_DIST = 140, PARTICLE_COUNT = window.innerWidth < 768 ? 80 : 140;

            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            resize();
            window.addEventListener('resize', () => {
                resize();
                const nc = window.innerWidth < 768 ? 80 : 140;
                while (particles.length < nc) particles.push(createParticle());
                while (particles.length > nc) particles.pop();
            });

            function createParticle() {
                const cols = ['rgba(77,171,247,','rgba(56,189,248,','rgba(167,139,250,','rgba(139,92,246,','rgba(45,212,191,','rgba(96,165,250,','rgba(192,132,252,','rgba(52,211,153,'];
                const c = cols[Math.floor(Math.random()*cols.length)];
                return {
                    x: Math.random()*canvas.width, y: Math.random()*canvas.height,
                    vx: (Math.random()-0.5)*0.7, vy: (Math.random()-0.5)*0.7,
                    size: 1.8+Math.random()*3.5, color: c,
                    glowAlpha: 0.5+Math.random()*0.5,
                    pulsePhase: Math.random()*Math.PI*2,
                    pulseSpeed: 0.008+Math.random()*0.025,
                    baseSize: 1.8+Math.random()*3.5
                };
            }
            for(let i=0;i<PARTICLE_COUNT;i++) particles.push(createParticle());

            document.addEventListener('mousemove',e=>{ targetMouseX=e.clientX; targetMouseY=e.clientY; });
            document.addEventListener('mouseleave',()=>{ targetMouseX=-999; targetMouseY=-999; });
            document.addEventListener('touchmove',e=>{ if(e.touches.length>0){ targetMouseX=e.touches[0].clientX; targetMouseY=e.touches[0].clientY; } },{passive:true});
            document.addEventListener('touchend',()=>{ targetMouseX=-999; targetMouseY=-999; });

            function animate(ts) {
                mouseX+=(targetMouseX-mouseX)*0.18; mouseY+=(targetMouseY-mouseY)*0.18;
                ctx.clearRect(0,0,canvas.width,canvas.height);
                const time=ts*0.001;
                for(let p of particles) {
                    p.vx+=Math.sin(time*0.7+p.pulsePhase)*0.025;
                    p.vy+=Math.cos(time*0.6+p.pulsePhase+1.3)*0.025;
                    if(mouseX>-500&&mouseY>-500){
                        const dx=p.x-mouseX,dy=p.y-mouseY,dist=Math.sqrt(dx*dx+dy*dy);
                        if(dist<SPLATTER_RADIUS&&dist>0.5){
                            const force=(1-dist/SPLATTER_RADIUS)*4.5;
                            p.vx+=(dx/dist)*force; p.vy+=(dy/dist)*force;
                            p.glowAlpha=Math.min(1,p.glowAlpha+0.06);
                        }
                    }
                    p.x+=p.vx; p.y+=p.vy;
                    p.vx*=0.94; p.vy*=0.94;
                    const sp=Math.sqrt(p.vx*p.vx+p.vy*p.vy); if(sp>6){ p.vx=(p.vx/sp)*6; p.vy=(p.vy/sp)*6; }
                    if(p.x<-30)p.x=canvas.width+30; if(p.x>canvas.width+30)p.x=-30;
                    if(p.y<-30)p.y=canvas.height+30; if(p.y>canvas.height+30)p.y=-30;
                    p.size=p.baseSize+Math.sin(time*p.pulseSpeed*10+p.pulsePhase)*0.7;
                    p.glowAlpha+=(0.6-p.glowAlpha)*0.03;
                }
                for(let i=0;i<particles.length;i++) for(let j=i+1;j<particles.length;j++) {
                    const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,dist=Math.sqrt(dx*dx+dy*dy);
                    if(dist<CONNECTION_DIST){
                        const alpha=(1-dist/CONNECTION_DIST)*0.28, pulse=Math.sin(ts*0.003+i*0.4+j*0.3)*0.5+0.5;
                        ctx.beginPath(); ctx.moveTo(particles[i].x,particles[i].y); ctx.lineTo(particles[j].x,particles[j].y);
                        ctx.strokeStyle=`rgba(120,170,230,${alpha*(0.5+pulse*0.5)})`; ctx.lineWidth=0.6; ctx.stroke();
                    }
                }
                for(let p of particles) {
                    const grad=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.size*3.5);
                    grad.addColorStop(0,p.color+(p.glowAlpha*0.7)+')');
                    grad.addColorStop(0.35,p.color+(p.glowAlpha*0.25)+')');
                    grad.addColorStop(1,p.color+'0)');
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.size*3.5,0,Math.PI*2); ctx.fillStyle=grad; ctx.fill();
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.size*0.65,0,Math.PI*2);
                    ctx.fillStyle=`rgba(255,255,255,${0.7+p.glowAlpha*0.3})`; ctx.fill();
                }
                if(mouseX>-500&&mouseY>-500){
                    const mg=ctx.createRadialGradient(mouseX,mouseY,0,mouseX,mouseY,SPLATTER_RADIUS*0.7);
                    mg.addColorStop(0,'rgba(120,180,240,0.08)'); mg.addColorStop(0.5,'rgba(100,150,220,0.03)'); mg.addColorStop(1,'rgba(0,0,0,0)');
                    ctx.beginPath(); ctx.arc(mouseX,mouseY,SPLATTER_RADIUS*0.7,0,Math.PI*2); ctx.fillStyle=mg; ctx.fill();
                }
                requestAnimationFrame(animate);
            }
            requestAnimationFrame(animate);

            // ═══════════ SIDEBAR TOGGLE ═══════════
            const sidebar = document.getElementById('sidebar');
            const menuToggle = document.getElementById('menuToggle');
            const toggleSidebar = document.getElementById('toggleSidebar');
            function toggleSidebarFunc(e) { e.stopPropagation(); sidebar.classList.toggle('active'); }
            menuToggle?.addEventListener('click', toggleSidebarFunc);
            toggleSidebar?.addEventListener('click', toggleSidebarFunc);
            document.addEventListener('click', function(e) {
                if (window.innerWidth <= 992 && !sidebar.contains(e.target) && !menuToggle.contains(e.target) && sidebar.classList.contains('active'))
                    sidebar.classList.remove('active');
            });

            // ═══════════ TOAST ═══════════
            function showToast(msg, icon = 'fa-bell') {
                const old = document.querySelector('.notification-toast'); if (old) old.remove();
                const t = document.createElement('div'); t.className = 'notification-toast';
                t.innerHTML = `<i class="fas ${icon}" style="color:var(--accent-cyan);font-size:1.3rem;"></i><span>${msg}</span>`;
                document.body.appendChild(t);
                setTimeout(() => { t.style.opacity='0'; t.style.transform='translateX(50px)'; t.style.transition='all 0.35s ease'; setTimeout(() => t.remove(),350); }, 2400);
            }

            // ═══════════ API CONFIG ═══════════
            const API_BASE = 'http://localhost:3000/admin';
            const loadingOverlay = document.getElementById('loadingOverlay');
            function showLoading(show) { loadingOverlay.classList.toggle('hidden', !show); }

            let allProducts = [], allOrders = [], revenueData = [], customerCountData = null;
            let revenueChartInstance = null;
            const chartPeriodSelect = document.getElementById('chartPeriodSelect');
            const revenueChartCtx = document.getElementById('revenueChart')?.getContext('2d');

            function formatCurrency(val) {
                return '₹' + Number(val).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }
            function formatCompact(val) {
                if (val >= 1000) return (val / 1000).toFixed(1) + 'k';
                return String(val);
            }
            function getStatusClass(st) {
                const s = (st || '').toLowerCase();
                if (s.includes('completed')||s.includes('delivered')) return 'status-completed';
                if (s.includes('processing')||s.includes('shipped')) return 'status-processing';
                if (s.includes('cancelled')) return 'status-cancelled';
                return 'status-pending';
            }
            function getStatusLabel(st) {
                const s = (st || '').toLowerCase();
                if (s.includes('completed')) return 'completed';
                if (s.includes('delivered')) return 'delivered';
                if (s.includes('processing')) return 'processing';
                if (s.includes('shipped')) return 'shipped';
                if (s.includes('cancelled')) return 'cancelled';
                return 'pending';
            }
            function getDateFromObjectId(oid) {
                if (!oid) return null;
                const str = oid.toString?.() || String(oid);
                if (str.length < 8) return null;
                try { return new Date(parseInt(str.substring(0,8),16)*1000); } catch { return null; }
            }

            async function fetchJSON(url) {
                const resp = await fetch(url);
                if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                return resp.json();
            }

            async function fetchAllData() {
                showLoading(true);
                try {
                    const [prodRes, ordRes, revRes, custRes] = await Promise.all([
                        fetchJSON(`${API_BASE}/allproduct`),
                        fetchJSON(`${API_BASE}/orders`),
                        fetchJSON(`${API_BASE}/orders/revenue`),
                        fetchJSON(`${API_BASE}/customers/count`).catch(() => null)
                    ]);
                    allProducts = prodRes.data || [];
                    allOrders = ordRes.orderData || [];
                    revenueData = revRes.revenueData || [];
                    customerCountData = custRes?.data || null;
                    updateAllUI();
                    showToast('📊 Dashboard ready', 'fa-check-circle');
                } catch (e) {
                    console.error(e);
                    showToast('⚠️ Failed to load data', 'fa-exclamation-triangle');
                } finally {
                    showLoading(false);
                }
            }

            function updateAllUI() {
                updateStatCards();
                updateRevenueChart();
                updateAnalyticsSummary();
                updateTopCategories();
                updateRecentOrders();
                updateTopProducts();
                updateBadges();
                updatePendingCount();
            }

            function updateStatCards() {
                const totalRev = revenueData.reduce((s,d) => s + (d.totalRevenue||0), 0);
                document.getElementById('totalRevenue').textContent = formatCurrency(totalRev);

                const sorted = [...revenueData].sort((a,b) => new Date(b._id.year,b._id.month-1,b._id.day) - new Date(a._id.year,a._id.month-1,a._id.day));
                const last7 = sorted.slice(0,7).reduce((s,d)=>s+(d.totalRevenue||0),0);
                const prev7 = sorted.slice(7,14).reduce((s,d)=>s+(d.totalRevenue||0),0);
                const revChange = prev7 > 0 ? ((last7-prev7)/prev7*100) : 0;
                const revTrend = document.getElementById('revenueTrend');
                if (revChange >= 0) {
                    revTrend.innerHTML = `<i class="fas fa-arrow-up"></i> ${revChange.toFixed(1)}%`;
                    revTrend.className = 'card-detail positive';
                } else {
                    revTrend.innerHTML = `<i class="fas fa-arrow-down"></i> ${Math.abs(revChange).toFixed(1)}%`;
                    revTrend.className = 'card-detail negative';
                }

                const totalOrd = allOrders.length;
                document.getElementById('totalOrders').textContent = totalOrd.toLocaleString();
                const recentOrd = allOrders.filter(o => { const d = getDateFromObjectId(o.orderId); return d && d >= new Date(Date.now()-7*86400000); }).length;
                const prevOrd = allOrders.filter(o => { const d = getDateFromObjectId(o.orderId); return d && d >= new Date(Date.now()-14*86400000) && d < new Date(Date.now()-7*86400000); }).length;
                const ordChange = prevOrd > 0 ? ((recentOrd-prevOrd)/prevOrd*100) : (recentOrd>0?100:0);
                const ordTrend = document.getElementById('ordersTrend');
                if (ordChange >= 0) {
                    ordTrend.innerHTML = `<i class="fas fa-arrow-up"></i> ${ordChange.toFixed(1)}%`;
                    ordTrend.className = 'card-detail positive';
                } else {
                    ordTrend.innerHTML = `<i class="fas fa-arrow-down"></i> ${Math.abs(ordChange).toFixed(1)}%`;
                    ordTrend.className = 'card-detail negative';
                }

                document.getElementById('totalProducts').textContent = allProducts.length.toLocaleString();
                const activeProd = allProducts.filter(p => { const st = (p.status||'').toLowerCase(); return !st.includes('discontinued')&&!st.includes('inactive'); }).length;
                document.getElementById('productsTrend').innerHTML = `<i class="fas fa-check-circle"></i> ${activeProd} active`;

                const uniqueUsers = new Set(allOrders.map(o => o.userId?._id?.toString()||o.userId?.toString?.()||'').filter(Boolean));
                const totalCust = uniqueUsers.size || (customerCountData ? computeTotalCustomersFromCountData() : 0);
                document.getElementById('totalCustomers').textContent = formatCompact(totalCust);
                let newCustThisMonth = 0;
                if (customerCountData?.daily) {
                    const now = new Date(), cm = now.getMonth()+1, cy = now.getFullYear();
                    newCustThisMonth = customerCountData.daily.filter(d => d._id.year===cy && d._id.month===cm).reduce((s,d)=>s+(d.count||0),0);
                }
                document.getElementById('customersTrend').innerHTML = `<i class="fas fa-user-plus"></i> +${newCustThisMonth||'—'} new`;
            }

            function computeTotalCustomersFromCountData() {
                if (!customerCountData?.daily) return 0;
                const seen = new Set();
                let total = 0;
                customerCountData.daily.forEach(d => {
                    const key = `${d._id.year}-${d._id.month}-${d._id.day}-${d._id.isBlocked}`;
                    if (!seen.has(key)) { seen.add(key); total += d.count || 0; }
                });
                return total;
            }

            function updateAnalyticsSummary() {
                const today = new Date();
                const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
                const todayRev = revenueData.filter(d => new Date(d._id.year,d._id.month-1,d._id.day).toISOString().slice(0,10)===todayStr).reduce((s,d)=>s+(d.totalRevenue||0),0);
                const oneWeekAgo = new Date(Date.now()-6*86400000);
                const weekRev = revenueData.filter(d => new Date(d._id.year,d._id.month-1,d._id.day) >= oneWeekAgo).reduce((s,d)=>s+(d.totalRevenue||0),0);
                const twoWeeksAgoStart = new Date(Date.now()-13*86400000);
                const twoWeeksAgoEnd = new Date(Date.now()-7*86400000);
                const lastWeekRev = revenueData.filter(d => {
                    const dt = new Date(d._id.year,d._id.month-1,d._id.day);
                    return dt >= twoWeeksAgoStart && dt < twoWeeksAgoEnd;
                }).reduce((s,d)=>s+(d.totalRevenue||0),0);
                const growth = lastWeekRev > 0 ? ((weekRev - lastWeekRev) / lastWeekRev * 100) : 0;

                document.getElementById('todayRevenue').textContent = formatCurrency(todayRev);
                document.getElementById('weekRevenue').textContent = formatCurrency(weekRev);
                const growthEl = document.getElementById('growthPercent');
                growthEl.textContent = (growth >= 0 ? '+' : '') + growth.toFixed(1) + '%';
                growthEl.style.color = growth >= 0 ? 'var(--accent-green)' : 'var(--accent-red)';
            }

            function updateRevenueChart() {
                if (!revenueChartCtx) return;
                const days = parseInt(chartPeriodSelect.value) || 30;
                const cutoff = new Date(Date.now() - days*86400000);
                const filtered = revenueData
                    .filter(d => new Date(d._id.year,d._id.month-1,d._id.day) >= cutoff)
                    .sort((a,b) => new Date(a._id.year,a._id.month-1,a._id.day) - new Date(b._id.year,b._id.month-1,b._id.day));
                const labels = filtered.map(d => `${String(d._id.month).padStart(2,'0')}-${String(d._id.day).padStart(2,'0')}`);
                const data = filtered.map(d => d.totalRevenue || 0);

                if (revenueChartInstance) revenueChartInstance.destroy();
                revenueChartInstance = new Chart(revenueChartCtx, {
                    type: 'bar',
                    data: {
                        labels: labels.length ? labels : ['No data'],
                        datasets: [{
                            label: 'Daily Revenue (₹)',
                            data: data.length ? data : [0],
                            backgroundColor: 'rgba(77,171,247,0.6)',
                            borderColor: '#4dabf7',
                            borderWidth: 1.5,
                            borderRadius: 8,
                            hoverBackgroundColor: 'rgba(56,189,248,0.85)'
                        }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.06)' }, ticks: { callback: v => '₹'+v.toLocaleString(), color: '#b0bdd0' } },
                            x: { grid: { display: false }, ticks: { maxTicksLimit: 14, color: '#b0bdd0' } }
                        },
                        plugins: {
                            legend: { labels: { usePointStyle: true, padding: 20, color: '#e8ecf4' } },
                            tooltip: { callbacks: { label: ctx => 'Revenue: ₹' + ctx.raw.toLocaleString() } }
                        }
                    }
                });
            }

            function updateTopCategories() {
                const container = document.getElementById('topCategoriesContainer');
                if (!allProducts.length) {
                    container.innerHTML = '<div class="stat-item" style="color:var(--text-muted);">No product data</div>';
                    return;
                }
                const catCount = {};
                allProducts.forEach(p => {
                    const cat = p.category?.categoryName || 'Uncategorized';
                    catCount[cat] = (catCount[cat] || 0) + 1;
                });
                const total = allProducts.length;
                const sorted = Object.entries(catCount).sort((a,b) => b[1]-a[1]).slice(0,5);
                container.innerHTML = sorted.map(([cat, count]) => {
                    const pct = Math.round(count/total*100);
                    return `<div class="stat-item"><strong>${cat}</strong> ${pct}%</div>`;
                }).join('') || '<div class="stat-item" style="color:var(--text-muted);">No categories</div>';
            }

            function updateRecentOrders() {
                const tbody = document.getElementById('recentOrdersBody');
                if (!allOrders.length) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text-muted);">No orders</td></tr>';
                    return;
                }
                const recent = allOrders.slice(0,5);
                tbody.innerHTML = recent.map(o => {
                    const date = getDateFromObjectId(o.orderId);
                    const dateStr = date ? date.toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '—';
                    const email = o.userId?.email || 'Guest';
                    const amount = o.totals?.totalAmount || 0;
                    const status = o.orderStatus || 'pending';
                    return `<tr>
                        <td><strong>#SM-${String(o.orderId).slice(-6)}</strong></td>
                        <td>${escapeHTML(email)}</td>
                        <td>${dateStr}</td>
                        <td>${formatCurrency(amount)}</td>
                        <td><span class="status ${getStatusClass(status)}">${getStatusLabel(status)}</span></td>
                    </tr>`;
                }).join('');
            }

            function updateTopProducts() {
                const tbody = document.getElementById('topProductsBody');
                if (!allProducts.length) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text-muted);">No products</td></tr>';
                    return;
                }
                const soldMap = {};
                allOrders.forEach(o => {
                    (o.items||[]).forEach(item => {
                        const pid = item.productId?._id?.toString() || item.productId?.toString?.() || '';
                        if (pid) soldMap[pid] = (soldMap[pid]||0) + (item.quantity||1);
                    });
                });
                const productsWithSold = allProducts.map(p => ({...p, sold: soldMap[p._id?.toString()]||0}));
                productsWithSold.sort((a,b) => b.sold - a.sold);
                const top = productsWithSold.slice(0,5);
                tbody.innerHTML = top.map(p => {
                    const name = p.productName || 'Unnamed';
                    const cat = p.category?.categoryName || '—';
                    const price = p.price || p.productPrice || p.sellingPrice || 0;
                    const stock = p.stock ?? p.stockQuantity ?? p.inventory ?? p.quantity ?? 0;
                    return `<tr>
                        <td><strong>${escapeHTML(String(name).substring(0,28))}</strong></td>
                        <td>${escapeHTML(cat)}</td>
                        <td>${formatCurrency(price)}</td>
                        <td>${stock}</td>
                        <td><strong>${p.sold}</strong></td>
                    </tr>`;
                }).join('') || '<tr><td colspan="5" style="text-align:center;color:var(--text-muted);">No data</td></tr>';
            }

            function updateBadges() {
                const pendingCount = allOrders.filter(o => {
                    const s = (o.orderStatus||'').toLowerCase();
                    return s.includes('pending') || (!s.includes('delivered')&&!s.includes('completed')&&!s.includes('cancelled')&&!s.includes('shipped'));
                }).length;
                document.getElementById('notifBadge').textContent = pendingCount || '0';
                document.getElementById('emailBadge').textContent = Math.min(allOrders.length,99) || '0';
            }

            function updatePendingCount() {
                const pendingCount = allOrders.filter(o => {
                    const s = (o.orderStatus||'').toLowerCase();
                    return s.includes('pending') || (!s.includes('delivered')&&!s.includes('completed')&&!s.includes('cancelled')&&!s.includes('shipped'));
                }).length;
                document.getElementById('pendingCount').textContent = `Pending ${pendingCount}`;
            }

            function escapeHTML(str) {
                const div = document.createElement('div');
                div.textContent = str || '';
                return div.innerHTML;
            }

            // ═══════════ EVENT LISTENERS ═══════════
            chartPeriodSelect?.addEventListener('change', () => { updateRevenueChart(); updateAnalyticsSummary(); });

            document.getElementById('btnViewAllCategories')?.addEventListener('click', () => window.location.href = '/Admin/category');
            document.getElementById('btnRevenueDetail')?.addEventListener('click', () => {
                chartPeriodSelect.value = '30';
                updateRevenueChart();
                updateAnalyticsSummary();
                document.querySelector('.chart-container')?.scrollIntoView({ behavior: 'smooth' });
            });
            document.getElementById('btnOrdersView')?.addEventListener('click', () => window.location.href = '/Admin/order');
            document.getElementById('btnProductsManage')?.addEventListener('click', () => window.location.href = '/Admin/product');
            document.getElementById('btnCustomersView')?.addEventListener('click', () => window.location.href = '/Admin/customer');
            document.getElementById('quickAddProduct')?.addEventListener('click', () => window.location.href = '/Admin/product');
            document.getElementById('quickProcessOrder')?.addEventListener('click', () => window.location.href = '/Admin/order');
            document.getElementById('quickReports')?.addEventListener('click', () => document.querySelector('.analytics-container')?.scrollIntoView({ behavior: 'smooth' }));
            document.getElementById('quickUsers')?.addEventListener('click', () => window.location.href = '/Admin/customer');

            document.getElementById('searchInput')?.addEventListener('keydown', e => {
                if (e.key === 'Enter') {
                    const q = e.target.value.trim().toLowerCase();
                    document.querySelectorAll('#recentOrdersBody tr').forEach(r => {
                        r.style.opacity = r.textContent.toLowerCase().includes(q) ? '1' : '0.3';
                    });
                }
            });

            fetchAllData();
            setInterval(fetchAllData, 300000);
        })();
    </script>
</body>
</html>