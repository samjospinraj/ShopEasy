        const PRODUCT_EDIT = 'http://localhost:3000/Admin/editproductForm';

        function getProductIdFromURL() {
            const parts = window.location.pathname.split("/").filter(Boolean);
            const last = parts[parts.length - 1];
            return last === "productForm" ? null : last;
        }

        function setValue(el, val = "") {
            if (el) el.value = val ?? "";
        }

        // ✅ Updated to handle nested object structure from API
        async function setCategoryHierarchy(data) {
            if (!data.category) return;

            // Wait for categories to load if needed
            if (mainSelect.options.length <= 1) {
                await new Promise(r => setTimeout(r, 500));
            }

            // Main Category
            mainSelect.value = data.category;

            // Update the option text if we have a name
            if (data.categoryName) {
                const option = mainSelect.querySelector(`option[value="${data.category}"]`);
                if (option && !option.textContent.includes(data.categoryName)) {
                    option.textContent = data.categoryName;
                }
            }

            mainSelect.dispatchEvent(new Event("change"));

            await new Promise(r => setTimeout(r, 400));

            // Subcategory - Only set if it exists and is not empty
            if (data.subcategory && data.subcategory !== "") {
                subSelect.value = data.subcategory;

                if (data.subcategoryName) {
                    const option = subSelect.querySelector(`option[value="${data.subcategory}"]`);
                    if (option && !option.textContent.includes(data.subcategoryName)) {
                        option.textContent = data.subcategoryName;
                    }
                }

                subSelect.dispatchEvent(new Event("change"));

                await new Promise(r => setTimeout(r, 400));

                // Sub-subcategory - Only set if it exists and is not empty
                if (data.sub_subcategory && data.sub_subcategory !== "") {
                    subSubSelect.value = data.sub_subcategory;

                    if (data.subSubcategoryName) {
                        const option = subSubSelect.querySelector(
                        `option[value="${data.sub_subcategory}"]`);
                        if (option && !option.textContent.includes(data.subSubcategoryName)) {
                            option.textContent = data.subSubcategoryName;
                        }
                    }
                } else {
                    subSubSelect.value = "";
                }
            } else {
                subSelect.value = "";
                subSubSelect.value = "";
                subSubSelect.disabled = true;
            }
        }

        function renderSpecs(containerId, data, keyName, valueName) {
            const container = document.getElementById(containerId);
            if (!container) return;
            container.innerHTML = "";
            if (!Array.isArray(data)) return;
            data.forEach(spec => {
                addSpecRow(containerId, keyName, valueName, "Key", "Value");
                const row = container.lastElementChild;
                const keyInput = row.querySelector(`[name="${keyName}"]`);
                const valueInput = row.querySelector(`[name="${valueName}"]`);
                if (keyInput) keyInput.value = spec.key || "";
                if (valueInput) valueInput.value = spec.value || "";
            });
        }

        function renderMainImage(mainImage) {
            if (!mainImage?.path) return;
            const url = `${BASE_URL}${mainImage.path}`;
            if (mainPreview) {
                mainPreview.innerHTML = "";
                const div = document.createElement("div");
                div.className = "preview-item";
                div.innerHTML = `
                    <img src="${url}" style="width:100%;height:100%;object-fit:cover">
                    <span class="preview-label">Main</span>
                    <button type="button" class="remove-image" style="position:absolute;top:2px;right:2px;background:red;color:white;border:none;border-radius:50%;width:20px;height:20px;cursor:pointer;">×</button>
                `;
                div.querySelector(".remove-image").onclick = () => {
                    div.remove();
                    mainImageInput.value = "";
                    if (mainFileNameSpan) mainFileNameSpan.textContent = "No file chosen";
                };
                mainPreview.appendChild(div);
                if (mainFileNameSpan) mainFileNameSpan.textContent = mainImage.filename || "Existing image";
            }
        }

        async function loadProductForEdit() {
            const id = getProductIdFromURL();

            if (!id) {
                showToast("Create Mode", "info");
                return;
            }

            showToast("Loading product...", "info");

            try {
                const res = await fetch(`${PRODUCT_API}/${id}`);
                const result = await res.json();

                if (!res.ok || !result?.data) {
                    throw new Error(result?.message || "Invalid product response");
                }

                const data = result.data;

                // ================= BASIC INFO =================
                setValue(productNameInput, data.productName);
                setValue(skuInput, data.sku);
                setValue(brandInput, data.brand);
                setValue(modelInput, data.model);

                // ================= CATEGORY FIX =================
                const categoryId = (data.category && typeof data.category === 'object') ? data.category
                    ._id : (data.category || "");
                const categoryName = (data.category && typeof data.category === 'object') ? data.category
                    .categoryName : "";

                const subcategoryId = (data.subcategory && typeof data.subcategory === 'object') ? data
                    .subcategory._id : (data.subcategory || "");
                const subcategoryName = (data.subcategory && typeof data.subcategory === 'object') ? data
                    .subcategory.subcategoryName : "";

                const subSubcategoryId = (data.sub_subcategory && typeof data.sub_subcategory === 'object') ?
                    data.sub_subcategory._id : (data.sub_subcategory || "");
                const subSubcategoryName = (data.sub_subcategory && typeof data.sub_subcategory === 'object') ?
                    data.sub_subcategory.subSubName : "";

                await setCategoryHierarchy({
                    category: categoryId,
                    categoryName,
                    subcategory: subcategoryId,
                    subcategoryName,
                    sub_subcategory: subSubcategoryId,
                    subSubcategoryName
                });

                // ================= PRICING =================
                setValue(sizeSelect, data.size);
                setValue(priceInput, data.price);
                setValue(comparePriceInput, data.comparePrice);
                setValue(costPriceInput, data.costPrice);
                setValue(offerPercentInput, data.offerPercent);

                // ================= STOCK =================
                setValue(stockQuantityInput, data.stockQuantity);
                setValue(lowStockThresholdInput, data.lowStockThreshold);
                setValue(barcodeInput, data.barcode);

                // ================= DESCRIPTION =================
                setValue(shortDescriptionInput, data.shortDescription);
                setValue(fullDescriptionInput, data.fullDescription);

                // ================= SHIPPING =================
                setValue(shippingClassSelect, data.shippingClass);
                setValue(freeShippingSelect, data.freeShipping ? "true" : "false");

                // ================= DIMENSIONS =================
                if (data.dimensions) {
                    setValue(lengthInput, data.dimensions.length);
                    setValue(widthInput, data.dimensions.width);
                    setValue(heightInput, data.dimensions.height);
                    setValue(weightInput, data.dimensions.weight);
                    setValue(shippingCostInput, data.dimensions.shippingCost);
                }

                // ================= DELIVERY - FIXED: Use delivery.minDays and delivery.maxDays =================
                if (data.delivery) {
                    setValue(minDayInput, data.delivery.minDays);
                    setValue(maxDayInput, data.delivery.maxDays);
                }

                // ================= STATUS =================
                setValue(statusSelect, data.status);
                setValue(visibilitySelect, data.visibility);

                // ================= TAGS =================
                tagsInput.value = Array.isArray(data.tags) ?
                    data.tags.join(", ") :
                    "";

                setValue(internalNotesInput, data.internalNotes);

                // ================= SPEC TITLES =================
                setValue(specTitleInput, data.specTitle);
                setValue(designTitleInput, data.designTitle);
                setValue(performanceTitleInput, data.performanceTitle);
                setValue(additionalTitleInput, data.additionalTitle);

                // ================= SPECS =================
                renderSpecs("keySpecsContainer", data.keySpecs || [], "keySpecs_keys[]", "keySpecs_values[]");
                renderSpecs("detailedSpecsContainer", data.detailedSpecs || [], "detailedSpecs_keys[]",
                    "detailedSpecs_values[]");
                renderSpecs("designSpecsContainer", data.designSpecs || [], "designSpecs_keys[]",
                "designSpecs_values[]");
                renderSpecs("perfSpecsContainer", data.perfSpecs || [], "perfSpecs_keys[]", "perfSpecs_values[]");
                renderSpecs("additionalSpecsContainer", data.additionalSpecs || [], "additionalSpecs_keys[]",
                    "additionalSpecs_values[]");

                // ================= IMAGES =================
                renderMainImage(data.mainImage);

                existingImages = data.additionalImages || [];
                renderImages();

                // ================= VIDEOS =================
                existingVideos = data.productVideos || [];
                renderVideosUI();

                // ================= VIDEO LINKS =================
                const videoLinksContainer = document.getElementById("videoLinksContainer");
                if (videoLinksContainer && Array.isArray(data.videoLinks)) {
                    videoLinksContainer.innerHTML = "";

                    data.videoLinks.forEach(link => {
                        addVideoLinkRow();
                        const row = videoLinksContainer.lastElementChild;
                        const input = row.querySelector("input");
                        if (input) input.value = link;
                    });
                }

                // ================= UPDATE DELIVERY COUNTER =================
                updateDeliveryCounter();

                showToast("Product loaded successfully", "success");

            } catch (err) {
                console.error(err);
                showToast(err.message || "Load failed", "error");
            }
        }

        loadProductForEdit();

        // ================= FORM SUBMIT =================
        if (form) {
            form.addEventListener("submit", async function(e) {
                e.preventDefault();
                clearErrors();

                const formData = new FormData();
                let hasError = false;
                let firstErrorElement = null;

                const productId = getProductIdFromURL();
                const isEdit = !!productId;

                const setError = (el, msg) => {
                    if (!hasError) firstErrorElement = el;
                    highlightError(el, msg);
                    hasError = true;
                };

                const append = (key, value) => {
                    if (value !== undefined && value !== null && value !== "") {
                        formData.append(key, value);
                    }
                };

                const safeParse = (val, def = 0) => {
                    const num = parseFloat(val);
                    return isNaN(num) ? def : num;
                };

                const safeParseInt = (val, def = 0) => {
                    const num = parseInt(val);
                    return isNaN(num) ? def : num;
                };

                // ================= PRODUCT NAME (3-100 chars) =================
                const productName = productNameInput?.value.trim();
                if (!productName) {
                    setError(productNameInput, "Product name is required");
                } else if (productName.length < 3 || productName.length > 100) {
                    setError(productNameInput, "Product name must be between 3 and 100 characters");
                } else {
                    append("productName", productName);
                }

                // ================= SKU (3-60 chars) =================
                const sku = skuInput?.value.trim();
                if (!sku) {
                    setError(skuInput, "SKU is required");
                } else if (sku.length < 3 || sku.length > 60) {
                    setError(skuInput, "SKU must be between 3 and 60 characters");
                } else {
                    append("sku", sku);
                }

                // ================= BRAND (2-60 chars) =================
                const brand = brandInput?.value.trim();
                if (!brand) {
                    setError(brandInput, "Brand is required");
                } else if (brand.length < 2 || brand.length > 60) {
                    setError(brandInput, "Brand must be between 2 and 60 characters");
                } else {
                    append("brand", brand);
                }

                // ================= MODEL (1-60 chars) =================
                const model = modelInput?.value.trim();
                if (!model) {
                    setError(modelInput, "Model is required");
                } else if (model.length < 1 || model.length > 60) {
                    setError(modelInput, "Model must be between 1 and 60 characters");
                } else {
                    append("model", model);
                }

                // ================= CATEGORY =================
                if (!categorySelect.value) {
                    setError(categorySelect, "Category is required");
                }
                append("category", categorySelect.value);

                if (subcategorySelect.value) {
                    append("subcategory", subcategorySelect.value);
                }
                if (subSubcategorySelect.value) {
                    append("sub_subcategory", subSubcategorySelect.value);
                }

                // ================= SIZE =================
                const size = sizeSelect?.value?.trim();
                const validSizes = ["S", "M", "L", "XL", "NONE"];

                if (size) {
                    if (!validSizes.includes(size.toUpperCase())) {
                        setError(sizeSelect, "Valid size required (S, M, L, XL, NONE)");
                    } else {
                        append("size", size.toUpperCase());
                    }
                }

                // ================= PRICE =================
                const price = safeParse(priceInput?.value, NaN);
                if (isNaN(price) || price < 0) {
                    setError(priceInput, "Price must be a non-negative number");
                } else {
                    append("price", price);
                }

                // ================= COMPARE PRICE =================
                const comparePrice = safeParse(comparePriceInput?.value, NaN);
                if (!isNaN(comparePrice) && comparePrice >= 0) {
                    append("comparePrice", comparePrice);
                }

                // ================= COST PRICE =================
                const costPrice = safeParse(costPriceInput?.value, NaN);
                if (!isNaN(costPrice) && costPrice >= 0) {
                    append("costPrice", costPrice);
                }

                // ================= OFFER PERCENT (0-100) =================
                const offerPercent = safeParse(offerPercentInput?.value, NaN);
                if (!isNaN(offerPercent)) {
                    if (offerPercent < 0 || offerPercent > 100) {
                        setError(offerPercentInput, "Offer percent must be between 0 and 100");
                    } else {
                        append("offerPercent", offerPercent);
                    }
                }

                // ================= STOCK QUANTITY =================
                const stock = safeParseInt(stockQuantityInput?.value, NaN);
                if (isNaN(stock) || stock < 0) {
                    setError(stockQuantityInput, "Stock quantity must be a non-negative integer");
                } else {
                    append("stockQuantity", stock);
                }

                // ================= LOW STOCK THRESHOLD =================
                const lowStock = safeParseInt(lowStockThresholdInput?.value, NaN);
                if (!isNaN(lowStock) && lowStock >= 0) {
                    append("lowStockThreshold", lowStock);
                } else if (lowStockThresholdInput?.value && isNaN(lowStock)) {
                    setError(lowStockThresholdInput, "Low stock threshold must be a non-negative integer");
                }

                // ================= BARCODE (3-60 chars) =================
                const barcode = barcodeInput?.value.trim();
                if (barcode) {
                    if (barcode.length < 3 || barcode.length > 60) {
                        setError(barcodeInput, "Barcode must be between 3 and 60 characters");
                    } else {
                        append("barcode", barcode);
                    }
                }

                // ================= SHORT DESCRIPTION (3-300 chars) =================
                const shortDesc = shortDescriptionInput?.value.trim();
                if (!shortDesc) {
                    setError(shortDescriptionInput, "Short description is required");
                } else if (shortDesc.length < 3 || shortDesc.length > 300) {
                    setError(shortDescriptionInput,
                    "Short description must be between 3 and 300 characters");
                } else {
                    append("shortDescription", shortDesc);
                }

                // ================= FULL DESCRIPTION (3-2000 chars) =================
                const fullDesc = fullDescriptionInput?.value.trim();
                if (!fullDesc) {
                    setError(fullDescriptionInput, "Full description is required");
                } else if (fullDesc.length < 3 || fullDesc.length > 2000) {
                    setError(fullDescriptionInput,
                    "Full description must be between 3 and 2000 characters");
                } else {
                    append("fullDescription", fullDesc);
                }

                // ================= SHIPPING =================
                append("shippingClass", shippingClassSelect?.value || "Standard");
                append("freeShipping", freeShippingSelect?.value === "true");

                // ================= DIMENSIONS =================
                const length = safeParse(lengthInput?.value, NaN);
                if (!isNaN(length) && length >= 0) append("length", length);
                else if (lengthInput?.value && length < 0) setError(lengthInput,
                    "Length must be a non-negative number");

                const width = safeParse(widthInput?.value, NaN);
                if (!isNaN(width) && width >= 0) append("width", width);
                else if (widthInput?.value && width < 0) setError(widthInput,
                "Width must be a non-negative number");

                const height = safeParse(heightInput?.value, NaN);
                if (!isNaN(height) && height >= 0) append("height", height);
                else if (heightInput?.value && height < 0) setError(heightInput,
                    "Height must be a non-negative number");

                const weight = safeParse(weightInput?.value, NaN);
                if (!isNaN(weight) && weight >= 0) append("weight", weight);
                else if (weightInput?.value && weight < 0) setError(weightInput,
                    "Weight must be a non-negative number");

                const shippingCost = safeParse(shippingCostInput?.value, NaN);
                if (!isNaN(shippingCost) && shippingCost >= 0) append("shippingCost", shippingCost);
                else if (shippingCostInput?.value && shippingCost < 0) setError(shippingCostInput,
                    "Shipping cost must be a non-negative number");

                // ================= DELIVERY DAYS (0-365, minDay <= maxDay) =================
                const minDay = safeParseInt(minDayInput?.value, NaN);
                const maxDay = safeParseInt(maxDayInput?.value, NaN);

                if (!isNaN(minDay)) {
                    if (minDay < 0 || minDay > 365) {
                        setError(minDayInput, "Minimum days must be between 0 and 365");
                    } else {
                        append("minDay", minDay);
                    }
                }

                if (!isNaN(maxDay)) {
                    if (maxDay < 0 || maxDay > 365) {
                        setError(maxDayInput, "Maximum days must be between 0 and 365");
                    } else {
                        append("maxDay", maxDay);
                    }
                }

                if (!isNaN(minDay) && !isNaN(maxDay) && minDay > maxDay) {
                    setError(minDayInput, "Minimum days cannot be greater than maximum days");
                    setError(maxDayInput, "Maximum days cannot be less than minimum days");
                }

                // ================= STATUS =================
                const status = statusSelect?.value;
                if (status && !["draft", "active", "archived"].includes(status)) {
                    setError(statusSelect, "Invalid status value");
                } else {
                    append("status", status || "draft");
                }

                // ================= VISIBILITY =================
                const visibility = visibilitySelect?.value;
                if (visibility && !["visible", "hidden"].includes(visibility)) {
                    setError(visibilitySelect, "Invalid visibility value");
                } else {
                    append("visibility", visibility || "visible");
                }

                // ================= TAGS (max 200 chars) =================
                const tags = tagsInput?.value.trim();
                if (tags && tags.length > 200) {
                    setError(tagsInput, "Tags cannot exceed 200 characters");
                } else {
                    append("tags", tags || "");
                }

                // ================= INTERNAL NOTES (max 500 chars) =================
                const internalNotes = internalNotesInput?.value.trim();
                if (internalNotes && internalNotes.length > 500) {
                    setError(internalNotesInput, "Internal notes cannot exceed 500 characters");
                } else {
                    append("internalNotes", internalNotes || "");
                }

                // ================= SPEC TITLES (3-100 chars) =================
                const specTitle = specTitleInput?.value.trim();
                if (specTitle) {
                    if (specTitle.length < 3 || specTitle.length > 100) {
                        setError(specTitleInput,
                        "Specification title must be between 3 and 100 characters");
                    } else {
                        append("specTitle", specTitle);
                    }
                }

                const designTitle = designTitleInput?.value.trim();
                if (designTitle) {
                    if (designTitle.length < 3 || designTitle.length > 100) {
                        setError(designTitleInput, "Design title must be between 3 and 100 characters");
                    } else {
                        append("designTitle", designTitle);
                    }
                }

                const performanceTitle = performanceTitleInput?.value.trim();
                if (performanceTitle) {
                    if (performanceTitle.length < 3 || performanceTitle.length > 100) {
                        setError(performanceTitleInput,
                            "Performance title must be between 3 and 100 characters");
                    } else {
                        append("performanceTitle", performanceTitle);
                    }
                }

                const additionalTitle = additionalTitleInput?.value.trim();
                if (additionalTitle) {
                    if (additionalTitle.length < 3 || additionalTitle.length > 100) {
                        setError(additionalTitleInput,
                        "Additional title must be between 3 and 100 characters");
                    } else {
                        append("additionalTitle", additionalTitle);
                    }
                }

                // ================= SPECIFICATIONS =================
                append("keySpecs", JSON.stringify(collectSpecifications("keySpecsContainer",
                    "keySpecs_keys[]", "keySpecs_values[]")));
                append("detailedSpecs", JSON.stringify(collectSpecifications("detailedSpecsContainer",
                    "detailedSpecs_keys[]", "detailedSpecs_values[]")));
                append("designSpecs", JSON.stringify(collectSpecifications("designSpecsContainer",
                    "designSpecs_keys[]", "designSpecs_values[]")));
                append("perfSpecs", JSON.stringify(collectSpecifications("perfSpecsContainer",
                    "perfSpecs_keys[]", "perfSpecs_values[]")));
                append("additionalSpecs", JSON.stringify(collectSpecifications("additionalSpecsContainer",
                    "additionalSpecs_keys[]", "additionalSpecs_values[]")));
                append("videoLinks", JSON.stringify(collectVideoLinks()));

                // ================= MAIN IMAGE =================
                const mainFile = mainImageInput?.files?.[0];
                const hasPreviewImage = !!mainPreview?.querySelector('img');

                if (!mainFile && !hasPreviewImage) {
                    showToast("Main image is required", "error");
                    hasError = true;
                }

                if (mainFile) {
                    // Validate main image type
                    if (!mainFile.type.startsWith("image/")) {
                        showToast("Main image must be an image file", "error");
                        hasError = true;
                    }
                    // Validate main image size (5MB)
                    if (mainFile.size > 5 * 1024 * 1024) {
                        showToast("Main image size must be less than 5MB", "error");
                        hasError = true;
                    }
                    if (!hasError) {
                        formData.append("mainImage", mainFile);
                    }
                }

                // ================= ADDITIONAL IMAGES =================
                if (isEdit) {
                    if (existingImages.length > 0) formData.append("existingImages", JSON.stringify(
                    existingImages));
                    if (removedImages.length > 0) formData.append("removedImages", JSON.stringify(removedImages.map(
                        img => img.filename)));
                }
                selectedImages.forEach(file => {
                    if (file.size > 5 * 1024 * 1024) {
                        showToast(`${file.name} exceeds 5MB limit`, "error");
                        hasError = true;
                    }
                    if (!file.type.startsWith("image/")) {
                        showToast(`${file.name} is not a valid image`, "error");
                        hasError = true;
                    }
                });
                if (!hasError) {
                    selectedImages.forEach(file => formData.append("additionalImages", file));
                }

                // ================= VIDEOS =================
                if (isEdit) {
                    if (existingVideos.length > 0) formData.append("existingVideos", JSON.stringify(
                    existingVideos));
                    if (removedVideos.length > 0) formData.append("removedVideos", JSON.stringify(
                    removedVideos));
                }
                selectedVideos.forEach(file => {
                    if (file.size > 200 * 1024 * 1024) {
                        showToast(`${file.name} exceeds 200MB limit`, "error");
                        hasError = true;
                    }
                    if (!file.type.startsWith("video/")) {
                        showToast(`${file.name} is not a valid video`, "error");
                        hasError = true;
                    }
                });
                if (!hasError) {
                    selectedVideos.forEach(file => formData.append("productVideos", file));
                }

                // ================= STOP IF ERRORS =================
                if (hasError) {
                    if (firstErrorElement) firstErrorElement.focus();
                    return;
                }

                // ================= SUBMIT =================
                const originalText = submitBtn?.innerHTML;
                try {
                    if (submitBtn) {
                        submitBtn.innerHTML = "Saving...";
                        submitBtn.disabled = true;
                    }

                    const url = isEdit ? `${PRODUCT_EDIT}/${productId}` : PRODUCT_API;
                    const method = isEdit ? "PUT" : "POST";

                    const response = await fetch(url, { method: method, body: formData });
                    const data = await response.json();

                    if (!response.ok) {
                        if (data.errors) data.errors.forEach(err => showToast(err, "error"));
                        else showToast(data.message || "Something went wrong", "error");
                        return;
                    }

                    showToast(isEdit ? "Product updated successfully!" : "Product created successfully!",
                        "success");

                    if (!isEdit) {
                        setTimeout(() => {
                            form.reset();
                            selectedImages = [];
                            selectedVideos = [];
                            if (mainPreview) mainPreview.innerHTML = "";
                            if (additionalPreview) additionalPreview.innerHTML = "";
                            if (videosPreview) videosPreview.innerHTML = "";
                            if (mainFileNameSpan) mainFileNameSpan.textContent =
                                "No file chosen";
                            if (additionalFileNameSpan) additionalFileNameSpan.textContent =
                                "No images selected";
                            if (videosFileNameSpan) videosFileNameSpan.textContent =
                                "No files chosen";
                            if (deliveryCounter) deliveryCounter.style.display = "none";
                        }, 1000);
                    }
                } catch (error) {
                    console.error(error);
                    showToast("Server error", "error");
                } finally {
                    if (submitBtn) {
                        submitBtn.innerHTML = originalText;
                        submitBtn.disabled = false;
                    }
                }
            });
        }

        // Focus first input on load
        setTimeout(() => {
            if (productNameInput) productNameInput.focus();
        }, 100);
    </script>
</body>

</html>