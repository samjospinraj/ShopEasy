    <!-- AOS Animation Library -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js">
    </script>
    <script>
        AOS.init({ duration: 800, once: true, offset: 80 });

        (function() {
            const BASE_URL = "http://localhost:3000";
            const PRODUCT_API = `${BASE_URL}/allproduct`;
            const REVIEWS_API = `${BASE_URL}/reviews`;
            const RATING_COUNT_API = `${BASE_URL}/reviews/ratings/count`;

            // State
            let allProducts = [];
            let categoriesData = [];
            let subcategoriesMap = {};
            let subSubcategoriesMap = {};
            let cartItemIds = new Set();
            let wishlistItemIds = new Set();
            let isSearchActive = false;
            let isLoggedIn = false;
            let allReviews = [];
            let ratingCounts = {};
            let productRatingsMap = {};

            // DOM refs
            const featuredGrid = document.getElementById("featuredGrid");
            const moreGrid = document.getElementById("moreGrid");
            const saleGrid = document.getElementById("saleGrid");
            const categoryChips = document.getElementById("categoryChips");
            const megaPanel = document.getElementById("megaPanel");
            const panelGrid = document.getElementById("panelGrid");
            const panelCloseBtn = document.getElementById("panelCloseBtn");
            const cartCountSpan = document.getElementById("cartCount");
            const searchInput = document.getElementById("searchInput");
            const searchBtn = document.getElementById("searchBtn");
            const searchResultsCount = document.getElementById("searchResultsCount");
            const sidebarCategoryList = document.getElementById("sidebarCategoryList");
            const mobileMenuToggle = document.getElementById("mobileMenuToggle");
            const sidebarOverlay = document.getElementById("sidebarOverlay");
            const categorySidebar = document.getElementById("categorySidebar");
            const closeSidebarBtn = document.getElementById("closeSidebar");
            const userIconBtn = document.getElementById("userIconBtn");
            const userDropdownMenu = document.getElementById("userDropdownMenu");
            const menuLogout = document.getElementById("menuLogout");
            const scrollLeftBtn = document.getElementById("scrollLeft");
            const scrollRightBtn = document.getElementById("scrollRight");
            const scrollToEndBtn = document.getElementById("scrollToEnd");
            const scrollIndicator = document.getElementById("scrollIndicator");

            // Review DOM refs
            const ratingSummaryCard = document.getElementById("ratingSummaryCard");
            const avgRatingBig = document.getElementById("avgRatingBig");
            const avgStarsBig = document.getElementById("avgStarsBig");
            const totalReviewsText = document.getElementById("totalReviewsText");
            const ratingBarsContainer = document.getElementById("ratingBarsContainer");
            const reviewCardsGrid = document.getElementById("reviewCardsGrid");

            // Modal elements
            const notificationModal = document.getElementById("notificationModal");
            const modalIconCircle = document.getElementById("modalIconCircle");
            const modalTitle = document.getElementById("modalTitle");
            const modalMessage = document.getElementById("modalMessage");
            const modalPrimaryBtn = document.getElementById("modalPrimaryBtn");
            const modalSecondaryBtn = document.getElementById("modalSecondaryBtn");
            let bsModalInstance = null;
            let modalAutoHideTimer = null;

            if (notificationModal) {
                bsModalInstance = new bootstrap.Modal(notificationModal, {
                    backdrop: 'static',
                    keyboard: true
                });
            }

            let hidePanelTimeout;

            // ========== Modal System ==========
            function showModal(type = 'success', title = 'Success!', message = '', options = {}) {
                if (!bsModalInstance) return;
                if (modalAutoHideTimer) {
                    clearTimeout(modalAutoHideTimer);
                    modalAutoHideTimer = null;
                }
                modalIconCircle.className = 'modal-icon-circle';
                modalIconCircle.innerHTML = '';
                switch (type) {
                    case 'success':
                        modalIconCircle.classList.add('success');
                        modalIconCircle.innerHTML = '<i class="fas fa-check-circle"></i>';
                        break;
                    case 'error':
                        modalIconCircle.classList.add('error');
                        modalIconCircle.innerHTML = '<i class="fas fa-times-circle"></i>';
                        break;
                    case 'warning':
                        modalIconCircle.classList.add('warning');
                        modalIconCircle.innerHTML = '<i class="fas fa-exclamation-triangle"></i>';
                        break;
                    case 'info':
                    default:
                        modalIconCircle.classList.add('info');
                        modalIconCircle.innerHTML = '<i class="fas fa-info-circle"></i>';
                        break;
                }
                modalTitle.textContent = title;
                modalMessage.textContent = message;
                modalPrimaryBtn.textContent = options.primaryText || 'OK';
                modalPrimaryBtn.style.display = 'inline-block';
                modalPrimaryBtn.onclick = function() {
                    if (options.onPrimary && typeof options.onPrimary === 'function') options.onPrimary();
                    bsModalInstance.hide();
                };
                if (options.secondaryText) {
                    modalSecondaryBtn.textContent = options.secondaryText;
                    modalSecondaryBtn.style.display = 'inline-block';
                    modalSecondaryBtn.onclick = function() {
                        if (options.onSecondary && typeof options.onSecondary === 'function') options.onSecondary();
                        bsModalInstance.hide();
                    };
                } else {
                    modalSecondaryBtn.style.display = 'none';
                }
                bsModalInstance.show();
                const autoHideDelay = options.autoHide || (type === 'success' ? 2500 : (type === 'info' ? 3000 : 0));
                if (autoHideDelay > 0) {
                    modalAutoHideTimer = setTimeout(() => {
                        if (bsModalInstance && notificationModal.classList.contains('show')) bsModalInstance
                            .hide();
                    }, autoHideDelay);
                }
            }

            function showToast(msg) {
                const toast = document.getElementById("toastMsg");
                document.getElementById("toastText").innerText = msg;
                toast.classList.add("show");
                setTimeout(() => toast.classList.remove("show"), 2500);
            }

            function escapeHtml(str) {
                if (!str) return "";
                return String(str).replace(/[&<>"']/g, m => ({
                    "&": "&amp;",
                    "<": "&lt;",
                    ">": "&gt;",
                    '"': "&quot;",
                    "'": "&#39;"
                })[m]);
            }

            function updateCartCountUI(count) {
                cartCountSpan.textContent = count || 0;
            }

            // ========== Generate Stars HTML ==========
            function generateStarsHTML(rating, emptyClass = 'empty-inline') {
                const fullStars = Math.floor(rating);
                const halfStar = rating % 1 >= 0.5;
                const emptyStars = 5 - fullStars - (halfStar ? 1 : 0);
                let html = '';
                for (let i = 0; i < fullStars; i++) html += '<i class="fas fa-star"></i>';
                if (halfStar) html += '<i class="fas fa-star-half-alt"></i>';
                for (let i = 0; i < emptyStars; i++) html += `<i class="far fa-star ${emptyClass}"></i>`;
                return html;
            }

            function generateReviewStarsHTML(rating) {
                return generateStarsHTML(rating, 'empty-review');
            }

            function generateBigStarsHTML(rating) {
                return generateStarsHTML(rating, 'empty-big');
            }

            // ========== User Dropdown ==========
            userIconBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                if (!isLoggedIn) {
                    window.location.href = "/login";
                    return;
                }
                userDropdownMenu.classList.toggle("show");
            });

            async function checkAuth() {
                try {
                    const response = await fetch("/api/check-auth", {
                        method: "GET",
                        credentials: "include"
                    });
                    if (!response.ok) throw new Error('Auth check failed');
                    const data = await response.json();
                    isLoggedIn = data.loggedIn;
                    updateLoginUI();
                    if (isLoggedIn) await fetchCartAndWishlist();
                } catch (error) {
                    console.error("Auth check failed:", error);
                    isLoggedIn = false;
                    updateLoginUI();
                }
            }

            function updateLoginUI() {
                if (menuLogout) menuLogout.style.display = isLoggedIn ? "flex" : "none";
                if (userIconBtn) userIconBtn.style.color = isLoggedIn ? "#4ecdc4" : "#666";
            }

            menuLogout.addEventListener("click", async (e) => {
                e.preventDefault();
                e.stopPropagation();
                try {
                    const response = await fetch("/logout", { method: "GET", credentials: "include" });
                    if (response.ok || response.redirected) {
                        isLoggedIn = false;
                        updateLoginUI();
                        userDropdownMenu.classList.remove("show");
                        cartItemIds.clear();
                        wishlistItemIds.clear();
                        updateCartCountUI(0);
                        renderProductSections();
                        showModal('info', 'Logged Out', 'You have been logged out successfully.', {
                            autoHide: 2000,
                            onPrimary: () => { window.location.href = "/"; }
                        });
                        setTimeout(() => { window.location.href = "/"; }, 2200);
                    }
                } catch (error) {
                    console.error("Logout failed:", error);
                    showModal('error', 'Error', 'Logout failed. Please try again.');
                }
            });

            document.addEventListener("click", (e) => {
                if (!e.target.closest("#userDropdown")) userDropdownMenu.classList.remove("show");
            });

            // ========== Mobile Sidebar ==========
            function openSidebar() {
                categorySidebar.classList.add("open");
                sidebarOverlay.classList.add("active");
                document.body.style.overflow = "hidden";
            }

            function closeSidebarFunc() {
                categorySidebar.classList.remove("open");
                sidebarOverlay.classList.remove("active");
                document.body.style.overflow = "";
            }
            mobileMenuToggle.addEventListener("click", openSidebar);
            closeSidebarBtn.addEventListener("click", closeSidebarFunc);
            sidebarOverlay.addEventListener("click", closeSidebarFunc);

            panelCloseBtn.addEventListener("click", () => {
                megaPanel.classList.remove("show");
                document.querySelectorAll(".category-chip").forEach(c => c.classList.remove("active"));
                if (categoryChips.firstChild) categoryChips.firstChild.classList.add("active");
            });

            // ========== API: Fetch Cart ==========
            async function fetchCart() {
                if (!isLoggedIn) { updateCartCountUI(0); return; }
                try {
                    const res = await fetch(`${BASE_URL}/carts`, { credentials: "include" });
                    if (res.ok) {
                        const data = await res.json();
                        if (data.success && data.data) {
                            cartItemIds.clear();
                            data.data.forEach(item => cartItemIds.add(item.productId.toString()));
                            updateCartCountUI(data.count || data.data.length);
                        }
                    } else if (res.status === 401) {
                        isLoggedIn = false;
                        updateLoginUI();
                        updateCartCountUI(0);
                    } else { updateCartCountUI(0); }
                } catch (err) { console.error("Cart fetch error:", err);
                    updateCartCountUI(0); }
            }

            async function fetchWishlist() {
                if (!isLoggedIn) return;
                try {
                    const res = await fetch(`${BASE_URL}/wishlists`, { credentials: "include" });
                    if (res.ok) {
                        const data = await res.json();
                        if (data.success && data.data) {
                            wishlistItemIds.clear();
                            data.data.forEach(item => wishlistItemIds.add(item.productId.toString()));
                        }
                    }
                } catch (err) { console.error("Wishlist fetch error:", err); }
            }

            async function fetchCartAndWishlist() {
                await Promise.all([fetchCart(), fetchWishlist()]);
                renderProductSections();
            }

            async function addToCart(productId, productName, buttonElement) {
                if (!isLoggedIn) {
                    showModal('warning', 'Login Required', 'Please login first to add items to your cart.', {
                        autoHide: 2500,
                        primaryText: 'Login Now',
                        onPrimary: () => { window.location.href = "/login"; },
                        secondaryText: 'Later'
                    });
                    return;
                }
                if (cartItemIds.has(productId.toString())) { window.location.href = "/cart"; return; }
                try {
                    buttonElement.disabled = true;
                    const originalHTML = buttonElement.innerHTML;
                    buttonElement.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding...';
                    const res = await fetch(`${BASE_URL}/cart`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify({ productId, quantity: 1 })
                    });
                    const data = await res.json();
                    if (data.success) {
                        cartItemIds.add(productId.toString());
                        showModal('success', 'Added to Cart!',
                            `${productName || "Item"} has been added to your cart.`, {
                                autoHide: 2200,
                                primaryText: 'Continue Shopping',
                                secondaryText: 'View Cart',
                                onSecondary: () => { window.location.href = "/cart"; }
                            });
                        await fetchCart();
                        renderProductSections();
                    } else if (res.status === 401) {
                        showModal('warning', 'Login Required', 'Please login to add items to your cart.', {
                            autoHide: 2500,
                            primaryText: 'Login Now',
                            onPrimary: () => { window.location.href = "/login"; }
                        });
                    } else {
                        showModal('error', 'Oops!', data.message || "Failed to add to cart");
                        buttonElement.disabled = false;
                        buttonElement.innerHTML = originalHTML;
                    }
                } catch (err) {
                    console.error("Add to cart error:", err);
                    showModal('warning', 'Login Required', 'Please login first to add items.');
                    buttonElement.disabled = false;
                    buttonElement.innerHTML = '<i class="fas fa-cart-plus me-1"></i> Add to Cart';
                }
            }

            async function toggleWishlist(productId, buttonElement) {
                if (!isLoggedIn) {
                    showModal('warning', 'Login Required', 'Please login first to manage your wishlist.', {
                        autoHide: 2500,
                        primaryText: 'Login Now',
                        onPrimary: () => { window.location.href = "/login"; },
                        secondaryText: 'Later'
                    });
                    return;
                }
                const isActive = buttonElement.classList.contains("active");
                try {
                    buttonElement.disabled = true;
                    const res = await fetch(`${BASE_URL}/wishlist`, {
                        method: isActive ? "DELETE" : "POST",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify({ productId })
                    });
                    const data = await res.json();
                    if (data.success) {
                        if (isActive) {
                            wishlistItemIds.delete(productId.toString());
                            buttonElement.classList.remove("active");
                            buttonElement.querySelector("i").className = "far fa-heart";
                            showModal('info', 'Removed', 'Item removed from your wishlist.', { autoHide: 2000 });
                        } else {
                            wishlistItemIds.add(productId.toString());
                            buttonElement.classList.add("active");
                            buttonElement.querySelector("i").className = "fas fa-heart";
                            showModal('success', 'Wishlisted!', 'Item added to your wishlist! ❤️', { autoHide: 2000 });
                        }
                    } else if (res.status === 401) {
                        showModal('warning', 'Login Required', 'Please login to manage your wishlist.', {
                            autoHide: 2500,
                            primaryText: 'Login Now',
                            onPrimary: () => { window.location.href = "/login"; }
                        });
                    } else {
                        showModal('error', 'Error', data.message || "Action failed");
                    }
                } catch (err) {
                    console.error("Wishlist error:", err);
                    showModal('warning', 'Login Required', 'Please login first.');
                } finally { buttonElement.disabled = false; }
            }

            // ========== Category Scroll ==========
            function setupCategoryScroll() {
                if (!categoryChips) return;
                const scrollAmount = 300;

                function updateScrollButtons() {
                    const canScrollLeft = categoryChips.scrollLeft > 5;
                    const canScrollRight = categoryChips.scrollLeft < categoryChips.scrollWidth - categoryChips
                        .clientWidth - 5;
                    const hasOverflow = categoryChips.scrollWidth > categoryChips.clientWidth;
                    scrollLeftBtn.classList.toggle("visible", hasOverflow && canScrollLeft);
                    scrollRightBtn.classList.toggle("visible", hasOverflow && canScrollRight);
                    scrollToEndBtn.style.display = hasOverflow && canScrollRight ? "flex" : "none";
                    updateScrollIndicator();
                }

                function updateScrollIndicator() {
                    if (!scrollIndicator) return;
                    const totalWidth = categoryChips.scrollWidth;
                    const visibleWidth = categoryChips.clientWidth;
                    if (totalWidth <= visibleWidth) { scrollIndicator.innerHTML = ""; return; }
                    const numDots = Math.min(Math.ceil(totalWidth / visibleWidth), 8);
                    const currentDot = Math.floor(categoryChips.scrollLeft / (totalWidth / numDots));
                    scrollIndicator.innerHTML = Array.from({ length: numDots }, (_, i) =>
                        `<div class="scroll-dot ${i === currentDot ? "active" : ""}" data-index="${i}"></div>`
                    ).join("");
                    scrollIndicator.querySelectorAll(".scroll-dot").forEach(dot => {
                        dot.addEventListener("click", () => {
                            categoryChips.scrollTo({ left: (totalWidth / numDots) * parseInt(dot
                                    .dataset.index),
                                behavior: "smooth" });
                        });
                    });
                }
                scrollLeftBtn.addEventListener("click", () => categoryChips.scrollBy({ left: -scrollAmount,
                    behavior: "smooth" }));
                scrollRightBtn.addEventListener("click", () => categoryChips.scrollBy({ left: scrollAmount,
                    behavior: "smooth" }));
                scrollToEndBtn.addEventListener("click", () => categoryChips.scrollTo({ left: categoryChips.scrollWidth,
                    behavior: "smooth" }));
                categoryChips.addEventListener("scroll", updateScrollButtons);
                updateScrollButtons();
                window.addEventListener("resize", updateScrollButtons);
                setTimeout(updateScrollButtons, 500);
            }

            function getGradientClass(index) {
                return ["gradient-1", "gradient-2", "gradient-3", "gradient-4", "gradient-5"][index % 5];
            }

            function getAvatarClass(index) {
                return ["av-1", "av-2", "av-3", "av-4", "av-5"][index % 5];
            }

