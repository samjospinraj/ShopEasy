<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>ShopMaster · Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --bg-deep: #060b1f;
            --bg-card: rgba(10, 16, 36, 0.65);
            --primary: #4dabf7;
            --primary-glow: #339af0;
            --accent-cyan: #38bdf8;
            --accent-green: #34d399;
            --accent-red: #f87171;
            --text-primary: #e8ecf4;
            --text-secondary: #b0bdd0;
            --text-muted: #7b8ca6;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(77, 171, 247, 0.3);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.45), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-glow: 0 0 40px rgba(77, 171, 247, 0.18);
            --radius-xl: 22px;
            --radius-md: 12px;
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        body {
            background: radial-gradient(ellipse at 20% 20%, #0b1430 0%, #060b1f 45%, #04091a 70%, #020617 100%);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            overflow: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
        }

        #nuranCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        .login-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 423px;
            background: var(--bg-card);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius-xl);
            padding: 40px 32px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-subtle);
            transition: var(--transition);
            animation: fadeInUp 0.6s ease;
        }
        .login-container:hover {
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }

        .logo-area {
            text-align: center;
            margin-bottom: 32px;
        }
        .logo-text {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .logo-sub {
            font-size: 0.75rem;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-top: 4px;
        }

        .form-group {
            margin-bottom: 22px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.04) !important;
            border: 1px solid var(--border-subtle) !important;
            border-radius: 40px !important;
            color: var(--text-primary) !important;
            font-size: 0.95rem !important;
            transition: var(--transition) !important;
        }
        .form-control:focus {
            border-color: var(--border-glow) !important;
            box-shadow: 0 0 14px rgba(77, 171, 247, 0.15) !important;
            background: rgba(255, 255, 255, 0.06) !important;
            outline: none !important;
        }
        .form-control::placeholder {
            color: var(--text-muted);
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 40px;
            font-size: 1rem;
            font-weight: 600;
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: #fff;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 10px;
            box-shadow: 0 4px 16px rgba(77, 171, 247, 0.3);
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(77, 171, 247, 0.45);
            filter: brightness(1.05);
        }

        .error-message {
            background: rgba(248, 113, 113, 0.1);
            border: 1px solid rgba(248, 113, 113, 0.3);
            padding: 10px 16px;
            border-radius: 30px;
            color: var(--accent-red);
            font-size: 0.85rem;
            margin-top: 16px;
            display: none;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 480px) {
            .login-container {
                padding: 30px 20px;
            }
            .logo-text {
                font-size: 1.6rem;
            }
        }
    </style>
</head>
<body>
    <canvas id="nuranCanvas"></canvas>

    <div class="login-container">
        <div class="logo-area">
            <div class="logo-text">ShopMaster</div>
            <div class="logo-sub">admin · 2026</div>
        </div>

        <form id="loginForm" method="POST" action="/admin/login">
            <div class="form-group">
                <label for="username"><i class="fas fa-user" style="margin-right:6px; color:var(--accent-cyan);"></i>Username</label>
                <input type="text" id="username" name="username" class="form-control" 
                       placeholder="Enter your username" minlength="6" maxlength="20" required>
            </div>
            
            <div class="form-group">
                <label for="password"><i class="fas fa-lock" style="margin-right:6px; color:var(--accent-cyan);"></i>Password</label>
                <input type="password" id="password" name="password" class="form-control" 
                       placeholder="Enter your password" minlength="6" maxlength="30" required>
            </div>
            
            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt"></i> Login
            </button>

            <div id="errorMessage" class="error-message">
                <i class="fas fa-exclamation-circle"></i> <span id="errorText"></span>
            </div>
        </form>

        <div style="text-align:center; margin-top:24px; color:var(--text-muted); font-size:0.85rem;">
            Don't have an account? 
            <a href="/admin/register" style="color:var(--accent-cyan); text-decoration:none; font-weight:500;">
                Sign up
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // ═══════════ NURAN PARTICLE BACKGROUND ═══════════
            const canvas = document.getElementById('nuranCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouseX = -999, mouseY = -999, targetMouseX = -999, targetMouseY = -999;
            const SPLATTER_RADIUS = 190, CONNECTION_DIST = 140;
            const PARTICLE_COUNT = window.innerWidth < 768 ? 80 : 140;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', () => {
                resize();
                const nc = window.innerWidth < 768 ? 80 : 140;
                while (particles.length < nc) particles.push(createParticle());
                while (particles.length > nc) particles.pop();
            });

            function createParticle() {
                const cols = [
                    'rgba(77,171,247,', 'rgba(56,189,248,', 'rgba(167,139,250,', 'rgba(139,92,246,',
                    'rgba(45,212,191,', 'rgba(96,165,250,', 'rgba(192,132,252,', 'rgba(52,211,153,'
                ];
                const c = cols[Math.floor(Math.random() * cols.length)];
                return {
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.7,
                    vy: (Math.random() - 0.5) * 0.7,
                    size: 1.8 + Math.random() * 3.5,
                    color: c,
                    glowAlpha: 0.5 + Math.random() * 0.5,
                    pulsePhase: Math.random() * Math.PI * 2,
                    pulseSpeed: 0.008 + Math.random() * 0.025,
                    baseSize: 1.8 + Math.random() * 3.5
                };
            }
            for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(createParticle());

            document.addEventListener('mousemove', e => {
                targetMouseX = e.clientX;
                targetMouseY = e.clientY;
            });
            document.addEventListener('mouseleave', () => {
                targetMouseX = -999;
                targetMouseY = -999;
            });
            document.addEventListener('touchmove', e => {
                if (e.touches.length > 0) {
                    targetMouseX = e.touches[0].clientX;
                    targetMouseY = e.touches[0].clientY;
                }
            }, { passive: true });
            document.addEventListener('touchend', () => {
                targetMouseX = -999;
                targetMouseY = -999;
            });

            function animate(ts) {
                mouseX += (targetMouseX - mouseX) * 0.18;
                mouseY += (targetMouseY - mouseY) * 0.18;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                const time = ts * 0.001;
                for (let p of particles) {
                    p.vx += Math.sin(time * 0.7 + p.pulsePhase) * 0.025;
                    p.vy += Math.cos(time * 0.6 + p.pulsePhase + 1.3) * 0.025;
                    if (mouseX > -500 && mouseY > -500) {
                        const dx = p.x - mouseX, dy = p.y - mouseY, dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < SPLATTER_RADIUS && dist > 0.5) {
                            const force = (1 - dist / SPLATTER_RADIUS) * 4.5;
                            p.vx += (dx / dist) * force;
                            p.vy += (dy / dist) * force;
                            p.glowAlpha = Math.min(1, p.glowAlpha + 0.06);
                        }
                    }
                    p.x += p.vx;
                    p.y += p.vy;
                    p.vx *= 0.94;
                    p.vy *= 0.94;
                    const sp = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
                    if (sp > 6) {
                        p.vx = (p.vx / sp) * 6;
                        p.vy = (p.vy / sp) * 6;
                    }
                    if (p.x < -30) p.x = canvas.width + 30;
                    if (p.x > canvas.width + 30) p.x = -30;
                    if (p.y < -30) p.y = canvas.height + 30;
                    if (p.y > canvas.height + 30) p.y = -30;
                    p.size = p.baseSize + Math.sin(time * p.pulseSpeed * 10 + p.pulsePhase) * 0.7;
                    p.glowAlpha += (0.6 - p.glowAlpha) * 0.03;
                }

                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x;
                        const dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < CONNECTION_DIST) {
                            const alpha = (1 - dist / CONNECTION_DIST) * 0.28;
                            const pulse = Math.sin(ts * 0.003 + i * 0.4 + j * 0.3) * 0.5 + 0.5;
                            ctx.beginPath();
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.strokeStyle = `rgba(120,170,230,${alpha * (0.5 + pulse * 0.5)})`;
                            ctx.lineWidth = 0.6;
                            ctx.stroke();
                        }
                    }
                }

                for (let p of particles) {
                    const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * 3.5);
                    grad.addColorStop(0, p.color + (p.glowAlpha * 0.7) + ')');
                    grad.addColorStop(0.35, p.color + (p.glowAlpha * 0.25) + ')');
                    grad.addColorStop(1, p.color + '0)');
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * 3.5, 0, Math.PI * 2);
                    ctx.fillStyle = grad;
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * 0.65, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255,255,255,${0.7 + p.glowAlpha * 0.3})`;
                    ctx.fill();
                }

                if (mouseX > -500 && mouseY > -500) {
                    const mg = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, SPLATTER_RADIUS * 0.7);
                    mg.addColorStop(0, 'rgba(120,180,240,0.08)');
                    mg.addColorStop(0.5, 'rgba(100,150,220,0.03)');
                    mg.addColorStop(1, 'rgba(0,0,0,0)');
                    ctx.beginPath();
                    ctx.arc(mouseX, mouseY, SPLATTER_RADIUS * 0.7, 0, Math.PI * 2);
                    ctx.fillStyle = mg;
                    ctx.fill();
                }

                requestAnimationFrame(animate);
            }
            requestAnimationFrame(animate);

            // ═══════════ SIMPLE ERROR DISPLAY (client‑side only) ═══════════
            const errorDiv = document.getElementById('errorMessage');
            const errorText = document.getElementById('errorText');

            // Example: show error if form has invalid submission (optional)
            // We can also handle a server error message if returned via query param
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('error')) {
                errorText.textContent = urlParams.get('error') || 'Invalid credentials';
                errorDiv.style.display = 'block';
            }
        })();
    </script>
</body>
</html>