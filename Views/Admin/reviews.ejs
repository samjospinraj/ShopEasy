<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
    <title>ShopMaster · Reviews | Admin 2026</title>
    <!-- Bootstrap 5.3.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --bg-deep: #060b1f;
            --bg-card: rgba(10, 16, 36, 0.65);
            --bg-sidebar: rgba(7, 11, 28, 0.82);
            --bg-header: rgba(9, 14, 32, 0.7);
            --glass-blur: 20px;
            --primary: #4dabf7;
            --primary-glow: #339af0;
            --accent-cyan: #38bdf8;
            --accent-green: #34d399;
            --accent-red: #f87171;
            --accent-orange: #fb923c;
            --accent-purple: #a78bfa;
            --text-primary: #e8ecf4;
            --text-secondary: #b0bdd0;
            --text-muted: #7b8ca6;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(77, 171, 247, 0.3);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.45), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-glow: 0 0 40px rgba(77, 171, 247, 0.18);
            --radius-xl: 22px;
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-full: 50px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        body {
            background: radial-gradient(ellipse at 20% 20%, #0b1430 0%, #060b1f 45%, #04091a 70%, #020617 100%);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        #nuranCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        .loading-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(6, 11, 31, 0.8);
            z-index: 9999; display: flex; align-items: center; justify-content: center;
            backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        }
        .spinner-ring {
            width: 52px; height: 52px; border-radius: 50%;
            border: 3px solid rgba(255,255,255,0.08);
            border-top-color: var(--accent-cyan);
            border-right-color: var(--accent-purple);
            animation: spin 0.8s linear infinite;
            box-shadow: 0 0 30px rgba(56,189,248,0.4);
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── SIDEBAR ── */
        .sidebar {
            width: 280px;
            background: var(--bg-sidebar);
            backdrop-filter: blur(26px); -webkit-backdrop-filter: blur(26px);
            color: var(--text-primary);
            padding: 20px 0;
            position: fixed; height: 100vh; z-index: 1000;
            border-right: 1px solid var(--border-subtle);
            box-shadow: 4px 0 30px rgba(0,0,0,0.5);
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
            overflow-y: auto; display: flex; flex-direction: column;
        }
        .sidebar-header {
            padding: 0 20px 18px 20px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex; justify-content: space-between; align-items: center;
        }
        .logo-text {
            font-size: 1.6rem; font-weight: 700;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .logo-subtext {
            font-size: 0.68rem; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.4px;
        }
        .toggle-sidebar {
            background: rgba(255,255,255,0.04); border: 1px solid var(--border-subtle);
            color: var(--text-secondary); width: 36px; height: 36px; border-radius: 10px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: 0.2s; font-size: 1rem;
        }
        .toggle-sidebar:hover {
            background: rgba(77,171,247,0.15); border-color: var(--border-glow);
            color: var(--accent-cyan); box-shadow: 0 0 16px rgba(56,189,248,0.25);
        }
        .sidebar-menu { flex: 1; padding: 20px 0; }
        .menu-item {
            display: flex; align-items: center; padding: 13px 20px; margin: 3px 10px;
            color: var(--text-secondary); text-decoration: none; transition: 0.2s;
            border-radius: 10px; cursor: pointer; font-weight: 450;
            border: 1px solid transparent;
        }
        .menu-item:hover {
            background: rgba(77,171,247,0.08); color: var(--text-primary);
            border-color: rgba(77,171,247,0.2);
        }
        .menu-item.active-menu {
            background: rgba(77,171,247,0.13); color: #fff;
            border-color: rgba(77,171,247,0.35);
            box-shadow: 0 0 18px rgba(56,189,248,0.15); position: relative;
        }
        .menu-item.active-menu::before {
            content: ''; position: absolute; left: -2px; top: 50%; transform: translateY(-50%);
            width: 4px; height: 22px; border-radius: 0 4px 4px 0;
            background: var(--accent-cyan); box-shadow: 0 0 14px var(--accent-cyan);
        }
        .menu-item i { width: 24px; font-size: 1.15rem; margin-right: 14px; text-align: center; }
        .menu-text { font-size: 0.95rem; }

        /* ── MAIN CONTENT ── */
        .main-content {
            flex: 1; margin-left: 280px; padding: 22px 30px;
            transition: margin-left 0.35s ease; position: relative; z-index: 1;
        }

        /* ── HEADER ── */
        .header {
            display: flex; justify-content: space-between; align-items: center;
            background: var(--bg-header); backdrop-filter: blur(22px);
            -webkit-backdrop-filter: blur(22px); padding: 14px 26px;
            border-radius: 50px; box-shadow: var(--shadow-card);
            margin-bottom: 28px; border: 1px solid var(--border-subtle);
            flex-wrap: wrap; gap: 14px;
        }
        .menu-toggle {
            display: none; background: rgba(255,255,255,0.04);
            border: 1px solid var(--border-subtle); color: var(--text-secondary);
            width: 44px; height: 44px; border-radius: 14px; cursor: pointer;
            font-size: 1.2rem; align-items: center; justify-content: center; transition: 0.2s;
        }
        .menu-toggle:hover {
            border-color: var(--border-glow); box-shadow: 0 0 18px rgba(56,189,248,0.2);
            color: var(--accent-cyan);
        }
        .search-bar {
            display: flex; align-items: center; background: rgba(255,255,255,0.03);
            border-radius: 50px; padding: 8px 20px; width: min(400px, 100%);
            border: 1px solid var(--border-subtle);
        }
        .search-bar input {
            border: none; background: transparent; padding: 8px 10px;
            width: 100%; outline: none; font-size: 0.95rem; color: var(--text-primary);
        }
        .search-bar input::placeholder { color: var(--text-muted); }
        .search-bar i { color: var(--text-muted); }
        .header-actions { display: flex; align-items: center; gap: 10px; }
        .notification-btn {
            position: relative; background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-subtle); font-size: 1.15rem;
            color: var(--text-secondary); cursor: pointer; padding: 10px 12px;
            border-radius: 50%; transition: 0.2s; display: flex; align-items: center; justify-content: center;
            width: 40px; height: 40px;
        }
        .notification-btn:hover {
            background: rgba(77,171,247,0.12); border-color: var(--border-glow);
            color: var(--accent-cyan); box-shadow: 0 0 16px rgba(56,189,248,0.2);
        }
        .notification-badge {
            position: absolute; top: 2px; right: 3px;
            background: var(--accent-red); color: #fff; font-size: 0.6rem;
            width: 18px; height: 18px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center; font-weight: 700;
        }
        .user-info {
            display: flex; align-items: center; gap: 12px;
            padding: 5px 18px 5px 8px; background: rgba(255,255,255,0.03);
            border-radius: 50px; border: 1px solid var(--border-subtle); cursor: pointer;
        }
        .user-info img {
            width: 40px; height: 40px; border-radius: 50%;
            border: 2px solid rgba(77,171,247,0.5); object-fit: cover;
        }
        .user-details h4 { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); margin: 0; }
        .user-details p { font-size: 0.7rem; color: var(--text-muted); margin: 0; }

        /* ── FILTER & CARDS ── */
        .filter-row {
            display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 24px;
        }
        .form-select {
            background: rgba(255,255,255,0.04) !important;
            border: 1px solid var(--border-subtle) !important;
            border-radius: 40px !important; padding: 10px 16px !important;
            font-size: 0.9rem !important; color: #ffffff !important;
            transition: 0.2s; box-shadow: none !important;
        }
        .form-select option {
            background: #0f1829; color: #e0e7f0;
        }
        .form-select option:checked {
            background: linear-gradient(135deg, #4dabf7, #339af0); color: white;
        }

        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
            border-radius: var(--radius-xl); padding: 22px;
            border: 1px solid var(--border-subtle); transition: 0.35s;
            margin-bottom: 24px;
        }
        .glass-card:hover {
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }
        .glass-card h5, .glass-card h6 {
            color: var(--text-primary);
        }

        .stats-row {
            display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px;
        }
        .stat-box { text-align: center; }
        .stat-value { font-size: 2rem; font-weight: 700; }

        .rating-bar {
            height: 8px; background: rgba(255,255,255,0.1);
            border-radius: 4px; margin: 4px 0;
        }
        .rating-fill {
            height: 100%; border-radius: 4px;
            background: linear-gradient(90deg, var(--accent-cyan), var(--primary));
        }

        /* Table */
        .table-wrapper {
            overflow-x: auto;
        }
        table { width: 100%; border-collapse: collapse; }
        th {
            text-align: left; padding: 12px 8px; color: var(--text-muted);
            font-size: 0.78rem; text-transform: uppercase; border-bottom: 2px solid var(--border-subtle);
        }
        td {
            padding: 12px 8px; border-bottom: 1px solid rgba(255,255,255,0.04);
            color: var(--text-secondary);
        }

        /* Card View (Mobile) */
        .review-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            padding: 16px;
            margin-bottom: 16px;
            transition: 0.35s;
        }
        .review-card:hover {
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }
        .review-card .stars {
            color: #fbbf24;
            font-size: 1.1rem;
        }

        .btn-glass {
            background: rgba(77,171,247,0.15); border: 1px solid rgba(77,171,247,0.4);
            color: var(--accent-cyan); border-radius: 30px; padding: 6px 16px;
            font-weight: 600; cursor: pointer; transition: 0.2s; text-decoration: none;
            display: inline-block;
        }
        .btn-glass:hover {
            background: rgba(77,171,247,0.25);
            box-shadow: 0 0 14px rgba(56,189,248,0.3);
        }

        /* ── DETAIL MODAL ── */
        .detail-modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.7); backdrop-filter: blur(8px);
            z-index: 10000; display: flex; align-items: center; justify-content: center;
            animation: fadeInOverlay 0.25s ease;
        }
        .detail-modal-content {
            background: linear-gradient(145deg, rgba(18,28,52,0.95), rgba(10,18,40,0.95));
            backdrop-filter: blur(20px);
            border: 1px solid var(--border-glow);
            border-radius: 24px; padding: 32px 36px;
            max-width: 800px; width: 90%; max-height: 85vh; overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 0 30px rgba(77,171,247,0.3);
            animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
        }
        .detail-close-btn {
            position: absolute; top: 16px; right: 20px;
            background: rgba(255,255,255,0.05); border: 1px solid var(--border-subtle);
            color: var(--text-secondary); width: 38px; height: 38px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 1.1rem; transition: 0.2s; z-index: 5;
        }
        .detail-close-btn:hover {
            background: rgba(248,113,113,0.15); border-color: var(--accent-red);
            color: var(--accent-red); box-shadow: 0 0 14px rgba(248,113,113,0.2);
        }

        /* Ensure all text inside detail modal is visible */
        .detail-modal-content, .detail-modal-content * {
            color: var(--text-primary);
        }
        .detail-modal-content .text-muted,
        .detail-modal-content .text-secondary {
            color: #b0bdd0 !important;
        }
        .detail-modal-content h4,
        .detail-modal-content h5 {
            color: #ffffff !important;
        }
        .review-item-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg); padding: 20px; margin-bottom: 20px;
        }
        .review-item-card * {
            color: #e8ecf4 !important;
        }
        .product-img {
            width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-md);
            background: rgba(255,255,255,0.05); border: 1px solid var(--border-subtle);
        }
        .media-preview {
            width: 100px; height: 100px; object-fit: cover; border-radius: var(--radius-md);
            margin-right: 8px; margin-bottom: 8px; border: 1px solid var(--border-subtle);
            cursor: pointer;
        }

        /* ── MODAL POPUP (ALERTS) ── */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
            z-index: 10001; display: flex; align-items: center; justify-content: center;
            animation: fadeInOverlay 0.25s ease;
        }
        .modal-content {
            background: linear-gradient(145deg, rgba(18,28,52,0.95), rgba(10,18,40,0.95));
            backdrop-filter: blur(16px);
            border: 1px solid var(--border-glow);
            border-radius: 24px; padding: 32px 36px;
            max-width: 420px; width: 90%; text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6), 0 0 30px rgba(77,171,247,0.3);
            animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .modal-icon { font-size: 3rem; margin-bottom: 16px; }
        .modal-message {
            font-size: 1.15rem; font-weight: 500; color: var(--text-primary);
            margin-bottom: 24px; line-height: 1.5;
        }
        .modal-btn {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            border: none; padding: 12px 32px; border-radius: 40px;
            font-weight: 600; color: #fff; cursor: pointer; transition: 0.2s;
            box-shadow: 0 4px 12px rgba(77,171,247,0.3);
        }
        .modal-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(77,171,247,0.4);
        }

        @keyframes fadeInOverlay { from { opacity:0; } to { opacity:1; } }
        @keyframes scaleIn {
            0% { transform: scale(0.7); opacity:0; }
            100% { transform: scale(1); opacity:1; }
        }

        /* Responsive visibility */
        @media (max-width: 767.98px) {
            .desktop-table { display: none; }
            .mobile-cards { display: block; }
        }
        @media (min-width: 768px) {
            .desktop-table { display: block; }
            .mobile-cards { display: none; }
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .menu-toggle { display: flex; }
        }
        @media (max-width: 768px) {
            .stats-row { grid-template-columns: repeat(2,1fr); }
            .main-content { padding: 14px; }
        }
        @media (max-width: 576px) {
            .stats-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <canvas id="nuranCanvas"></canvas>
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner-ring"></div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div>
                <span class="logo-text">ShopMaster</span>
                <div class="logo-subtext">admin · 2026</div>
            </div>
            <button class="toggle-sidebar" id="toggleSidebar"><i class="fas fa-chevron-left"></i></button>
        </div>
        <div class="sidebar-menu">
            <a href="/Admin/dashboard" class="menu-item"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <a href="/Admin/product" class="menu-item"><i class="fas fa-box"></i> Products</a>
            <a href="/Admin/category" class="menu-item"><i class="fas fa-tags"></i> Categories</a>
            <a href="/Admin/order" class="menu-item"><i class="fas fa-shopping-cart"></i> Orders</a>
            <a href="/Admin/customer" class="menu-item"><i class="fas fa-users"></i> Customers</a>
            <a href="/Admin/reviews" class="menu-item active-menu"><i class="fas fa-star"></i> Reviews</a>
            <a href="/Admin/analytics" class="menu-item"><i class="fas fa-chart-line"></i> Analytics</a>
            <a href="/Admin/setting" class="menu-item"><i class="fas fa-cog"></i> Settings</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <!-- HEADER -->
        <div class="header">
            <button class="menu-toggle" id="menuToggle" aria-label="menu"><i class="fas fa-bars"></i></button>
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search reviews..." id="searchInput">
            </div>
            <div class="header-actions">
                <button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge" id="notifBadge">0</span></button>
                <button class="notification-btn"><i class="fas fa-envelope"></i><span class="notification-badge" id="emailBadge">0</span></button>
                <div class="user-info">
                    <a href="/Admin/profile">
                        <img src="https://ui-avatars.com/api/?name=Admin+Master&background=4dabf7&color=fff&bold=true&size=42" alt="admin">
                    </a>
                    <div class="user-details">
                        <h4>Alex Master</h4>
                        <p>Super Admin</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Optional Filter Row -->
        <div class="filter-row">
            <select class="form-select" id="ratingFilter" style="width:auto;">
                <option value="all">All Ratings</option>
                <option value="5">5 Stars</option>
                <option value="4">4 Stars</option>
                <option value="3">3 Stars</option>
                <option value="2">2 Stars</option>
                <option value="1">1 Star</option>
            </select>
        </div>

        <!-- Stats Row -->
        <div class="stats-row" id="statsRow">
            <div class="glass-card stat-box">
                <h6>Total Reviews</h6>
                <div class="stat-value" id="totalReviews">0</div>
            </div>
            <div class="glass-card stat-box">
                <h6>Avg Rating</h6>
                <div class="stat-value" id="avgRating">0.0</div>
            </div>
            <div class="glass-card stat-box">
                <h6>5★ Reviews</h6>
                <div class="stat-value" id="fiveStarCount">0</div>
            </div>
            <div class="glass-card stat-box">
                <h6>1★ Reviews</h6>
                <div class="stat-value" id="oneStarCount">0</div>
            </div>
        </div>

        <!-- Rating Distribution -->
        <div class="glass-card mb-4">
            <h5 class="mb-3">⭐ Rating Distribution</h5>
            <div id="ratingDistribution"></div>
        </div>

        <!-- Recent Reviews: Table (Desktop) / Cards (Mobile) -->
        <div class="glass-card">
            <h5 class="mb-3">📝 Recent Reviews</h5>
            <!-- Desktop Table -->
            <div class="table-wrapper desktop-table">
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Product</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="reviewsTableBody"></tbody>
                </table>
            </div>
            <!-- Mobile Cards -->
            <div class="mobile-cards" id="reviewsCardsContainer"></div>
        </div>
    </div>

    <!-- DETAIL MODAL -->
    <div class="detail-modal-overlay d-none" id="detailModal">
        <div class="detail-modal-content" id="detailModalContent">
            <button class="detail-close-btn" id="closeDetailModal"><i class="fas fa-times"></i></button>
            <div id="detailContentBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Loading review details…</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            // ═══════════ NURAN PARTICLE BACKGROUND (mouse splatter) ═══════════
            const canvas = document.getElementById('nuranCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [], mouseX = -999, mouseY = -999, targetMouseX = -999, targetMouseY = -999;
            const SPLATTER_RADIUS = 190, CONNECTION_DIST = 140, PARTICLE_COUNT = window.innerWidth < 768 ? 80 : 140;

            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            resize(); window.addEventListener('resize', () => {
                resize();
                const newCount = window.innerWidth < 768 ? 80 : 140;
                while (particles.length < newCount) particles.push(createParticle());
                while (particles.length > newCount) particles.pop();
            });

            function createParticle() {
                const colors = ['rgba(77,171,247,', 'rgba(56,189,248,', 'rgba(167,139,250,', 'rgba(139,92,246,', 'rgba(45,212,191,', 'rgba(52,211,153,'];
                const color = colors[Math.floor(Math.random() * colors.length)];
                return {
                    x: Math.random() * canvas.width, y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.7, vy: (Math.random() - 0.5) * 0.7,
                    size: 1.8 + Math.random() * 3.5, color, glowAlpha: 0.5 + Math.random() * 0.5,
                    pulsePhase: Math.random() * Math.PI * 2, pulseSpeed: 0.008 + Math.random() * 0.025,
                    baseSize: 1.8 + Math.random() * 3.5
                };
            }
            for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(createParticle());

            document.addEventListener('mousemove', e => { targetMouseX = e.clientX; targetMouseY = e.clientY; });
            document.addEventListener('mouseleave', () => { targetMouseX = -999; targetMouseY = -999; });
            document.addEventListener('touchmove', e => { if (e.touches.length > 0) { targetMouseX = e.touches[0].clientX; targetMouseY = e.touches[0].clientY; } }, { passive: true });
            document.addEventListener('touchend', () => { targetMouseX = -999; targetMouseY = -999; });

            function animate(ts) {
                mouseX += (targetMouseX - mouseX) * 0.18; mouseY += (targetMouseY - mouseY) * 0.18;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                for (let p of particles) {
                    const t = ts * 0.001;
                    p.vx += Math.sin(t * 0.7 + p.pulsePhase) * 0.025; p.vy += Math.cos(t * 0.6 + p.pulsePhase + 1.3) * 0.025;
                    if (mouseX > -500 && mouseY > -500) {
                        const dx = p.x - mouseX, dy = p.y - mouseY, dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < SPLATTER_RADIUS && dist > 0.5) {
                            const f = (1 - dist / SPLATTER_RADIUS) * 4.5;
                            p.vx += (dx / dist) * f; p.vy += (dy / dist) * f;
                            p.glowAlpha = Math.min(1, p.glowAlpha + 0.06);
                        }
                    }
                    p.x += p.vx; p.y += p.vy; p.vx *= 0.94; p.vy *= 0.94;
                    const sp = Math.sqrt(p.vx ** 2 + p.vy ** 2);
                    if (sp > 6) { p.vx = (p.vx / sp) * 6; p.vy = (p.vy / sp) * 6; }
                    if (p.x < -30) p.x = canvas.width + 30; if (p.x > canvas.width + 30) p.x = -30;
                    if (p.y < -30) p.y = canvas.height + 30; if (p.y > canvas.height + 30) p.y = -30;
                    p.size = p.baseSize + Math.sin(t * p.pulseSpeed * 10 + p.pulsePhase) * 0.7;
                    p.glowAlpha += (0.6 - p.glowAlpha) * 0.03;
                }
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < CONNECTION_DIST) {
                            ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y); ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.strokeStyle = `rgba(120,170,230,${(1 - dist / CONNECTION_DIST) * 0.28})`; ctx.lineWidth = 0.6; ctx.stroke();
                        }
                    }
                }
                for (let p of particles) {
                    const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * 3.5);
                    g.addColorStop(0, p.color + (p.glowAlpha * 0.7) + ')'); g.addColorStop(0.35, p.color + (p.glowAlpha * 0.25) + ')'); g.addColorStop(1, p.color + '0)');
                    ctx.beginPath(); ctx.arc(p.x, p.y, p.size * 3.5, 0, Math.PI * 2); ctx.fillStyle = g; ctx.fill();
                    ctx.beginPath(); ctx.arc(p.x, p.y, p.size * 0.65, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255,255,255,${0.7 + p.glowAlpha * 0.3})`; ctx.fill();
                }
                requestAnimationFrame(animate);
            }
            requestAnimationFrame(animate);

            // ═══════════ MODAL POPUP (ALERTS) ═══════════
            function showModal(message, isSuccess = true) {
                const existing = document.querySelector('.modal-overlay');
                if(existing) existing.remove();
                const overlay = document.createElement('div');
                overlay.className = 'modal-overlay';
                const iconClass = isSuccess ? 'fa-check-circle' : 'fa-exclamation-triangle';
                const iconColor = isSuccess ? 'var(--accent-green)' : 'var(--accent-red)';
                overlay.innerHTML = `
                    <div class="modal-content">
                        <div class="modal-icon" style="color: ${iconColor};"><i class="fas ${iconClass}"></i></div>
                        <div class="modal-message">${message}</div>
                        <button class="modal-btn">OK</button>
                    </div>
                `;
                document.body.appendChild(overlay);
                const closeModal = () => {
                    overlay.style.opacity = '0'; overlay.style.transition = 'opacity 0.2s';
                    setTimeout(() => overlay.remove(), 200);
                };
                overlay.querySelector('.modal-btn').addEventListener('click', closeModal);
                overlay.addEventListener('click', (e) => { if(e.target === overlay) closeModal(); });
                setTimeout(closeModal, 3500);
            }

            // ═══════════ REVIEWS LOGIC ═══════════
            const API_BASE = 'http://localhost:3000/admin';
            const loadingOverlay = document.getElementById('loadingOverlay');
            let allReviews = [];
            let currentRatingFilter = 'all';

            function showLoading(show) { loadingOverlay.classList.toggle('d-none', !show); }
            function escapeHtml(str) { const d = document.createElement('div'); d.textContent = str || ''; return d.innerHTML; }

            async function fetchAllData() {
                showLoading(true);
                try {
                    const [revRes, countRes] = await Promise.all([
                        fetch(`${API_BASE}/reviews`),
                        fetch(`${API_BASE}/reviews/ratings/count`)
                    ]);
                    const revData = await revRes.json();
                    const countData = await countRes.json();
                    
                    if (revData.success) {
                        allReviews = revData.reviews || [];
                    } else {
                        throw new Error(revData.message || 'Failed to fetch reviews');
                    }
                    if (countData.success) {
                        window._ratingCounts = countData.ratingCounts || {};
                    }
                    updateUI();
                } catch (err) {
                    console.error(err);
                    showModal('Failed to load reviews. ' + (err.message || ''), false);
                    document.getElementById('reviewsTableBody').innerHTML = `<tr><td colspan="6" class="text-center text-danger">Failed to load reviews.</td></tr>`;
                } finally {
                    showLoading(false);
                }
            }

            function updateUI() {
                updateStats();
                renderRatingDistribution();
                const filtered = getFilteredReviews();
                renderTable(filtered);
                renderCards(filtered);
            }

            function getFilteredReviews() {
                if (currentRatingFilter === 'all') return allReviews;
                const rating = parseInt(currentRatingFilter, 10);
                return allReviews.filter(rev => rev.reviewItems?.some(item => item.rating === rating));
            }

            function updateStats() {
                const filtered = getFilteredReviews();
                const total = filtered.length;
                document.getElementById('totalReviews').textContent = total;
                if (total === 0) {
                    document.getElementById('avgRating').textContent = '0.0';
                    document.getElementById('fiveStarCount').textContent = '0';
                    document.getElementById('oneStarCount').textContent = '0';
                    return;
                }
                let sumRatings = 0, totalRatings = 0, fiveStar = 0, oneStar = 0;
                filtered.forEach(rev => {
                    rev.reviewItems?.forEach(item => {
                        const r = item.rating || 0;
                        sumRatings += r;
                        totalRatings++;
                        if (r === 5) fiveStar++;
                        if (r === 1) oneStar++;
                    });
                });
                const avg = totalRatings ? (sumRatings / totalRatings).toFixed(1) : '0.0';
                document.getElementById('avgRating').textContent = avg;
                document.getElementById('fiveStarCount').textContent = fiveStar;
                document.getElementById('oneStarCount').textContent = oneStar;
            }

            function renderRatingDistribution() {
                const container = document.getElementById('ratingDistribution');
                const counts = window._ratingCounts || {};
                const total = Object.values(counts).reduce((a,b)=>a+b,0) || 1;
                let html = '';
                for (let i = 5; i >= 1; i--) {
                    const count = counts[i] || 0;
                    const percent = Math.round((count / total) * 100);
                    html += `
                        <div class="d-flex align-items-center mb-2">
                            <span style="width:30px">${i}★</span>
                            <div class="flex-grow-1 mx-2"><div class="rating-bar"><div class="rating-fill" style="width:${percent}%"></div></div></div>
                            <span style="width:50px; text-align:right">${count}</span>
                        </div>`;
                }
                container.innerHTML = html || '<p class="text-muted">No ratings yet</p>';
            }

            function renderTable(reviews) {
                const tbody = document.getElementById('reviewsTableBody');
                if (!reviews.length) {
                    tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted">No reviews found.</td></tr>`;
                    return;
                }
                tbody.innerHTML = reviews.map(rev => {
                    const user = rev.userId?.fullName || rev.userId?.email || 'Unknown';
                    const product = rev.reviewItems?.[0]?.productId?.productName || 'Product';
                    const rating = rev.reviewItems?.[0]?.rating || 0;
                    const comment = (rev.reviewItems?.[0]?.comment || '').substring(0, 50) + (rev.reviewItems?.[0]?.comment?.length > 50 ? '…' : '');
                    const date = rev.createdAt ? new Date(rev.createdAt).toLocaleDateString() : '—';
                    const stars = '★'.repeat(rating) + '☆'.repeat(5 - rating);
                    return `<tr>
                        <td>${escapeHtml(user)}</td>
                        <td>${escapeHtml(product)}</td>
                        <td><span style="color:#fbbf24;">${stars}</span></td>
                        <td>${escapeHtml(comment) || '—'}</td>
                        <td>${date}</td>
                        <td><button class="btn-glass view-detail-btn" data-id="${rev._id}"><i class="fas fa-eye"></i> View</button></td>
                    </tr>`;
                }).join('');
            }

            function renderCards(reviews) {
                const container = document.getElementById('reviewsCardsContainer');
                if (!reviews.length) {
                    container.innerHTML = `<div class="text-center text-muted py-4">No reviews found.</div>`;
                    return;
                }
                container.innerHTML = reviews.map(rev => {
                    const user = rev.userId?.fullName || rev.userId?.email || 'Unknown';
                    const product = rev.reviewItems?.[0]?.productId?.productName || 'Product';
                    const rating = rev.reviewItems?.[0]?.rating || 0;
                    const comment = (rev.reviewItems?.[0]?.comment || '').substring(0, 80) + (rev.reviewItems?.[0]?.comment?.length > 80 ? '…' : '');
                    const date = rev.createdAt ? new Date(rev.createdAt).toLocaleDateString() : '—';
                    const stars = '★'.repeat(rating) + '☆'.repeat(5 - rating);
                    return `
                        <div class="review-card">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <strong>${escapeHtml(user)}</strong>
                                    <span class="text-muted ms-2">${date}</span>
                                </div>
                                <span class="stars">${stars}</span>
                            </div>
                            <div class="text-muted mb-1">${escapeHtml(product)}</div>
                            <div class="mb-2">${escapeHtml(comment) || '—'}</div>
                            <button class="btn-glass view-detail-btn" data-id="${rev._id}"><i class="fas fa-eye"></i> View</button>
                        </div>`;
                }).join('');
            }

            function attachDetailButtons() {
                document.querySelectorAll('.view-detail-btn').forEach(btn => {
                    btn.addEventListener('click', () => openDetailModal(btn.dataset.id));
                });
            }

            // Override render functions to attach listeners
            const originalRenderTable = renderTable;
            renderTable = function(reviews) {
                originalRenderTable(reviews);
                attachDetailButtons();
            };
            const originalRenderCards = renderCards;
            renderCards = function(reviews) {
                originalRenderCards(reviews);
                attachDetailButtons();
            };

            // ═══════════ DETAIL MODAL ═══════════
            const detailModal = document.getElementById('detailModal');
            const detailContentBody = document.getElementById('detailContentBody');
            const closeDetailBtn = document.getElementById('closeDetailModal');

            function openDetailModal(reviewId) {
                detailModal.classList.remove('d-none');
                detailContentBody.innerHTML = `<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>`;
                fetchReviewDetail(reviewId);
            }

            function closeDetailModalFn() {
                detailModal.classList.add('d-none');
                detailContentBody.innerHTML = '';
            }
            closeDetailBtn.addEventListener('click', closeDetailModalFn);
            detailModal.addEventListener('click', (e) => {
                if (e.target === detailModal) closeDetailModalFn();
            });

            function getMediaUrl(path) {
                if (!path) return 'https://ui-avatars.com/api/?name=No+Img&background=ccc&color=fff&size=100';
                const normalizedPath = path.replace(/\\/g, '/').replace(/^\/+/, '');
                return `http://localhost:3000/${normalizedPath}`;
            }

            function renderStars(rating) {
                return '★'.repeat(rating) + '☆'.repeat(5 - rating);
            }

            async function fetchReviewDetail(id) {
                try {
                    const response = await fetch(`${API_BASE}/review/${id}`);
                    const data = await response.json();
                    if (data.success) {
                        renderReviewDetail(data.review);
                    } else {
                        throw new Error(data.message || 'Review not found');
                    }
                } catch (err) {
                    console.error(err);
                    showModal('Failed to load review details. ' + (err.message || ''), false);
                    detailContentBody.innerHTML = `<p class="text-center text-danger">Failed to load details.</p>`;
                }
            }

            function renderReviewDetail(review) {
                const user = review.userId?.fullName || review.userId?.email || 'Unknown User';
                const createdAt = review.createdAt ? new Date(review.createdAt).toLocaleString('en-US', { dateStyle: 'long', timeStyle: 'short' }) : '—';
                const updatedAt = review.updatedAt ? new Date(review.updatedAt).toLocaleString('en-US', { dateStyle: 'long', timeStyle: 'short' }) : '—';

                const itemsHtml = review.reviewItems?.length ? review.reviewItems.map((item) => {
                    const product = item.productId || {};
                    const productName = product.productName || 'Unknown Product';
                    const brand = product.brand || '';
                    const model = product.model || '';
                    const price = product.price ? `$${product.price.toFixed(2)}` : '';
                    const mainImage = product.mainImage?.path ? getMediaUrl(product.mainImage.path) : 'https://ui-avatars.com/api/?name=No+Img&background=ccc&color=fff&size=80';
                    const rating = item.rating || 0;
                    const comment = item.comment || 'No comment';
                    const reviewImages = item.reviewImages || [];
                    const reviewVideos = item.reviewVideos || [];

                    const imagesHtml = reviewImages.map(img => {
                        const url = getMediaUrl(img.path);
                        return `<img src="${url}" class="media-preview" onclick="window.open('${url}','_blank')" alt="review image" />`;
                    }).join('') || '<span>No images</span>';

                    const videosHtml = reviewVideos.length ? reviewVideos.map(video => {
                        const url = getMediaUrl(video.path);
                        return `<video controls class="media-preview" style="width:150px; height:auto;"><source src="${url}" type="${video.mimetype || 'video/mp4'}"></video>`;
                    }).join('') : '<span>No videos</span>';

                    return `
                    <div class="review-item-card">
                        <div class="d-flex flex-wrap align-items-start gap-3 mb-3">
                            <img src="${mainImage}" class="product-img" alt="${escapeHtml(productName)}">
                            <div>
                                <h5 class="mb-1" style="color:#ffffff;">${escapeHtml(productName)}</h5>
                                <div class="small" style="color:#b0bdd0;">${escapeHtml(brand)} ${escapeHtml(model)} ${price ? '· ' + price : ''}</div>
                                <div class="mt-2" style="color:#fbbf24; font-size:1.2rem;">${renderStars(rating)}</div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <strong style="color:#ffffff;">Comment:</strong>
                            <p class="mt-1 mb-0" style="color:#e8ecf4;">${escapeHtml(comment)}</p>
                        </div>
                        <div class="mb-3">
                            <strong style="color:#ffffff;">Review Images:</strong>
                            <div class="d-flex flex-wrap gap-2 mt-1">${imagesHtml}</div>
                        </div>
                        <div>
                            <strong style="color:#ffffff;">Review Videos:</strong>
                            <div class="d-flex flex-wrap gap-2 mt-1">${videosHtml}</div>
                        </div>
                    </div>`;
                }).join('') : '<div class="text-muted">No review items.</div>';

                detailContentBody.innerHTML = `
                    <h4 class="mb-3" style="color:#ffffff;"><i class="fas fa-user me-2"></i> Review by ${escapeHtml(user)}</h4>
                    <div class="row g-3 mb-4" style="color:#b0bdd0;">
                        <div class="col-md-6"><strong>Created:</strong> ${createdAt}</div>
                        <div class="col-md-6"><strong>Updated:</strong> ${updatedAt}</div>
                    </div>
                    <h5 class="mb-3" style="color:#ffffff;"><i class="fas fa-boxes me-2"></i> Reviewed Products</h5>
                    ${itemsHtml}
                `;
            }

            // Search filter
            document.getElementById('searchInput').addEventListener('input', e => {
                const q = e.target.value.toLowerCase();
                const filtered = getFilteredReviews().filter(r => {
                    const user = (r.userId?.fullName || '').toLowerCase();
                    const product = (r.reviewItems?.[0]?.productId?.productName || '').toLowerCase();
                    return user.includes(q) || product.includes(q);
                });
                renderTable(filtered);
                renderCards(filtered);
            });

            // Rating filter
            document.getElementById('ratingFilter').addEventListener('change', e => {
                currentRatingFilter = e.target.value;
                document.getElementById('searchInput').value = ''; // reset search
                updateUI();
            });

            // Sidebar toggle
            document.getElementById('menuToggle')?.addEventListener('click', () => document.getElementById('sidebar').classList.toggle('active'));
            document.getElementById('toggleSidebar')?.addEventListener('click', () => document.getElementById('sidebar').classList.toggle('active'));

            // Initial fetch
            fetchAllData();
        })();
    </script>
</body>
</html>