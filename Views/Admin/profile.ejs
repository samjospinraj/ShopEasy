                </div>
            </div>
            <button class="toggle-sidebar" id="toggleSidebar" aria-label="close sidebar">
                <i class="fas fa-chevron-left"></i>
            </button>
        </div>
        <div class="sidebar-menu">
            <a href="/Admin/dashboard" class="menu-item"><i class="fas fa-tachometer-alt"></i><span class="menu-text">Dashboard</span></a>
            <a href="/Admin/product" class="menu-item"><i class="fas fa-box"></i><span class="menu-text">Products</span></a>
            <a href="/Admin/category" class="menu-item"><i class="fas fa-tags"></i><span class="menu-text">Categories</span></a>
            <a href="/Admin/order" class="menu-item"><i class="fas fa-shopping-cart"></i><span class="menu-text">Orders</span></a>
            <a href="/Admin/customer" class="menu-item"><i class="fas fa-users"></i><span class="menu-text">Customers</span></a>
            <a href="/Admin/analytics" class="menu-item"><i class="fas fa-chart-line"></i><span class="menu-text">Analytics</span></a>
            <a href="/Admin/profile" class="menu-item active-menu"><i class="fas fa-id-badge"></i><span class="menu-text">Profile</span></a>
            <a href="/Admin/setting" class="menu-item"><i class="fas fa-cog"></i><span class="menu-text">Settings</span></a>
        </div>
    </div>

    <!-- MAIN PROFILE CONTENT -->
    <div class="main-content" id="mainContent">
        <!-- HEADER (same) -->
        <div class="header">
            <button class="menu-toggle" id="menuToggle" aria-label="menu"><i class="fas fa-bars"></i></button>
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search orders, products...">
            </div>
            <div class="header-actions">
                <button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge">5</span></button>
                <button class="notification-btn"><i class="fas fa-envelope"></i><span class="notification-badge">3</span></button>
                <div class="user-info" id="profileButton">
                    <img src="https://ui-avatars.com/api/?name=Admin+Master&background=2c6de9&color=fff&bold=true&size=42" alt="admin">
                    <div class="user-details">
                        <h4>Alex Master</h4>
                        <p>Super Admin</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- PROFILE LAYOUT (two columns) -->
        <div class="profile-container">
            <!-- left column: avatar and contact card -->
            <div class="profile-side-card">
                <img src="https://ui-avatars.com/api/?name=Alex+Master&background=2c6de9&color=fff&size=140&bold=true&length=2" alt="avatar" class="profile-avatar">
                <h2>Alex Master</h2>
                <div class="profile-badge">Super Administrator</div>
                <div class="profile-contact">
                    <div class="contact-item"><i class="fas fa-envelope"></i> <span>a.master@shopmaster.com</span></div>
                    <div class="contact-item"><i class="fas fa-phone-alt"></i> <span>+1 (555) 237-8941</span></div>
                    <div class="contact-item"><i class="fas fa-map-marker-alt"></i> <span>New York, NY 10001</span></div>
                    <div class="contact-item"><i class="fas fa-calendar"></i> <span>Joined Mar 2022</span></div>
                </div>
                <div class="profile-stats">
                    <div class="stat-bubble"><h3>284</h3><p>orders managed</p></div>
                    <div class="stat-bubble"><h3>12</h3><p>products added</p></div>
                </div>
                <button class="btn" style="margin-top: 20px; width: 100%;" id="editProfileBtn"><i class="fas fa-pen"></i> edit profile</button>
            </div>

            <!-- right column: tabs with personal, activity, security -->
            <div class="profile-details-card">
                <div class="detail-tabs">
                    <button class="tab-btn active-tab" id="tabPersonal">Personal info</button>
                    <button class="tab-btn" id="tabActivity">Activity log</button>
                    <button class="tab-btn" id="tabSecurity">Security & prefs</button>
