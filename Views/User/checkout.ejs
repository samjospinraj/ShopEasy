            function updateTotalAmount() {
                const subtotal = window.cartTotals?.subtotal || 0;
                const tax = window.cartTotals?.tax || 0;
                const shipping = shippingCost || 0;
                document.getElementById('totalAmount').textContent = `₹${(subtotal + tax + shipping).toFixed(2)}`;
