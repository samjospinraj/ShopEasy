<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>ShopMaster · Product Form 2026</title>

    <!-- Bootstrap 5.3.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --bg-deep: #060b1f;
            --bg-card: rgba(10, 16, 36, 0.65);
            --bg-card-hover: rgba(14, 22, 45, 0.82);
            --bg-sidebar: rgba(7, 11, 28, 0.82);
            --bg-header: rgba(9, 14, 32, 0.7);
            --glass-blur: 20px;
            --glass-blur-light: 12px;
            --primary: #4dabf7;
            --primary-glow: #339af0;
            --accent-cyan: #38bdf8;
            --accent-teal: #2dd4bf;
            --accent-purple: #a78bfa;
            --accent-violet: #8b5cf6;
            --accent-green: #34d399;
            --accent-orange: #fb923c;
            --accent-red: #f87171;
            --accent-pink: #f472b6;
            --text-primary: #e8ecf4;
            --text-secondary: #b0bdd0;
            --text-muted: #7b8ca6;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(77, 171, 247, 0.3);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.45), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-glow: 0 0 40px rgba(77, 171, 247, 0.18), 0 0 80px rgba(77, 171, 247, 0.06);
            --radius-xl: 22px;
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-smooth: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            --bs-body-bg: transparent;
            --bs-body-color: #e8ecf4;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'SF Pro Display', 'Inter', Roboto, system-ui, sans-serif;
        }

        body {
            background: radial-gradient(ellipse at 20% 20%, #0b1430 0%, #060b1f 45%, #04091a 70%, #020617 100%);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
            margin: 0;
            padding: 0;
        }

        #nuranCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        /* ───────── SIDEBAR ───────── */
        .sidebar {
            width: 280px;
            background: var(--bg-sidebar);
            backdrop-filter: blur(26px);
            -webkit-backdrop-filter: blur(26px);
            color: var(--text-primary);
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            border-right: 1px solid var(--border-subtle);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            top: 0;
            left: 0;
        }

        .sidebar-header {
            padding: 0 20px 18px 20px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-text {
            font-size: 1.6rem;
            font-weight: 700;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .logo-subtext {
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }

        .toggle-sidebar {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 36px;
            height: 36px;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
            font-size: 1rem;
        }

        .toggle-sidebar:hover {
            background: rgba(77, 171, 247, 0.15);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.25);
        }

        .sidebar-menu {
            flex: 1;
            padding: 20px 0;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 13px 20px;
            margin: 3px 10px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition-fast);
            border-radius: 10px;
            cursor: pointer;
            font-weight: 450;
            border: 1px solid transparent;
        }

        .menu-item:hover {
            background: rgba(77, 171, 247, 0.08);
            color: var(--text-primary);
            border-color: rgba(77, 171, 247, 0.2);
        }

        .menu-item.active-menu {
            background: rgba(77, 171, 247, 0.13);
            color: #fff;
            border-color: rgba(77, 171, 247, 0.35);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.15);
            position: relative;
        }

        .menu-item.active-menu::before {
            content: '';
            position: absolute;
            left: -2px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 22px;
            border-radius: 0 4px 4px 0;
            background: var(--accent-cyan);
            box-shadow: 0 0 14px var(--accent-cyan);
        }

        .menu-item i {
            width: 24px;
            font-size: 1.15rem;
            margin-right: 14px;
            text-align: center;
        }

        .menu-text {
            font-size: 0.95rem;
        }

        /* ───────── MAIN CONTENT ───────── */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 22px 30px;
            transition: margin-left 0.35s ease;
            width: 100%;
            position: relative;
            z-index: 1;
            min-height: 100vh;
        }

        /* ───────── HEADER ───────── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-header);
            backdrop-filter: blur(22px);
            -webkit-backdrop-filter: blur(22px);
            padding: 14px 26px;
            border-radius: 50px;
            box-shadow: var(--shadow-card);
            margin-bottom: 28px;
            border: 1px solid var(--border-subtle);
            flex-wrap: wrap;
            gap: 14px;
            z-index: 2;
        }

        .menu-toggle {
            display: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 44px;
            height: 44px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1.2rem;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
        }

        .menu-toggle:hover {
            border-color: var(--border-glow);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.2);
            color: var(--accent-cyan);
        }

        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            padding: 8px 20px;
            width: min(400px, 100%);
            border: 1px solid var(--border-subtle);
        }

        .search-bar input {
            border: none;
            background: transparent;
            padding: 8px 10px;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
            color: var(--text-primary);
        }

        .search-bar input::placeholder {
            color: var(--text-muted);
        }

        .search-bar i {
            color: var(--text-muted);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 5px 18px 5px 8px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            border: 1px solid var(--border-subtle);
            cursor: pointer;
        }

        .user-info img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid rgba(77, 171, 247, 0.5);
            object-fit: cover;
        }

        .user-details h4 {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }

        .user-details p {
            font-size: 0.7rem;
            color: var(--text-muted);
            margin: 0;
        }

        /* ───────── FORM CARD ───────── */
        .form-card {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            -webkit-backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 32px;
            border: 1px solid var(--border-subtle);
            box-shadow: var(--shadow-card);
            max-width: 100%;
            margin: 0 auto 30px auto;
            position: relative;
            transition: var(--transition-smooth);
        }

        .form-card:hover {
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }

        .form-close-btn {
            position: absolute;
            top: 16px;
            right: 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition-fast);
            font-size: 1.1rem;
            z-index: 5;
        }

        .form-close-btn:hover {
            background: rgba(248, 113, 113, 0.15);
            border-color: var(--accent-red);
            color: var(--accent-red);
            box-shadow: 0 0 14px rgba(248, 113, 113, 0.2);
        }

        /* ───────── CATEGORY SECTIONS ───────── */
        .category-section {
            margin-bottom: 28px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-subtle);
            overflow: hidden;
        }

        .category-title {
            background: rgba(255, 255, 255, 0.03);
            padding: 16px 22px;
            font-size: 1.1rem;
            font-weight: 600;
            border-bottom: 1px solid var(--border-subtle);
            color: var(--text-primary);
            margin: 0;
        }

        .category-title i {
            color: var(--accent-cyan);
            margin-right: 10px;
        }

        .subcategory {
            border-bottom: 1px solid var(--border-subtle);
        }

        .subcategory:last-child {
            border-bottom: none;
        }

        .subcategory-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 22px;
            background: rgba(255, 255, 255, 0.01);
            cursor: pointer;
            font-weight: 500;
            color: var(--text-secondary);
            transition: var(--transition-fast);
            user-select: none;
        }

        .subcategory-header h3 {
            margin: 0;
            font-size: 0.95rem;
            font-weight: 500;
        }

        .subcategory-header:hover {
            background: rgba(77, 171, 247, 0.05);
            color: var(--text-primary);
        }

        .subcategory-content {
            padding: 18px 22px;
            border-top: 1px solid var(--border-subtle);
            background: transparent;
            display: block;
        }

        /* ───────── FORM OVERRIDES FOR BOOTSTRAP ───────── */
        .form-control,
        .form-select {
            background: rgba(255, 255, 255, 0.04) !important;
            border: 1px solid var(--border-subtle) !important;
            border-radius: 40px !important;
            font-size: 0.9rem !important;
            color: var(--text-primary) !important;
            padding: 12px 16px !important;
            transition: var(--transition-fast) !important;
            box-shadow: none !important;
        }

        .form-control:focus,
        .form-select:focus {
            outline: none !important;
            border-color: var(--border-glow) !important;
            box-shadow: 0 0 14px rgba(77, 171, 247, 0.15) !important;
            background: rgba(255, 255, 255, 0.06) !important;
        }

        .form-control::placeholder {
            color: var(--text-muted) !important;
            opacity: 0.7;
        }

        /* Dark dropdown options */
        .form-select option {
            background-color: #0f1829;
            color: #e0e7f0;
        }

        .form-select option:checked {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: white;
        }

        .form-select {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23b0bdd0' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
            background-repeat: no-repeat !important;
            background-position: right 16px center !important;
            background-size: 14px 10px !important;
            -webkit-appearance: none !important;
            -moz-appearance: none !important;
            appearance: none !important;
            cursor: pointer;
        }

        textarea.form-control {
            border-radius: var(--radius-md) !important;
            resize: vertical;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 6px;
            color: var(--text-secondary);
        }

        .required .form-label::after,
        label.required::after {
            content: " *";
            color: var(--accent-red);
        }

        .error-border {
            border: 2px solid var(--accent-red) !important;
            box-shadow: 0 0 10px rgba(248, 113, 113, 0.25) !important;
        }

        .error-message {
            color: var(--accent-red);
            font-size: 0.75rem;
            margin-top: 5px;
            font-weight: 500;
        }

        .hint {
            font-size: 0.7rem;
            color: var(--text-muted);
            margin-top: 5px;
        }

        /* ───────── SPECIFICATION ROWS ───────── */
        .specification-row {
            display: flex;
            gap: 12px;
            margin-bottom: 12px;
            align-items: center;
            flex-wrap: wrap;
        }

        .spec-input {
            flex: 1;
            min-width: 120px;
        }

        .btn-small {
            padding: 8px 14px;
            font-size: 0.8rem;
            border-radius: 40px;
            border: 1px solid var(--border-subtle);
            background: rgba(255, 255, 255, 0.04);
            color: var(--text-secondary);
            cursor: pointer;
            transition: var(--transition-fast);
            white-space: nowrap;
        }

        .btn-small.btn-danger {
            background: rgba(248, 113, 113, 0.1);
            border-color: rgba(248, 113, 113, 0.3);
            color: var(--accent-red);
        }

        .btn-small.btn-danger:hover {
            background: rgba(248, 113, 113, 0.25);
            box-shadow: 0 0 12px rgba(248, 113, 113, 0.3);
        }

        .btn-secondary-custom {
            background: rgba(77, 171, 247, 0.1);
            border: 1px solid var(--border-glow);
            color: var(--accent-cyan);
            padding: 9px 18px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition-fast);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            text-decoration: none;
        }

        .btn-secondary-custom:hover {
            background: rgba(77, 171, 247, 0.2);
            box-shadow: 0 0 14px rgba(56, 189, 248, 0.2);
            color: #fff;
        }

        /* ───────── FILE UPLOAD ───────── */
        .file-upload {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }

        .image-preview,
        .video-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 12px;
        }

        .preview-item {
            position: relative;
            width: 90px;
            height: 90px;
            border-radius: 16px;
            border: 1px solid var(--border-subtle);
            overflow: hidden;
            background: rgba(255, 255, 255, 0.03);
            flex-shrink: 0;
        }

        .preview-item.video-item {
            width: 150px;
            height: 100px;
        }

        .preview-item img,
        .preview-item video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .preview-label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            font-size: 0.65rem;
            text-align: center;
            padding: 2px 4px;
        }

        .remove-image,
        .remove-video,
        .remove-btn,
        .remove-video-btn,
        .remove-new-video-btn {
            position: absolute;
            top: 2px;
            right: 2px;
            background: rgba(239, 68, 68, 0.9);
            color: white;
            border: none;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            font-size: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            z-index: 3;
            transition: var(--transition-fast);
        }

        .remove-image:hover,
        .remove-video:hover,
        .remove-btn:hover,
        .remove-video-btn:hover,
        .remove-new-video-btn:hover {
            background: rgba(239, 68, 68, 1);
            transform: scale(1.1);
        }

        /* ───────── DELIVERY COUNTER ───────── */
        .delivery-counter {
            background: linear-gradient(135deg, rgba(77, 171, 247, 0.15), rgba(51, 154, 240, 0.1));
            border: 1px solid var(--border-glow);
            color: white;
            padding: 16px 20px;
            border-radius: 16px;
            margin-top: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .delivery-counter .counter-label {
            font-size: 0.85rem;
            opacity: 0.9;
        }

        .delivery-counter .counter-values {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .delivery-counter .counter-item {
            text-align: center;
        }

        .delivery-counter .counter-number {
            font-size: 1.8rem;
            font-weight: 700;
        }

        .delivery-counter .counter-unit {
            font-size: 0.75rem;
            opacity: 0.8;
        }

        .delivery-counter .counter-divider {
            font-size: 1.5rem;
            font-weight: 300;
            opacity: 0.6;
        }

        .delivery-counter .delivery-dates {
            font-size: 0.8rem;
            opacity: 0.85;
            text-align: right;
        }

        .delivery-counter .delivery-dates span {
            display: block;
        }

        /* ───────── FORM ACTIONS ───────── */
        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 16px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 1px solid var(--border-subtle);
            flex-wrap: wrap;
        }

        .btn-submit {
            padding: 12px 30px;
            border: none;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: var(--transition-fast);
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: #fff;
            box-shadow: 0 4px 16px rgba(77, 171, 247, 0.3);
            text-decoration: none;
            display: inline-block;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(77, 171, 247, 0.4);
            color: #fff;
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .btn-cancel {
            padding: 12px 30px;
            border: 1px solid var(--border-subtle);
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: var(--transition-fast);
            background: rgba(255, 255, 255, 0.04);
            color: var(--text-secondary);
        }

        .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.08);
            color: var(--text-primary);
        }

        /* ═══════════ MODAL POPUP (2026 animation) ═══════════ */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeInOverlay 0.25s ease;
        }
        .modal-content {
            background: linear-gradient(145deg, rgba(18, 28, 52, 0.95), rgba(10, 18, 40, 0.95));
            backdrop-filter: blur(16px);
            border: 1px solid var(--border-glow);
            border-radius: 24px;
            padding: 32px 36px;
            max-width: 420px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6), 0 0 30px rgba(77, 171, 247, 0.3);
            animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .modal-icon {
            font-size: 3rem;
            margin-bottom: 16px;
        }
        .modal-message {
            font-size: 1.15rem;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 24px;
            line-height: 1.5;
        }
        .modal-btn {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            border: none;
            padding: 12px 32px;
            border-radius: 40px;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 4px 12px rgba(77, 171, 247, 0.3);
        }
        .modal-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(77, 171, 247, 0.4);
        }

        @keyframes fadeInOverlay {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes scaleIn {
            0% { transform: scale(0.7); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        /* ───────── RESPONSIVE ───────── */
        @media (max-width: 992px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.active {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
            .menu-toggle {
                display: flex;
            }
            .form-card {
                padding: 20px;
            }
        }

        @media (max-width: 768px) {
            .form-card {
                padding: 16px;
                border-radius: var(--radius-lg);
            }
            .delivery-counter {
                flex-direction: column;
                align-items: flex-start;
            }
            .specification-row {
                flex-direction: column;
                gap: 8px;
            }
            .spec-input {
                width: 100%;
            }
            .header {
                padding: 10px 16px;
                border-radius: 30px;
            }
            .main-content {
                padding: 12px 10px;
            }
            .preview-item {
                width: 70px;
                height: 70px;
            }
            .preview-item.video-item {
                width: 120px;
                height: 80px;
            }
            .form-actions {
                flex-direction: column;
                gap: 10px;
            }
            .form-actions .btn-submit,
            .form-actions .btn-cancel {
                width: 100%;
                text-align: center;
            }
            .delivery-counter .counter-number {
                font-size: 1.3rem;
            }
        }

        @media (max-width: 480px) {
            .category-title {
                font-size: 0.95rem;
                padding: 12px 14px;
            }
            .subcategory-content {
                padding: 12px 10px;
            }
            .subcategory-header {
                padding: 10px 14px;
            }
            .subcategory-header h3 {
                font-size: 0.85rem;
            }
            .form-control,
            .form-select {
                font-size: 0.82rem !important;
                padding: 10px 14px !important;
            }
            .btn-submit,
            .btn-cancel {
                padding: 10px 20px;
                font-size: 0.82rem;
            }
            .file-upload {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>

<body>
    <canvas id="nuranCanvas"></canvas>

    <!-- ═══════════ SIDEBAR ═══════════ -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div>
                <div class="logo-text">ShopMaster</div>
                <div class="logo-subtext">admin · 2026</div>
            </div>
            <button class="toggle-sidebar" id="toggleSidebarBtn" aria-label="Toggle sidebar">
                <i class="fas fa-chevron-left"></i>
            </button>
        </div>
        <div class="sidebar-menu">
            <a href="/Admin/dashboard" class="menu-item"><i class="fas fa-tachometer-alt"></i><span class="menu-text">Dashboard</span></a>
            <a href="/Admin/product" class="menu-item active-menu"><i class="fas fa-box"></i><span class="menu-text">Products</span></a>
            <a href="/Admin/category" class="menu-item"><i class="fas fa-tags"></i><span class="menu-text">Categories</span></a>
            <a href="/Admin/order" class="menu-item"><i class="fas fa-shopping-cart"></i><span class="menu-text">Orders</span></a>
            <a href="/Admin/customer" class="menu-item"><i class="fas fa-users"></i><span class="menu-text">Customers</span></a>
            <a href="/Admin/review" class="menu-item "><i class="fas fa-star"></i> Reviews</a>
            <a href="/Admin/analytics" class="menu-item"><i class="fas fa-chart-line"></i><span class="menu-text">Analytics</span></a>
            <a href="/Admin/profile" class="menu-item"><i class="fas fa-id-badge"></i><span class="menu-text">Profile</span></a>
            <a href="/Admin/setting" class="menu-item"><i class="fas fa-cog"></i><span class="menu-text">Settings</span></a>
        </div>
    </div>

    <!-- ═══════════ MAIN CONTENT ═══════════ -->
    <div class="main-content" id="mainContent">
        <!-- HEADER -->
        <div class="header">
            <button class="menu-toggle" id="mobileMenuToggle" aria-label="Menu"><i class="fas fa-bars"></i></button>
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search products..." />
            </div>
            <div class="user-info">
                <a href="/Admin/profile">
                    <img src="https://ui-avatars.com/api/?name=Admin+Master&background=4dabf7&color=fff&bold=true&size=42" alt="admin" />
                </a>
                <div class="user-details">
                    <h4>Alex Master</h4>
                    <p>Super Admin</p>
                </div>
            </div>
        </div>

        <!-- ═══════════ FORM CARD ═══════════ -->
        <div class="form-card" id="productFormCard">
            <button class="form-close-btn" title="Close & return to products" onclick="window.location.href='/Admin/product'">
                <i class="fas fa-times"></i>
            </button>

            <form id="productForm" enctype="multipart/form-data" novalidate>
                <!-- Basic Information -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-info-circle"></i> Basic Information</h2>

                    <!-- Product Identification -->
                    <div class="subcategory">
                        <div class="subcategory-header" role="button" tabindex="0">
                            <h3>Product Identification</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="prodName">Product Name</label>
                                        <input type="text" name="productName" class="form-control" id="prodName" placeholder="Enter product name (3-100 chars)" minlength="3" maxlength="100" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="sku">SKU</label>
                                        <input type="text" name="sku" class="form-control" id="sku" placeholder="Product SKU (3-60 chars)" minlength="3" maxlength="60" />
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3 mt-2">
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="brand">Brand</label>
                                        <input type="text" name="brand" class="form-control" id="brand" placeholder="Brand (2-60 chars)" minlength="2" maxlength="60" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="model">Model</label>
                                        <input type="text" name="model" class="form-control" id="model" placeholder="Model (1-60 chars)" minlength="1" maxlength="60" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Categorization -->
                    <div class="subcategory">
                        <div class="subcategory-header" role="button" tabindex="0">
                            <h3>Categorization</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="mainCategorySelect">Main Category</label>
                                        <select name="category" class="form-select" id="mainCategorySelect">
                                            <option value="">Select category</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="subCategorySelect">Subcategory</label>
                                    <select name="subcategory" class="form-select" id="subCategorySelect">
                                        <option value="">Select subcategory</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row g-3 mt-2">
                                <div class="col-md-6">
                                    <label class="form-label" for="subSubCategorySelect">Sub-subcategory</label>
                                    <select name="sub_subcategory" class="form-select" id="subSubCategorySelect">
                                        <option value="">Select sub-subcategory</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="sizeSelect">Product Size</label>
                                        <select name="size" class="form-select" id="sizeSelect">
                                            <option value="">Select size</option>
                                            <option value="S">S</option>
                                            <option value="M" selected>M</option>
                                            <option value="L">L</option>
                                            <option value="XL">XL</option>
                                            <option value="NONE">NONE</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pricing & Inventory -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-tag"></i> Pricing & Inventory</h2>
                    <div class="subcategory">
                        <div class="subcategory-header" role="button" tabindex="0">
                            <h3>Pricing Details</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="price">Price ($)</label>
                                        <input type="number" step="0.01" name="price" class="form-control" id="price" placeholder="Non-negative number" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="comparePrice">Compare at Price</label>
                                    <input type="number" step="0.01" name="comparePrice" class="form-control" id="comparePrice" min="0" />
                                </div>
                            </div>
                            <div class="row g-3 mt-2">
                                <div class="col-md-6">
                                    <label class="form-label" for="costPrice">Cost per Item</label>
                                    <input type="number" step="0.01" name="costPrice" class="form-control" id="costPrice" min="0" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="offerPercent">Offer (%)</label>
                                    <input type="number" step="0.1" name="offerPercent" class="form-control" id="offerPercent" placeholder="0-100" min="0" max="100" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="subcategory">
                        <div class="subcategory-header" role="button" tabindex="0">
                            <h3>Inventory</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="required">
                                        <label class="form-label" for="stock">Stock Quantity</label>
                                        <input type="number" name="stockQuantity" class="form-control" id="stock" placeholder="Non-negative integer" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="lowStockThreshold">Low Stock Threshold</label>
                                    <input type="number" name="lowStockThreshold" class="form-control" id="lowStockThreshold" placeholder="Non-negative integer" min="0" />
                                </div>
                            </div>
                            <div class="mt-3">
                                <label class="form-label" for="barcode">Barcode</label>
                                <input type="text" name="barcode" class="form-control" id="barcode" placeholder="Barcode (3-60 chars)" minlength="3" maxlength="60" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Key Specifications -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-key"></i> Key Specifications</h2>
                    <div class="subcategory-content">
                        <div id="keySpecsContainer">
                            <div class="specification-row">
                                <div class="spec-input"><input type="text" name="keySpecs_keys[]" class="form-control" placeholder="Spec name" /></div>
                                <div class="spec-input"><input type="text" name="keySpecs_values[]" class="form-control" placeholder="Value" /></div>
                                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                            </div>
                        </div>
                        <button type="button" class="btn-secondary-custom mt-3" id="addKeySpecBtn"><i class="fas fa-plus"></i> Add Key Spec</button>
                    </div>
                </div>

                <!-- Description -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-file-alt"></i> Description</h2>
                    <div class="subcategory-content">
                        <div class="mb-3 required">
                            <label class="form-label" for="shortDesc">Short Description</label>
                            <textarea name="shortDescription" class="form-control" id="shortDesc" rows="2" placeholder="Brief summary (3-300 chars)" minlength="3" maxlength="300"></textarea>
                        </div>
                        <div class="mb-0 required">
                            <label class="form-label" for="fullDesc">Full Description</label>
                            <textarea name="fullDescription" class="form-control" id="fullDesc" rows="4" placeholder="Detailed product description (3-2000 chars)" minlength="3" maxlength="2000"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Technical Specifications -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-list-alt"></i> Technical Specifications</h2>
                    <div class="subcategory-content">
                        <div class="mb-3">
                            <label class="form-label" for="specTitle">Spec Title</label>
                            <input type="text" name="specTitle" class="form-control" id="specTitle" placeholder="e.g., Technical Specs (3-100 chars)" minlength="3" maxlength="100" />
                        </div>
                        <div id="detailedSpecsContainer">
                            <div class="specification-row">
                                <div class="spec-input"><input type="text" name="detailedSpecs_keys[]" class="form-control" placeholder="Category" /></div>
                                <div class="spec-input"><input type="text" name="detailedSpecs_values[]" class="form-control" placeholder="Value" /></div>
                                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                            </div>
                        </div>
                        <button type="button" class="btn-secondary-custom mt-3" id="addDetailedSpecBtn"><i class="fas fa-plus"></i> Add Detail</button>
                    </div>
                </div>

                <!-- Design Specifications -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-palette"></i> Design Specifications</h2>
                    <div class="subcategory-content">
                        <div class="mb-3">
                            <label class="form-label" for="designTitle">Design Title</label>
                            <input type="text" name="designTitle" class="form-control" id="designTitle" placeholder="Design specs (3-100 chars)" minlength="3" maxlength="100" />
                        </div>
                        <div id="designSpecsContainer">
                            <div class="specification-row">
                                <div class="spec-input"><input type="text" name="designSpecs_keys[]" class="form-control" placeholder="Design feature" /></div>
                                <div class="spec-input"><input type="text" name="designSpecs_values[]" class="form-control" placeholder="Value" /></div>
                                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                            </div>
                        </div>
                        <button type="button" class="btn-secondary-custom mt-3" id="addDesignSpecBtn"><i class="fas fa-plus"></i> Add Design Spec</button>
                    </div>
                </div>

                <!-- Performance Specifications -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-microchip"></i> Performance Specifications</h2>
                    <div class="subcategory-content">
                        <div class="mb-3">
                            <label class="form-label" for="performanceTitle">Performance Title</label>
                            <input type="text" name="performanceTitle" class="form-control" id="performanceTitle" placeholder="Performance metrics (3-100 chars)" minlength="3" maxlength="100" />
                        </div>
                        <div id="perfSpecsContainer">
                            <div class="specification-row">
                                <div class="spec-input"><input type="text" name="perfSpecs_keys[]" class="form-control" placeholder="Metric" /></div>
                                <div class="spec-input"><input type="text" name="perfSpecs_values[]" class="form-control" placeholder="Value" /></div>
                                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                            </div>
                        </div>
                        <button type="button" class="btn-secondary-custom mt-3" id="addPerfSpecBtn"><i class="fas fa-plus"></i> Add Performance Spec</button>
                    </div>
                </div>

                <!-- Additional Specifications -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-plus-circle"></i> Additional Specifications</h2>
                    <div class="subcategory-content">
                        <div class="mb-3">
                            <label class="form-label" for="additionalTitle">Additional Title</label>
                            <input type="text" name="additionalTitle" class="form-control" id="additionalTitle" placeholder="More details (3-100 chars)" minlength="3" maxlength="100" />
                        </div>
                        <div id="additionalSpecsContainer">
                            <div class="specification-row">
                                <div class="spec-input"><input type="text" name="additionalSpecs_keys[]" class="form-control" placeholder="Feature" /></div>
                                <div class="spec-input"><input type="text" name="additionalSpecs_values[]" class="form-control" placeholder="Value" /></div>
                                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                            </div>
                        </div>
                        <button type="button" class="btn-secondary-custom mt-3" id="addAdditionalSpecBtn"><i class="fas fa-plus"></i> Add Additional</button>
                    </div>
                </div>

                <!-- Media & Images -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-images"></i> Media & Images</h2>
                    <div class="subcategory-content">
                        <div class="mb-3 required">
                            <label class="form-label">Main Image</label>
                            <div class="file-upload">
                                <button type="button" class="btn-secondary-custom" id="triggerMainImage">Upload Main Image</button>
                                <input type="file" id="mainImageInput" name="mainImage" accept="image/*" style="display:none" />
                                <span id="mainFileName" class="text-muted" style="font-size:0.85rem;">No file chosen</span>
                            </div>
                            <div class="hint">Max 5MB. Allowed: JPG, PNG, WEBP</div>
                            <div id="mainImagePreview" class="image-preview"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Additional Images</label>
                            <div class="file-upload">
                                <button type="button" class="btn-secondary-custom" id="triggerAdditionalImages">Upload Additional</button>
                                <input type="file" id="additionalImagesInput" name="additionalImages" accept="image/*" multiple style="display:none" />
                                <span id="additionalFileName" class="text-muted" style="font-size:0.85rem;">No files chosen</span>
                            </div>
                            <div class="hint">Max 5 images, each up to 5MB. Allowed: JPG, PNG, WEBP. Duplicates not allowed.</div>
                            <div id="additionalImagesPreview" class="image-preview"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Product Videos</label>
                            <div class="file-upload">
                                <button type="button" class="btn-secondary-custom" id="triggerVideos">Upload Videos</button>
                                <input type="file" id="videosInput" name="productVideos" accept="video/*" multiple style="display:none" />
                                <span id="videosFileName" class="text-muted" style="font-size:0.85rem;">No files chosen</span>
                            </div>
                            <div class="hint">Max 5 videos, each up to 200MB. Allowed: MP4, WEBM, MPEG, MOV, AVI. Duplicates not allowed.</div>
                            <div id="videosPreview" class="video-preview"></div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label">Video Links (YouTube/Vimeo)</label>
                            <div id="videoLinksContainer">
                                <div class="specification-row">
                                    <div class="spec-input"><input type="url" name="videoLinks[]" class="form-control" placeholder="https://youtube.com/watch?v=..." /></div>
                                    <button type="button" class="btn-small btn-danger removeVideoLinkBtn">Remove</button>
                                </div>
                            </div>
                            <button type="button" class="btn-secondary-custom mt-3" id="addVideoLinkBtn"><i class="fas fa-plus"></i> Add Video Link</button>
                        </div>
                    </div>
                </div>

                <!-- Shipping & Dimensions -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-shipping-fast"></i> Shipping & Dimensions</h2>
                    <div class="subcategory-content">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="shippingClassSelect">Shipping Class</label>
                                <select name="shippingClass" class="form-select" id="shippingClassSelect">
                                    <option value="Standard">Standard</option>
                                    <option value="Express">Express</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="freeShippingSelect">Free Shipping</label>
                                <select name="freeShipping" class="form-select" id="freeShippingSelect">
                                    <option value="false">No</option>
                                    <option value="true">Yes</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-md-4">
                                <label class="form-label" for="length">Length (cm)</label>
                                <input type="number" name="length" class="form-control" id="length" min="0" step="0.01" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="width">Width (cm)</label>
                                <input type="number" name="width" class="form-control" id="width" min="0" step="0.01" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="height">Height (cm)</label>
                                <input type="number" name="height" class="form-control" id="height" min="0" step="0.01" />
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <label class="form-label" for="weight">Weight (kg)</label>
                                <input type="number" step="0.01" name="weight" class="form-control" id="weight" min="0" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="shippingCost">Shipping Cost</label>
                                <input type="number" id="shippingCost" name="shippingCost" class="form-control" min="0" step="0.01" />
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <label class="form-label" for="minDay">Min Delivery Days</label>
                                <input type="number" name="minDay" class="form-control" id="minDay" placeholder="0-365" min="0" max="365" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="maxDay">Max Delivery Days</label>
                                <input type="number" name="maxDay" class="form-control" id="maxDay" placeholder="0-365" min="0" max="365" />
                            </div>
                        </div>
                        <div class="hint">Min day must be ≤ max day. Both between 0 and 365.</div>
                        <div class="delivery-counter" id="deliveryCounter" style="display:none;">
                            <div class="counter-label"><i class="fas fa-clock"></i> Estimated Delivery</div>
                            <div class="counter-values">
                                <div class="counter-item">
                                    <div class="counter-number" id="minDaysCounter">--</div>
                                    <div class="counter-unit">Min Days</div>
                                </div>
                                <div class="counter-divider">→</div>
                                <div class="counter-item">
                                    <div class="counter-number" id="maxDaysCounter">--</div>
                                    <div class="counter-unit">Max Days</div>
                                </div>
                            </div>
                            <div class="delivery-dates">
                                <span id="minDeliveryDate">Min: --</span>
                                <span id="maxDeliveryDate">Max: --</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status & Visibility -->
                <div class="category-section">
                    <h2 class="category-title"><i class="fas fa-ellipsis-h"></i> Status & Visibility</h2>
                    <div class="subcategory-content">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="statusSelect">Product Status</label>
                                <select name="status" class="form-select" id="statusSelect">
                                    <option value="draft">Draft</option>
                                    <option value="active" selected>Active</option>
                                    <option value="archived">Archived</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="visibilitySelect">Visibility</label>
                                <select name="visibility" class="form-select" id="visibilitySelect">
                                    <option value="visible">Visible</option>
                                    <option value="hidden">Hidden</option>
                                </select>
                            </div>
                        </div>
                        <div class="mt-3">
                            <label class="form-label" for="tags">Tags</label>
                            <input type="text" name="tags" class="form-control" id="tags" placeholder="new, popular (max 200 chars)" maxlength="200" />
                        </div>
                        <div class="mt-3">
                            <label class="form-label" for="internalNotes">Internal Notes</label>
