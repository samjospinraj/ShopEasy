            function calculateTotalAmount() {
                const subtotal = window.cartTotals?.subtotal || 0;
                const tax = window.cartTotals?.tax || 0;
                const shipping = shippingCost || 0;
                return subtotal + tax + shipping;
            }

            // ============ ORDER SUBMISSION ============
            async function initializeRazorpayPayment(orderData) {
                try {
                    // Step 1: Create Razorpay order via backend
                    const createResponse = await fetch(`${API_BASE}/create-razorpay-order`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ items: cartItems })
                    });
                    if (!createResponse.ok) {
                        const err = await createResponse.json();
                        throw new Error(err.message || 'Failed to create Razorpay order');
                    }
                    const razorpayOrder = await createResponse.json();

                    // 🔎 NEW: Validate the key before opening the popup
                    if (!razorpayOrder.key || !razorpayOrder.key.startsWith('rzp_')) {
                        throw new Error('Invalid Razorpay API key received. Please check your server .env file.');
                    }

                    const options = {
                        key: razorpayOrder.key,
                        amount: razorpayOrder.amount,
                        currency: razorpayOrder.currency || 'INR',
                        name: 'ShopEasy',
                        description: 'Purchase from ShopEasy',
                        order_id: razorpayOrder.id,
                        handler: async function(response) {
                            const finalOrderData = {
                                ...orderData,
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_signature: response.razorpay_signature,
                                items: cartItems
                            };
                            await finalizeRazorpayOrder(finalOrderData);
                        },
                        prefill: { name: orderData.fullName, contact: orderData.phone },
                        theme: { color: '#ff6b6b' },
                        modal: {
                            ondismiss: function() {
                                showModal('warning', 'Payment Cancelled', 'You have cancelled the payment.');
                                resetPlaceOrderBtn();
                            }
                        }
                    };

                    const rzp = new Razorpay(options);
                    rzp.on('payment.failed', function(response) {
                        showModal('error', 'Payment Failed', response.error.description || 'Unknown error');
                        resetPlaceOrderBtn();
                    });
                    rzp.open();
                } catch (error) {
                    showModal('error', 'Payment Error', error.message);
                    resetPlaceOrderBtn();
                }
            }

            async function finalizeRazorpayOrder(orderData) {
                try {
                    const res = await fetch(`${API_BASE}/online-payment`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify(orderData)
                    });
                    const result = await res.json();
                    if (res.ok && result.success) {
                        updateCartBadge(0);
                        showSuccessModal({
                            orderId: result.order?._id || '#SHOP' + Date.now().toString().slice(-8),
                            totalAmount: calculateTotalAmount(),
                            paymentMethod: 'Online Payment'
                        });
                    } else {
                        showModal('error', 'Order Failed', result.message || 'Failed to place order');
                        resetPlaceOrderBtn();
                    }
                } catch (e) {
                    showModal('error', 'Network Error', 'Please try again.');
                    resetPlaceOrderBtn();
                }
            }

            async function submitCODOrder(orderData) {
                try {
                    const res = await fetch(`${API_BASE}/cash-on-delivery`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify(orderData)
                    });
                    const result = await res.json();
                    if (res.ok && result.success) {
                        updateCartBadge(0);
                        showSuccessModal({
                            orderId: result.order?._id || '#SHOP' + Date.now().toString().slice(-8),
                            totalAmount: calculateTotalAmount(),
                            paymentMethod: 'Cash on Delivery'
                        });
                    } else {
                        showModal('error', 'Order Failed', result.message || 'Failed to place COD order');
                        resetPlaceOrderBtn();
                    }
                } catch (e) {
                    showModal('error', 'Network Error', 'Please try again.');
                    resetPlaceOrderBtn();
                }
            }

            function resetPlaceOrderBtn() {
                const btn = document.getElementById('placeOrderBtn');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-lock me-2"></i>Place Order';
            }

            // ============ EVENT LISTENERS ============
            document.getElementById('placeOrderBtn').addEventListener('click', async () => {
                if (!validateAllFields()) {
                    showModal('warning', 'Validation Error', 'Please fill in all required fields correctly.');
                    return;
                }
                const fullName = document.getElementById('customerName').value.trim();
                const phone = document.getElementById('customerPhone').value.trim();
                const address = document.getElementById('deliveryAddress').value.trim();
                const city = document.getElementById('city').value.trim();
                const postalCode = document.getElementById('postalCode').value.trim();
                const state = document.getElementById('state').value.trim();
                const country = document.getElementById('country').value;

                if (cartItems.length === 0) {
                    showModal('warning', 'No Items', 'No items to order.');
                    return;
                }

                const btn = document.getElementById('placeOrderBtn');
                btn.disabled = true;
                btn.innerHTML = '<span class="loading-spinner-white me-2"></span>Processing...';

                const baseOrderData = { fullName, phone, address, city, postalCode, state, country, items: cartItems };

                try {
                    if (selectedPayment === 'razorpay') {
                        await initializeRazorpayPayment(baseOrderData);
                    } else if (selectedPayment === 'cod') {
                        await submitCODOrder(baseOrderData);
                    }
                } catch (error) {
                    showModal('error', 'Error', 'Something went wrong. Please try again.');
                } finally {
                    if (btn.disabled) resetPlaceOrderBtn();
                }
            });

            document.getElementById('userIconBtn').addEventListener('click', (e) => {
                e.stopPropagation();
                if (!isAuthenticated) { redirectToLogin(); return; }
                document.getElementById('userDropdownMenu').classList.toggle('show');
            });
            document.addEventListener('click', (e) => { if (!e.target.closest('#userDropdown')) document.getElementById('userDropdownMenu').classList.remove('show'); });

            document.getElementById('menuLogout').addEventListener('click', async (e) => {
                e.preventDefault();
                try {
                    const response = await fetch(`${API_BASE}/logout`, { method: 'GET', credentials: 'include' });
                    if (response.ok) {
                        isAuthenticated = false; updateLoginUI(); updateCartBadge(0);
                        showModal('info', 'Logged Out', 'You have been logged out successfully.', { autoHide: 2000, onPrimary: () => redirectToLogin() });
                    }
                } catch (error) { showModal('error', 'Logout Error', 'Error logging out.'); }
            });

            document.getElementById('giftBoxWrapper').addEventListener('click', openGiftBox);
            document.getElementById('successModalOverlay').addEventListener('click', function(e) {
                if (e.target === this && document.getElementById('giftBox').classList.contains('opened')) closeSuccessModal();
            });

            function getCheckoutType() {
                const urlParams = new URLSearchParams(window.location.search);
                singleProductId = urlParams.get('productId');
                checkoutType = singleProductId ? 'single' : 'cart';
                const indicator = document.getElementById('checkoutTypeIndicator');
                indicator.innerHTML = checkoutType === 'single'
                    ? '<span class="checkout-type-badge badge-single"><i class="fas fa-bolt me-1"></i>Buy Now - Single Product</span>'
                    : '<span class="checkout-type-badge badge-cart"><i class="fas fa-shopping-cart me-1"></i>Cart Checkout</span>';
            }

            // ============ INIT ============
            (async () => {
                getCheckoutType();
                setupValidation();
                if (await checkAuth()) {
                    await fetchCheckoutData();
                    updatePaymentSummary();
                    updateTotalAmount();
                    setTimeout(() => {
                        for (const fieldId of ['customerName', 'customerPhone', 'deliveryAddress', 'city', 'postalCode', 'state']) {
                            const input = document.getElementById(fieldId);
                            if (input && !input.value.trim()) { input.focus(); break; }
                        }
                    }, 500);
                }
            })();
        })();
    </script>
</body>
</html>