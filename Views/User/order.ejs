            font-size: 1rem;
            color: #f59e0b;
            flex-shrink: 0;
        }

        /* ---------- Notification Modal (Premium Pop-up) – always on top ---------- */
        .modal-premium {
            z-index: 3500 !important;            /* above custom overlays */
        }
        .modal-premium + .modal-backdrop {
            z-index: 3499 !important;
        }

        .modal-premium .modal-content {
            border-radius: 28px;
            border: none;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
            animation: modalBounceIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        @keyframes modalBounceIn {
            from {
                opacity: 0;
                transform: scale(0.85) translateY(-30px);
            }
            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
        .modal-premium .modal-header {
            border-bottom: none;
            padding: 25px 24px 5px;
            text-align: center;
            display: block;
        }
        .modal-icon-circle {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin: 0 auto 12px;
            color: white;
        }
        .modal-icon-circle.success {
            background: var(--gradient-2);
        }
        .modal-icon-circle.error {
            background: var(--gradient-1);
        }
        .modal-icon-circle.warning {
            background: linear-gradient(135deg, #f39c12, #e67e22);
        }
        .modal-icon-circle.info {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }
        .modal-premium .modal-body {
            padding: 5px 24px 18px;
            text-align: center;
            font-size: 0.95rem;
            color: #555;
        }
        .modal-message-title {
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--dark);
            margin-bottom: 5px;
        }
        .modal-premium .modal-footer {
            border-top: none;
            padding: 0 24px 22px;
            justify-content: center;
            gap: 10px;
        }
        .btn-modal-action {
            padding: 10px 26px;
            border-radius: 50px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .btn-modal-primary {
            background: var(--gradient-1);
            color: white;
        }
        .btn-modal-primary:hover {
            filter: brightness(1.1);
        }
        .btn-modal-secondary {
            background: #f0f0f0;
            color: #333;
        }
        .btn-modal-secondary:hover {
            background: #e0e0e0;
        }

        /* ---------- Responsive (no break on any device) ---------- */
        @media (max-width:992px) {
            .brand-premium {
                font-size: 1.7rem;
            }
            .page-title {
                font-size: 1.7rem;
            }
            .stats-row {
                grid-template-columns: repeat(3, 1fr);
                gap: 10px;
            }
            .stat-card {
                padding: 14px;
                gap: 10px;
            }
            .stat-icon {
                width: 38px;
                height: 38px;
                font-size: 1rem;
            }
            .stat-info h5 {
                font-size: 1.2rem;
            }
            .filter-tabs {
                gap: 6px;
            }
            .filter-tab {
                padding: 8px 14px;
                font-size: 0.78rem;
            }
        }
        @media (max-width:768px) {
            .brand-premium {
                font-size: 1.5rem;
            }
            .page-title {
                font-size: 1.4rem;
            }
            .page-subtitle {
                font-size: 0.8rem;
            }
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
                gap: 8px;
            }
            .stat-card {
                padding: 12px;
                gap: 8px;
                border-radius: 16px;
            }
            .stat-icon {
                width: 34px;
                height: 34px;
                font-size: 0.9rem;
                border-radius: 10px;
            }
            .stat-info h5 {
                font-size: 1.1rem;
            }
            .stat-info small {
                font-size: 0.65rem;
            }
            .order-header {
                flex-direction: column;
            }
            .order-footer {
                flex-direction: column;
                align-items: flex-start;
            }
            .filter-tabs {
                overflow-x: auto;
                flex-wrap: nowrap;
                padding-bottom: 8px;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
            }
            .filter-tabs::-webkit-scrollbar {
                display: none;
            }
            .filter-tab {
                flex-shrink: 0;
                padding: 8px 14px;
                font-size: 0.75rem;
            }
            .order-actions {
                flex-direction: column;
                width: 100%;
            }
            .btn-order-action {
                justify-content: center;
                width: 100%;
            }
            .modal-dialog-premium {
                padding: 20px;
                width: 95%;
                border-radius: 20px;
            }
            .order-progress {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
            }
            .order-progress::-webkit-scrollbar {
                display: none;
            }
