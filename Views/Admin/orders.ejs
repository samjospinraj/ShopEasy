    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // PARTICLE BACKGROUND
            const canvas = document.getElementById('nuranCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [], mouseX = -999, mouseY = -999, targetMouseX = -999, targetMouseY = -999;
            const SPLATTER_RADIUS = 190, CONNECTION_DIST = 140, PARTICLE_COUNT = window.innerWidth < 768 ? 80 : 140;
            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            resize(); window.addEventListener('resize', () => { resize(); const nc = window.innerWidth < 768 ? 80 : 140; while (particles.length < nc) particles.push(createParticle()); while (particles.length > nc) particles.pop(); });
            function createParticle() {
                const cols = ['rgba(77,171,247,','rgba(56,189,248,','rgba(167,139,250,','rgba(139,92,246,','rgba(45,212,191,','rgba(96,165,250,','rgba(192,132,252,','rgba(52,211,153,'];
                const c = cols[Math.floor(Math.random()*cols.length)];
                return { x:Math.random()*canvas.width, y:Math.random()*canvas.height, vx:(Math.random()-0.5)*0.7, vy:(Math.random()-0.5)*0.7, size:1.8+Math.random()*3.5, color:c, glowAlpha:0.5+Math.random()*0.5, pulsePhase:Math.random()*Math.PI*2, pulseSpeed:0.008+Math.random()*0.025, baseSize:1.8+Math.random()*3.5 };
            }
            for(let i=0;i<PARTICLE_COUNT;i++) particles.push(createParticle());
            document.addEventListener('mousemove',e=>{ targetMouseX=e.clientX; targetMouseY=e.clientY; });
            document.addEventListener('mouseleave',()=>{ targetMouseX=-999; targetMouseY=-999; });
            document.addEventListener('touchmove',e=>{ if(e.touches.length>0){ targetMouseX=e.touches[0].clientX; targetMouseY=e.touches[0].clientY; } },{passive:true});
            document.addEventListener('touchend',()=>{ targetMouseX=-999; targetMouseY=-999; });
            function animate(ts) {
                mouseX+=(targetMouseX-mouseX)*0.18; mouseY+=(targetMouseY-mouseY)*0.18;
                ctx.clearRect(0,0,canvas.width,canvas.height);
                const time=ts*0.001;
                for(let p of particles) {
                    p.vx+=Math.sin(time*0.7+p.pulsePhase)*0.025; p.vy+=Math.cos(time*0.6+p.pulsePhase+1.3)*0.025;
                    if(mouseX>-500&&mouseY>-500){ const dx=p.x-mouseX,dy=p.y-mouseY,dist=Math.sqrt(dx*dx+dy*dy); if(dist<SPLATTER_RADIUS&&dist>0.5){ const force=(1-dist/SPLATTER_RADIUS)*4.5; p.vx+=(dx/dist)*force; p.vy+=(dy/dist)*force; p.glowAlpha=Math.min(1,p.glowAlpha+0.06); } }
                    p.x+=p.vx; p.y+=p.vy; p.vx*=0.94; p.vy*=0.94;
                    const sp=Math.sqrt(p.vx*p.vx+p.vy*p.vy); if(sp>6){ p.vx=(p.vx/sp)*6; p.vy=(p.vy/sp)*6; }
                    if(p.x<-30)p.x=canvas.width+30; if(p.x>canvas.width+30)p.x=-30; if(p.y<-30)p.y=canvas.height+30; if(p.y>canvas.height+30)p.y=-30;
                    p.size=p.baseSize+Math.sin(time*p.pulseSpeed*10+p.pulsePhase)*0.7;
                    p.glowAlpha+=(0.6-p.glowAlpha)*0.03;
                }
                for(let i=0;i<particles.length;i++) for(let j=i+1;j<particles.length;j++) {
                    const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,dist=Math.sqrt(dx*dx+dy*dy);
                    if(dist<CONNECTION_DIST){ const alpha=(1-dist/CONNECTION_DIST)*0.28, pulse=Math.sin(ts*0.003+i*0.4+j*0.3)*0.5+0.5; ctx.beginPath(); ctx.moveTo(particles[i].x,particles[i].y); ctx.lineTo(particles[j].x,particles[j].y); ctx.strokeStyle=`rgba(120,170,230,${alpha*(0.5+pulse*0.5)})`; ctx.lineWidth=0.6; ctx.stroke(); }
                }
                for(let p of particles) {
                    const grad=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.size*3.5);
                    grad.addColorStop(0,p.color+(p.glowAlpha*0.7)+')'); grad.addColorStop(0.35,p.color+(p.glowAlpha*0.25)+')'); grad.addColorStop(1,p.color+'0)');
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.size*3.5,0,Math.PI*2); ctx.fillStyle=grad; ctx.fill();
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.size*0.65,0,Math.PI*2); ctx.fillStyle=`rgba(255,255,255,${0.7+p.glowAlpha*0.3})`; ctx.fill();
                }
                if(mouseX>-500&&mouseY>-500){ const mg=ctx.createRadialGradient(mouseX,mouseY,0,mouseX,mouseY,SPLATTER_RADIUS*0.7); mg.addColorStop(0,'rgba(120,180,240,0.08)'); mg.addColorStop(0.5,'rgba(100,150,220,0.03)'); mg.addColorStop(1,'rgba(0,0,0,0)'); ctx.beginPath(); ctx.arc(mouseX,mouseY,SPLATTER_RADIUS*0.7,0,Math.PI*2); ctx.fillStyle=mg; ctx.fill(); }
                requestAnimationFrame(animate);
            }
            requestAnimationFrame(animate);

            // SIDEBAR TOGGLE
            const sidebar = document.getElementById('sidebar');
            const menuToggleBtn = document.getElementById('menuToggle');
            const toggleSidebarBtn = document.getElementById('toggleSidebarBtn');
            function toggleSidebarFunc(e) { e?.stopPropagation(); sidebar.classList.toggle('active'); }
            menuToggleBtn?.addEventListener('click', toggleSidebarFunc);
            toggleSidebarBtn?.addEventListener('click', toggleSidebarFunc);
            document.addEventListener('click', function(e) {
                if (window.innerWidth <= 992 && !sidebar.contains(e.target) && !menuToggleBtn?.contains(e.target) && sidebar.classList.contains('active')) sidebar.classList.remove('active');
            });

            // MODAL POPUP
            function showModal(message, isSuccess = true) {
                const existing = document.querySelector('.modal-overlay'); if (existing) existing.remove();
                const overlay = document.createElement('div'); overlay.className = 'modal-overlay';
                const iconClass = isSuccess ? 'fa-check-circle' : 'fa-exclamation-triangle';
                const iconColor = isSuccess ? 'var(--accent-green)' : 'var(--accent-red)';
                overlay.innerHTML = `
                    <div class="modal-content">
                        <div class="modal-icon" style="color: ${iconColor};"><i class="fas ${iconClass}"></i></div>
                        <div class="modal-message">${message}</div>
                        <button class="modal-btn">OK</button>
                    </div>`;
                document.body.appendChild(overlay);
                const closeModal = () => { overlay.style.opacity = '0'; overlay.style.transition = 'opacity 0.2s'; setTimeout(() => overlay.remove(), 200); };
                overlay.querySelector('.modal-btn').addEventListener('click', closeModal);
                overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
                setTimeout(closeModal, 3500);
            }

            // FETCH REVENUE
            async function fetchRevenueData() {
                try {
                    const resp = await fetch(`/admin/orders/revenue`);
                    if (!resp.ok) throw new Error();
                    const data = await resp.json();
                    if (data.success && data.revenueData) {
                        const totalRevenue = data.revenueData.reduce((sum, entry) => sum + (entry.totalRevenue || 0), 0);
                        const totalOrders = data.revenueData.reduce((sum, entry) => sum + (entry.orderCount || 0), 0);
                        document.getElementById('totalRevenue').textContent = `₹${totalRevenue.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
                        document.getElementById('totalOrders').textContent = totalOrders;
                    } else {
                        document.getElementById('totalRevenue').textContent = '—';
                        document.getElementById('totalOrders').textContent = '—';
                    }
                } catch (e) { console.warn('Revenue data not loaded'); document.getElementById('totalRevenue').textContent = '—'; document.getElementById('totalOrders').textContent = '—'; }
            }

            // ORDERS LOGIC
            let allOrders = [], normalizedOrders = [];
            let currentFilter = 'all', currentPaymentFilter = 'all', searchQuery = '', customerNameFilter = '', dateFromFilter = '', dateToFilter = '';
            const timerIntervals = {};
            const tableBody = document.getElementById('tableBody'), cardContainer = document.getElementById('cardView');
            const filterMenu = document.getElementById('filterMenu'), filterBtn = document.getElementById('filterBtn');
            const paymentFilterMenu = document.getElementById('paymentFilterMenu'), paymentFilterBtn = document.getElementById('paymentFilterBtn');
            const activeFilterTag = document.getElementById('activeFilterTag'), orderCountSpan = document.getElementById('orderCount');
            const searchInput = document.getElementById('globalSearch'), customerInput = document.getElementById('customerFilterInput');
            const dateFromInput = document.getElementById('dateFrom'), dateToInput = document.getElementById('dateTo');
            const tableView = document.getElementById('tableView'), cardViewDiv = document.getElementById('cardView');
            const tableBtn = document.getElementById('tableViewBtn'), cardBtn = document.getElementById('cardViewBtn');

            function formatDateTime(iso) { if (!iso) return '—'; const d = new Date(iso); return d.toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
            function getProductImageUrl(product) { return product?.mainImage?.path ? `http://localhost:3000${product.mainImage.path}` : 'https://ui-avatars.com/api/?name=No+Img&background=ccc&color=fff&size=44'; }
            const TWO_DAYS_MS = 2 * 24 * 60 * 60 * 1000;
            function formatTimeRemaining(ms) { if (ms <= 0) return { expired: true, display: '00:00:00', totalMs: 0 }; const s = Math.floor(ms / 1000), h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60; return { expired: false, display: `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(sec).padStart(2, '0')}`, totalMs: ms }; }
            function getTimeRemaining(from) { if (!from) return { expired: true, display: '00:00:00', totalMs: 0 }; const remaining = new Date(from).getTime() + TWO_DAYS_MS - Date.now(); return formatTimeRemaining(remaining); }
            function isExpiringSoon(ms) { return ms > 0 && ms <= 6 * 60 * 60 * 1000; }
            function getReturnStatusClass(rs) { if (!rs || rs === 'none') return ''; const map = { 'requested': 'status-return_requested', 'approved': 'status-return_approved', 'returned': 'status-returned', 'completed': 'status-returned', 'expired': 'status-return_expired', 'rejected': 'status-return_rejected' }; return map[rs] || ''; }
            function getPaymentMethodDisplay(pm) { if (pm === 'onlinePayment') return 'Online'; if (pm === 'cashOnDelivery' || pm === 'cod') return 'COD'; return pm || 'Online'; }
            function getPaymentMethodClass(pm) { if (pm === 'onlinePayment') return 'payment-online'; if (pm === 'cashOnDelivery' || pm === 'cod') return 'payment-cod'; return ''; }
            function truncateRazorpayId(id) { if (!id) return '—'; if (id.length > 18) return id.substring(0, 15) + '...'; return id; }

            // 🆕 CORRECTED MAPPING FOR THE PROVIDED API STRUCTURE
            async function fetchOrders() {
                try {
                    const resp = await fetch('/admin/orders');
                    if (!resp.ok) throw new Error();
                    const data = await resp.json();
                    if (data.success && data.orderData) {
                        allOrders = data.orderData.map(order => ({
                            orderId: order.orderId,                                   // main identifier
                            fullName: order.shippingAddress?.fullName || (order.userId?.email ? order.userId.email.split('@')[0] : 'Unknown'),
                            userId: { email: order.userId?.email || null },
                            totalAmount: order.totals?.totalAmount || 0,
                            orderStatus: order.orderStatus || 'confirmed',
                            returnStatus: order.returnStatus || 'none',
                            refundStatus: order.refundStatus || '',
                            createdAt: order.orderTimeline?.orderedAt || order.createdAt || null,   // may be missing
                            paymentMethod: order.paymentMethod || 'onlinePayment',
                            razorpayOrderId: order.razorpay?.orderId || null,
                            razorpayPaymentId: order.razorpay?.paymentId || null,
                            returnApprovedAt: order.returnTimeline?.returnApprovedAt || null,
                            returnRequestedAt: order.returnTimeline?.returnRequestedAt || null,
                            returnCompletedAt: order.returnTimeline?.returnCompletedAt || null,
                            items: (order.items || []).map(item => ({
                                productId: item.productId ? {
                                    productName: item.productName || item.productId.productName,
                                    mainImage: item.productId.mainImage || null,
                                    brand: item.productId.brand || null,
                                    model: item.productId.model || null
                                } : null,
                                quantity: item.quantity || 0
                            }))
                        }));
                    } else {
                        throw new Error('Invalid API response');
                    }
                } catch (e) {
                    console.warn('API failed, using static demo data');
                    allOrders = [
                        { orderId: '6a27a7027f17fb9d964e169a', fullName: 'remauseuquaki-5732', userId: { email: 'remauseuquaki-5732@yopmail.com' }, totalAmount: 662, orderStatus: 'returned', returnStatus: 'completed', createdAt: null, paymentMethod: 'onlinePayment', razorpayOrderId: null, razorpayPaymentId: null, returnApprovedAt: '2026-06-09T05:41:45.208Z', returnRequestedAt: '2026-06-09T05:41:35.559Z', items: [{ productId: { productName: 'AeroFit Tracker', brand: 'EcoSip Bottle', model: 'PureWave Air Purifier', mainImage: { path: '/Uploads/mainProduct/1780581479659-517931534-download (4).jpg' } }, quantity: 1 }] },
                        { orderId: '6a27a5d87f17fb9d964e1561', fullName: 'remauseuquaki-5732', userId: { email: 'remauseuquaki-5732@yopmail.com' }, totalAmount: 662, orderStatus: 'returned', returnStatus: 'completed', createdAt: null, paymentMethod: 'onlinePayment', razorpayOrderId: null, razorpayPaymentId: null, returnApprovedAt: '2026-06-09T05:38:15.190Z', returnRequestedAt: '2026-06-09T05:38:04.818Z', items: [{ productId: { productName: 'AeroFit Tracker', brand: 'EcoSip Bottle', model: 'PureWave Air Purifier', mainImage: { path: '/Uploads/mainProduct/1780581479659-517931534-download (4).jpg' } }, quantity: 1 }] }
                    ];
                }
                normalizeOrders();
                buildFilterMenu();
                updateDisplay();
                fetchRevenueData();
            }

            function normalizeOrders() {
                normalizedOrders = allOrders.map(order => {
                    const items = order.items || [];
                    const firstProd = items[0]?.productId || null;
                    const productNames = items.map(i => i.productId?.productName || 'Unknown').join(', ');
                    const rawDate = order.createdAt ? new Date(order.createdAt) : null;
                    return {
                        id: order.orderId ? (order.orderId.length > 8 ? order.orderId.substring(order.orderId.length - 8) : order.orderId) : 'N/A',
                        fullId: order.orderId,
                        customer: order.fullName || 'Unknown',
                        email: order.userId?.email || 'N/A',
                        date: rawDate ? rawDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'N/A',
                        rawDate,
                        amount: order.totalAmount || 0,
                        status: order.orderStatus || 'Unknown',
                        returnStatus: order.returnStatus || 'none',
                        returnApprovedAt: order.returnApprovedAt || null,
                        returnRequestedAt: order.returnRequestedAt || null,
                        paymentMethod: order.paymentMethod || 'onlinePayment',
                        razorpay: {
                            orderId: order.razorpayOrderId || null,
                            paymentId: order.razorpayPaymentId || null,
                        },
                        items,
                        productCount: items.length,
                        itemsPreview: productNames.length > 40 ? productNames.substring(0, 37) + '...' : productNames,
                        firstProductImage: getProductImageUrl(firstProd)
                    };
                });
            }

            function buildFilterMenu() {
                const statuses = [...new Set(normalizedOrders.map(o => o.status))];
                let html = '<div class="filter-menu-item" data-filter="all"><i class="fas fa-list-ul"></i> All orders</div>';
                statuses.forEach(st => { html += `<div class="filter-menu-item" data-filter="${st}"><i class="fas fa-circle" style="font-size:0.5rem; color:${getStatusColor(st)};"></i> ${capitalize(st.replace(/_/g, ' '))}</div>`; });
                filterMenu.innerHTML = html;
                filterMenu.querySelectorAll('.filter-menu-item').forEach(i => i.addEventListener('click', () => { currentFilter = i.dataset.filter; updateDisplay(); filterMenu.classList.remove('show'); }));
                paymentFilterMenu.querySelectorAll('.filter-menu-item').forEach(i => i.addEventListener('click', () => { currentPaymentFilter = i.dataset.payment; updateDisplay(); paymentFilterMenu.classList.remove('show'); }));
            }
            function getStatusColor(st) { const s = st.toLowerCase(); if (s.includes('delivered')||s.includes('completed')) return '#10b981'; if (s.includes('confirmed')) return '#38bdf8'; if (s.includes('process')||s.includes('shipped')||s.includes('packed')||s.includes('out_for')) return '#f59e0b'; return '#ef4444'; }
            function capitalize(str) { return str.charAt(0).toUpperCase() + str.slice(1); }

            function getFilteredOrders() {
                return normalizedOrders.filter(o => {
                    if (currentFilter !== 'all' && o.status !== currentFilter) return false;
                    if (currentPaymentFilter !== 'all' && o.paymentMethod !== currentPaymentFilter) return false;
                    if (searchQuery) {
                        const q = searchQuery.toLowerCase();
                        if (!o.id.toLowerCase().includes(q) && !o.customer.toLowerCase().includes(q) && !o.email.toLowerCase().includes(q) && !o.itemsPreview.toLowerCase().includes(q) && !(o.razorpay.orderId && o.razorpay.orderId.toLowerCase().includes(q)) && !(o.razorpay.paymentId && o.razorpay.paymentId.toLowerCase().includes(q))) return false;
                    }
                    if (customerNameFilter && !o.customer.toLowerCase().includes(customerNameFilter.toLowerCase())) return false;
                    if (dateFromFilter || dateToFilter) {
                        if (!o.rawDate) return false;
                        const from = dateFromFilter ? new Date(dateFromFilter + 'T00:00:00') : null, to = dateToFilter ? new Date(dateToFilter + 'T23:59:59') : null;
                        if (from && o.rawDate < from) return false;
                        if (to && o.rawDate > to) return false;
                    }
                    return true;
                });
            }

            function goToOrderDetail(orderId) { const ord = normalizedOrders.find(o => o.id === orderId); if (ord) window.location.href = `/Admin/orderDetails/${ord.fullId}`; }

            function clearAllTimers() { Object.values(timerIntervals).forEach(clearInterval); for (let k in timerIntervals) delete timerIntervals[k]; }
            function startTimerForOrder(order) {
                if (order.returnStatus !== 'approved' || !order.returnApprovedAt) return;
                const wrap = document.getElementById(`timer-${order.id}`); if (!wrap) return;
                const update = () => {
                    const data = getTimeRemaining(order.returnApprovedAt);
                    const txt = wrap.querySelector('.timer-text'), lbl = wrap.querySelector('.timer-label');
                    if (txt) txt.textContent = data.display;
                    wrap.classList.remove('urgent', 'expired-timer');
                    if (data.expired) {
                        wrap.classList.add('expired-timer'); if (lbl) lbl.textContent = 'EXPIRED';
                        handleTimerExpired(order); return true;
                    } else if (isExpiringSoon(data.totalMs)) {
                        wrap.classList.add('urgent'); if (lbl) lbl.textContent = 'ENDING SOON';
                    } else if (lbl) lbl.textContent = 'REMAINING';
                    return false;
                };
                update();
                const interval = setInterval(() => { if (update()) clearInterval(interval); }, 1000);
                timerIntervals[order.id] = interval;
            }
            async function handleTimerExpired(order) {
                try { await fetch(`/admin/order/return-complete/${order.fullId}`, { method: 'PUT' }); } catch (e) {}
                showModal(`⏰ Return window expired for #${order.id}.`, false);
                setTimeout(() => location.reload(), 1800);
            }

            function updateDisplay() {
                clearAllTimers();
                const filtered = getFilteredOrders();
                orderCountSpan.innerText = filtered.length + ' orders';
                let tableHtml = '';
                filtered.forEach(o => {
                    let returnBadgeHtml = '<span style="color:var(--text-muted);">—</span>';
                    if (o.returnStatus && o.returnStatus !== 'none') {
                        const returnClass = getReturnStatusClass(o.returnStatus);
                        returnBadgeHtml = `<span class="status ${returnClass}">${capitalize(o.returnStatus.replace(/_/g, ' '))}</span>`;
                    }
                    const approvalTimeFormatted = (o.returnStatus === 'approved' && o.returnApprovedAt) ? formatDateTime(o.returnApprovedAt) : '—';
                    const paymentClass = getPaymentMethodClass(o.paymentMethod);
                    const paymentDisplay = getPaymentMethodDisplay(o.paymentMethod);
                    const razorpayOrderDisplay = o.razorpay.orderId ? truncateRazorpayId(o.razorpay.orderId) : '—';
                    const razorpayPaymentDisplay = o.razorpay.paymentId ? truncateRazorpayId(o.razorpay.paymentId) : '—';
                    tableHtml += `<tr data-id="${o.id}">
                        <td><strong>#${o.id}</strong></td>
                        <td>${o.customer}</td>
                        <td>${o.date}</td>
                        <td>₹${o.amount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                        <td><span class="status status-${o.status}">${capitalize(o.status.replace(/_/g, ' '))}</span></td>
                        <td><span class="${paymentClass}">${paymentDisplay}</span></td>
                        <td><span class="razorpay-cell" title="${o.razorpay.orderId || 'N/A'}">${razorpayOrderDisplay}</span></td>
                        <td><span class="razorpay-cell" title="${o.razorpay.paymentId || 'N/A'}">${razorpayPaymentDisplay}</span></td>
                        <td>${returnBadgeHtml}</td>
                        <td style="font-size:0.8rem;">${approvalTimeFormatted}</td>
                        <td>${o.productCount} item(s)</td>
                    </tr>`;
                });
                tableBody.innerHTML = tableHtml;
                let cardHtml = '';
                filtered.forEach(o => {
                    const statusClass = `status-${o.status}`;
                    let badges = `<span class="status ${statusClass}">${capitalize(o.status.replace(/_/g, ' '))}</span>`;
                    const paymentClass = getPaymentMethodClass(o.paymentMethod);
                    const paymentDisplay = getPaymentMethodDisplay(o.paymentMethod);
                    badges += `<span class="${paymentClass}">${paymentDisplay}</span>`;
                    if (o.returnStatus && o.returnStatus !== 'none') {
                        const returnClass = getReturnStatusClass(o.returnStatus);
                        badges += `<span class="status ${returnClass}">${capitalize(o.returnStatus.replace(/_/g, ' '))}</span>`;
                    }
                    let approvalRow = '';
                    if (o.returnStatus === 'approved' && o.returnApprovedAt) {
                        approvalRow = `<div class="approval-row"><i class="fas fa-check-circle"></i> <span><strong>Return approved:</strong> ${formatDateTime(o.returnApprovedAt)}</span></div>`;
                    }
                    let paymentInfoRow = '';
                    if (o.paymentMethod === 'onlinePayment' && o.razorpay?.orderId) {
                        paymentInfoRow = `<div class="payment-info-row"><i class="fas fa-receipt"></i><span><strong>Razorpay:</strong></span><span class="razorpay-detail" title="${o.razorpay.orderId}">Order: ${truncateRazorpayId(o.razorpay.orderId)}</span>${o.razorpay?.paymentId ? `<span class="razorpay-detail" title="${o.razorpay.paymentId}">Pay: ${truncateRazorpayId(o.razorpay.paymentId)}</span>` : ''}</div>`;
                    } else if (o.paymentMethod === 'cashOnDelivery' || o.paymentMethod === 'cod') {
                        paymentInfoRow = `<div class="payment-info-row" style="border-left-color: #f59e0b;"><i class="fas fa-money-bill-wave" style="color:#f59e0b;"></i><span><strong>Cash on Delivery</strong></span></div>`;
                    }
                    let timerHtml = '';
                    if (o.returnStatus === 'approved' && o.returnApprovedAt) {
                        const timeData = getTimeRemaining(o.returnApprovedAt);
                        const urgentClass = timeData.expired ? 'expired-timer' : (isExpiringSoon(timeData.totalMs) ? 'urgent' : '');
                        timerHtml = `<div class="countdown-timer-wrap ${urgentClass}" id="timer-${o.id}"><span class="timer-icon"><i class="fas fa-hourglass-half"></i></span><div style="display:flex;flex-direction:column;align-items:center;"><span class="timer-text">${timeData.display}</span><span class="timer-label">${timeData.expired ? 'EXPIRED' : (isExpiringSoon(timeData.totalMs) ? 'ENDING SOON' : 'REMAINING')}</span></div></div>`;
                    }
                    cardHtml += `<div class="order-card" data-id="${o.id}">
                        <div class="card-header-row"><span class="order-id">#${o.id}</span><div class="status-badges">${badges}</div></div>
                        <div class="customer-row"><div class="customer-avatar">${o.customer.charAt(0)}</div><div class="customer-info"><h4>${o.customer}</h4><p>${o.email}</p></div></div>
                        <div class="order-detail-row">
                            <div class="detail-item"><span class="detail-label">Date</span><div class="detail-value">${o.date}</div></div>
                            <div class="detail-item"><span class="detail-label">Amount</span><div class="detail-value">₹${o.amount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div></div>
                            <div class="detail-item"><span class="detail-label">Items</span><div class="detail-value">${o.productCount}</div></div>
                        </div>
                        <div class="products-preview"><img class="preview-image" src="${o.firstProductImage}" onerror="this.src='https://ui-avatars.com/api/?name=No+Img&background=ccc&color=fff&size=40'"><span>${o.itemsPreview}</span></div>
                        ${paymentInfoRow}
                        ${approvalRow}
                        ${timerHtml}
                        <div class="card-footer"><button class="btn btn-outline card-detail-btn" data-id="${o.id}"><i class="fas fa-info-circle"></i> Details</button></div>
                    </div>`;
                });
                cardContainer.innerHTML = cardHtml;
                let filterParts = [];
                if (currentFilter !== 'all') filterParts.push(capitalize(currentFilter.replace(/_/g, ' ')));
                if (currentPaymentFilter !== 'all') filterParts.push(getPaymentMethodDisplay(currentPaymentFilter));
                if (customerNameFilter) filterParts.push(`Customer: ${customerNameFilter}`);
                if (dateFromFilter || dateToFilter) filterParts.push(`${dateFromFilter ? `from ${dateFromFilter}` : ''}${dateToFilter ? ` to ${dateToFilter}` : ''}`);
                const filterTagText = filterParts.length > 0 ? filterParts.join(' | ') : 'All orders';
                activeFilterTag.innerHTML = `${filterTagText} <span class="clear-filter" id="clearFilter"><i class="fas fa-times-circle"></i></span>`;
                document.getElementById('clearFilter')?.addEventListener('click', clearAllFilters);
                document.querySelectorAll('#tableBody tr').forEach(r => r.addEventListener('click', () => goToOrderDetail(r.dataset.id)));
                filtered.filter(o => o.returnStatus === 'approved' && o.returnApprovedAt).forEach(o => startTimerForOrder(o));
            }

            function clearAllFilters() {
                currentFilter = 'all'; currentPaymentFilter = 'all'; searchQuery = ''; customerNameFilter = ''; dateFromFilter = ''; dateToFilter = '';
                if (searchInput) searchInput.value = ''; if (customerInput) customerInput.value = ''; if (dateFromInput) dateFromInput.value = ''; if (dateToInput) dateToInput.value = '';
                updateDisplay();
            }

            function setActiveView(view) {
                if (view === 'table') {
                    tableView.classList.remove('hidden'); cardViewDiv.classList.add('hidden');
                    tableBtn.classList.add('active-view'); cardBtn.classList.remove('active-view');
                } else {
                    tableView.classList.add('hidden'); cardViewDiv.classList.remove('hidden');
                    cardBtn.classList.add('active-view'); tableBtn.classList.remove('active-view');
                }
            }
            tableBtn.addEventListener('click', () => setActiveView('table'));
            cardBtn.addEventListener('click', () => setActiveView('cards'));
            filterBtn.addEventListener('click', (e) => { e.stopPropagation(); filterMenu.classList.toggle('show'); paymentFilterMenu.classList.remove('show'); });
            paymentFilterBtn.addEventListener('click', (e) => { e.stopPropagation(); paymentFilterMenu.classList.toggle('show'); filterMenu.classList.remove('show'); });
            document.addEventListener('click', (e) => {
                if (!filterBtn.contains(e.target) && !filterMenu.contains(e.target)) filterMenu.classList.remove('show');
                if (!paymentFilterBtn.contains(e.target) && !paymentFilterMenu.contains(e.target)) paymentFilterMenu.classList.remove('show');
            });
            customerInput.addEventListener('keyup', () => { customerNameFilter = customerInput.value.trim(); updateDisplay(); });
            dateFromInput.addEventListener('change', () => { dateFromFilter = dateFromInput.value; updateDisplay(); });
            dateToInput.addEventListener('change', () => { dateToFilter = dateToInput.value; updateDisplay(); });
            searchInput.addEventListener('keyup', () => { searchQuery = searchInput.value.trim(); updateDisplay(); });
            cardContainer.addEventListener('click', (e) => {
                const card = e.target.closest('.order-card'); if (!card) return;
                if (e.target.closest('.card-detail-btn')) { goToOrderDetail(e.target.closest('.card-detail-btn').dataset.id); return; }
                if (!e.target.closest('button')) goToOrderDetail(card.dataset.id);
            });

            fetchOrders();
        })();
    </script>
</body>
</html>