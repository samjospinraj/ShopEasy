    <div id="toastMsg" class="toast-notify"><i class="fas fa-check-circle me-2"></i><span id="toastText">Success!</span></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            const API_BASE = 'http://localhost:3000';

            let isAuthenticated = false;
            let allOrders = [];
            let currentFilter = 'all';
            let currentReviewOrderId = null;
            let selectedRating = 0;
            let selectedVideoFile = null;

            // Particles Background
            const pc = document.getElementById('particles');
            for (let i = 0; i < 30; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                const s = Math.random() * 25 + 5;
                p.style.cssText =
                    `width:${s}px;height:${s}px;background:hsl(${Math.random() * 360},70%,65%);left:${Math.random() * 100}%;top:${Math.random() * 100}%;animation-delay:${Math.random() * 15}s;`;
                pc.appendChild(p);
            }

            window.addEventListener('scroll', () => document.getElementById('header').classList.toggle('scrolled',
                window.scrollY > 50));

            // Star Rating System
            function initStarRating() {
                const stars = document.querySelectorAll('#starRating .star');
                stars.forEach(star => {
                    star.addEventListener('click', function() {
                        const rating = parseInt(this.dataset.rating);
                        selectedRating = rating;
                        document.getElementById('reviewRating').value = rating;
                        updateStars(rating);
                    });

                    star.addEventListener('mouseenter', function() {
                        const rating = parseInt(this.dataset.rating);
                        updateStars(rating);
                    });
                });

                document.getElementById('starRating').addEventListener('mouseleave', function() {
                    updateStars(selectedRating);
                });
            }

            function updateStars(rating) {
                const stars = document.querySelectorAll('#starRating .star');
                stars.forEach(star => {
                    const starRating = parseInt(star.dataset.rating);
                    if (starRating <= rating) {
                        star.classList.add('active');
                    } else {
                        star.classList.remove('active');
                    }
                });
            }

            // Video Upload Functions
            window.handleVideoSelect = function(event) {
                const file = event.target.files[0];
                if (file) {
                    validateAndPreviewVideo(file);
                }
            };

            function validateAndPreviewVideo(file) {
                // Validate file type
                const allowedTypes = ['video/mp4', 'video/webm', 'video/quicktime'];
                if (!allowedTypes.includes(file.type)) {
                    toast('⚠️ Please select a valid video file (MP4, WebM, or MOV)');
                    return;
                }

                // Validate file size (50MB max)
                const maxSize = 50 * 1024 * 1024;
                if (file.size > maxSize) {
                    toast('⚠️ Video file size must be less than 50MB');
                    return;
                }

                // Create video element to check duration
                const video = document.createElement('video');
                video.preload = 'metadata';

                video.onloadedmetadata = function() {
                    window.URL.revokeObjectURL(video.src);
                    
                    // Validate duration (60 seconds max)
                    if (video.duration > 60) {
                        toast('⚠️ Video must be 60 seconds or less');
                        return;
                    }

                    // File is valid
                    selectedVideoFile = file;
                    
                    // Show preview
                    const previewContainer = document.getElementById('videoPreviewContainer');
                    const preview = document.getElementById('videoPreview');
                    const videoInfo = document.getElementById('videoInfo');
                    const videoInfoText = document.getElementById('videoInfoText');
                    const uploadArea = document.getElementById('videoUploadArea');

                    preview.src = URL.createObjectURL(file);
                    previewContainer.classList.add('show');
                    uploadArea.style.display = 'none';
                    videoInfo.style.display = 'flex';
                    
                    const durationSec = Math.round(video.duration);
                    const sizeMB = (file.size / (1024 * 1024)).toFixed(1);
                    videoInfoText.textContent = `Video ready • ${durationSec}s • ${sizeMB}MB`;
                };

                video.src = URL.createObjectURL(file);
            };

            window.removeVideo = function() {
                selectedVideoFile = null;
                document.getElementById('videoInput').value = '';
                document.getElementById('videoPreviewContainer').classList.remove('show');
                document.getElementById('videoPreview').src = '';
                document.getElementById('videoUploadArea').style.display = 'block';
                document.getElementById('videoInfo').style.display = 'none';
                document.getElementById('uploadProgress').classList.remove('show');
            };

            // Drag and Drop for Video
            const videoUploadArea = document.getElementById('videoUploadArea');
            if (videoUploadArea) {
                videoUploadArea.addEventListener('dragover', function(e) {
                    e.preventDefault();
                    this.classList.add('dragover');
                });

                videoUploadArea.addEventListener('dragleave', function(e) {
                    e.preventDefault();
                    this.classList.remove('dragover');
                });

                videoUploadArea.addEventListener('drop', function(e) {
                    e.preventDefault();
                    this.classList.remove('dragover');
                    
                    const file = e.dataTransfer.files[0];
                    if (file) {
                        validateAndPreviewVideo(file);
                    }
                });
            }

            function toast(msg) {
                const t = document.getElementById('toastMsg');
                document.getElementById('toastText').innerText = msg;
                t.classList.add('show');
                setTimeout(() => t.classList.remove('show'), 2800);
            }

            function updateCartBadge(count = 0) {
                document.getElementById('cartCount').innerText = count;
            }

            function redirectToLogin() {
                window.location.href = `/login?returnTo=${encodeURIComponent(window.location.href)}`;
            }

            async function checkAuth() {
                try {
                    const res = await fetch(`${API_BASE}/api/check-auth`, { credentials: 'include' });
                    if (res.ok) {
                        const json = await res.json();
                        isAuthenticated = json.loggedIn === true;
                    } else { isAuthenticated = false; }
                } catch (e) {
                    isAuthenticated = false;
                }
                updateLoginUI();
                if (!isAuthenticated) {
                    redirectToLogin();
                    return false;
                }
                return true;
            }

            function updateLoginUI() {
                const menuLogout = document.getElementById('menuLogout');
                const userIconBtn = document.getElementById('userIconBtn');
                if (menuLogout) menuLogout.style.display = isAuthenticated ? 'flex' : 'none';
                if (userIconBtn) userIconBtn.style.color = isAuthenticated ? '#4ecdc4' : '#666';
            }

            async function fetchCartCount() {
                if (!isAuthenticated) { updateCartBadge(0); return 0; }
                try {
                    const res = await fetch(`${API_BASE}/carts`, { credentials: 'include' });
                    if (res.ok) {
                        const json = await res.json();
                        if (json.success) {
                            const count = json.count || (json.data ? json.data.length : 0);
                            updateCartBadge(count);
                            return count;
                        }
                    }
                } catch (e) {}
                return 0;
            }

            async function fetchOrders() {
                const ordersContainer = document.getElementById('ordersContainer');
                const loadingDiv = document.getElementById('ordersLoading');
                const emptyState = document.getElementById('emptyState');

                if (loadingDiv) loadingDiv.style.display = 'block';
                emptyState.style.display = 'none';
                ordersContainer.innerHTML = '';

                try {
                    const res = await fetch(`${API_BASE}/orders`, { credentials: 'include' });
                    const result = await res.json();

                    console.log('Orders response:', result);

                    if (res.ok && result.success) {
                        let ordersData = result.orders;

                        if (!ordersData) {
                            allOrders = [];
                        } else if (Array.isArray(ordersData)) {
                            allOrders = ordersData;
                        } else if (typeof ordersData === 'object' && ordersData._id) {
                            allOrders = [ordersData];
                        } else if (ordersData.items && Array.isArray(ordersData.items)) {
                            allOrders = [ordersData];
                        } else {
                            allOrders = [];
                        }

                        console.log('Processed orders:', allOrders);
                        updateStats();
                        renderOrders(allOrders);
                    } else {
                        throw new Error(result.message || 'Failed to fetch orders');
                    }
                } catch (error) {
                    console.error('Error fetching orders:', error);
                    allOrders = [];
                    updateStats();
                    renderOrders([]);
                    toast('Error loading orders: ' + error.message);
                }
            }

            function updateStats() {
                const statusCounts = {
                    all: allOrders.length,
                    pending: 0,
                    confirmed: 0,
                    processing: 0,
                    packed: 0,
                    shipped: 0,
                    'out for delivery': 0,
                    delivered: 0,
                    cancelled: 0
                };

                allOrders.forEach(order => {
                    const status = (order.orderStatus || '').toLowerCase();
                    if (statusCounts.hasOwnProperty(status)) {
                        statusCounts[status]++;
                    }
                });

                document.getElementById('statAll').textContent = statusCounts.all;
                document.getElementById('statPending').textContent = statusCounts.pending;
                document.getElementById('statConfirmed').textContent = statusCounts.confirmed;
                document.getElementById('statProcessing').textContent = statusCounts.processing;
                document.getElementById('statPacked').textContent = statusCounts.packed;
                document.getElementById('statShipped').textContent = statusCounts.shipped;
                document.getElementById('statOutForDelivery').textContent = statusCounts['out for delivery'];
                document.getElementById('statDelivered').textContent = statusCounts.delivered;
                document.getElementById('statCancelled').textContent = statusCounts.cancelled;
            }

            window.filterOrders = function(filter) {
                currentFilter = filter;

                document.querySelectorAll('.stat-card').forEach(card => card.classList.remove('active'));
                const statCard = document.querySelector(`.stat-card[data-filter="${filter}"]`);
                if (statCard) statCard.classList.add('active');

                document.querySelectorAll('.filter-tab').forEach(tab => tab.classList.remove('active'));
                const filterTab = document.querySelector(`.filter-tab[data-filter="${filter}"]`);
                if (filterTab) filterTab.classList.add('active');

                let filteredOrders = allOrders;
                if (filter !== 'all') {
                    filteredOrders = allOrders.filter(o => (o.orderStatus || '').toLowerCase() === filter.toLowerCase());
                }

                renderOrders(filteredOrders);
            };

            function renderOrders(orders) {
                const ordersContainer = document.getElementById('ordersContainer');
                const loadingDiv = document.getElementById('ordersLoading');
                const emptyState = document.getElementById('emptyState');

                if (loadingDiv) loadingDiv.style.display = 'none';

                if (!orders || orders.length === 0) {
                    ordersContainer.innerHTML = '';
                    emptyState.style.display = 'block';

                    if (currentFilter === 'all') {
                        document.getElementById('emptyStateMessage').textContent =
                            "You haven't placed any orders yet. Start shopping now!";
                    } else {
                        document.getElementById('emptyStateMessage').textContent =
                            `No ${currentFilter} orders found.`;
                    }
                    return;
                }

                emptyState.style.display = 'none';

                let html = '';
                orders.forEach((order, index) => {
                    html += createOrderCard(order, index);
                });

                ordersContainer.innerHTML = html;
                initStarRating();
            }

            function createOrderCard(order, index) {
                const orderId = order._id || order.orderId || 'N/A';
                const shortOrderId = orderId.toString().substring(orderId.toString().length - 8);

                const orderDate = order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-IN', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                }) : 'N/A';

                const orderStatus = (order.orderStatus || 'pending').toLowerCase();
                const totalAmount = order.totalAmount || 0;
                const paymentMethod = order.paymentMethod === 'cashOnDelivery' ? 'Cash on Delivery' :
                    order.paymentMethod === 'onlinePayment' ? 'Online Payment' :
                    order.paymentMethod || 'N/A';

                const statusClass = `status-${orderStatus.replace(/\s+/g, '')}`;
                const statusDotClass = `dot-${orderStatus.replace(/\s+/g, '')}`;
                const statusLabel = orderStatus.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

                const items = order.items || [];
                let itemsHTML = '';
                const maxVisible = 4;

                items.slice(0, maxVisible).forEach(item => {
                    const product = item.productId || item;
                    const productName = product?.productName || product?.name || 'Product';
                    const brand = product?.brand || '';
                    const model = product?.model || '';
                    const quantity = item.quantity || 1;

                    let imageUrl =
                        'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=40&h=40&fit=crop';

                    if (product?.mainImage) {
                        if (typeof product.mainImage === 'string') {
                            imageUrl = product.mainImage;
                        } else if (product.mainImage.path || product.mainImage.url || product.mainImage
                            .secure_url) {
                            imageUrl = product.mainImage.path || product.mainImage.url || product.mainImage
                                .secure_url;
                        }
                    }

                    const brandText = brand ? (model ? `${brand} - ${model}` : brand) : '';

                    itemsHTML += `
                    <div class="order-item-chip">
                        <img src="${imageUrl}" alt="${productName}" class="order-item-img" onerror="this.src='https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=40&h=40&fit=crop'">
                        <div class="order-item-info">
                            <div class="order-item-name" title="${productName}${brandText ? ' - ' + brandText : ''}">${productName}</div>
                            <div class="order-item-qty">Qty: ${quantity}</div>
                        </div>
                    </div>`;
                });

                if (items.length > maxVisible) {
                    itemsHTML +=
                    `<div class="more-items-badge">+${items.length - maxVisible} more</div>`;
                }

                let progressHTML = '';
                const progressSteps = ['pending', 'confirmed', 'processing', 'packed', 'shipped', 'out for delivery',
                    'delivered'
                ];
                const currentStepIndex = progressSteps.indexOf(orderStatus);

                if (orderStatus === 'cancelled') {
                    progressHTML = `
                    <div class="order-progress">
                        <div class="progress-step cancelled-step">
                            <div class="progress-line"></div>
                            <div class="progress-dot" style="background:#ef4444;box-shadow:0 0 0 2px #ef4444;"></div>
                            <span class="progress-label" style="color:#ef4444;">Cancelled</span>
                        </div>
                        ${progressSteps.slice(1).map(step => `
                            <div class="progress-step">
                                <div class="progress-line"></div>
                                <div class="progress-dot"></div>
                                <span class="progress-label">${step === 'out for delivery' ? 'Out for Delivery' : step.charAt(0).toUpperCase() + step.slice(1)}</span>
                            </div>`).join('')}
                    </div>`;
                } else {
                    progressHTML = `
                    <div class="order-progress">
                        ${progressSteps.map((step, i) => {
                            let stepClass = '';
                            let lineClass = '';
                            if (i < currentStepIndex) stepClass = 'completed';
                            else if (i === currentStepIndex) stepClass = 'active';
                            if (i < progressSteps.length - 1) {
                                lineClass = i < currentStepIndex ? 'progress-line fill' : 'progress-line';
                            }
                            return `
                            <div class="progress-step ${stepClass}">
                                ${i < progressSteps.length - 1 ? `<div class="${lineClass}"></div>` : ''}
                                <div class="progress-dot"></div>
                                <span class="progress-label">${step === 'out for delivery' ? 'Out for Delivery' : step.charAt(0).toUpperCase() + step.slice(1)}</span>
                            </div>`;
                        }).join('')}
                    </div>`;
                }

                const city = order.city || 'N/A';
                const state = order.state || '';
                const country = order.country || 'India';

                const nonCancellableStatuses = ['shipped', 'out for delivery', 'delivered', 'cancelled'];
                const canCancel = !nonCancellableStatuses.includes(orderStatus);

                return `
                <div class="order-card" style="animation-delay: ${index * 0.1}s">
                    <div class="order-header">
                        <div>
                            <div class="order-id-section">
                                <span class="order-id">#${shortOrderId}</span>
                                <span class="order-date"><i class="far fa-calendar-alt me-1"></i>${orderDate}</span>
                            </div>
                            <div class="delivery-info-row mt-2">
                                <i class="fas fa-map-marker-alt"></i>
                                <span>${city}${state ? ', ' + state : ''}, ${country} 🇮🇳</span>
                            </div>
                        </div>
                        <div class="order-status-badge ${statusClass}">
                            <span class="status-dot ${statusDotClass}"></span>
                            ${statusLabel}
                        </div>
                    </div>

                    ${progressHTML}

                    <div class="order-items">
                        ${itemsHTML || '<span class="text-muted small">No items</span>'}
                    </div>

                    <div class="order-footer">
                        <div>
                            <small class="text-muted d-block">Total Amount</small>
                            <span class="order-total">₹${Number(totalAmount).toFixed(2)}</span>
                            <small class="text-muted d-block mt-1">
                                <i class="fas fa-credit-card me-1"></i>${paymentMethod}
                            </small>
                        </div>
                        <div class="order-actions">
                            <button class="btn-order-action primary" onclick="viewOrderDetails('${orderId}')">
                                <i class="fas fa-eye"></i> View Details
                            </button>
                            ${orderStatus === 'delivered' ? `
                            <button class="btn-order-action purple" onclick="openReviewModal('${orderId}')">
                                <i class="fas fa-star"></i> Write Review
                            </button>
                            <button class="btn-order-action warning" onclick="openReturnModal('${orderId}')">
                                <i class="fas fa-undo-alt"></i> Return
                            </button>
                            <button class="btn-order-action" onclick="buyAgain('${orderId}')">
                                <i class="fas fa-redo"></i> Buy Again
                            </button>` : ''}
                            ${(orderStatus === 'cancelled') ? `
                            <button class="btn-order-action info" onclick="openRefundModal('${orderId}')">
                                <i class="fas fa-money-bill-wave"></i> Refund
                            </button>` : ''}
                            ${canCancel ? `
                            <button class="btn-order-action danger" onclick="cancelOrder('${orderId}')">
                                <i class="fas fa-times"></i> Cancel
                            </button>` : ''}
                        </div>
                    </div>
                </div>`;
            }

            // Modal Functions
            window.openReviewModal = function(orderId) {
                currentReviewOrderId = orderId;
                selectedRating = 0;
                document.getElementById('reviewRating').value = '0';
                updateStars(0);
                document.getElementById('reviewTitle').value = '';
                document.getElementById('reviewComments').value = '';
                removeVideo();
                document.getElementById('reviewModal').classList.add('show');
            };

            window.closeReviewModal = function() {
                document.getElementById('reviewModal').classList.remove('show');
                currentReviewOrderId = null;
                removeVideo();
            };

            window.openReturnModal = function(orderId) {
                currentReviewOrderId = orderId;
                document.getElementById('returnReason').value = '';
                document.getElementById('returnComments').value = '';
                document.getElementById('returnModal').classList.add('show');
            };

            window.closeReturnModal = function() {
                document.getElementById('returnModal').classList.remove('show');
                document.getElementById('returnReason').value = '';
                document.getElementById('returnComments').value = '';
            };

            window.openRefundModal = function(orderId) {
                currentReviewOrderId = orderId;
                document.getElementById('refundReason').value = '';
                document.getElementById('refundComments').value = '';
                document.getElementById('refundModal').classList.add('show');
            };

            window.closeRefundModal = function() {
                document.getElementById('refundModal').classList.remove('show');
                document.getElementById('refundReason').value = '';
                document.getElementById('refundComments').value = '';
            };

            window.submitReview = async function() {
                const rating = parseInt(document.getElementById('reviewRating').value);
                const title = document.getElementById('reviewTitle').value.trim();
                const comments = document.getElementById('reviewComments').value.trim();

                if (!rating || rating < 1 || rating > 5) {
                    toast('⚠️ Please select a rating');
                    return;
                }

                if (!title) {
                    toast('⚠️ Please enter a review title');
                    return;
                }

                if (!comments) {
                    toast('⚠️ Please write your review');
                    return;
                }

                try {
                    // If video is selected, upload it first
                    let videoUrl = null;
                    if (selectedVideoFile) {
                        toast('📤 Uploading video...');
                        videoUrl = await uploadVideo(selectedVideoFile);
                        if (!videoUrl) {
                            toast('⚠️ Video upload failed. Submitting review without video.');
                        }
                    }

                    toast('📝 Submitting your review...');

                    const reviewData = {
                        orderId: currentReviewOrderId,
                        rating: rating,
                        title: title,
                        review: comments
                    };

                    if (videoUrl) {
                        reviewData.videoUrl = videoUrl;
                        reviewData.videoFileName = selectedVideoFile.name;
                    }

                    const res = await fetch(`${API_BASE}/product/review`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify(reviewData)
                    });

                    const result = await res.json();

                    if (res.ok && result.success) {
                        closeReviewModal();
                        toast('⭐ Review submitted successfully! Thank you for your feedback.');
                    } else {
                        toast('❌ ' + (result.message || 'Failed to submit review'));
                    }
                } catch (e) {
                    console.error('Review submission error:', e);
                    toast('❌ Network error. Please try again.');
                }
            };

            async function uploadVideo(file) {
                const formData = new FormData();
                formData.append('video', file);
                formData.append('orderId', currentReviewOrderId);

                const progressBar = document.getElementById('uploadProgressBar');
                const progressContainer = document.getElementById('uploadProgress');
                progressContainer.classList.add('show');
                progressBar.style.width = '0%';

                try {
                    // Simulate upload progress
                    const progressInterval = setInterval(() => {
                        const currentWidth = parseInt(progressBar.style.width) || 0;
                        if (currentWidth < 90) {
                            progressBar.style.width = (currentWidth + Math.random() * 15) + '%';
                        }
                    }, 300);

                    const res = await fetch(`${API_BASE}/product/review/upload-video`, {
                        method: 'POST',
                        credentials: 'include',
                        body: formData
                    });

                    clearInterval(progressInterval);
                    progressBar.style.width = '100%';

                    const result = await res.json();

                    if (res.ok && result.success) {
                        progressContainer.classList.remove('show');
                        return result.videoUrl || result.url;
                    } else {
                        progressContainer.classList.remove('show');
                        console.error('Video upload failed:', result.message);
                        return null;
                    }
                } catch (e) {
                    console.error('Video upload error:', e);
                    document.getElementById('uploadProgress').classList.remove('show');
                    return null;
                }
            }

            window.submitReturn = async function() {
                const reason = document.getElementById('returnReason').value;
                const comments = document.getElementById('returnComments').value;

                if (!reason) {
                    toast('⚠️ Please select a return reason');
                    return;
                }

                try {
                    toast('🔄 Processing return request...');

                    const res = await fetch(`${API_BASE}/order/return-request/${currentReviewOrderId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ returnReason: reason, returnComments: comments })
                    });

                    const result = await res.json();

                    if (res.ok && result.success) {
                        closeReturnModal();
                        toast('✅ Return request submitted successfully');
                        setTimeout(() => fetchOrders(), 1500);
                    } else {
                        toast('❌ ' + (result.message || 'Failed to submit return request'));
                    }
                } catch (e) {
                    console.error('Return request error:', e);
                    toast('❌ Network error. Please try again.');
                }
            };

            window.submitRefund = async function() {
                const reason = document.getElementById('refundReason').value;
                const comments = document.getElementById('refundComments').value;

                if (!reason) {
                    toast('⚠️ Please select a refund reason');
                    return;
                }

                try {
                    toast('🔄 Processing refund request...');

                    const res = await fetch(`${API_BASE}/orders/refund/${currentReviewOrderId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ refundReason: reason, refundComments: comments })
                    });

                    const result = await res.json();

                    if (res.ok && result.success) {
                        closeRefundModal();
                        toast('✅ Refund request submitted successfully');
                        setTimeout(() => fetchOrders(), 1500);
                    } else {
                        toast('❌ ' + (result.message || 'Failed to submit refund request'));
                    }
                } catch (e) {
                    console.error('Refund request error:', e);
                    toast('❌ Network error. Please try again.');
                }
            };

            // Close modals on overlay click
            document.getElementById('reviewModal').addEventListener('click', function(e) {
                if (e.target === this) closeReviewModal();
            });

            document.getElementById('returnModal').addEventListener('click', function(e) {
                if (e.target === this) closeReturnModal();
            });

            document.getElementById('refundModal').addEventListener('click', function(e) {
                if (e.target === this) closeRefundModal();
            });

            window.viewOrderDetails = function(orderId) {
                window.location.href = `/myOrder/${orderId}`;
            };

            window.buyAgain = function(orderId) {
                const order = allOrders.find(o => (o._id || o.orderId) === orderId);
                if (order && order.items && order.items.length > 0) {
                    toast('🛒 Adding items to cart...');
                    setTimeout(() => {
                        window.location.href = '/cart';
                    }, 1000);
                }
            };

            window.cancelOrder = async function(orderId) {
                if (!confirm('Are you sure you want to cancel this order? This action cannot be undone.')) return;

                try {
                    toast('⏳ Cancelling order...');

                    const res = await fetch(`${API_BASE}/orders/cancel/${orderId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include'
                    });

                    const result = await res.json();

                    console.log('Cancel order response:', result);

                    if (res.ok && result.success) {
                        toast('✅ Order cancelled successfully');
                        await fetchOrders();
                    } else {
                        const errorMsg = result.message || 'Failed to cancel order';
                        toast('❌ ' + errorMsg);
                    }
                } catch (e) {
                    console.error('Cancel order error:', e);
                    toast('❌ Network error. Please try again.');
                }
            };

            document.getElementById('userIconBtn').addEventListener('click', (e) => {
                e.stopPropagation();
                if (!isAuthenticated) { redirectToLogin(); return; }
                document.getElementById('userDropdownMenu').classList.toggle('show');
            });

            document.addEventListener('click', (e) => {
                if (!e.target.closest('#userDropdown'))
                    document.getElementById('userDropdownMenu').classList.remove('show');
            });

            document.getElementById('menuLogout').addEventListener('click', async (e) => {
                e.preventDefault();
                try {
                    await fetch('/logout', { method: 'GET', credentials: 'include' });
                } catch (e) {
                    console.error('Logout error:', e);
                }
                isAuthenticated = false;
                updateLoginUI();
                updateCartBadge(0);
                toast('Logged out 🚪');
                setTimeout(() => redirectToLogin(), 800);
            });

            (async () => {
                if (await checkAuth()) {
                    await fetchCartCount();
                    await fetchOrders();
                }
            })();
        })();
    </script>
</body>

</html>