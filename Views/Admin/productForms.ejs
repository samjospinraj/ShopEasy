<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>ShopMaster · Complete Product Management Suite</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", Roboto, system-ui, sans-serif;
        }

        :root {
            --primary-blue: #2c6de9;
            --dark-blue: #1a4fb3;
            --light-blue: #e8f1ff;
            --accent-green: #10b981;
            --accent-orange: #f59e0b;
            --accent-red: #ef4444;
            --dark-charcoal: #1f2937;
            --medium-charcoal: #374151;
            --light-charcoal: #f9fafb;
            --white: #ffffff;
            --shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
            --border-radius: 12px;
            --transition: all 0.25s ease;
        }

        body {
            background: linear-gradient(145deg, #f0f5fe 0%, #e9f0fa 100%);
            color: var(--dark-charcoal);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: 280px;
            background: var(--white);
            color: var(--dark-charcoal);
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            border-right: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: var(--shadow);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 0 20px 20px 20px;
            border-bottom: 1px solid #eef2f6;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-text {
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--primary-blue);
        }

        .logo-subtext {
            font-size: 0.7rem;
            color: var(--medium-charcoal);
        }

        .toggle-sidebar {
            background: transparent;
            border: 2px solid var(--primary-blue);
            color: var(--primary-blue);
            width: 38px;
            height: 38px;
            border-radius: 8px;
            cursor: pointer;
            transition: var(--transition);
        }

        .toggle-sidebar:hover {
            background: var(--primary-blue);
            color: white;
        }

        .sidebar-menu {
            flex: 1;
            padding: 20px 0;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 14px 20px;
            color: var(--medium-charcoal);
            text-decoration: none;
            transition: var(--transition);
            border-left: 4px solid transparent;
            cursor: pointer;
            font-weight: 450;
        }

        .menu-item:hover,
        .menu-item.active-menu {
            background: var(--light-blue);
            border-left-color: var(--primary-blue);
            color: var(--primary-blue);
        }

        .menu-item i {
            width: 24px;
            font-size: 1.2rem;
            margin-right: 14px;
        }

        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 20px 30px;
            transition: margin-left 0.3s ease;
            width: 100%;
        }

        /* HEADER */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--white);
            padding: 16px 28px;
            border-radius: 40px;
            box-shadow: var(--shadow);
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .menu-toggle {
            display: none;
            background: transparent;
            border: 2px solid var(--primary-blue);
            color: var(--primary-blue);
            width: 45px;
            height: 45px;
            border-radius: 12px;
            cursor: pointer;
            font-size: 1.3rem;
            align-items: center;
            justify-content: center;
        }

        .search-bar {
            display: flex;
            align-items: center;
            background: var(--light-charcoal);
            border-radius: 40px;
            padding: 8px 20px;
            width: min(400px, 100%);
            border: 1px solid #dee4ed;
        }

        .search-bar input {
            border: none;
            background: transparent;
            padding: 8px 10px;
            width: 100%;
            outline: none;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 6px 16px 6px 10px;
            background: var(--light-charcoal);
            border-radius: 40px;
        }

        .user-info img {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 2px solid var(--primary-blue);
            object-fit: cover;
        }

        /* Delivery Counter */
        .delivery-counter {
            background: linear-gradient(135deg, var(--primary-blue), var(--dark-blue));
            color: white;
            padding: 16px 20px;
            border-radius: 16px;
            margin-top: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .delivery-counter .counter-label {
            font-size: 0.85rem;
            opacity: 0.9;
            font-weight: 500;
        }

        .delivery-counter .counter-values {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .delivery-counter .counter-item {
            text-align: center;
        }

        .delivery-counter .counter-number {
            font-size: 1.8rem;
            font-weight: 700;
            line-height: 1;
        }

        .delivery-counter .counter-unit {
            font-size: 0.75rem;
            opacity: 0.8;
            margin-top: 2px;
        }

        .delivery-counter .counter-divider {
            font-size: 1.5rem;
            font-weight: 300;
            opacity: 0.6;
        }

        .delivery-counter .delivery-dates {
            font-size: 0.8rem;
            opacity: 0.85;
            text-align: right;
        }

        .delivery-counter .delivery-dates span {
            display: block;
        }

        /* FORM STYLES */
        .form-card {
            background: var(--white);
            border-radius: 30px;
            padding: 32px;
            box-shadow: var(--shadow);
            border: 1px solid #edf2f7;
            max-width: 100%;
            margin: 0 auto 30px auto;
        }

        .category-section {
            margin-bottom: 32px;
            background: var(--white);
            border-radius: 24px;
            border: 1px solid #edf2f7;
            overflow: hidden;
        }

        .category-title {
            background: var(--light-charcoal);
            padding: 18px 24px;
            font-size: 1.2rem;
            font-weight: 600;
            border-bottom: 1px solid #eef2f6;
            margin: 0;
        }

        .category-title i {
            color: var(--primary-blue);
            margin-right: 12px;
        }

        .subcategory {
            border-bottom: 1px solid #eef2f6;
        }

        .subcategory-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 24px;
            background: #fefefe;
            cursor: pointer;
            transition: var(--transition);
            font-weight: 500;
        }

        .subcategory-header:hover {
            background: var(--light-blue);
        }

        .subcategory-content {
            padding: 20px 24px;
            border-top: 1px solid #eef2f6;
            background: var(--white);
            display: block;
        }

        .form-row-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 8px;
            color: var(--dark-charcoal);
        }

        .required:after {
            content: " *";
            color: var(--accent-red);
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 18px;
            font-size: 0.95rem;
            transition: var(--transition);
            background: var(--light-charcoal);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px rgba(44, 109, 233, 0.15);
            background: var(--white);
        }

        .error-border {
            border: 2px solid #dc3545 !important;
            background-color: #fff8f8 !important;
        }

        .error-message {
            color: #dc3545;
            font-size: 12px;
            margin-top: 5px;
        }

        .hint {
            font-size: 0.7rem;
            color: var(--medium-charcoal);
            margin-top: 5px;
        }

        .specification-row {
            display: flex;
            gap: 12px;
            margin-bottom: 12px;
            align-items: center;
            flex-wrap: wrap;
        }

        .spec-input {
            flex: 1;
        }

        .btn-small {
            padding: 8px 14px;
            font-size: 0.8rem;
            border-radius: 40px;
        }

        .btn-danger {
            background: #fee2e2;
            color: var(--accent-red);
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn-secondary {
            background: var(--light-blue);
            color: var(--primary-blue);
            border: none;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 8px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .file-upload {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .image-preview,
        .video-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 12px;
        }

        .preview-item {
            position: relative;
            width: 90px;
            height: 90px;
            border-radius: 16px;
            border: 2px solid #e2e8f0;
            overflow: hidden;
            background: #f8fafc;
        }

        .preview-item img,
        .preview-item video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .preview-label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.6);
            color: white;
            font-size: 0.65rem;
            text-align: center;
        }

        .remove-image,
        .remove-video {
            position: absolute;
            top: 2px;
            right: 2px;
            background: rgba(239, 68, 68, 0.9);
            color: white;
            border: none;
            border-radius: 30px;
            width: 20px;
            height: 20px;
            font-size: 12px;
            cursor: pointer;
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 16px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 2px solid #eef2f6;
        }

        .btn {
            padding: 14px 32px;
            border: none;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            background: var(--primary-blue);
            color: white;
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-primary:hover {
            background: var(--dark-blue);
            transform: translateY(-2px);
        }

        /* Toast Notifications */
        .toast-notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 20px;
            border-radius: 12px;
            color: white;
            z-index: 10000;
            animation: slideInRight 0.3s ease;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            max-width: 400px;
        }

        .toast-success {
            background: #10b981;
        }

        .toast-error {
            background: #ef4444;
        }

        .toast-info {
            background: #3b82f6;
        }

        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @keyframes slideOutRight {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(100%);
                opacity: 0;
            }
        }

        @media (max-width: 992px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.active {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
            .menu-toggle {
                display: flex;
            }
        }

        @media (max-width: 768px) {
            .form-row-grid {
                grid-template-columns: 1fr;
            }
            .form-card {
                padding: 20px;
            }
            .delivery-counter {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>

<body>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div>
                <div class="logo-text">ShopMaster</div>
                <div class="logo-subtext">admin panel</div>
            </div>
            <button class="toggle-sidebar" id="toggleSidebarBtn">
                <i class="fas fa-chevron-left"></i>
            </button>
        </div>
        <div class="sidebar-menu">
            <a href="/Admin/dashboard" class="menu-item"><i class="fas fa-tachometer-alt"></i><span
                    class="menu-text">Dashboard</span></a>
            <a href="/Admin/product" class="menu-item active-menu"><i class="fas fa-box"></i><span
                    class="menu-text">Products</span></a>
            <a href="/Admin/category" class="menu-item"><i class="fas fa-tags"></i><span
                    class="menu-text">Categories</span></a>
            <a href="/Admin/order" class="menu-item"><i class="fas fa-shopping-cart"></i><span
                    class="menu-text">Orders</span></a>
            <a href="/Admin/customer" class="menu-item"><i class="fas fa-users"></i><span
                    class="menu-text">Customers</span></a>
            <a href="/Admin/analytics" class="menu-item"><i class="fas fa-chart-line"></i><span
                    class="menu-text">Analytics</span></a>
            <a href="/Admin/profile" class="menu-item"><i class="fas fa-id-badge"></i><span
                    class="menu-text">Profile</span></a>
            <a href="/Admin/setting" class="menu-item"><i class="fas fa-cog"></i><span
                    class="menu-text">Settings</span></a>
        </div>
    </div>

    <div class="main-content" id="mainContent">
        <div class="header">
            <button class="menu-toggle" id="mobileMenuToggle">
                <i class="fas fa-bars"></i>
            </button>
            <div class="search-bar">
                <i class="fas fa-search"></i><input type="text" placeholder="Search products..." />
            </div>
            <div class="user-info">
                <a href="/Admin/profile">
                    <img src="https://ui-avatars.com/api/?name=Admin+Master&background=2c6de9&color=fff&bold=true&size=42"
                        alt="admin" />
                </a>
                <div class="user-details">
                    <h4>Alex Master</h4>
                    <p>Super Admin</p>
                </div>
            </div>
        </div>

        <div class="form-card">
            <form id="productForm" enctype="multipart/form-data">
                <!-- Basic Information -->
                <div class="category-section">
                    <h2 class="category-title">
                        <i class="fas fa-info-circle"></i> Basic Information
                    </h2>

                    <div class="subcategory">
                        <div class="subcategory-header">
                            <h3>Product Identification</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="form-row-grid">
                                <div class="form-group">
                                    <label class="required">Product Name</label>
                                    <input type="text" name="productName" class="form-control"
                                        placeholder="Enter product name (3-100 chars)" id="prodName" minlength="3"
                                        maxlength="100" />
                                </div>
                                <div class="form-group">
                                    <label class="required">SKU</label>
                                    <input type="text" name="sku" class="form-control"
                                        placeholder="Product SKU (3-60 chars)" id="sku" minlength="3" maxlength="60" />
                                </div>
                            </div>
                            <div class="form-row-grid">
                                <div class="form-group">
                                    <label class="required">Brand</label>
                                    <input type="text" name="brand" class="form-control"
                                        placeholder="Brand (2-60 chars)" id="brand" minlength="2" maxlength="60" />
                                </div>
                                <div class="form-group">
                                    <label class="required">Model</label>
                                    <input type="text" name="model" class="form-control"
                                        placeholder="Model (1-60 chars)" id="model" minlength="1" maxlength="60" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="subcategory">
                        <div class="subcategory-header">
                            <h3>Categorization</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="form-row-grid">
                                <div class="form-group">
                                    <label class="required">Main Category</label>
                                    <select name="category" class="form-control" id="mainCategorySelect">
                                        <option value="">Select category</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Subcategory</label>
                                    <select name="subcategory" id="subCategorySelect" class="form-control">
                                        <option value="">Select subcategory</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row-grid">
                                <div class="form-group">
                                    <label>Sub-subcategory</label>
                                    <select name="sub_subcategory" class="form-control" id="subSubCategorySelect">
                                        <option value="">Select sub-subcategory</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="required">Product Size</label>
                                    <select name="size" class="form-control" id="sizeSelect">
                                        <option value="">Select size</option>
                                        <option value="S">S</option>
                                        <option value="M" selected>M</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                        <option value="NONE">NONE</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pricing & Inventory -->
                <div class="category-section">
                    <h2 class="category-title">
                        <i class="fas fa-tag"></i> Pricing & Inventory
                    </h2>
                    <div class="subcategory">
                        <div class="subcategory-header">
                            <h3>Pricing Details</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="form-row-grid">
                                <div class="form-group">
                                    <label class="required">Price ($)</label>
                                    <input type="number" step="0.01" name="price" class="form-control"
                                        placeholder="Non-negative number" id="price" min="0" />
                                </div>
                                <div class="form-group">
                                    <label>Compare at Price</label>
                                    <input type="number" step="0.01" name="comparePrice" class="form-control"
                                        id="comparePrice" min="0" />
                                </div>
                            </div>
                            <div class="form-row-grid">
                                <div class="form-group">
                                    <label>Cost per Item</label>
                                    <input type="number" step="0.01" name="costPrice" class="form-control"
                                        id="costPrice" min="0" />
                                </div>
                                <div class="form-group">
                                    <label>Offer (%)</label>
                                    <input type="number" step="0.1" name="offerPercent" class="form-control"
                                        placeholder="0-100" id="offerPercent" min="0" max="100" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="subcategory">
                        <div class="subcategory-header">
                            <h3>Inventory</h3>
                            <span><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="subcategory-content">
                            <div class="form-row-grid">
                                <div class="form-group">
                                    <label class="required">Stock Quantity</label>
                                    <input type="number" name="stockQuantity" class="form-control"
                                        placeholder="Non-negative integer" id="stock" min="0" />
                                </div>
                                <div class="form-group">
                                    <label>Low Stock Threshold</label>
                                    <input type="number" name="lowStockThreshold" class="form-control"
                                        placeholder="Non-negative integer" id="lowStockThreshold" min="0" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Barcode</label>
                                <input type="text" name="barcode" class="form-control"
                                    placeholder="Barcode (3-60 chars)" id="barcode" minlength="3" maxlength="60" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Key Specifications -->
                <div class="category-section">
                    <h2 class="category-title">
                        <i class="fas fa-key"></i> Key Specifications
                    </h2>
                    <div class="subcategory-content">
                        <div id="keySpecsContainer">
                            <div class="specification-row">
                                <div class="spec-input">
                                    <input type="text" name="keySpecs_keys[]" class="form-control"
                                        placeholder="Spec name" />
                                </div>
                                <div class="spec-input">
                                    <input type="text" name="keySpecs_values[]" class="form-control"
                                        placeholder="Value" />
                                </div>
                                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                            </div>
                        </div>
                        <button type="button" class="btn-secondary" id="addKeySpecBtn">
                            <i class="fas fa-plus"></i> Add Key Spec
                        </button>
                    </div>
                </div>

                <!-- Description -->
                <div class="category-section">
                    <h2 class="category-title">
                        <i class="fas fa-file-alt"></i> Description
                    </h2>
                    <div class="subcategory-content">
                        <div class="form-group">
                            <label class="required">Short Description</label>
                            <textarea name="shortDescription" class="form-control" rows="2"
                                placeholder="Brief summary (3-300 chars)" id="shortDesc" minlength="3"
                                maxlength="300"></textarea>
                        </div>
                        <div class="form-group">
                            <label class="required">Full Description</label>
                            <textarea name="fullDescription" class="form-control" rows="4"
                                placeholder="Detailed product description (3-2000 chars)" id="fullDesc" minlength="3"
                                maxlength="2000"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Technical Specifications -->
                <div class="category-section">
                    <h2 class="category-title">
                        <i class="fas fa-list-alt"></i> Technical Specifications
                    </h2>
                    <div class="subcategory-content">
                        <div class="form-group">
                            <label>Spec Title</label>
                            <input type="text" name="specTitle" class="form-control"
                                placeholder="e.g., Technical Specs (3-100 chars)" id="specTitle" minlength="3"
                                maxlength="100" />
                        </div>
                        <div id="detailedSpecsContainer">
                            <div class="specification-row">
                                <div class="spec-input">
                                    <input type="text" name="detailedSpecs_keys[]" class="form-control"
                                        placeholder="Category" />
                                </div>
                                <div class="spec-input">
                                    <input type="text" name="detailedSpecs_values[]" class="form-control"
                                        placeholder="Value" />
                                </div>
                                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                            </div>
