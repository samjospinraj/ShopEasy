<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>ShopMaster · Customers 2026</title>
    <!-- Bootstrap 5.3.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --bg-deep: #060b1f;
            --bg-card: rgba(10, 16, 36, 0.65);
            --bg-sidebar: rgba(7, 11, 28, 0.82);
            --bg-header: rgba(9, 14, 32, 0.7);
            --glass-blur: 20px;
            --primary: #4dabf7;
            --primary-glow: #339af0;
            --accent-cyan: #38bdf8;
            --accent-green: #34d399;
            --accent-red: #f87171;
            --accent-orange: #fb923c;
            --text-primary: #e8ecf4;
            --text-secondary: #b0bdd0;
            --text-muted: #7b8ca6;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(77, 171, 247, 0.3);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.45), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-glow: 0 0 40px rgba(77, 171, 247, 0.18);
            --radius-xl: 22px;
            --radius-lg: 16px;
            --radius-md: 12px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        body {
            background: radial-gradient(ellipse at 20% 20%, #0b1430 0%, #060b1f 45%, #04091a 70%, #020617 100%);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
            display: flex;
        }

        #nuranCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: 280px;
            background: var(--bg-sidebar);
            backdrop-filter: blur(26px);
            -webkit-backdrop-filter: blur(26px);
            color: var(--text-primary);
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            border-right: 1px solid var(--border-subtle);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 0 20px 18px 20px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-text {
            font-size: 1.6rem;
            font-weight: 700;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .logo-subtext {
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }
        .toggle-sidebar {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 36px;
            height: 36px;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
            font-size: 1rem;
        }
        .toggle-sidebar:hover {
            background: rgba(77, 171, 247, 0.15);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
        }
        .sidebar-menu {
            flex: 1;
            padding: 20px 0;
        }
        .menu-item {
            display: flex;
            align-items: center;
            padding: 13px 20px;
            margin: 3px 10px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: 0.2s;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 450;
            border: 1px solid transparent;
        }
        .menu-item:hover {
            background: rgba(77, 171, 247, 0.08);
            color: var(--text-primary);
            border-color: rgba(77, 171, 247, 0.2);
        }
        .menu-item.active-menu {
            background: rgba(77, 171, 247, 0.13);
            color: #fff;
            border-color: rgba(77, 171, 247, 0.35);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.15);
            position: relative;
        }
        .menu-item.active-menu::before {
            content: '';
            position: absolute;
            left: -2px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 22px;
            border-radius: 0 4px 4px 0;
            background: var(--accent-cyan);
            box-shadow: 0 0 14px var(--accent-cyan);
        }
        .menu-item i {
            width: 24px;
            font-size: 1.15rem;
            margin-right: 14px;
            text-align: center;
        }
        .menu-text {
            font-size: 0.95rem;
        }

        /* ── MAIN CONTENT ── */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 22px 30px;
            transition: margin-left 0.35s ease;
            width: 100%;
            position: relative;
            z-index: 1;
        }

        /* ── HEADER ── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-header);
            backdrop-filter: blur(22px);
            -webkit-backdrop-filter: blur(22px);
            padding: 14px 26px;
            border-radius: 50px;
            box-shadow: var(--shadow-card);
            margin-bottom: 28px;
            border: 1px solid var(--border-subtle);
            flex-wrap: wrap;
            gap: 14px;
        }
        .menu-toggle {
            display: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 44px;
            height: 44px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1.2rem;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
        }
        .menu-toggle:hover {
            border-color: var(--border-glow);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.2);
            color: var(--accent-cyan);
        }
        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            padding: 8px 20px;
            width: min(400px, 100%);
            border: 1px solid var(--border-subtle);
        }
        .search-bar input {
            border: none;
            background: transparent;
            padding: 8px 10px;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
            color: var(--text-primary);
        }
        .search-bar input::placeholder {
            color: var(--text-muted);
        }
        .search-bar i {
            color: var(--text-muted);
        }
        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .notification-btn {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-subtle);
            font-size: 1.15rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 10px 12px;
            border-radius: 50%;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .notification-btn:hover {
            background: rgba(77, 171, 247, 0.12);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
        }
        .notification-badge {
            position: absolute;
            top: 2px;
            right: 3px;
            background: var(--accent-red);
            color: #fff;
            font-size: 0.6rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 5px 18px 5px 8px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            border: 1px solid var(--border-subtle);
            cursor: pointer;
        }
        .user-info img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid rgba(77, 171, 247, 0.5);
            object-fit: cover;
        }
        .user-details h4 {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }
        .user-details p {
            font-size: 0.7rem;
            color: var(--text-muted);
            margin: 0;
        }

        /* ── STATS ROW ── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }
        @media (max-width: 992px) {
            .stats-row {
                grid-template-columns: 1fr;
            }
        }

        .stat-box {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            border-radius: var(--radius-lg);
            padding: 18px 20px;
            border: 1px solid var(--border-subtle);
            display: flex;
            align-items: center;
            gap: 14px;
            transition: 0.35s;
        }
        .stat-box:hover {
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }
        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }
        .stat-value {
            font-size: 1.8rem;
            font-weight: 700;
            line-height: 1.2;
            color: var(--text-primary);
        }
        .stat-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ── FILTERS ── */
        .filter-container {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            border-radius: var(--radius-xl);
            padding: 22px 28px;
            margin-bottom: 24px;
            border: 1px solid var(--border-subtle);
            display: flex;
            flex-wrap: wrap;
            align-items: flex-end;
            gap: 20px;
        }
        .filter-group {
            display: flex;
            flex-direction: column;
            min-width: 160px;
        }
        .filter-group label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 6px;
        }
        .form-control, .form-select {
            background: rgba(255, 255, 255, 0.04) !important;
            border: 1px solid var(--border-subtle) !important;
            border-radius: 40px !important;
            padding: 10px 16px !important;
            font-size: 0.9rem !important;
            color: #ffffff !important;
            transition: 0.2s;
            box-shadow: none !important;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--border-glow) !important;
            box-shadow: 0 0 14px rgba(77, 171, 247, 0.15) !important;
            background: rgba(255, 255, 255, 0.06) !important;
        }
        .form-select option {
            background: #0f1829;
            color: #e0e7f0;
        }
        .btn-filter {
            padding: 10px 24px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: none;
        }
        .btn-apply {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: #fff;
        }
        .btn-clear {
            background: transparent;
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
        }
        .btn-apply:hover, .btn-clear:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }

        /* ── CARDS & TABLE ── */
        .view-toggle {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
        }
        .view-btn {
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            background: transparent;
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .view-btn.active-view {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            border-color: transparent;
            color: #fff;
        }

        /* ── CUSTOMER CARDS GRID (max 3 per row) ── */
        .customers-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-bottom: 40px;
        }
        @media (max-width: 992px) {
            .customers-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        @media (max-width: 576px) {
            .customers-grid {
                grid-template-columns: 1fr;
            }
        }

        .customer-card {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            border-radius: var(--radius-xl);
            padding: 22px 18px 18px;
            border: 1px solid var(--border-subtle);
            transition: 0.35s;
            display: flex;
            flex-direction: column;
            position: relative;
        }
        .customer-card:hover {
            transform: translateY(-6px);
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }
        .customer-badge {
            position: absolute;
            top: 14px;
            right: 16px;
            font-size: 0.7rem;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 30px;
            text-transform: uppercase;
        }
        .badge-active { background: rgba(52,211,153,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.3); }
        .badge-inactive { background: rgba(255,255,255,0.05); color: #9ca3af; border: 1px solid rgba(255,255,255,0.1); }
        .badge-blocked { background: rgba(248,113,113,0.15); color: #f87171; border: 1px solid rgba(248,113,113,0.3); }

        .customer-avatar {
            width: 80px;
            height: 80px;
            margin: 0 auto 12px;
            border-radius: 50%;
            background: rgba(77,171,247,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--border-subtle);
            overflow: hidden;
        }
        .customer-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .customer-info h4 {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-primary);
            text-align: center;
        }
        .customer-email {
            font-size: 0.85rem;
            color: var(--text-secondary);
            background: rgba(255,255,255,0.03);
            display: inline-block;
            padding: 5px 14px;
            border-radius: 30px;
            margin: 8px 0;
            word-break: break-all;
            text-align: center;
            width: 100%;
        }
        .customer-detail-row {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin: 14px 0 8px;
            font-size: 0.9rem;
            color: var(--text-secondary);
        }
        .customer-orders {
            background: rgba(77,171,247,0.1);
            border-radius: 30px;
            padding: 6px 12px;
            font-weight: 600;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--accent-cyan);
        }
        .customer-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
            border-top: 1px solid var(--border-subtle);
            padding-top: 14px;
            color: var(--text-secondary);
        }
        .card-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
        }
        .card-action-btn {
            flex: 1;
            border: 1px solid var(--border-subtle);
            background: rgba(255,255,255,0.03);
            padding: 8px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--text-secondary);
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }
        .card-action-btn:hover {
            background: rgba(77,171,247,0.15);
            border-color: var(--border-glow);
            color: #fff;
        }
        .block-btn:hover { background: rgba(248,113,113,0.2); border-color: var(--accent-red); color: var(--accent-red); }
        .unblock-btn:hover { background: rgba(52,211,153,0.2); border-color: var(--accent-green); color: var(--accent-green); }

        /* ── TABLE VIEW ── */
        .table-view {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            border-radius: var(--radius-xl);
            padding: 20px;
            border: 1px solid var(--border-subtle);
            overflow-x: auto;
            margin-bottom: 40px;
        }
        .table-view table {
            width: 100%;
            border-collapse: collapse;
            min-width: 800px;
            color: var(--text-primary);
        }
        .table-view th {
            text-align: left;
            padding: 14px 12px;
            color: var(--text-muted);
            font-weight: 600;
            border-bottom: 2px solid var(--border-subtle);
        }
        .table-view td {
            padding: 14px 12px;
            border-bottom: 1px solid var(--border-subtle);
            vertical-align: middle;
        }
        .table-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: rgba(77,171,247,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .status-indicator {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .status-active { background: rgba(52,211,153,0.15); color: #34d399; }
        .status-inactive-table { background: rgba(255,255,255,0.05); color: #9ca3af; }
        .status-blocked-table { background: rgba(248,113,113,0.15); color: #f87171; }

        /* ── COUNTS SECTION ── */
        .counts-tabs .nav-pills .nav-link {
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            border-radius: 40px;
            margin-right: 6px;
        }
        .counts-tabs .nav-pills .nav-link.active {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            border-color: transparent;
            color: #fff;
        }
        .count-table { display: none; }
        @media (min-width: 768px) {
            .count-table { display: block; }
            .count-cards { display: none; }
        }
        @media (max-width: 767.98px) {
            .count-table { display: none; }
            .count-cards { display: block; }
        }
        .count-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .count-card .period {
            font-weight: 600;
            color: var(--accent-cyan);
        }
        .count-card .value {
            font-size: 1.2rem;
            font-weight: 700;
        }
        .count-card .label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        /* ═══ MODAL POPUP 2026 ═══ */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeInOverlay 0.25s ease;
        }
        .modal-content {
            background: linear-gradient(145deg, rgba(18,28,52,0.95), rgba(10,18,40,0.95));
            backdrop-filter: blur(16px);
            border: 1px solid var(--border-glow);
            border-radius: 24px;
            padding: 32px 36px;
            max-width: 420px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6), 0 0 30px rgba(77,171,247,0.3);
            animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .modal-icon {
            font-size: 3rem;
            margin-bottom: 16px;
        }
        .modal-message {
            font-size: 1.15rem;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 24px;
            line-height: 1.5;
        }
        .modal-btn {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            border: none;
            padding: 12px 32px;
            border-radius: 40px;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 4px 12px rgba(77,171,247,0.3);
        }
        .modal-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(77,171,247,0.4);
        }

        @keyframes fadeInOverlay { from { opacity:0; } to { opacity:1; } }
        @keyframes scaleIn {
            0% { transform: scale(0.7); opacity:0; }
            100% { transform: scale(1); opacity:1; }
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .menu-toggle { display: flex; }
        }
        @media (max-width: 768px) {
            .filter-container { flex-direction: column; align-items: stretch; }
        }
    </style>
</head>
<body>
    <canvas id="nuranCanvas"></canvas>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div>
                <div class="logo-text">ShopMaster</div>
                <div class="logo-subtext">admin · 2026</div>
            </div>
            <button class="toggle-sidebar" id="toggleSidebarBtn"><i class="fas fa-chevron-left"></i></button>
        </div>
        <div class="sidebar-menu">
            <a href="/Admin/dashboard" class="menu-item"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
