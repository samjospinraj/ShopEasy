    <div id="toastMsg" class="toast-notify"><i class="fas fa-check-circle me-2"></i><span id="toastText">Success!</span></div>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // ----------------------------------------------------------------
            // 1. CONFIGURATION – CHANGE THIS TO YOUR BACKEND URL
            // ----------------------------------------------------------------
            const API_BASE = 'http://localhost:3000';

            let isAuthenticated = false;
            let selectedPayment = 'razorpay';
            let checkoutData = null;
            let checkoutType = 'cart';
            let singleProductId = null;
            let shippingCost = 0;
            let cartItems = [];
            let deliveryTimeline = { minTime: null, maxTime: null, minDays: null, maxDays: null };

            // ============ MODAL POP-UP SYSTEM ============
            const notifModal = document.getElementById('notificationModal');
            const bsNotifModal = notifModal ? new bootstrap.Modal(notifModal, { backdrop: 'static' }) : null;
            function showModal(type, title, msg, opts = {}) {
                if (!bsNotifModal) return;
                const map = {
                    success: { cls: 'success', icon: 'fa-check-circle' },
                    error: { cls: 'error', icon: 'fa-times-circle' },
                    warning: { cls: 'warning', icon: 'fa-exclamation-triangle' },
                    info: { cls: 'info', icon: 'fa-info-circle' }
                };
                const cfg = map[type] || map.info;
                document.getElementById('modalIconCircle').className = 'modal-icon-circle ' + cfg.cls;
                document.getElementById('modalIconCircle').innerHTML = `<i class="fas ${cfg.icon}"></i>`;
                document.getElementById('modalTitle').textContent = title;
                document.getElementById('modalMessage').textContent = msg;

                const pri = document.getElementById('modalPrimaryBtn');
                pri.textContent = opts.primaryText || 'OK';
                pri.style.display = 'inline-block';
                pri.onclick = () => { opts.onPrimary?.(); bsNotifModal.hide(); };

                const sec = document.getElementById('modalSecondaryBtn');
                let secondaryText = opts.secondaryText;
                if (secondaryText === undefined) secondaryText = 'Cancel';
                if (secondaryText) {
                    sec.textContent = secondaryText;
                    sec.style.display = 'inline-block';
                    sec.onclick = () => {
                        if (opts.onSecondary) opts.onSecondary();
                        bsNotifModal.hide();
                    };
                } else {
                    sec.style.display = 'none';
                }

                bsNotifModal.show();
                if (opts.autoHide) setTimeout(() => bsNotifModal.hide(), opts.autoHide);
            }

            // ============ VALIDATION ============
            const validationRules = {
                fullName: { test: (value) => value.trim().length >= 3 && value.trim().length <= 50, message: 'Full name must be between 3 and 50 characters' },
                phone: { test: (value) => /^[0-9]{10,15}$/.test(value.replace(/\s/g, '')), message: 'Please enter a valid phone number (10-15 digits)' },
                address: { test: (value) => value.trim().length >= 5 && value.trim().length <= 200, message: 'Address must be between 5 and 200 characters' },
                city: { test: (value) => value.trim().length >= 2 && /^[a-zA-Z\s]{2,50}$/.test(value.trim()), message: 'Please enter a valid city name (2-50 characters)' },
                postalCode: { test: (value) => /^[1-9][0-9]{5}$/.test(value), message: 'Please enter a valid 6-digit PIN code' },
                state: { test: (value) => value.trim().length >= 2 && /^[a-zA-Z\s]{2,50}$/.test(value.trim()), message: 'Please enter a valid state name (2-50 characters)' },
                country: { test: (value) => value !== '' && value !== null && value.toLowerCase() === 'india', message: 'Currently only shipping within India' }
            };

            function validateField(input) {
                const fieldId = input.id;
                const validateType = input.dataset.validate;
                const msgElement = document.getElementById(fieldId + 'Msg');
                if (!validateType || !validationRules[validateType]) return true;

                const value = input.value;
                const rule = validationRules[validateType];
                const isValid = value.trim().length > 0 && rule.test(value);

                if (value.trim().length === 0) {
                    input.classList.remove('is-invalid', 'is-valid');
                    if (msgElement) { msgElement.textContent = ''; msgElement.className = 'validation-message'; }
                } else if (isValid) {
                    input.classList.add('is-valid'); input.classList.remove('is-invalid');
                    if (msgElement) { msgElement.innerHTML = '<i class="fas fa-check-circle"></i> Valid'; msgElement.className = 'validation-message success'; }
                } else {
                    input.classList.add('is-invalid'); input.classList.remove('is-valid');
                    if (msgElement) { msgElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${rule.message}`; msgElement.className = 'validation-message error'; }
                }
                return isValid;
            }

            function validateAllFields() {
                let allValid = true;
                let firstInvalid = null;
                const requiredFields = ['customerName', 'customerPhone', 'deliveryAddress', 'city', 'postalCode', 'state', 'country'];
                requiredFields.forEach(fieldId => {
                    const input = document.getElementById(fieldId);
                    if (!input) return;
                    const value = input.value;
                    const isValid = validateField(input);
                    if (value.trim().length === 0) {
                        input.classList.add('is-invalid');
                        const msgEl = document.getElementById(fieldId + 'Msg');
                        if (msgEl) { msgEl.innerHTML = '<i class="fas fa-exclamation-circle"></i> This field is required'; msgEl.className = 'validation-message error'; }
                        allValid = false;
                        if (!firstInvalid) firstInvalid = input;
                    } else if (!isValid) {
                        allValid = false;
                        if (!firstInvalid) firstInvalid = input;
                    }
                });
                if (firstInvalid) {
                    firstInvalid.focus();
                    firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
                return allValid;
            }

            function setupValidation() {
                document.querySelectorAll('[data-validate]').forEach(input => {
                    input.addEventListener('input', () => validateField(input));
                    input.addEventListener('blur', function() {
                        if (this.value.trim().length === 0) {
                            this.classList.add('is-invalid');
                            const msgEl = document.getElementById(this.id + 'Msg');
                            if (msgEl) { msgEl.innerHTML = '<i class="fas fa-exclamation-circle"></i> This field is required'; msgEl.className = 'validation-message error'; }
                        } else { validateField(this); }
                    });
                    input.addEventListener('focus', function() {
                        this.classList.remove('is-invalid', 'is-valid');
                        const msgEl = document.getElementById(this.id + 'Msg');
                        if (msgEl) { msgEl.textContent = ''; msgEl.className = 'validation-message'; }
                    });
                });

                document.getElementById('postalCode').addEventListener('input', function(e) { this.value = this.value.replace(/[^0-9]/g, ''); });
                document.getElementById('customerPhone').addEventListener('input', function(e) { this.value = this.value.replace(/[^0-9]/g, ''); });
            }

            // ============ DELIVERY TIMELINE ============
            function formatDate(date) {
                if (!date) return '--';
                const d = new Date(date);
                return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            }

            function formatDayName(date) {
                if (!date) return '';
                return new Date(date).toLocaleDateString('en-US', { weekday: 'long' });
            }

            function calculateDaysFromNow(date) {
                if (!date) return null;
                const now = new Date();
                const target = new Date(date);
                return Math.ceil((target.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
            }

            function updateDeliveryTimelineDisplay() {
                const minTime = deliveryTimeline.minTime;
                const maxTime = deliveryTimeline.maxTime;
                if (!minTime || !maxTime) {
                    document.getElementById('minDeliveryDate').textContent = '--';
                    document.getElementById('maxDeliveryDate').textContent = '--';
                    document.getElementById('minDeliveryDay').textContent = 'Not available';
                    document.getElementById('maxDeliveryDay').textContent = 'Not available';
                    document.getElementById('deliveryDaysText').textContent = 'Timeline unavailable';
                    document.getElementById('deliveryEstimateText').textContent = 'Estimated: --';
                    return;
                }
                document.getElementById('minDeliveryDate').textContent = formatDate(minTime);
                document.getElementById('maxDeliveryDate').textContent = formatDate(maxTime);
                document.getElementById('minDeliveryDay').textContent = formatDayName(minTime);
                document.getElementById('maxDeliveryDay').textContent = formatDayName(maxTime);

                const minDays = calculateDaysFromNow(minTime);
                const maxDays = calculateDaysFromNow(maxTime);
                deliveryTimeline.minDays = minDays;
                deliveryTimeline.maxDays = maxDays;

                if (minDays !== null && maxDays !== null) {
                    document.getElementById('deliveryDaysText').textContent = `${minDays} - ${maxDays} business days`;
                    document.getElementById('deliveryEstimateText').textContent = `Between ${formatDate(minTime)} and ${formatDate(maxTime)}`;
                }

                setTimeout(() => {
                    const progressBar = document.getElementById('timelineProgress');
                    if (progressBar) {
                        const minDate = new Date(minTime);
                        const maxDate = new Date(maxTime);
                        const now = new Date();
                        const totalDuration = maxDate.getTime() - minDate.getTime();
                        const elapsed = now.getTime() - minDate.getTime();
                        let progress = totalDuration > 0 ? Math.min(Math.max((elapsed / totalDuration) * 100, 0), 100) : (now >= minDate ? 50 : 0);
                        progressBar.style.width = progress + '%';
                    }
                }, 500);
            }

            function extractDeliveryTimeline(productData) {
                if (!productData) return;
                if (productData.deliveryTimeline) {
                    if (productData.deliveryTimeline.minTime) deliveryTimeline.minTime = productData.deliveryTimeline.minTime;
                    if (productData.deliveryTimeline.maxTime) deliveryTimeline.maxTime = productData.deliveryTimeline.maxTime;
                }
                if (productData.productId && productData.productId.deliveryTimeline) {
                    if (productData.productId.deliveryTimeline.minTime) deliveryTimeline.minTime = productData.productId.deliveryTimeline.minTime;
                    if (productData.productId.deliveryTimeline.maxTime) deliveryTimeline.maxTime = productData.productId.deliveryTimeline.maxTime;
                }
                if (productData.dimensions && productData.dimensions.shippingCost) shippingCost += Number(productData.dimensions.shippingCost || 0);
                if (productData.productId && productData.productId.dimensions && productData.productId.dimensions.shippingCost) shippingCost += Number(productData.productId.dimensions.shippingCost || 0);
            }

            function consolidateDeliveryTimelines(items) {
                let globalMinTime = null, globalMaxTime = null;
                items.forEach(product => {
                    if (product.deliveryTimeline) {
                        if (product.deliveryTimeline.minTime) {
                            const minDate = new Date(product.deliveryTimeline.minTime);
                            if (!globalMinTime || minDate < globalMinTime) globalMinTime = minDate;
                        }
                        if (product.deliveryTimeline.maxTime) {
                            const maxDate = new Date(product.deliveryTimeline.maxTime);
                            if (!globalMaxTime || maxDate > globalMaxTime) globalMaxTime = maxDate;
                        }
                    }
                });
                if (globalMinTime) deliveryTimeline.minTime = globalMinTime.toISOString();
                if (globalMaxTime) deliveryTimeline.maxTime = globalMaxTime.toISOString();
            }

