<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopMaster · Analytics 2026</title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js">
    </script>

    <style>
        :root {
            --bg-deep: #080c18;
            --bg-surface: #0f1424;
            --bg-card: rgba(18, 24, 42, 0.75);
            --bg-card-hover: rgba(22, 30, 52, 0.9);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-border-hover: rgba(255, 255, 255, 0.18);
            --text-primary: #e8ecf4;
            --text-secondary: #a0aec0;
            --text-muted: #6b7d95;
            --accent-blue: #4d8fff;
            --accent-blue-glow: rgba(77, 143, 255, 0.35);
            --accent-cyan: #3ce4d4;
            --accent-cyan-glow: rgba(60, 228, 212, 0.3);
            --accent-purple: #9b6dff;
            --accent-purple-glow: rgba(155, 109, 255, 0.3);
            --accent-green: #34d399;
            --accent-green-glow: rgba(52, 211, 153, 0.3);
            --accent-amber: #fbbf24;
            --accent-amber-glow: rgba(251, 191, 36, 0.3);
            --accent-rose: #f87171;
            --accent-rose-glow: rgba(248, 113, 113, 0.3);
            --accent-pink: #f472b6;
            --accent-pink-glow: rgba(244, 114, 182, 0.25);
            --shadow-card: 0 4px 32px rgba(0, 0, 0, 0.5), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-card-hover: 0 12px 48px rgba(0, 0, 0, 0.6), 0 1px 0 rgba(255, 255, 255, 0.08) inset,
                0 0 60px var(--accent-blue-glow);
            --shadow-glow-blue: 0 0 40px var(--accent-blue-glow);
            --shadow-glow-purple: 0 0 40px var(--accent-purple-glow);
            --radius-xl: 24px;
            --radius-lg: 18px;
            --radius-md: 14px;
            --radius-sm: 10px;
            --radius-full: 50px;
            --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-smooth: 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
            --transition-bounce: 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            --font-display: 'Segoe UI', 'Inter', system-ui, -apple-system, sans-serif;
            --mouse-x: 0.5;
            --mouse-y: 0.5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-deep);
            color: var(--text-primary);
            font-family: var(--font-display);
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            position: relative;
            cursor: default;
        }

        /* ──────── MOUSE GLOW ──────── */
        .mouse-glow {
            position: fixed;
            pointer-events: none;
            z-index: 0;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: radial-gradient(circle,
                    rgba(77, 143, 255, 0.12) 0%,
                    rgba(155, 109, 255, 0.05) 30%,
                    rgba(60, 228, 212, 0.02) 55%,
                    transparent 70%);
            transform: translate(-50%, -50%);
            transition: left 0.08s ease-out, top 0.08s ease-out;
            will-change: left, top;
            filter: blur(30px);
        }

        /* ──────── ANIMATED BACKGROUND ──────── */
        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background-image:
                linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
            background-size: 48px 48px;
            animation: gridShift 20s linear infinite;
        }
        @keyframes gridShift {
            0%,
            100% {
                background-position: 0 0;
            }
            50% {
                background-position: 24px 24px;
            }
        }

        .bg-orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(120px);
            pointer-events: none;
            z-index: 0;
            animation: orbFloat 14s ease-in-out infinite;
            opacity: 0.35;
            transition: transform 0.6s ease-out;
        }
        .bg-orb.orb-1 {
            width: 500px;
            height: 500px;
            background: var(--accent-blue);
            top: -15%;
            left: -10%;
            animation-delay: 0s;
        }
        .bg-orb.orb-2 {
            width: 400px;
            height: 400px;
            background: var(--accent-purple);
            bottom: -12%;
            right: -8%;
            animation-delay: -5s;
            animation-duration: 16s;
        }
        .bg-orb.orb-3 {
            width: 350px;
            height: 350px;
            background: var(--accent-cyan);
            top: 45%;
            left: 50%;
            animation-delay: -9s;
            animation-duration: 18s;
            opacity: 0.2;
        }
        @keyframes orbFloat {
            0%,
            100% {
                transform: translate(0, 0) scale(1);
            }
            25% {
                transform: translate(60px, -40px) scale(1.08);
            }
            50% {
                transform: translate(-30px, -70px) scale(0.94);
            }
            75% {
                transform: translate(-50px, 30px) scale(1.05);
            }
        }

        /* ──────── CANVAS PARTICLES ──────── */
        #particleCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        /* ──────── CSS PARTICLES (legacy) ──────── */
        .particles-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }
        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: white;
            border-radius: 50%;
            animation: particleFloat 8s ease-in-out infinite;
            opacity: 0;
        }
        @keyframes particleFloat {
            0% {
                opacity: 0;
                transform: translateY(100vh) scale(0);
            }
            10% {
                opacity: 0.7;
            }
            30% {
                opacity: 0.4;
            }
            60% {
                opacity: 0.7;
            }
            90% {
                opacity: 0;
                transform: translateY(-10vh) scale(1.5);
            }
            100% {
                opacity: 0;
                transform: translateY(-20vh) scale(0);
            }
        }

        /* ──────── SIDEBAR ──────── */
        .sidebar {
            width: 270px;
            background: var(--bg-card);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            position: fixed;
            height: 100vh;
            z-index: 1050;
            border-right: 1px solid var(--glass-border);
            box-shadow: var(--shadow-card);
            transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            padding: 18px 0;
        }
        .sidebar-header {
            padding: 0 18px 18px 18px;
            border-bottom: 1px solid var(--glass-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-icon {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-sm);
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: white;
            box-shadow: var(--shadow-glow-purple);
            animation: logoPulse 3s ease-in-out infinite;
        }
        @keyframes logoPulse {
            0%,
            100% {
                box-shadow: 0 0 25px var(--accent-purple-glow);
            }
            50% {
                box-shadow: 0 0 50px var(--accent-blue-glow), 0 0 80px var(--accent-purple-glow);
            }
        }
        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.3px;
        }
        .logo-subtext {
            font-size: 0.65rem;
            color: var(--text-muted);
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
        .toggle-sidebar {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--glass-border);
            color: var(--text-secondary);
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
            font-size: 1.1rem;
        }
        .toggle-sidebar:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--accent-blue);
            color: var(--accent-blue);
            box-shadow: var(--shadow-glow-blue);
        }
        .sidebar-menu {
            flex: 1;
            padding: 16px 0;
        }
        .menu-item {
            display: flex;
            align-items: center;
            padding: 13px 18px;
            margin: 3px 10px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition-fast);
            border-radius: var(--radius-md);
            cursor: pointer;
            font-weight: 450;
            position: relative;
            overflow: hidden;
        }
        .menu-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 3px;
            border-radius: 0 4px 4px 0;
            background: var(--accent-blue);
            transform: scaleY(0);
            transition: transform 0.3s ease;
        }
        .menu-item:hover,
        .menu-item.active-menu {
            background: rgba(77, 143, 255, 0.1);
            color: var(--text-primary);
        }
        .menu-item.active-menu::before {
            transform: scaleY(1);
        }
        .menu-item.active-menu {
            box-shadow: 0 0 20px rgba(77, 143, 255, 0.1);
        }
        .menu-item i {
            width: 22px;
            font-size: 1.1rem;
            margin-right: 12px;
            transition: var(--transition-fast);
        }
        .menu-item:hover i,
        .menu-item.active-menu i {
            color: var(--accent-blue);
            text-shadow: 0 0 18px var(--accent-blue-glow);
        }
        .menu-text {
            font-size: 0.9rem;
        }

        /* ──────── MAIN CONTENT ──────── */
        .main-content {
            margin-left: 270px;
            padding: 22px 28px;
            transition: margin-left 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
            width: calc(100% - 270px);
            position: relative;
            z-index: 1;
        }

        /* ──────── HEADER ──────── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-card);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            padding: 14px 24px;
            border-radius: var(--radius-full);
            box-shadow: var(--shadow-card);
            margin-bottom: 28px;
            border: 1px solid var(--glass-border);
            flex-wrap: wrap;
            gap: 12px;
            transition: var(--transition-fast);
        }
        .header:hover {
            border-color: var(--glass-border-hover);
        }
        .menu-toggle {
            display: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--glass-border);
            color: var(--text-secondary);
            width: 42px;
            height: 42px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 1.2rem;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
        }
        .menu-toggle:hover {
            border-color: var(--accent-blue);
            color: var(--accent-blue);
            box-shadow: var(--shadow-glow-blue);
        }
        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-full);
            padding: 9px 18px;
            width: min(380px, 100%);
            border: 1px solid var(--glass-border);
            transition: var(--transition-fast);
        }
        .search-bar:focus-within {
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(77, 143, 255, 0.12);
            background: rgba(255, 255, 255, 0.05);
        }
        .search-bar input {
            border: none;
            background: transparent;
            padding: 7px 8px;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
            color: var(--text-primary);
        }
        .search-bar input::placeholder {
            color: var(--text-muted);
        }
        .search-bar i {
            color: var(--text-muted);
            font-size: 0.95rem;
        }
        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .notification-btn {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            font-size: 1.15rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 10px 12px;
            border-radius: 50%;
            transition: var(--transition-fast);
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .notification-btn:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--accent-blue);
            color: var(--accent-blue);
            box-shadow: var(--shadow-glow-blue);
        }
        .notification-badge {
            position: absolute;
            top: 2px;
            right: 2px;
            background: var(--accent-rose);
            color: white;
            font-size: 0.6rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            box-shadow: 0 0 12px var(--accent-rose-glow);
            animation: badgePulse 2s ease-in-out infinite;
        }
        @keyframes badgePulse {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.18);
            }
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 5px 14px 5px 8px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-full);
            border: 1px solid var(--glass-border);
            transition: var(--transition-fast);
            cursor: pointer;
        }
        .user-info:hover {
            border-color: var(--glass-border-hover);
            background: rgba(255, 255, 255, 0.06);
        }
        .user-info img {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            border: 2px solid var(--accent-blue);
            object-fit: cover;
            box-shadow: 0 0 16px var(--accent-blue-glow);
        }
        .user-details h4 {
            font-size: 0.9rem;
            font-weight: 600;
            margin: 0;
            color: var(--text-primary);
        }
        .user-details p {
            font-size: 0.7rem;
            color: var(--text-muted);
            margin: 0;
            letter-spacing: 0.5px;
        }

        /* ──────── TYPE TABS ──────── */
        .type-tabs {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            background: var(--bg-card);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border-radius: var(--radius-full);
            padding: 6px 8px;
            box-shadow: var(--shadow-card);
            margin-bottom: 24px;
            border: 1px solid var(--glass-border);
        }
        .type-tab {
            padding: 10px 18px;
            border-radius: var(--radius-full);
            font-weight: 600;
            font-size: 0.82rem;
            cursor: pointer;
            border: 1px solid transparent;
            background: transparent;
            color: var(--text-secondary);
            transition: var(--transition-fast);
            display: flex;
            align-items: center;
            gap: 7px;
            white-space: nowrap;
            letter-spacing: 0.2px;
        }
        .type-tab i {
            font-size: 0.85rem;
        }
        .type-tab.active {
            background: linear-gradient(135deg, var(--accent-blue), #3b6fd4);
            color: white;
            border-color: transparent;
            box-shadow: 0 4px 20px var(--accent-blue-glow);
            animation: tabActivate 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        @keyframes tabActivate {
            0% {
                transform: scale(0.9);
            }
            100% {
                transform: scale(1);
            }
        }
        .type-tab:hover:not(.active) {
            background: rgba(255, 255, 255, 0.04);
            color: var(--text-primary);
            border-color: rgba(255, 255, 255, 0.1);
        }

        /* ──────── QUICK ACTIONS ──────── */
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 28px;
        }
        .action-card {
            background: var(--bg-card);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border-radius: var(--radius-lg);
            padding: 20px 14px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--glass-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            transition: var(--transition-bounce);
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            position: relative;
            overflow: hidden;
        }
        .action-card::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.03) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
        }
        .action-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-card-hover);
            border-color: var(--glass-border-hover);
        }
        .action-card:hover::after {
            opacity: 1;
        }
        .action-card:nth-child(1):hover {
            border-color: var(--accent-blue);
        }
        .action-card:nth-child(2):hover {
            border-color: var(--accent-green);
        }
        .action-card:nth-child(3):hover {
            border-color: var(--accent-amber);
        }
        .action-card:nth-child(4):hover {
            border-color: var(--accent-purple);
        }
        .action-icon {
            width: 56px;
            height: 56px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            margin-bottom: 14px;
            position: relative;
            z-index: 1;
        }
        .action-card:nth-child(1) .action-icon {
            background: linear-gradient(145deg, #4d8fff, #3060cc);
            box-shadow: 0 8px 24px var(--accent-blue-glow);
        }
        .action-card:nth-child(2) .action-icon {
            background: linear-gradient(145deg, #34d399, #1a8a5e);
            box-shadow: 0 8px 24px var(--accent-green-glow);
        }
        .action-card:nth-child(3) .action-icon {
            background: linear-gradient(145deg, #fbbf24, #c4890a);
            box-shadow: 0 8px 24px var(--accent-amber-glow);
        }
        .action-card:nth-child(4) .action-icon {
            background: linear-gradient(145deg, #9b6dff, #6a3fd1);
            box-shadow: 0 8px 24px var(--accent-purple-glow);
        }
        .action-card h4 {
            font-size: 1rem;
            margin-bottom: 4px;
            font-weight: 600;
            color: var(--text-primary);
        }
        .action-card p {
            font-size: 0.78rem;
            color: var(--text-muted);
            margin: 0;
        }

        /* ──────── FILTER SECTION ──────── */
        .filter-header {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--bg-card);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border-radius: var(--radius-full);
            padding: 12px 20px;
            margin-bottom: 24px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--glass-border);
            flex-wrap: wrap;
            transition: var(--transition-fast);
        }
        .filter-header:hover {
            border-color: var(--glass-border-hover);
        }
        .filter-badge {
            background: rgba(77, 143, 255, 0.15);
            color: var(--accent-blue);
            padding: 8px 16px;
            border-radius: var(--radius-full);
            font-weight: 600;
            font-size: 0.82rem;
            display: flex;
            align-items: center;
            gap: 7px;
            border: 1px solid rgba(77, 143, 255, 0.25);
            letter-spacing: 0.3px;
        }
        .calendar-filter,
        .filter-select {
            padding: 9px 16px;
            border-radius: var(--radius-full);
            border: 1px solid var(--glass-border);
            background: rgba(255, 255, 255, 0.03);
            font-weight: 500;
            font-size: 0.82rem;
            cursor: pointer;
            font-family: var(--font-display);
            color: var(--text-primary);
            outline: none;
            transition: var(--transition-fast);
            min-width: 150px;
        }
        .calendar-filter:focus,
        .filter-select:focus {
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(77, 143, 255, 0.1);
        }
        .calendar-filter::placeholder {
            color: var(--text-muted);
        }
        .filter-select option {
            background: var(--bg-surface);
            color: var(--text-primary);
        }
        .filter-clean {
            background: transparent;
            border: 2px solid var(--accent-blue);
            color: var(--accent-blue);
            padding: 8px 16px;
            border-radius: var(--radius-full);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition-fast);
            font-size: 0.82rem;
            white-space: nowrap;
            letter-spacing: 0.2px;
        }
        .filter-clean:hover {
            background: var(--accent-blue);
            color: white;
            box-shadow: var(--shadow-glow-blue);
        }

        /* ──────── GRAPHIC TILES ──────── */
        .graphic-cluster {
            display: grid;
            grid-template-columns: repeat(3, 1fr) 1.2fr;
            gap: 18px;
            margin-bottom: 30px;
        }
        .graphic-tile {
            background: var(--bg-card);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border-radius: var(--radius-xl);
            padding: 20px 18px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--glass-border);
            transition: var(--transition-bounce);
            position: relative;
            overflow: hidden;
            cursor: default;
        }
        .graphic-tile.revenue-clickable {
            cursor: pointer;
        }
        .graphic-tile.revenue-clickable:hover {
            border-color: var(--accent-cyan);
            box-shadow: 0 12px 48px rgba(0, 0, 0, 0.6), 0 1px 0 rgba(255, 255, 255, 0.08) inset,
                0 0 60px var(--accent-cyan-glow);
        }
        .graphic-tile.revenue-clickable::after {
            content: '🔍 Click for details';
            position: absolute;
            bottom: 8px;
            right: 14px;
            font-size: 0.65rem;
            color: var(--accent-cyan);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            letter-spacing: 0.4px;
        }
        .graphic-tile.revenue-clickable:hover::after {
            opacity: 0.9;
        }
        .graphic-tile::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        .graphic-tile:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-card-hover);
            border-color: var(--glass-border-hover);
        }
        .graphic-tile:hover::before {
            opacity: 1;
        }
        .tile-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }
        .tile-header h3 {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin: 0;
            letter-spacing: 0.2px;
        }
        .tile-header i {
            font-size: 1.3rem;
            color: var(--accent-blue);
            background: rgba(77, 143, 255, 0.1);
            padding: 9px;
            border-radius: var(--radius-sm);
            transition: var(--transition-fast);
        }
        .graphic-tile:hover .tile-header i {
            box-shadow: 0 0 20px var(--accent-blue-glow);
            background: rgba(77, 143, 255, 0.18);
        }
        .price-range {
            display: flex;
            flex-direction: column;
            gap: 7px;
            margin-top: 6px;
        }
        .price-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .price-bar-bg {
            flex: 1;
            height: 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            overflow: hidden;
        }
        .price-bar-fill {
            height: 8px;
            border-radius: 20px;
            transition: width 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
            position: relative;
        }
        .price-bar-fill::after {
            content: '';
            position: absolute;
            right: 0;
            top: 0;
            height: 100%;
            width: 6px;
            background: white;
            border-radius: 50%;
            opacity: 0.5;
            box-shadow: 0 0 8px currentColor;
        }
        .price-tag {
            font-weight: 600;
            color: var(--text-primary);
            min-width: 55px;
            font-size: 0.78rem;
        }
        .price-pct {
            font-weight: 700;
            font-size: 0.78rem;
            color: var(--text-secondary);
            min-width: 32px;
            text-align: right;
        }
        .graphic-caption {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            font-size: 0.78rem;
            color: var(--text-muted);
        }
        .graphic-caption span:first-child {
            color: var(--accent-green);
            font-weight: 600;
        }
        .order-status-ring {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin: 8px 0;
        }
        .status-dot {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.78rem;
            font-weight: 500;
        }
        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
            box-shadow: 0 0 10px currentColor;
        }
        .dot.pending {
            background: #fbbf24;
            box-shadow: 0 0 10px var(--accent-amber-glow);
        }
        .dot.shipped {
            background: #4d8fff;
            box-shadow: 0 0 10px var(--accent-blue-glow);
        }
        .dot.delivered {
            background: #34d399;
            box-shadow: 0 0 10px var(--accent-green-glow);
        }
        .dot.cancelled {
            background: #f87171;
            box-shadow: 0 0 10px var(--accent-rose-glow);
        }
        .os-pct {
            font-weight: 700;
            font-size: 0.75rem;
            color: var(--text-secondary);
        }
        .status-bar-row {
            display: flex;
            align-items: flex-end;
            gap: 6px;
            height: 50px;
            margin-top: 4px;
        }
        .status-bar-row span {
            border-radius: 8px 8px 0 0;
            transition: all 0.5s cubic-bezier(0.22, 0.61, 0.36, 1);
            min-width: 22px;
        }
        .customer-pie {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .pie-simple {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            flex-shrink: 0;
            box-shadow: 0 0 20px rgba(52, 211, 153, 0.25);
        }
        .pie-legend span {
            display: block;
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--text-secondary);
        }
        .product-stack {
            display: flex;
            justify-content: space-around;
            margin: 8px 0;
            gap: 8px;
        }
        .stack-circle {
            width: 50px;
            height: 50px;
            border-radius: var(--radius-md);
            background: rgba(77, 143, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--accent-blue);
            flex-direction: column;
            line-height: 1.2;
            border: 1px solid rgba(77, 143, 255, 0.2);
            transition: var(--transition-bounce);
            font-size: 1.1rem;
        }
        .stack-circle:hover {
            transform: scale(1.08);
            box-shadow: 0 0 20px var(--accent-blue-glow);
            border-color: var(--accent-blue);
        }
        .stack-circle small {
            font-size: 0.55rem;
            font-weight: 400;
            color: var(--text-muted);
        }
        .margin-ring {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .ring-item {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .ring-bg {
            flex: 1;
            height: 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            overflow: hidden;
        }
        .ring-fill {
            height: 8px;
            border-radius: 20px;
            transition: width 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
        }
        .ring-label {
            font-weight: 600;
            font-size: 0.75rem;
            width: 65px;
            flex-shrink: 0;
            color: var(--text-secondary);
        }
        .donut-container {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 8px 0;
        }
        .donut {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            flex-shrink: 0;
            transition: all 0.6s ease;
        }
        .donut-label {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.2;
        }
        .donut-label small {
            font-size: 0.7rem;
            font-weight: 400;
            color: var(--text-muted);
            display: block;
        }

        /* ──────── CHART CARD ──────── */
        .chart-card {
            background: var(--bg-card);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border-radius: var(--radius-xl);
            padding: 22px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--glass-border);
            margin: 20px 0;
            transition: var(--transition-fast);
            position: relative;
        }
        .chart-card:hover {
            border-color: var(--glass-border-hover);
        }
        .chart-card.revenue-clickable {
            cursor: pointer;
        }
        .chart-card.revenue-clickable:hover {
            border-color: var(--accent-cyan);
            box-shadow: 0 12px 48px rgba(0, 0, 0, 0.6), 0 0 80px var(--accent-cyan-glow), 0 1px 0 rgba(255, 255, 255,
                    0.08) inset;
        }
        .chart-card.revenue-clickable::after {
            content: '🔍 Click to expand revenue details';
            position: absolute;
            top: 16px;
            right: 20px;
            font-size: 0.7rem;
            color: var(--accent-cyan);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            letter-spacing: 0.4px;
        }
        .chart-card.revenue-clickable:hover::after {
            opacity: 0.85;
        }
        .chart-card h3 {
            font-size: 1.1rem;
            margin-bottom: 18px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--glass-border);
            font-weight: 600;
            color: var(--text-primary);
            letter-spacing: 0.2px;
        }
        .extra-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 18px;
            margin-top: 12px;
        }

        /* ──────── REVENUE DETAIL PANEL ──────── */
        .revenue-detail-panel {
            background: var(--bg-card);
            backdrop-filter: blur(32px);
            -webkit-backdrop-filter: blur(32px);
            border-radius: var(--radius-xl);
            padding: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7), 0 0 80px var(--accent-cyan-glow);
            border: 2px solid var(--accent-cyan);
            margin: 20px 0;
            animation: panelSlideDown 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
        }
        .revenue-detail-panel::before {
            content: '';
            position: absolute;
            top: -100px;
            right: -100px;
            width: 250px;
            height: 250px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--accent-cyan-glow) 0%, transparent 70%);
            pointer-events: none;
            animation: panelGlowPulse 3s ease-in-out infinite;
        }
        @keyframes panelGlowPulse {
            0%,
            100% {
                opacity: 0.4;
                transform: scale(1);
            }
            50% {
                opacity: 0.8;
                transform: scale(1.3);
            }
        }
        @keyframes panelSlideDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .revenue-detail-panel .close-panel {
            position: absolute;
            top: 14px;
            right: 18px;
            z-index: 2;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid var(--glass-border);
            color: var(--text-secondary);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
            font-size: 1rem;
        }
        .close-panel:hover {
            background: rgba(248, 113, 113, 0.2);
            border-color: var(--accent-rose);
            color: var(--accent-rose);
            box-shadow: 0 0 20px var(--accent-rose-glow);
        }
        .revenue-metrics {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }
        .rev-metric {
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-lg);
            padding: 18px;
            border: 1px solid var(--glass-border);
            text-align: center;
            transition: var(--transition-fast);
        }
        .rev-metric:hover {
            border-color: var(--accent-cyan);
            box-shadow: 0 0 30px var(--accent-cyan-glow);
            background: rgba(60, 228, 212, 0.05);
        }
        .rev-metric .rev-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }
        .rev-metric .rev-label {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 4px;
        }
        .rev-table-wrapper {
            max-height: 280px;
            overflow-y: auto;
            border-radius: var(--radius-md);
            border: 1px solid var(--glass-border);
        }
        .rev-table-wrapper table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.82rem;
        }
        .rev-table-wrapper th {
            background: rgba(77, 143, 255, 0.12);
            color: var(--text-primary);
            padding: 11px 14px;
            text-align: left;
            font-weight: 600;
            position: sticky;
            top: 0;
            letter-spacing: 0.3px;
        }
        .rev-table-wrapper td {
            padding: 10px 14px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            color: var(--text-secondary);
        }
        .rev-table-wrapper tr:hover td {
            background: rgba(255, 255, 255, 0.02);
            color: var(--text-primary);
        }
        .rev-table-wrapper::-webkit-scrollbar {
            width: 4px;
        }
        .rev-table-wrapper::-webkit-scrollbar-track {
            background: transparent;
        }
        .rev-table-wrapper::-webkit-scrollbar-thumb {
            background: var(--accent-cyan);
            border-radius: 10px;
        }

        /* ──────── MODAL & TOAST ──────── */
        .notification-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--bg-card);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-left: 4px solid var(--accent-blue);
            padding: 14px 20px;
            border-radius: var(--radius-lg);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
            animation: slideInRight 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            color: var(--text-primary);
            font-size: 0.9rem;
        }
        @keyframes slideInRight {
            from {
                transform: translateX(80px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(8, 12, 24, 0.8);
            z-index: 9998;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }
        .spinner-lg {
            width: 52px;
            height: 52px;
            border: 3px solid rgba(255, 255, 255, 0.08);
            border-top-color: var(--accent-blue);
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            box-shadow: 0 0 30px var(--accent-blue-glow);
        }
        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
        .modal-content {
            border-radius: var(--radius-xl);
            border: 1px solid var(--glass-border);
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.7);
            overflow: hidden;
            background: var(--bg-surface);
            color: var(--text-primary);
        }
        .modal-header {
            border-bottom: 1px solid var(--glass-border);
            background: rgba(77, 143, 255, 0.08);
            padding: 16px 20px;
        }
        .modal-title {
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: 0.3px;
        }
        .modal-body {
            padding: 20px;
            color: var(--text-secondary);
        }
        .modal-footer {
            border-top: 1px solid var(--glass-border);
            padding: 14px 20px;
        }
        .btn-close {
            filter: invert(0.7);
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-blue), #3060cc);
            border: none;
            font-weight: 600;
            letter-spacing: 0.3px;
            box-shadow: 0 4px 16px var(--accent-blue-glow);
            transition: var(--transition-fast);
        }
        .btn-primary:hover {
            box-shadow: 0 8px 28px var(--accent-blue-glow);
            transform: translateY(-1px);
        }

        /* ──────── HIDDEN STATE ──────── */
        .d-none-soft {
            display: none !important;
        }

        /* ──────── RESPONSIVE ──────── */
        @media (max-width: 1200px) {
            .graphic-cluster {
                grid-template-columns: repeat(2, 1fr);
            }
            .quick-actions {
                grid-template-columns: repeat(2, 1fr);
            }
            .revenue-metrics {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        @media (max-width: 992px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.active {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
                width: 100%;
            }
            .menu-toggle {
                display: flex;
            }
            .extra-grid {
                grid-template-columns: 1fr;
            }
            .revenue-metrics {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        @media (max-width: 768px) {
            .graphic-cluster {
                grid-template-columns: 1fr;
            }
            .quick-actions {
                grid-template-columns: 1fr 1fr;
            }
            .filter-header {
                gap: 6px;
                padding: 10px 14px;
                border-radius: var(--radius-lg);
            }
            .header {
                padding: 10px 14px;
                border-radius: var(--radius-lg);
            }
            .main-content {
                padding: 10px 12px;
            }
            .chart-card {
                padding: 14px;
            }
            .type-tabs {
                border-radius: var(--radius-lg);
                padding: 5px 6px;
                gap: 3px;
            }
            .type-tab {
                padding: 8px 12px;
                font-size: 0.7rem;
            }
            .revenue-metrics {
                grid-template-columns: 1fr 1fr;
            }
            .revenue-detail-panel {
                padding: 14px;
            }
        }
        @media (max-width: 480px) {
            .quick-actions {
                grid-template-columns: 1fr;
            }
            .user-details {
                display: none;
            }
            .header-actions {
                gap: 4px;
            }
            .revenue-metrics {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- ═══════════ MOUSE GLOW ═══════════ -->
    <div class="mouse-glow" id="mouseGlow"></div>

    <!-- ═══════════ ANIMATED BACKGROUND ═══════════ -->
    <div class="bg-grid"></div>
    <div class="bg-orb orb-1" id="orb1"></div>
    <div class="bg-orb orb-2" id="orb2"></div>
    <div class="bg-orb orb-3" id="orb3"></div>
    <canvas id="particleCanvas"></canvas>
    <div class="particles-container" id="particlesContainer"></div>

    <!-- ═══════════ SIDEBAR ═══════════ -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon"><i class="fas fa-chart-simple"></i></div>
                <div>
                    <div class="logo-text">ShopMaster</div>
                    <div class="logo-subtext">analytics 2026</div>
                </div>
            </div>
            <button class="toggle-sidebar" id="toggleSidebar"><i class="fas fa-chevron-left"></i></button>
        </div>
        <nav class="sidebar-menu">
            <a href="/Admin/dashboard" class="menu-item"><i class="fas fa-tachometer-alt"></i><span class="menu-text">Dashboard</span></a>
            <a href="/Admin/product" class="menu-item"><i class="fas fa-box"></i><span class="menu-text">Products</span></a>
            <a href="/Admin/category" class="menu-item"><i class="fas fa-tags"></i><span class="menu-text">Categories</span></a>
            <a href="/Admin/order" class="menu-item"><i class="fas fa-shopping-cart"></i><span class="menu-text">Orders</span></a>
            <a href="/Admin/customer" class="menu-item"><i class="fas fa-users"></i><span class="menu-text">Customers</span></a>
            <a href="/Admin/review" class="menu-item "><i class="fas fa-star"></i> Reviews</a>
            <a href="/Admin/analytics" class="menu-item active-menu"><i class="fas fa-chart-line"></i><span class="menu-text">Analytics</span></a>
            <a href="/Admin/profile" class="menu-item"><i class="fas fa-id-badge"></i><span class="menu-text">Profile</span></a>
            <a href="/Admin/setting" class="menu-item"><i class="fas fa-cog"></i><span class="menu-text">Settings</span></a>
        </nav>
    </aside>

    <!-- ═══════════ MAIN CONTENT ═══════════ -->
    <main class="main-content" id="mainContent">
        <div class="header">
            <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
            <div class="search-bar"><i class="fas fa-search"></i><input type="text" placeholder="Search analytics..." id="searchInput"></div>
            <div class="header-actions">
                <button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge" id="notifBadge">5</span></button>
                <button class="notification-btn"><i class="fas fa-envelope"></i><span class="notification-badge">3</span></button>
                <div class="user-info">
                    <a href="/Admin/profile"><img src="https://ui-avatars.com/api/?name=Admin+Master&background=4d8fff&color=fff&bold=true&size=42" alt="admin"></a>
                    <div class="user-details"><h4>Alex Master</h4><p>Super Admin</p></div>
                </div>
            </div>
        </div>

        <!-- ─────── TYPE TABS ─────── -->
        <div class="type-tabs" id="typeTabs">
            <button class="type-tab active" data-type="all"><i class="fas fa-globe"></i> All</button>
            <button class="type-tab" data-type="customers"><i class="fas fa-users"></i> Customers</button>
            <button class="type-tab" data-type="products"><i class="fas fa-box"></i> Products</button>
            <button class="type-tab" data-type="categories"><i class="fas fa-tags"></i> Categories</button>
            <button class="type-tab" data-type="subcategories"><i class="fas fa-folder"></i> Subcategories</button>
