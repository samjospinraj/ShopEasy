<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>ShopEasy • Secure Email Verification</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    :root {
      --primary: #ff6b6b;
      --secondary: #4ecdc4;
      --accent: #ffe66d;
      --dark: #2c3e50;
      --light: #f7f9fc;
      --white: #ffffff;
      --gradient-1: linear-gradient(135deg, #ff6b6b, #ee5a24);
      --gradient-2: linear-gradient(135deg, #4ecdc4, #44bd32);
      --gradient-3: linear-gradient(135deg, #a55eea, #8854d0);
      --shadow-soft: 0 10px 40px rgba(0, 0, 0, 0.08);
      --shadow-hover: 0 20px 50px rgba(0, 0, 0, 0.15);
      --transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    }

    body {
      background: #f0f3f8;
      color: var(--dark);
      overflow-x: hidden;
    }

    .particles-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -1;
    }

    .particle {
      position: absolute;
      border-radius: 50%;
      animation: particleFloat 15s infinite ease-in-out;
      opacity: 0.3;
    }

    @keyframes particleFloat {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      25% { transform: translate(80px, -60px) rotate(90deg); }
      50% { transform: translate(-40px, 40px) rotate(180deg); }
      75% { transform: translate(-70px, -30px) rotate(270deg); }
    }

    .header-premium {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      padding: 12px 0;
      position: sticky;
      top: 0;
      z-index: 1030;
      transition: var(--transition);
    }

    .header-premium.scrolled {
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
      padding: 8px 0;
    }

    .brand-premium {
      font-size: 2.2rem;
      font-weight: 900;
      background: var(--gradient-1);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      letter-spacing: -1px;
      transition: var(--transition);
      text-decoration: none;
    }

    .brand-premium:hover {
      transform: scale(1.05);
      filter: brightness(1.2);
    }

    .nav-icon-premium {
      position: relative;
      color: #666;
      font-size: 1.4rem;
      margin-left: 22px;
      transition: var(--transition);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
    }

    .nav-icon-premium:hover {
      color: var(--primary);
      transform: translateY(-2px);
    }

    .cart-badge-premium {
      position: absolute;
      top: -10px;
      right: -14px;
      background: var(--gradient-1);
      color: white;
      border-radius: 50%;
      width: 24px;
      height: 24px;
      font-size: 0.7rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    /* Verification Card */
    .verification-section {
      min-height: calc(100vh - 200px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 20px;
    }

    .verify-card-premium {
      background: white;
      border-radius: 40px;
      box-shadow: var(--shadow-soft);
      overflow: hidden;
      transition: var(--transition);
      max-width: 550px;
      width: 100%;
      border: none;
    }

    .verify-card-premium:hover {
      box-shadow: var(--shadow-hover);
      transform: translateY(-8px);
    }

    .verify-header-premium {
      background: var(--gradient-3);
      padding: 35px 30px;
      text-align: center;
      color: white;
    }

    .verify-header-premium i {
      font-size: 4rem;
      background: rgba(255, 255, 255, 0.2);
      padding: 20px;
      border-radius: 80px;
      margin-bottom: 20px;
      backdrop-filter: blur(10px);
      transition: all 0.3s ease;
    }

    .verify-header-premium h3 {
      font-weight: 800;
      font-size: 1.8rem;
      margin-bottom: 8px;
    }

    .verify-header-premium p {
      opacity: 0.9;
      font-size: 0.9rem;
    }

    .verify-body-premium {
      padding: 40px 35px;
    }

    .email-step,
    .otp-step {
      transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .hide-step {
      display: none;
    }

    .input-group-premium {
      margin-bottom: 25px;
    }

    .input-group-premium label {
      font-weight: 700;
      font-size: 0.85rem;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--dark);
    }

    .input-group-premium label i {
      color: var(--primary);
    }

    .input-group-premium input {
      width: 100%;
      padding: 14px 20px;
      border: 2px solid #e8ecf1;
      border-radius: 60px;
      font-size: 0.95rem;
      transition: var(--transition);
      outline: none;
      background: white;
    }

    .input-group-premium input:focus {
      border-color: var(--primary);
      box-shadow: 0 5px 20px rgba(255, 107, 107, 0.15);
      transform: scale(1.02);
    }

    .btn-send-premium,
    .btn-verify-premium {
      background: var(--gradient-3);
      border: none;
      padding: 14px;
      border-radius: 60px;
      font-weight: 800;
      font-size: 1.1rem;
      width: 100%;
      color: white;
      transition: var(--transition);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .btn-send-premium:hover:not(:disabled),
    .btn-verify-premium:hover:not(:disabled) {
      transform: translateY(-3px);
      filter: brightness(1.05);
      box-shadow: 0 15px 30px rgba(165, 94, 234, 0.3);
    }

    .btn-send-premium:disabled,
    .btn-verify-premium:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .email-display {
      background: #f8f9fc;
      border-radius: 60px;
      padding: 12px 20px;
      text-align: center;
      margin-bottom: 25px;
      font-weight: 600;
      color: var(--dark);
      border: 2px solid #e8ecf1;
      word-break: break-all;
    }

    .email-display i {
      color: var(--primary);
      margin-right: 10px;
    }

    .code-instruction {
      text-align: center;
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 30px;
    }

    .otp-container {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-bottom: 30px;
      flex-wrap: wrap;
    }

    .otp-input {
      width: 65px;
      height: 75px;
      text-align: center;
      font-size: 1.8rem;
      font-weight: 700;
      border: 2px solid #e8ecf1;
      border-radius: 20px;
      background: white;
      transition: var(--transition);
      outline: none;
      color: var(--dark);
    }

    .otp-input:focus {
      border-color: var(--primary);
      box-shadow: 0 5px 20px rgba(255, 107, 107, 0.2);
      transform: translateY(-2px);
    }

    .otp-input::-webkit-inner-spin-button,
    .otp-input::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    .otp-input[type=number] {
      -moz-appearance: textfield;
    }

    .resend-code {
      text-align: center;
      margin-top: 20px;
    }

    .resend-link {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }

    .active-link {
      pointer-events: auto;
      opacity: 1;
    }

    .inactive-link {
      pointer-events: none;
      opacity: 0.5;
    }

    .timer-text {
      font-size: 0.85rem;
      color: #999;
      margin-top: 10px;
    }

    .back-to-login {
      text-align: center;
      margin-top: 20px;
    }

    .back-to-login a,
    .edit-email-link {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .back-to-login a:hover,
    .edit-email-link:hover {
      text-decoration: underline;
    }

    /* ---------- SUCCESS OVERLAY ---------- */
    .success-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(10px);
      z-index: 3000;
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
    }

    .success-overlay.show {
      display: flex;
    }

    .animation-container {
      position: relative;
      width: 220px;
      height: 220px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .success-message {
      color: white;
      font-size: 1.4rem;
      font-weight: 700;
      text-align: center;
      animation: fadeInUp 0.5s ease forwards;
      opacity: 0;
    }

    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .otp-animation .shield {
      width: 120px;
      height: 130px;
      background: linear-gradient(135deg, #3498db, #2980b9);
      clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
      position: absolute;
      animation: shieldAppear 0.6s ease forwards;
    }

    .otp-animation .lock {
      position: absolute;
      font-size: 40px;
      color: white;
      animation: lockUnlock 0.8s 0.6s ease forwards;
      opacity: 1;
    }

    @keyframes shieldAppear {
      0% { transform: scale(0); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes lockUnlock {
      0% { opacity: 1; transform: scale(1); }
      50% { opacity: 0; transform: scale(1.5); }
      100% { opacity: 0; transform: scale(0); }
    }

    /* ---------- NOTIFICATION MODAL ---------- */
    .modal-premium { z-index: 3500 !important; }
    .modal-premium + .modal-backdrop { z-index: 3499 !important; }
    .modal-premium .modal-content {
      border-radius: 28px;
      border: none;
      box-shadow: 0 30px 80px rgba(0,0,0,0.25);
      animation: modalBounceIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
    }
    @keyframes modalBounceIn {
      from { opacity: 0; transform: scale(0.85) translateY(-30px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .modal-premium .modal-header {
      border-bottom: none;
      padding: 25px 24px 5px;
      text-align: center;
      display: block;
    }
    .modal-icon-circle {
      width: 65px;
      height: 65px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 12px;
      color: white;
    }
    .modal-icon-circle.success { background: var(--gradient-2); }
    .modal-icon-circle.error { background: var(--gradient-1); }
    .modal-icon-circle.warning { background: linear-gradient(135deg, #f39c12, #e67e22); }
    .modal-icon-circle.info { background: linear-gradient(135deg, #667eea, #764ba2); }
    .modal-premium .modal-body {
      padding: 5px 24px 18px;
      text-align: center;
      font-size: 0.95rem;
      color: #555;
    }
    .modal-message-title {
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--dark);
      margin-bottom: 5px;
    }
    .modal-premium .modal-footer {
      border-top: none;
      padding: 0 24px 22px;
      justify-content: center;
      gap: 10px;
    }
    .btn-modal-action {
      padding: 10px 26px;
      border-radius: 50px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      font-size: 0.9rem;
      transition: all 0.2s;
    }
    .btn-modal-primary { background: var(--gradient-1); color: white; }
    .btn-modal-primary:hover { filter: brightness(1.1); }
    .btn-modal-secondary { background: #f0f0f0; color: #333; }
    .btn-modal-secondary:hover { background: #e0e0e0; }

    .footer-premium {
      background: #1a1a2e;
      color: #aab;
      padding: 60px 0 25px;
    }

    .footer-premium h6 { color: white; font-weight: 800; margin-bottom: 20px; }
    .footer-premium a {
      color: #889;
      text-decoration: none;
      display: block;
      margin-bottom: 12px;
      transition: var(--transition);
      font-size: 0.9rem;
    }
    .footer-premium a:hover { color: var(--primary); padding-left: 8px; }

    .social-circle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 45px;
      height: 45px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
      margin-right: 12px;
      color: white;
      text-decoration: none;
      transition: var(--transition);
    }
    .social-circle:hover {
      background: var(--gradient-1);
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(255,107,107,0.4);
    }

    @keyframes shake {
      0%,100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
    .shake-animation { animation: shake 0.3s ease-in-out; }

    .border-top { border-top: 1px solid rgba(255,255,255,0.1) !important; }

    /* Responsive refinements */
    @media (max-width: 576px) {
      .brand-premium { font-size: 1.8rem; }
      .nav-icon-premium { font-size: 1.2rem; margin-left: 12px; }
      .verify-body-premium { padding: 30px 20px; }
      .verify-header-premium { padding: 25px 20px; }
      .verify-header-premium i { font-size: 3rem; padding: 15px; }
      .verify-header-premium h3 { font-size: 1.4rem; }
      .otp-input { width: 50px; height: 60px; font-size: 1.4rem; }
      .otp-container { gap: 8px; }
    }

    @media (max-width: 380px) {
      .otp-input { width: 45px; height: 55px; font-size: 1.2rem; }
      .otp-container { gap: 6px; }
      .verify-body-premium { padding: 20px 15px; }
      .btn-send-premium, .btn-verify-premium { font-size: 1rem; padding: 12px; }
    }
  </style>
</head>

<body>
  <div class="particles-container" id="particlesContainer"></div>

  <!-- SUCCESS ANIMATION OVERLAY -->
  <div class="success-overlay" id="successOverlay">
    <div class="animation-container" id="animationContainer"></div>
    <div class="success-message" id="successMessage">Success!</div>
  </div>

  <!-- NOTIFICATION MODAL -->
  <div class="modal fade modal-premium" id="notificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <div class="modal-icon-circle" id="modalIconCircle"></div>
        </div>
        <div class="modal-body">
          <div class="modal-message-title" id="modalTitle"></div>
          <p class="mb-0" id="modalMessage"></p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-modal-action btn-modal-primary" id="modalPrimaryBtn" data-bs-dismiss="modal">OK</button>
          <button type="button" class="btn-modal-action btn-modal-secondary" id="modalSecondaryBtn" style="display:none;" data-bs-dismiss="modal">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <header class="header-premium" id="header">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center">
        <a href="#" class="brand-premium">ShopEasy</a>
        <div class="d-flex align-items-center">
          <a href="#" class="nav-icon-premium"><i class="fas fa-user-circle"></i></a>
          <a href="#" class="nav-icon-premium"><i class="fas fa-heart"></i></a>
          <a href="#" class="nav-icon-premium position-relative">
            <i class="fas fa-shopping-bag"></i>
            <span class="cart-badge-premium" id="cartCount">0</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <div class="container">
    <div class="verification-section">
      <div class="verify-card-premium">
        <div class="verify-header-premium">
          <i class="fas fa-envelope" id="headerIcon"></i>
          <h3 id="headerTitle">Verify Your Email</h3>
          <p id="headerSubtitle">Enter your email to receive a verification code</p>
        </div>
        <div class="verify-body-premium">
          <!-- Email Step -->
          <div class="email-step" id="emailStep">
            <form id="emailForm">
              <div class="input-group-premium">
                <label><i class="fas fa-envelope"></i> Email Address</label>
                <input type="email" id="userEmailInput" placeholder="Enter your email address" name="email" required autocomplete="email">
              </div>
              <button type="submit" class="btn-send-premium" id="sendCodeBtn">
                <i class="fas fa-paper-plane"></i> Send Verification Code
              </button>
            </form>
            <div class="back-to-login">
              <a href="" id="backToLogin"><i class="fas fa-arrow-left"></i> Back to Login</a>
            </div>
          </div>

          <!-- OTP Step -->
          <div class="otp-step hide-step" id="otpStep">
            <div class="email-display">
              <i class="fas fa-envelope"></i>
              <span id="userEmailDisplay"></span>
              <a href="#" class="edit-email-link" id="editEmailLink"><i class="fas fa-pencil-alt"></i> Edit</a>
            </div>
            <div class="code-instruction">We've sent a 6-digit verification code to your email. Please enter it below.</div>
            <div class="otp-container" id="otpContainer">
              <input type="number" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric" id="otp0" data-index="0">
              <input type="number" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric" id="otp1" data-index="1">
              <input type="number" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric" id="otp2" data-index="2">
              <input type="number" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric" id="otp3" data-index="3">
              <input type="number" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric" id="otp4" data-index="4">
              <input type="number" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric" id="otp5" data-index="5">
            </div>
            <button class="btn-verify-premium" id="verifyBtn">
              <i class="fas fa-check-circle"></i> Verify & Continue
            </button>
            <div class="resend-code">
              <span class="timer-text">Resend code in <span id="countdown">30</span> seconds</span>
              <div><a href="#" class="resend-link inactive-link" id="resendLink">Resend Code</a></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer-premium">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-3 col-6">
          <h6>ShopEasy</h6><a href="#">Our Story</a><a href="#">Careers</a><a href="#">Press</a>
        </div>
        <div class="col-md-3 col-6">
          <h6>Support</h6><a href="#">Help Center</a><a href="#">Shipping Info</a><a href="#">Returns</a>
        </div>
        <div class="col-md-3 col-6">
          <h6>Account</h6><a href="#">My Orders</a><a href="#">Wishlist</a><a href="#">Profile</a>
        </div>
        <div class="col-md-3 col-6">
          <h6>Connect</h6>
          <div>
            <a href="#" class="social-circle"><i class="fab fa-facebook-f"></i></a>
            <a href="#" class="social-circle"><i class="fab fa-instagram"></i></a>
            <a href="#" class="social-circle"><i class="fab fa-pinterest"></i></a>
          </div>
        </div>
      </div>
      <div class="text-center mt-5 pt-4 border-top">© 2025 ShopEasy Premium. All rights reserved.</div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function () {
      const API_BASE_URL = 'http://localhost:3000';

      // ========== PREMIUM POP-UP MODAL ==========
      const notifModal = document.getElementById('notificationModal');
      const bsNotifModal = notifModal ? new bootstrap.Modal(notifModal, { backdrop: 'static' }) : null;
      function showModal(type, title, msg, opts = {}) {
        if (!bsNotifModal) return;
        const map = {
          success: { cls: 'success', icon: 'fa-check-circle' },
          error: { cls: 'error', icon: 'fa-times-circle' },
          warning: { cls: 'warning', icon: 'fa-exclamation-triangle' },
          info: { cls: 'info', icon: 'fa-info-circle' }
        };
        const cfg = map[type] || map.info;
        document.getElementById('modalIconCircle').className = 'modal-icon-circle ' + cfg.cls;
        document.getElementById('modalIconCircle').innerHTML = `<i class="fas ${cfg.icon}"></i>`;
        document.getElementById('modalTitle').textContent = title;
        document.getElementById('modalMessage').textContent = msg;

        const pri = document.getElementById('modalPrimaryBtn');
        pri.textContent = opts.primaryText || 'OK';
        pri.style.display = 'inline-block';
        pri.onclick = () => { opts.onPrimary?.(); bsNotifModal.hide(); };

        const sec = document.getElementById('modalSecondaryBtn');
        let secondaryText = opts.secondaryText;
        if (secondaryText === undefined) secondaryText = 'Cancel';
        if (secondaryText) {
          sec.textContent = secondaryText;
          sec.style.display = 'inline-block';
          sec.onclick = () => { opts.onSecondary?.(); bsNotifModal.hide(); };
        } else {
          sec.style.display = 'none';
        }
        bsNotifModal.show();
        if (opts.autoHide) setTimeout(() => bsNotifModal.hide(), opts.autoHide);
      }

      // ========== SUCCESS ANIMATION ==========
      function showSuccessAnimation() {
        const overlay = document.getElementById('successOverlay');
        const container = document.getElementById('animationContainer');
        const msgEl = document.getElementById('successMessage');
        container.innerHTML = `
          <div class="otp-animation" style="position:relative;width:100%;height:100%">
            <div class="shield"></div>
            <div class="lock">🔒</div>
          </div>`;
        msgEl.textContent = 'Email Verified Successfully!';
        overlay.classList.add('show');
        setTimeout(() => {
          window.location.replace(`${API_BASE_URL}/signup`);
        }, 2500);
      }

      // ========== API FUNCTIONS ==========
      async function apiRequest(endpoint, method = 'GET', bodyObj = null) {
        const config = { method, headers: { 'Content-Type': 'application/json' } };
        if (bodyObj && method !== 'GET') config.body = JSON.stringify(bodyObj);
        const response = await fetch(`${API_BASE_URL}${endpoint}`, config);
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || data.message || `Request failed (${response.status})`);
        return data;
      }

      async function sendVerificationCode(email) { return apiRequest('/verification', 'POST', { email }); }
      async function verifyOtpCode(email, otp) { return apiRequest('/verify_otp', 'POST', { email, otp }); }
      async function resendVerificationCode(email) { return apiRequest('/resend-otp', 'POST', { email }); }

      // ========== UI SETUP ==========
      const particlesContainer = document.getElementById('particlesContainer');
      for (let i = 0; i < 20; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        const size = Math.random() * 30 + 10;
        p.style.width = size + 'px'; p.style.height = size + 'px';
        p.style.background = ['#ff6b6b', '#4ecdc4', '#ffe66d', '#a55eea'][Math.floor(Math.random() * 4)];
        p.style.left = Math.random() * 100 + '%'; p.style.top = Math.random() * 100 + '%';
        p.style.animationDelay = Math.random() * 10 + 's';
        p.style.animationDuration = (Math.random() * 10 + 15) + 's';
        particlesContainer.appendChild(p);
      }

      const header = document.getElementById('header');
      window.addEventListener('scroll', () => header.classList.toggle('scrolled', window.scrollY > 50));

      // ========== DOM ELEMENTS ==========
      const emailStep = document.getElementById('emailStep');
      const otpStep = document.getElementById('otpStep');
      const emailForm = document.getElementById('emailForm');
      const userEmailInput = document.getElementById('userEmailInput');
      const sendCodeBtn = document.getElementById('sendCodeBtn');
      const verifyBtn = document.getElementById('verifyBtn');
      const resendLink = document.getElementById('resendLink');
      const countdownSpan = document.getElementById('countdown');
      const editEmailLink = document.getElementById('editEmailLink');
      const userEmailDisplay = document.getElementById('userEmailDisplay');
      const backToLogin = document.getElementById('backToLogin');
      const otpInputs = document.querySelectorAll('.otp-input');

      // ========== STATE ==========
      let currentEmail = '';
      let timerInterval = null;
      let countdown = 0;

      function showEmailStep(resetEmail = true) {
        emailStep.classList.remove('hide-step');
        otpStep.classList.add('hide-step');
        document.getElementById('headerIcon').className = 'fas fa-envelope';
        document.getElementById('headerTitle').innerText = 'Verify Your Email';
        document.getElementById('headerSubtitle').innerText = 'Enter your email to receive a verification code';
        if (resetEmail && currentEmail && userEmailInput) userEmailInput.value = currentEmail;
        if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
      }

      function showOtpStep(email) {
        currentEmail = email;
        userEmailDisplay.innerText = email;
        emailStep.classList.add('hide-step');
        otpStep.classList.remove('hide-step');
        document.getElementById('headerIcon').className = 'fas fa-key';
        document.getElementById('headerTitle').innerText = 'Enter Security Code';
        document.getElementById('headerSubtitle').innerText = '6-digit code sent to your inbox';
        clearOtpInputs();
        startTimer();
        setTimeout(() => document.getElementById('otp0')?.focus(), 100);
      }

      function clearOtpInputs() { otpInputs.forEach(input => { if (input) input.value = ''; }); }
      function getFullOtp() {
        return Array.from({ length: 6 }, (_, i) => {
          const input = document.getElementById(`otp${i}`);
          return input ? input.value : '';
        }).join('');
      }

      function shakeInputs() {
        const container = document.querySelector('.otp-container');
        if (container) {
          container.classList.add('shake-animation');
          setTimeout(() => container.classList.remove('shake-animation'), 300);
        }
      }

      function startTimer(seconds = 45) {
        if (timerInterval) clearInterval(timerInterval);
        countdown = seconds;
        countdownSpan.innerText = countdown;
        resendLink.classList.remove('active-link');
        resendLink.classList.add('inactive-link');
        timerInterval = setInterval(() => {
          countdown--;
          countdownSpan.innerText = Math.max(0, countdown);
          if (countdown <= 0) {
            clearInterval(timerInterval);
            timerInterval = null;
            resendLink.classList.remove('inactive-link');
            resendLink.classList.add('active-link');
          }
        }, 1000);
      }

      // ========== EVENT HANDLERS ==========
      emailForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = userEmailInput?.value.trim();
        if (!email) { showModal('warning', 'Missing Email', 'Please enter your email address'); return; }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showModal('warning', 'Invalid Email', 'Enter a valid email address'); return; }

        sendCodeBtn.disabled = true;
        const originalHtml = sendCodeBtn.innerHTML;
        sendCodeBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Sending...';
        try {
          await sendVerificationCode(email);
          showOtpStep(email);
          showModal('success', 'Code Sent', `Verification code sent to ${email}`);
        } catch (err) {
          showModal('error', 'Error', err.message);
        } finally {
          sendCodeBtn.disabled = false;
          sendCodeBtn.innerHTML = originalHtml;
        }
      });

      verifyBtn?.addEventListener('click', async () => {
        const enteredOtp = getFullOtp();
        if (enteredOtp.length !== 6) { showModal('warning', 'Invalid OTP', 'Enter 6-digit verification code'); shakeInputs(); return; }
        verifyBtn.disabled = true;
        const originalHtml = verifyBtn.innerHTML;
        verifyBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Verifying...';
        try {
          await verifyOtpCode(currentEmail, enteredOtp);
          showSuccessAnimation();
        } catch (err) {
          showModal('error', 'Verification Failed', err.message);
          shakeInputs();
          clearOtpInputs();
          document.getElementById('otp0')?.focus();
        } finally {
          verifyBtn.disabled = false;
          verifyBtn.innerHTML = originalHtml;
        }
      });

      resendLink?.addEventListener('click', async (e) => {
        e.preventDefault();
        if (countdown > 0) { showModal('warning', 'Wait', `Please wait ${countdown} seconds`); return; }
        if (!currentEmail) { showModal('warning', 'Email Missing', 'Please go back and enter email'); return; }
        resendLink.classList.remove('active-link');
        resendLink.classList.add('inactive-link');
        try {
          await resendVerificationCode(currentEmail);
          startTimer();
          clearOtpInputs();
          showModal('success', 'Code Resent', 'New verification code sent');
        } catch (err) {
          showModal('error', 'Error', err.message);
          resendLink.classList.add('active-link');
          resendLink.classList.remove('inactive-link');
        }
      });

      editEmailLink?.addEventListener('click', (e) => {
        e.preventDefault();
        if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
        showEmailStep(true);
        if (userEmailInput) userEmailInput.value = currentEmail;
        currentEmail = '';
      });

      backToLogin?.addEventListener('click', (e) => {
        e.preventDefault();
        showModal('info', 'Redirecting', 'Redirecting to login...');
        setTimeout(() => window.location.replace(`${API_BASE_URL}/login`), 600);
      });

      // OTP input handlers
      function handleOtpInput(e, idx) {
        const val = e.target.value;
        if (val.length > 1) e.target.value = val.charAt(val.length - 1);
        if (val && idx < 5) document.getElementById(`otp${idx + 1}`)?.focus();
      }

      function handleOtpKeydown(e, idx) {
        if (e.key === 'Backspace') {
          e.preventDefault();
          if (e.target.value === '' && idx > 0) {
            const prev = document.getElementById(`otp${idx - 1}`);
            if (prev) { prev.focus(); prev.value = ''; }
          } else { e.target.value = ''; }
        } else if (e.key === 'ArrowLeft' && idx > 0) {
          e.preventDefault();
          document.getElementById(`otp${idx - 1}`)?.focus();
        } else if (e.key === 'ArrowRight' && idx < 5) {
          e.preventDefault();
          document.getElementById(`otp${idx + 1}`)?.focus();
        }
      }

      otpInputs.forEach((input, idx) => {
        if (!input) return;
        input.addEventListener('input', (e) => handleOtpInput(e, idx));
        input.addEventListener('keydown', (e) => handleOtpKeydown(e, idx));
      });

      const otpContainer = document.querySelector('.otp-container');
      otpContainer?.addEventListener('paste', (e) => {
        e.preventDefault();
        const pasteData = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 6);
        for (let i = 0; i < pasteData.length; i++) {
          const input = document.getElementById(`otp${i}`);
          if (input) input.value = pasteData[i];
        }
        if (pasteData.length === 6) verifyBtn?.focus();
        else if (pasteData.length > 0 && pasteData.length < 6) document.getElementById(`otp${pasteData.length}`)?.focus();
      });
    })();
  </script>
</body>

</html>