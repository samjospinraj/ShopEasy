<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopMaster · E‑commerce Admin Dashboard 2026</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --bg-deep: #060b1f;
            --bg-card: rgba(10, 16, 36, 0.65);
            --bg-card-hover: rgba(14, 22, 45, 0.78);
            --bg-sidebar: rgba(7, 11, 28, 0.82);
            --bg-header: rgba(9, 14, 32, 0.7);
            --glass-blur: 18px;
            --glass-blur-light: 10px;
            --primary: #4dabf7;
            --primary-glow: #339af0;
            --accent-cyan: #38bdf8;
            --accent-teal: #2dd4bf;
            --accent-purple: #a78bfa;
            --accent-violet: #8b5cf6;
            --accent-green: #34d399;
            --accent-orange: #fb923c;
            --accent-red: #f87171;
            --accent-pink: #f472b6;
            --text-primary: #e8ecf4;
            --text-secondary: #b0bdd0;
            --text-muted: #7b8ca6;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(77, 171, 247, 0.3);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.4), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-glow: 0 0 40px rgba(77, 171, 247, 0.18), 0 0 80px rgba(77, 171, 247, 0.06);
            --radius-xl: 22px;
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-smooth: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'SF Pro Display', 'Inter', Roboto, system-ui, sans-serif;
        }
        body {
            background: radial-gradient(ellipse at 20% 20%, #0b1430 0%, #060b1f 45%, #04091a 70%, #020617 100%);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
        }
        #nuranCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        .loading-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(6, 11, 31, 0.75);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
            transition: opacity 0.4s ease;
        }
        .loading-overlay.hidden { opacity: 0; pointer-events: none; }
        .spinner-ring {
            width: 52px; height: 52px;
            border-radius: 50%;
            border: 3px solid rgba(255, 255, 255, 0.08);
            border-top-color: var(--accent-cyan);
            border-right-color: var(--accent-purple);
            animation: spinRing 0.8s linear infinite;
            box-shadow: 0 0 30px rgba(56, 189, 248, 0.4), 0 0 60px rgba(139, 92, 246, 0.25);
        }
        @keyframes spinRing { to { transform: rotate(360deg); } }

        /* SIDEBAR */
        .sidebar {
            width: 280px;
            background: var(--bg-sidebar);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            color: var(--text-primary);
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            border-right: 1px solid var(--border-subtle);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        .sidebar-header {
            padding: 0 20px 18px 20px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo { display: flex; align-items: center; gap: 12px; }
        .logo-icon {
            font-size: 1.8rem;
            color: var(--accent-cyan);
            background: rgba(56, 189, 248, 0.1);
            padding: 10px;
            border-radius: 14px;
            border: 2px solid rgba(56, 189, 248, 0.3);
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.2);
        }
        .logo-text {
            font-size: 1.6rem;
            font-weight: 700;
            line-height: 1.2;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .logo-subtext {
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }
        .toggle-sidebar {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 36px; height: 36px;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
            font-size: 1rem;
        }
        .toggle-sidebar:hover {
            background: rgba(77, 171, 247, 0.15);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.25);
        }
        .sidebar-menu { flex: 1; padding: 20px 0; }
        .menu-item {
            display: flex;
            align-items: center;
            padding: 13px 20px;
            margin: 3px 10px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition-fast);
            border-radius: 10px;
            cursor: pointer;
            font-weight: 450;
            position: relative;
            border: 1px solid transparent;
        }
        .menu-item:hover {
            background: rgba(77, 171, 247, 0.08);
            color: var(--text-primary);
            border-color: rgba(77, 171, 247, 0.2);
        }
        .menu-item.active-menu {
            background: rgba(77, 171, 247, 0.13);
            color: #fff;
            border-color: rgba(77, 171, 247, 0.35);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.15);
        }
        .menu-item.active-menu::before {
            content: '';
            position: absolute;
            left: -2px; top: 50%;
            transform: translateY(-50%);
            width: 4px; height: 22px;
            border-radius: 0 4px 4px 0;
            background: var(--accent-cyan);
            box-shadow: 0 0 14px var(--accent-cyan);
        }
        .menu-item i { width: 24px; font-size: 1.15rem; margin-right: 14px; text-align: center; }
        .menu-text { font-size: 0.95rem; }

        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 22px 30px;
            transition: margin-left 0.35s ease;
            width: 100%;
            position: relative;
            z-index: 1;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-header);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 14px 26px;
            border-radius: 50px;
            box-shadow: var(--shadow-card);
            margin-bottom: 30px;
            border: 1px solid var(--border-subtle);
            flex-wrap: wrap;
            gap: 14px;
            position: relative;
            z-index: 2;
        }
        .menu-toggle {
            display: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 44px; height: 44px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1.2rem;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
        }
        .menu-toggle:hover {
            border-color: var(--border-glow);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.2);
            color: var(--accent-cyan);
        }
        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            padding: 8px 20px;
            width: min(400px, 100%);
            border: 1px solid var(--border-subtle);
            transition: var(--transition-fast);
        }
        .search-bar:focus-within {
            border-color: var(--border-glow);
            box-shadow: 0 0 20px rgba(77, 171, 247, 0.2);
            background: rgba(255, 255, 255, 0.05);
        }
        .search-bar input {
            border: none;
            background: transparent;
            padding: 8px 10px;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
            color: var(--text-primary);
        }
        .search-bar input::placeholder { color: var(--text-muted); }
        .search-bar i { color: var(--text-muted); }
        .header-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .notification-btn {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-subtle);
            font-size: 1.15rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 10px 12px;
            border-radius: 50%;
            transition: var(--transition-fast);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .notification-btn:hover {
            background: rgba(77, 171, 247, 0.12);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.2);
        }
        .notification-badge {
            position: absolute;
            top: 2px; right: 3px;
            background: var(--accent-red);
            color: #fff;
            font-size: 0.6rem;
            width: 18px; height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            box-shadow: 0 0 10px rgba(248, 113, 113, 0.5);
            animation: pulseBadge 2s ease-in-out infinite;
        }
        @keyframes pulseBadge {
            0%, 100% { box-shadow: 0 0 8px rgba(248, 113, 113, 0.5); }
            50% { box-shadow: 0 0 20px rgba(248, 113, 113, 0.8), 0 0 30px rgba(248, 113, 113, 0.3); }
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 5px 18px 5px 8px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            border: 1px solid var(--border-subtle);
            transition: var(--transition-fast);
        }
        .user-info:hover {
            border-color: var(--border-glow);
            box-shadow: 0 0 16px rgba(77, 171, 247, 0.15);
        }
        .user-info img {
            width: 40px; height: 40px;
            border-radius: 50%;
            border: 2px solid rgba(77, 171, 247, 0.5);
            object-fit: cover;
            box-shadow: 0 0 12px rgba(77, 171, 247, 0.3);
        }
        .user-details h4 { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); }
        .user-details p { font-size: 0.7rem; color: var(--text-muted); }

        /* Quick actions */
        .quick-actions { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 32px; position: relative; z-index: 1; }
        .action-card {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 22px 16px;
            border: 1px solid var(--border-subtle);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            transition: var(--transition-smooth);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        .action-card::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: var(--radius-xl);
            opacity: 0;
            transition: opacity 0.4s ease;
            background: radial-gradient(circle at 50% 0%, rgba(77, 171, 247, 0.12) 0%, transparent 70%);
            pointer-events: none;
        }
        .action-card:hover::after { opacity: 1; }
        .action-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-glow);
            border-color: var(--border-glow);
            background: var(--bg-card-hover);
        }
        .action-icon {
            width: 60px; height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.7rem;
            color: #fff;
            margin-bottom: 14px;
            position: relative;
            z-index: 1;
        }
        .action-card:nth-child(1) .action-icon { background: linear-gradient(135deg, #4dabf7, #228be6); box-shadow: 0 8px 24px rgba(77,171,247,0.35); }
        .action-card:nth-child(2) .action-icon { background: linear-gradient(135deg, #34d399, #10b981); box-shadow: 0 8px 24px rgba(52,211,153,0.35); }
        .action-card:nth-child(3) .action-icon { background: linear-gradient(135deg, #fb923c, #f97316); box-shadow: 0 8px 24px rgba(251,146,60,0.35); }
        .action-card:nth-child(4) .action-icon { background: linear-gradient(135deg, #a78bfa, #7c3aed); box-shadow: 0 8px 24px rgba(167,139,250,0.35); }
        .action-card h4 { font-size: 1rem; margin-bottom: 4px; color: var(--text-primary); position: relative; z-index: 1; }
        .action-card p { font-size: 0.8rem; color: var(--text-muted); position: relative; z-index: 1; }

        /* Stat cards */
        .cards-container { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 36px; position: relative; z-index: 1; }
        .card {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 22px;
            border: 1px solid var(--border-subtle);
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
        }
        .card:hover {
            box-shadow: var(--shadow-glow);
            border-color: var(--border-glow);
            background: var(--bg-card-hover);
            transform: translateY(-3px);
        }
        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 4px;
            border-radius: 4px 4px 0 0;
        }
        .card.revenue::before { background: linear-gradient(90deg, #4dabf7, #38bdf8, #228be6); }
        .card.orders::before { background: linear-gradient(90deg, #34d399, #2dd4bf, #10b981); }
        .card.products::before { background: linear-gradient(90deg, #fb923c, #f59e0b, #f97316); }
        .card.customers::before { background: linear-gradient(90deg, #a78bfa, #8b5cf6, #7c3aed); }
        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; margin-top: 6px; }
        .card-header h3 { font-size: 0.9rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; }
        .card-icon {
            width: 46px; height: 46px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: #fff;
        }
        .card.revenue .card-icon { background: linear-gradient(135deg, #4dabf7, #228be6); box-shadow: 0 6px 18px rgba(77,171,247,0.3); }
        .card.orders .card-icon { background: linear-gradient(135deg, #34d399, #10b981); box-shadow: 0 6px 18px rgba(52,211,153,0.3); }
        .card.products .card-icon { background: linear-gradient(135deg, #fb923c, #f59e0b); box-shadow: 0 6px 18px rgba(251,146,60,0.3); }
        .card.customers .card-icon { background: linear-gradient(135deg, #a78bfa, #7c3aed); box-shadow: 0 6px 18px rgba(167,139,250,0.3); }
        .card-value { font-size: 2rem; font-weight: 700; margin: 8px 0 4px; color: #fff; letter-spacing: -0.5px; }
        .card-detail { font-size: 0.82rem; display: flex; align-items: center; gap: 5px; margin-bottom: 16px; font-weight: 500; }
        .card-detail.positive { color: var(--accent-green); }
        .card-detail.negative { color: var(--accent-red); }
        .btn {
            padding: 10px 18px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: var(--transition-fast);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            letter-spacing: 0.3px;
        }
        .btn-primary { background: linear-gradient(135deg, #4dabf7, #339af0); color: #fff; box-shadow: 0 4px 16px rgba(77,171,247,0.3); }
        .btn-success { background: linear-gradient(135deg, #34d399, #10b981); color: #fff; box-shadow: 0 4px 16px rgba(52,211,153,0.3); }
        .btn-outline { background: transparent; border: 2px solid rgba(77, 171, 247, 0.5); color: var(--accent-cyan); }
        .btn:hover { transform: translateY(-3px); filter: brightness(1.1); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
        .btn-outline:hover { background: rgba(77, 171, 247, 0.1); border-color: var(--accent-cyan); box-shadow: 0 0 20px rgba(56,189,248,0.3); }

        /* Analytics section */
        .analytics-container { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 36px; position: relative; z-index: 1; }
        .chart-container, .summary-container {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 22px;
            border: 1px solid var(--border-subtle);
            transition: var(--transition-smooth);
        }
        .chart-container:hover, .summary-container:hover { border-color: var(--border-glow); box-shadow: var(--shadow-glow); }
        .chart-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 18px; }
        .chart-header h3 { font-size: 1.15rem; color: var(--text-primary); }
        .chart-header select {
            padding: 8px 16px;
            border-radius: 30px;
            border: 1px solid var(--border-subtle);
            background: rgba(255,255,255,0.04);
            color: var(--text-primary);
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition-fast);
            font-size: 0.85rem;
        }
        .chart-header select:hover { border-color: var(--border-glow); }
        .chart-canvas-wrap { height: 280px; position: relative; }
        .chart-canvas-wrap canvas { width: 100% !important; height: 100% !important; }
        .stats-summary { margin-top: 8px; }
        .stat-item {
            padding: 13px 8px;
            border-bottom: 1px solid var(--border-subtle);
            font-weight: 600;
            color: var(--text-primary);
            transition: var(--transition-fast);
        }
        .stat-item:hover { background: rgba(255,255,255,0.02); border-radius: 8px; }
        .stat-item strong { color: var(--accent-cyan); }
        .view-all-btn-small {
            margin-top: 14px;
            text-align: right;
        }
        .view-all-btn-small .btn {
            padding: 8px 16px;
            font-size: 0.8rem;
        }

        .analytics-summary-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 20px; }
        .analytics-mini-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border-subtle);
            border-radius: 16px;
            padding: 16px;
            text-align: center;
            transition: var(--transition-fast);
        }
        .analytics-mini-card:hover { background: rgba(77,171,247,0.05); border-color: var(--border-glow); }
        .analytics-mini-card .mini-icon { font-size: 1.5rem; color: var(--accent-cyan); margin-bottom: 6px; }
        .analytics-mini-card .mini-value { font-size: 1.3rem; font-weight: 700; color: #fff; }
        .analytics-mini-card .mini-label { font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px; }

        /* Tables */
        .tables-container { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 30px; position: relative; z-index: 1; }
        .table-card {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 20px;
            border: 1px solid var(--border-subtle);
            overflow-x: auto;
            transition: var(--transition-smooth);
        }
        .table-card:hover { border-color: var(--border-glow); box-shadow: var(--shadow-glow); }
        .table-card h3 {
            margin-bottom: 16px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-subtle);
            font-size: 1.15rem;
            color: var(--text-primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .table-card .view-all-link {
            font-size: 0.8rem;
            color: var(--accent-cyan);
            text-decoration: none;
            transition: color 0.2s;
        }
        .table-card .view-all-link:hover { color: #fff; text-decoration: underline; }
        table { width: 100%; border-collapse: collapse; min-width: 500px; }
        th {
            text-align: left;
            padding: 12px 8px;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--border-subtle);
        }
        td { padding: 12px 8px; border-bottom: 1px solid rgba(255,255,255,0.04); color: var(--text-secondary); font-size: 0.9rem; }
        tr:hover td { background: rgba(255,255,255,0.02); }
        tr:last-child td { border: none; }
        .status {
            padding: 5px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            letter-spacing: 0.3px;
        }
        .status-completed { background: rgba(52,211,153,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.3); }
        .status-processing { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
        .status-pending { background: rgba(248,113,113,0.15); color: #f87171; border: 1px solid rgba(248,113,113,0.3); }
        .status-cancelled { background: rgba(244,114,182,0.15); color: #f472b6; border: 1px solid rgba(244,114,182,0.3); }

        .notification-toast {
            position: fixed;
            top: 20px; right: 20px;
            background: rgba(14,22,45,0.9);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-left: 4px solid var(--accent-cyan);
            padding: 15px 22px;
            border-radius: 16px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 20px rgba(56,189,248,0.2);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
            color: var(--text-primary);
            animation: slideInToast 0.3s ease;
        }
        @keyframes slideInToast { from { opacity:0; transform:translateX(50px); } to { opacity:1; transform:translateX(0); } }

        @media (max-width: 1100px) {
            .quick-actions { grid-template-columns: repeat(2, 1fr); }
            .cards-container { grid-template-columns: repeat(2, 1fr); }
            .tables-container { grid-template-columns: 1fr; }
        }
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .menu-toggle { display: flex; }
            .header { border-radius: 30px; }
        }
        @media (max-width: 850px) {
            .analytics-container { grid-template-columns: 1fr; }
            .quick-actions { grid-template-columns: repeat(2, 1fr); }
            .analytics-summary-row { grid-template-columns: 1fr; }
        }
        @media (max-width: 680px) {
            .cards-container { grid-template-columns: 1fr; }
            .quick-actions { grid-template-columns: 1fr; }
            .header { flex-direction: column; align-items: stretch; }
            .search-bar { width: 100%; }
            .user-info { justify-content: center; }
            .main-content { padding: 14px; }
            .table-card { overflow-x: auto; }
            table { min-width: 550px; }
        }
        @media (max-width: 480px) {
            .header-actions { justify-content: center; }
            .user-details { display: none; }
            .card-value { font-size: 1.5rem; }
        }
    </style>
</head>
<body>
    <canvas id="nuranCanvas"></canvas>

    <div class="loading-overlay" id="loadingOverlay"><div class="spinner-ring"></div></div>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div>
                    <div class="logo-text">ShopMaster</div>
                    <div class="logo-subtext">admin · 2026</div>
