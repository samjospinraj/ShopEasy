                        <th>Order ID</th><th>Customer</th><th>Date</th><th>Amount</th><th>Status</th><th>Payment</th>
                        <th>Razorpay Order ID</th><th>Razorpay Payment ID</th><th>Return Status</th><th>Return Approved At</th><th>Items</th>
                    </tr>
