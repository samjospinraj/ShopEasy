    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content" id="mainContent">
        <!-- HEADER -->
        <div class="header">
            <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
            <div class="search-bar"><i class="fas fa-search"></i><input type="text" placeholder="Search orders, products..." id="searchInput"></div>
            <div class="header-actions">
                <button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge" id="notifBadge">0</span></button>
                <button class="notification-btn"><i class="fas fa-envelope"></i><span class="notification-badge" id="emailBadge">0</span></button>
                <div class="user-info">
                    <a href="/Admin/profile"><img src="https://ui-avatars.com/api/?name=Admin+Master&background=4dabf7&color=fff&bold=true&size=42" alt="admin"></a>
                    <div class="user-details"><h4>Alex Master</h4><p>Super Admin</p></div>
                </div>
            </div>
        </div>

        <!-- QUICK ACTIONS -->
        <div class="quick-actions">
            <div class="action-card" id="quickAddProduct"><div class="action-icon"><i class="fas fa-plus"></i></div><h4>Add product</h4><p>New item</p></div>
            <div class="action-card" id="quickProcessOrder"><div class="action-icon"><i class="fas fa-truck"></i></div><h4>Process orders</h4><p id="pendingCount">Pending —</p></div>
            <div class="action-card" id="quickReports"><div class="action-icon"><i class="fas fa-chart-bar"></i></div><h4>Reports</h4><p>Sales insights</p></div>
            <div class="action-card" id="quickUsers"><div class="action-icon"><i class="fas fa-user-cog"></i></div><h4>Manage users</h4><p>Staff & roles</p></div>
        </div>

        <!-- STAT CARDS -->
        <div class="cards-container">
            <div class="card revenue">
                <div class="card-header"><h3>Revenue</h3><div class="card-icon"><i class="fas fa-dollar-sign"></i></div></div>
                <div class="card-value" id="totalRevenue">₹0</div>
                <div class="card-detail positive" id="revenueTrend"><i class="fas fa-arrow-up"></i> —</div>
                <button class="btn btn-primary" id="btnRevenueDetail"><i class="fas fa-chart-bar"></i> details</button>
            </div>
            <div class="card orders">
                <div class="card-header"><h3>Orders</h3><div class="card-icon"><i class="fas fa-shopping-cart"></i></div></div>
                <div class="card-value" id="totalOrders">0</div>
                <div class="card-detail positive" id="ordersTrend"><i class="fas fa-arrow-up"></i> —</div>
                <button class="btn btn-success" id="btnOrdersView"><i class="fas fa-eye"></i> view</button>
            </div>
            <div class="card products">
                <div class="card-header"><h3>Products</h3><div class="card-icon"><i class="fas fa-box"></i></div></div>
                <div class="card-value" id="totalProducts">0</div>
                <div class="card-detail positive" id="productsTrend"><i class="fas fa-plus"></i> —</div>
                <button class="btn btn-outline" id="btnProductsManage"><i class="fas fa-boxes"></i> manage</button>
            </div>
            <div class="card customers">
                <div class="card-header"><h3>Customers</h3><div class="card-icon"><i class="fas fa-users"></i></div></div>
