        </div>

        <!-- optional extra row: last login sessions (just design consistency) -->
        <div style="background: white; border-radius: 24px; padding: 20px; border: 1px solid #edf2f9; margin-top: 16px;">
            <h3 style="margin-bottom: 10px;"><i class="fas fa-history" style="color: var(--primary-blue);"></i> Active sessions</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 28px;">
                <div><i class="fas fa-laptop"></i> Windows · Chrome <br> <small>NYC, 2 hrs ago</small></div>
                <div><i class="fas fa-mobile-alt"></i> iPhone 15 · Safari <br> <small>current session</small></div>
                <div><i class="fas fa-tablet"></i> iPad · <small>Mar 16, 2025</small></div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            // sidebar toggle (identical to dashboard)
            const sidebar = document.getElementById('sidebar');
            const menuToggle = document.getElementById('menuToggle');
            const toggleSidebar = document.getElementById('toggleSidebar');
            function toggleSidebarFunc(e) { e.stopPropagation(); sidebar.classList.toggle('active'); }
            if (menuToggle) menuToggle.addEventListener('click', toggleSidebarFunc);
            if (toggleSidebar) toggleSidebar.addEventListener('click', toggleSidebarFunc);
            document.addEventListener('click', function(e) {
                if (window.innerWidth <= 992 && !sidebar.contains(e.target) && !menuToggle.contains(e.target) && sidebar.classList.contains('active')) {
                    sidebar.classList.remove('active');
                }
            });

            // profile tab switching
            const tabPersonal = document.getElementById('tabPersonal');
            const tabActivity = document.getElementById('tabActivity');
            const tabSecurity = document.getElementById('tabSecurity');
            const personalSec = document.getElementById('personalSection');
            const activitySec = document.getElementById('activitySection');
            const securitySec = document.getElementById('securitySection');

            function setActiveTab(active) {
                [tabPersonal, tabActivity, tabSecurity].forEach(t => t.classList.remove('active-tab'));
                personalSec.classList.add('hidden');
                activitySec.classList.add('hidden');
                securitySec.classList.add('hidden');
                if (active === 'personal') {
                    tabPersonal.classList.add('active-tab');
                    personalSec.classList.remove('hidden');
                } else if (active === 'activity') {
                    tabActivity.classList.add('active-tab');
                    activitySec.classList.remove('hidden');
                } else if (active === 'security') {
                    tabSecurity.classList.add('active-tab');
                    securitySec.classList.remove('hidden');
                }
            }

            tabPersonal.addEventListener('click', () => setActiveTab('personal'));
            tabActivity.addEventListener('click', () => setActiveTab('activity'));
            tabSecurity.addEventListener('click', () => setActiveTab('security'));

            // toggle switches demo (just visual + toast)
            function showToast(msg) {
                const toast = document.createElement('div');
                toast.className = 'notification-toast';
                toast.innerHTML = `<i class="fas fa-info-circle" style="color: var(--primary-blue);"></i><span>${msg}</span>`;
                document.body.appendChild(toast);
                setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translateX(40px)'; setTimeout(() => toast.remove(), 300); }, 2000);
            }

            document.getElementById('toggle2FA')?.addEventListener('click', function(e) {
                this.classList.toggle('active');
                showToast(this.classList.contains('active') ? '2FA enabled' : '2FA disabled');
            });
            document.getElementById('toggleEmailNotif')?.addEventListener('click', function() {
                this.classList.toggle('active');
                showToast(this.classList.contains('active') ? 'Email notifications ON' : 'Email notifications OFF');
            });
            document.getElementById('toggleTimeout')?.addEventListener('click', function() {
                this.classList.toggle('active');
                showToast(this.classList.contains('active') ? 'Session timeout 30min' : 'Session timeout off');
            });

            // edit profile / buttons demo
            document.getElementById('editProfileBtn')?.addEventListener('click', () => showToast('✏️ Edit profile (demo)'));
            document.getElementById('changePwdBtn')?.addEventListener('click', () => showToast('🔐 Change password dialog'));
            document.getElementById('apiKeysBtn')?.addEventListener('click', () => showToast('🔑 API key management'));
            document.querySelectorAll('.edit-link').forEach(link => link.addEventListener('click', (e) => { e.preventDefault(); showToast('Edit field (demo)'); }));

            // profileButton from header also hint
            document.getElementById('profileButton')?.addEventListener('click', () => showToast('👤 Admin profile – you are here'));

            // update chevron icon (just style)
            const iconToggle = toggleSidebar?.querySelector('i');
            if (iconToggle) {
                const observer = new MutationObserver(() => {
                    if (sidebar.classList.contains('active')) iconToggle.classList.replace('fa-chevron-left', 'fa-chevron-right');
                    else iconToggle.classList.replace('fa-chevron-right', 'fa-chevron-left');
                });
                observer.observe(sidebar, { attributes: true, attributeFilter: ['class'] });
            }
        })();
    </script>
</body>
</html>