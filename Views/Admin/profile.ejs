                <!-- PERSONAL INFO SECTION -->
                <div id="personalSection" class="detail-section">
                    <div class="info-row"><span class="info-label">Full name</span><span class="info-value">Alexandre Master</span><a href="#" class="edit-link"><i class="fas fa-edit"></i> edit</a></div>
                    <div class="info-row"><span class="info-label">Email address</span><span class="info-value">a.master@shopmaster.com</span><a href="#" class="edit-link"><i class="fas fa-edit"></i> edit</a></div>
                    <div class="info-row"><span class="info-label">Phone (mobile)</span><span class="info-value">+1 (555) 237-8941</span><a href="#" class="edit-link"><i class="fas fa-edit"></i> edit</a></div>
                    <div class="info-row"><span class="info-label">Department</span><span class="info-value">Administration & IT</span></div>
                    <div class="info-row"><span class="info-label">Location</span><span class="info-value">Manhattan, NYC</span></div>
                    <div class="info-row"><span class="info-label">Languages</span><span class="info-value">English (native), Spanish (intermediate)</span></div>
                    <div class="info-row"><span class="info-label">Birth date</span><span class="info-value">May 14, 1988</span></div>
                </div>

                <!-- ACTIVITY SECTION (hidden) -->
                <div id="activitySection" class="detail-section hidden">
