    <!-- Bootstrap 5.3.3 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    <script>
        // ═══════════ NURAN PARTICLE BACKGROUND ═══════════
        (function() {
            const canvas = document.getElementById('nuranCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouseX = -999,
                mouseY = -999,
                targetMouseX = -999,
                targetMouseY = -999;
            const SPLATTER_RADIUS = 190,
                CONNECTION_DIST = 140,
                PARTICLE_COUNT = window.innerWidth < 768 ? 80 : 140;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', () => {
                resize();
                const nc = window.innerWidth < 768 ? 80 : 140;
                while (particles.length < nc) particles.push(createParticle());
                while (particles.length > nc) particles.pop();
            });

            function createParticle() {
                const cols = ['rgba(77,171,247,', 'rgba(56,189,248,', 'rgba(167,139,250,', 'rgba(139,92,246,',
                    'rgba(45,212,191,', 'rgba(96,165,250,', 'rgba(192,132,252,', 'rgba(52,211,153,'
                ];
                const c = cols[Math.floor(Math.random() * cols.length)];
                return {
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.7,
                    vy: (Math.random() - 0.5) * 0.7,
                    size: 1.8 + Math.random() * 3.5,
                    color: c,
                    glowAlpha: 0.5 + Math.random() * 0.5,
                    pulsePhase: Math.random() * Math.PI * 2,
                    pulseSpeed: 0.008 + Math.random() * 0.025,
                    baseSize: 1.8 + Math.random() * 3.5
                };
            }
            for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(createParticle());

            document.addEventListener('mousemove', e => {
                targetMouseX = e.clientX;
                targetMouseY = e.clientY;
            });
            document.addEventListener('mouseleave', () => {
                targetMouseX = -999;
                targetMouseY = -999;
            });
            document.addEventListener('touchmove', e => {
                if (e.touches.length > 0) {
                    targetMouseX = e.touches[0].clientX;
                    targetMouseY = e.touches[0].clientY;
                }
            }, { passive: true });
            document.addEventListener('touchend', () => {
                targetMouseX = -999;
                targetMouseY = -999;
            });

            function animate(ts) {
                mouseX += (targetMouseX - mouseX) * 0.18;
                mouseY += (targetMouseY - mouseY) * 0.18;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                const time = ts * 0.001;
                for (let p of particles) {
                    p.vx += Math.sin(time * 0.7 + p.pulsePhase) * 0.025;
                    p.vy += Math.cos(time * 0.6 + p.pulsePhase + 1.3) * 0.025;
                    if (mouseX > -500 && mouseY > -500) {
                        const dx = p.x - mouseX,
                            dy = p.y - mouseY,
                            dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < SPLATTER_RADIUS && dist > 0.5) {
                            const force = (1 - dist / SPLATTER_RADIUS) * 4.5;
                            p.vx += (dx / dist) * force;
                            p.vy += (dy / dist) * force;
                            p.glowAlpha = Math.min(1, p.glowAlpha + 0.06);
                        }
                    }
                    p.x += p.vx;
                    p.y += p.vy;
                    p.vx *= 0.94;
                    p.vy *= 0.94;
                    const sp = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
                    if (sp > 6) {
                        p.vx = (p.vx / sp) * 6;
                        p.vy = (p.vy / sp) * 6;
                    }
                    if (p.x < -30) p.x = canvas.width + 30;
                    if (p.x > canvas.width + 30) p.x = -30;
                    if (p.y < -30) p.y = canvas.height + 30;
                    if (p.y > canvas.height + 30) p.y = -30;
                    p.size = p.baseSize + Math.sin(time * p.pulseSpeed * 10 + p.pulsePhase) * 0.7;
                    p.glowAlpha += (0.6 - p.glowAlpha) * 0.03;
                }
                for (let i = 0; i < particles.length; i++)
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x,
                            dy = particles[i].y - particles[j].y,
                            dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < CONNECTION_DIST) {
                            const alpha = (1 - dist / CONNECTION_DIST) * 0.28,
                                pulse = Math.sin(ts * 0.003 + i * 0.4 + j * 0.3) * 0.5 + 0.5;
                            ctx.beginPath();
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.strokeStyle = `rgba(120,170,230,${alpha * (0.5 + pulse * 0.5)})`;
                            ctx.lineWidth = 0.6;
                            ctx.stroke();
                        }
                    }
                for (let p of particles) {
                    const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * 3.5);
                    grad.addColorStop(0, p.color + (p.glowAlpha * 0.7) + ')');
                    grad.addColorStop(0.35, p.color + (p.glowAlpha * 0.25) + ')');
                    grad.addColorStop(1, p.color + '0)');
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * 3.5, 0, Math.PI * 2);
                    ctx.fillStyle = grad;
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * 0.65, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255,255,255,${0.7 + p.glowAlpha * 0.3})`;
                    ctx.fill();
                }
                if (mouseX > -500 && mouseY > -500) {
                    const mg = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, SPLATTER_RADIUS * 0.7);
                    mg.addColorStop(0, 'rgba(120,180,240,0.08)');
                    mg.addColorStop(0.5, 'rgba(100,150,220,0.03)');
                    mg.addColorStop(1, 'rgba(0,0,0,0)');
                    ctx.beginPath();
                    ctx.arc(mouseX, mouseY, SPLATTER_RADIUS * 0.7, 0, Math.PI * 2);
                    ctx.fillStyle = mg;
                    ctx.fill();
                }
                requestAnimationFrame(animate);
            }
            requestAnimationFrame(animate);
        })();

        // ═══════════ SIDEBAR TOGGLE ═══════════
        const sidebar = document.getElementById("sidebar");
        const mobileToggle = document.getElementById("mobileMenuToggle");
        const toggleSidebarBtn = document.getElementById("toggleSidebarBtn");

        function toggleSidebar() {
            sidebar.classList.toggle("active");
        }
        mobileToggle?.addEventListener("click", toggleSidebar);
        toggleSidebarBtn?.addEventListener("click", () => {
            if (window.innerWidth <= 992) sidebar.classList.toggle("active");
        });

        document.addEventListener('click', (e) => {
            if (window.innerWidth <= 992 &&
                sidebar.classList.contains('active') &&
                !sidebar.contains(e.target) &&
                e.target !== mobileToggle &&
                !mobileToggle.contains(e.target)) {
                sidebar.classList.remove('active');
            }
        });

        // ═══════════ SUBCATEGORY TOGGLE ═══════════
        const subcategoryHeaders = document.querySelectorAll(".subcategory-header");
        subcategoryHeaders.forEach(header => {
            header.addEventListener("click", function(e) {
                const content = this.nextElementSibling;
                if (content && content.classList.contains("subcategory-content")) {
                    const hidden = content.style.display === "none";
                    content.style.display = hidden ? "block" : "none";
                    const icon = this.querySelector("i");
                    if (icon) {
                        icon.classList.toggle("fa-chevron-down", !hidden);
                        icon.classList.toggle("fa-chevron-up", hidden);
                    }
                }
            });
        });
        document.querySelectorAll(".subcategory-content").forEach(c => c.style.display = "block");

        // ═══════════ DELIVERY COUNTER ═══════════
        const minDayInput = document.getElementById("minDay"),
            maxDayInput = document.getElementById("maxDay");
        const deliveryCounter = document.getElementById("deliveryCounter");
        const minDaysCounter = document.getElementById("minDaysCounter"),
            maxDaysCounter = document.getElementById("maxDaysCounter");
        const minDeliveryDate = document.getElementById("minDeliveryDate"),
            maxDeliveryDate = document.getElementById("maxDeliveryDate");

        function updateDeliveryCounter() {
            const minDays = parseInt(minDayInput?.value),
                maxDays = parseInt(maxDayInput?.value);
            if (isNaN(minDays) || isNaN(maxDays) || minDays < 0 || maxDays < 0) {
                if (deliveryCounter) deliveryCounter.style.display = "none";
                return;
            }
            if (deliveryCounter) deliveryCounter.style.display = "flex";
            const now = new Date();
            const minDate = new Date(now.getTime() + minDays * 86400000),
                maxDate = new Date(now.getTime() + maxDays * 86400000);
            const fmt = d => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            if (minDaysCounter) minDaysCounter.textContent = minDays;
            if (maxDaysCounter) maxDaysCounter.textContent = maxDays;
            if (minDeliveryDate) minDeliveryDate.textContent = `Min: ${fmt(minDate)}`;
            if (maxDeliveryDate) maxDeliveryDate.textContent = `Max: ${fmt(maxDate)}`;
        }
        minDayInput?.addEventListener("input", updateDeliveryCounter);
        maxDayInput?.addEventListener("input", updateDeliveryCounter);

        // ═══════════ MODAL POPUP (2026 animation) ═══════════
        function showModal(message, isSuccess = true) {
            // Remove any existing modal
            const existing = document.querySelector('.modal-overlay');
            if (existing) existing.remove();

            const overlay = document.createElement('div');
            overlay.className = 'modal-overlay';

            const iconClass = isSuccess ? 'fa-check-circle' : 'fa-exclamation-triangle';
            const iconColor = isSuccess ? 'var(--accent-green)' : 'var(--accent-red)';

            overlay.innerHTML = `
                <div class="modal-content">
                    <div class="modal-icon" style="color: ${iconColor};"><i class="fas ${iconClass}"></i></div>
                    <div class="modal-message">${message}</div>
                    <button class="modal-btn">OK</button>
                </div>
            `;

            document.body.appendChild(overlay);

            const closeModal = () => {
                overlay.style.opacity = '0';
                overlay.style.transition = 'opacity 0.2s';
                setTimeout(() => overlay.remove(), 200);
            };

            overlay.querySelector('.modal-btn').addEventListener('click', closeModal);
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) closeModal();
            });

            // Auto close after 3.5 seconds
            setTimeout(closeModal, 3500);
        }

        // ═══════════ SPECIFICATION ROW HELPERS ═══════════
        function attachRemove(btn) {
            btn.addEventListener("click", function(e) {
                const row = e.target.closest(".specification-row");
                row?.remove();
            });
        }

        function addSpecRow(containerId, nameKeys, nameValues, keyPlaceholder, valPlaceholder) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const row = document.createElement("div");
            row.className = "specification-row";
            row.innerHTML = `
                <div class="spec-input"><input type="text" name="${nameKeys}" class="form-control" placeholder="${keyPlaceholder}"></div>
                <div class="spec-input"><input type="text" name="${nameValues}" class="form-control" placeholder="${valPlaceholder}"></div>
                <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
            `;
            container.appendChild(row);
            attachRemove(row.querySelector(".removeRowBtn"));
            setTimeout(() => {
                const inp = row.querySelector("input");
                if (inp) {
                    inp.focus();
                    inp.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            }, 100);
        }

        document.getElementById("addKeySpecBtn")?.addEventListener("click", () =>
            addSpecRow("keySpecsContainer", "keySpecs_keys[]", "keySpecs_values[]", "Spec name", "Value"));
        document.getElementById("addDetailedSpecBtn")?.addEventListener("click", () =>
            addSpecRow("detailedSpecsContainer", "detailedSpecs_keys[]", "detailedSpecs_values[]", "Category", "Detail"));
        document.getElementById("addDesignSpecBtn")?.addEventListener("click", () =>
            addSpecRow("designSpecsContainer", "designSpecs_keys[]", "designSpecs_values[]", "Design feature", "Value"));
        document.getElementById("addPerfSpecBtn")?.addEventListener("click", () =>
            addSpecRow("perfSpecsContainer", "perfSpecs_keys[]", "perfSpecs_values[]", "Performance metric", "Value"));
        document.getElementById("addAdditionalSpecBtn")?.addEventListener("click", () =>
            addSpecRow("additionalSpecsContainer", "additionalSpecs_keys[]", "additionalSpecs_values[]",
                "Additional feature", "Spec value"));

        function addVideoLinkRow() {
            const container = document.getElementById("videoLinksContainer");
            if (!container) return;
            const row = document.createElement("div");
            row.className = "specification-row";
            row.innerHTML = `
                <div class="spec-input"><input type="url" name="videoLinks[]" class="form-control" placeholder="https://youtube.com/watch?v=..."></div>
                <button type="button" class="btn-small btn-danger removeVideoLinkBtn">Remove</button>
            `;
            container.appendChild(row);
            row.querySelector(".removeVideoLinkBtn").addEventListener("click", () => row.remove());
        }
        document.getElementById("addVideoLinkBtn")?.addEventListener("click", addVideoLinkRow);

        document.querySelectorAll(".removeRowBtn").forEach(btn => attachRemove(btn));
        document.querySelectorAll(".removeVideoLinkBtn").forEach(btn =>
            btn.addEventListener("click", function() { this.closest(".specification-row").remove(); })
        );

        // ═══════════ FILE UPLOAD & PREVIEW ═══════════
        const BASE_URL = "http://localhost:3000";
        const MAX_IMAGES = 5,
            MAX_IMG_SIZE = 5 * 1024 * 1024;
        const MAX_VIDEOS = 5,
            MAX_VIDEO_SIZE = 200 * 1024 * 1024;
        const ALLOWED_IMG_TYPES = ["image/jpeg", "image/png", "image/webp"];
        const ALLOWED_VIDEO_TYPES = ["video/mp4", "video/webm", "video/mpeg", "video/quicktime",
            "video/x-msvideo"
        ];

        function getFileKey(file) {
            return `${file.name}__${file.size}__${file.lastModified}`;
        }

        function buildImgUrl(path) {
            return path ? `${BASE_URL}${path}` : "";
        }

        // ── MAIN IMAGE ──
        const mainImageInput = document.getElementById("mainImageInput"),
            mainPreview = document.getElementById("mainImagePreview"),
            mainFileNameSpan = document.getElementById("mainFileName"),
            triggerMain = document.getElementById("triggerMainImage");

        triggerMain?.addEventListener("click", () => mainImageInput.click());
        mainImageInput?.addEventListener("change", function() {
            if (!this.files || !this.files.length) return;
            const file = this.files[0];
            if (!ALLOWED_IMG_TYPES.includes(file.type)) {
                showModal("Only JPG, PNG, WEBP allowed for main image", false);
                this.value = "";
                return;
            }
            if (file.size > MAX_IMG_SIZE) {
                showModal("Main image must be less than 5MB", false);
                this.value = "";
                return;
            }
            mainFileNameSpan.textContent = file.name;
            mainPreview.innerHTML = "";
            const reader = new FileReader();
            reader.onload = ev => {
                const div = document.createElement("div");
                div.className = "preview-item";
                div.innerHTML = `
                    <img src="${ev.target.result}" alt="preview">
                    <span class="preview-label">Main</span>
                    <button type="button" class="remove-image">×</button>
                `;
                div.querySelector(".remove-image").onclick = () => {
                    div.remove();
                    mainImageInput.value = "";
                    mainFileNameSpan.textContent = "No file chosen";
                };
                mainPreview.appendChild(div);
            };
            reader.readAsDataURL(file);
        });

        // ── ADDITIONAL IMAGES (duplicate detection) ──
        let existingImages = [],
            selectedImages = [],
            removedImages = [];
        const additionalInput = document.getElementById("additionalImagesInput"),
            additionalPreview = document.getElementById("additionalImagesPreview"),
            additionalFileName = document.getElementById("additionalFileName"),
            triggerAdditional = document.getElementById("triggerAdditionalImages");

        function syncAdditionalInputFiles() {
            const dt = new DataTransfer();
            selectedImages.forEach(f => dt.items.add(f));
            if (additionalInput) additionalInput.files = dt.files;
        }

        function isImageDuplicate(file) {
            const fileKey = getFileKey(file);
            if (selectedImages.some(f => getFileKey(f) === fileKey)) return true;
            if (existingImages.some(img => img.filename === file.name && img.size === file.size)) return true;
            return false;
        }

        function renderAdditionalImages() {
            if (!additionalPreview) return;
            additionalPreview.innerHTML = "";

            existingImages.forEach(img => {
                const div = document.createElement("div");
                div.className = "preview-item";
                div.innerHTML = `
                    <img src="${buildImgUrl(img.path)}" style="width:100%;height:100%;object-fit:cover" alt="existing">
                    <button type="button" class="remove-btn">×</button>
                `;
                div.querySelector(".remove-btn").onclick = () => {
                    if (!removedImages.some(i => i.filename === img.filename)) {
                        removedImages.push(img);
                    }
                    existingImages = existingImages.filter(i => i.filename !== img.filename);
                    renderAdditionalImages();
                };
                additionalPreview.appendChild(div);
            });

            selectedImages.forEach((file, index) => {
                const url = URL.createObjectURL(file);
                const div = document.createElement("div");
                div.className = "preview-item";
                div.innerHTML = `
                    <img src="${url}" style="width:100%;height:100%;object-fit:cover" alt="new">
                    <button type="button" class="remove-btn">×</button>
                `;
                div.querySelector(".remove-btn").onclick = () => {
                    URL.revokeObjectURL(url);
                    selectedImages = selectedImages.filter((_, idx) => idx !== index);
                    renderAdditionalImages();
                    syncAdditionalInputFiles();
                };
                additionalPreview.appendChild(div);
            });

            const total = existingImages.length + selectedImages.length;
            additionalFileName.textContent = total ? `${total}/${MAX_IMAGES} images selected` :
                "No images selected";
            if (triggerAdditional) {
                triggerAdditional.style.opacity = total >= MAX_IMAGES ? "0.5" : "1";
                triggerAdditional.style.cursor = total >= MAX_IMAGES ? "not-allowed" : "pointer";
                triggerAdditional.style.pointerEvents = total >= MAX_IMAGES ? "none" : "auto";
            }
            syncAdditionalInputFiles();
        }

        triggerAdditional?.addEventListener("click", () => {
            if (existingImages.length + selectedImages.length >= MAX_IMAGES) {
                showModal(`Maximum ${MAX_IMAGES} additional images allowed`, false);
                return;
            }
            additionalInput.click();
        });

        additionalInput?.addEventListener("change", function(e) {
            let files = Array.from(e.target.files || []);
            let skippedDuplicates = 0;
            let skippedInvalid = 0;
            let skippedSize = 0;

            files = files.filter(f => {
                if (!ALLOWED_IMG_TYPES.includes(f.type)) { skippedInvalid++; return false; }
                if (f.size > MAX_IMG_SIZE) { skippedSize++; return false; }
                if (isImageDuplicate(f)) { skippedDuplicates++; return false; }
                return true;
            });

            const remaining = MAX_IMAGES - (existingImages.length + selectedImages.length);
            const overflow = files.length - remaining;
            if (overflow > 0) {
                files = files.slice(0, remaining);
                showModal(`${overflow} image(s) skipped — max ${MAX_IMAGES} total allowed`, false);
            }
            if (skippedDuplicates > 0) showModal(`${skippedDuplicates} duplicate image(s) skipped`, false);
            if (skippedInvalid > 0) showModal(`${skippedInvalid} file(s) skipped — invalid format`, false);
            if (skippedSize > 0) showModal(`${skippedSize} file(s) skipped — exceeds 5MB limit`, false);

            if (files.length > 0) {
                selectedImages.push(...files);
                renderAdditionalImages();
            }
            additionalInput.value = "";
        });

        // ── PRODUCT VIDEOS (duplicate detection) ──
        let selectedVideos = [],
            existingVideos = [],
            removedVideos = [];
        const videosInput = document.getElementById("videosInput"),
            videosPreview = document.getElementById("videosPreview"),
            videosFileName = document.getElementById("videosFileName"),
            triggerVideos = document.getElementById("triggerVideos");

        function isVideoDuplicate(file) {
            const fileKey = getFileKey(file);
            if (selectedVideos.some(f => getFileKey(f) === fileKey)) return true;
            if (existingVideos.some(v => v.filename === file.name && v.size === file.size)) return true;
            return false;
        }

        function renderVideosUI() {
            if (!videosPreview) return;
            videosPreview.innerHTML = "";

            existingVideos.forEach(v => {
                const div = document.createElement("div");
                div.className = "preview-item video-item";
                div.innerHTML = `
                    <video controls style="width:100%;height:100%;object-fit:cover">
                        <source src="${buildImgUrl(v.path)}">
                    </video>
                    <button type="button" class="remove-video-btn">×</button>
                `;
                div.querySelector(".remove-video-btn").onclick = () => {
                    removedVideos.push(v.filename);
                    existingVideos = existingVideos.filter(x => x.filename !== v.filename);
                    renderVideosUI();
                };
                videosPreview.appendChild(div);
            });

            selectedVideos.forEach((file, i) => {
                const url = URL.createObjectURL(file);
                const div = document.createElement("div");
                div.className = "preview-item video-item";
                div.innerHTML = `
                    <video controls style="width:100%;height:100%;object-fit:cover">
                        <source src="${url}">
                    </video>
                    <button type="button" class="remove-new-video-btn">×</button>
                `;
                div.querySelector(".remove-new-video-btn").onclick = () => {
                    URL.revokeObjectURL(url);
                    selectedVideos = selectedVideos.filter((_, idx) => idx !== i);
                    renderVideosUI();
                };
                videosPreview.appendChild(div);
            });

            const total = existingVideos.length + selectedVideos.length;
            videosFileName.textContent = total ? `${total} video(s) selected` : "No files chosen";
            if (triggerVideos) {
                triggerVideos.style.opacity = total >= MAX_VIDEOS ? "0.5" : "1";
                triggerVideos.style.pointerEvents = total >= MAX_VIDEOS ? "none" : "auto";
                triggerVideos.style.cursor = total >= MAX_VIDEOS ? "not-allowed" : "pointer";
            }
        }

        triggerVideos?.addEventListener("click", () => {
            if (existingVideos.length + selectedVideos.length >= MAX_VIDEOS) {
                showModal(`Maximum ${MAX_VIDEOS} videos allowed`, false);
                return;
            }
            videosInput.click();
        });

        videosInput?.addEventListener("change", (e) => {
            let files = Array.from(e.target.files);
            let skippedDuplicates = 0;
            let skippedInvalid = 0;
            let skippedSize = 0;

            files = files.filter(f => {
                if (!ALLOWED_VIDEO_TYPES.includes(f.type)) { skippedInvalid++; return false; }
                if (f.size > MAX_VIDEO_SIZE) { skippedSize++; return false; }
                if (isVideoDuplicate(f)) { skippedDuplicates++; return false; }
                return true;
            });

            const remaining = MAX_VIDEOS - (existingVideos.length + selectedVideos.length);
            const overflow = files.length - remaining;
            if (overflow > 0) {
                files = files.slice(0, remaining);
                showModal(`${overflow} video(s) skipped — max ${MAX_VIDEOS} total allowed`, false);
            }
            if (skippedDuplicates > 0) showModal(`${skippedDuplicates} duplicate video(s) skipped`, false);
            if (skippedInvalid > 0) showModal(`${skippedInvalid} file(s) skipped — invalid format`, false);
            if (skippedSize > 0) showModal(`${skippedSize} file(s) skipped — exceeds 200MB limit`, false);

            if (files.length > 0) {
                selectedVideos.push(...files);
                renderVideosUI();
            }
            videosInput.value = "";
        });

        // ═══════════ COLLECT SPECS & VIDEO LINKS ═══════════
        function collectSpecifications(containerId, keysName, valuesName) {
            const container = document.getElementById(containerId);
            if (!container) return [];
            const rows = container.querySelectorAll(".specification-row");
            const specs = [];
            rows.forEach(row => {
                const key = row.querySelector(`input[name="${keysName}"]`),
                    val = row.querySelector(`input[name="${valuesName}"]`);
                if (key && val && key.value.trim() && val.value.trim()) {
                    specs.push({ key: key.value.trim(), value: val.value.trim() });
                }
            });
            return specs;
        }

        function collectVideoLinks() {
            const c = document.getElementById("videoLinksContainer");
            if (!c) return [];
            return Array.from(c.querySelectorAll("input[name='videoLinks[]']"))
                .map(i => i.value.trim())
                .filter(Boolean);
        }

        // ═══════════ VALIDATION HELPERS ═══════════
        function highlightError(el, msg) {
            if (!el) return;
            el.classList.add("error-border");
            const parent = el.parentElement;
            parent.querySelector(".error-message")?.remove();
            const err = document.createElement("div");
            err.className = "error-message";
            err.textContent = msg;
            parent.appendChild(err);
            el.addEventListener("focus", () => {
                el.classList.remove("error-border");
                parent.querySelector(".error-message")?.remove();
            }, { once: true });
        }

        function clearErrors() {
            document.querySelectorAll(".error-border").forEach(e => e.classList.remove("error-border"));
            document.querySelectorAll(".error-message").forEach(e => e.remove());
        }

        // ═══════════ CATEGORY HIERARCHY ═══════════
        const CATEGORY_API = "http://localhost:3000/Admin/all-category-system";
        let categoriesData = { categories: [], subcategories: [], subSubcategories: [] };

        async function loadCategoryHierarchy() {
            try {
                const res = await fetch(CATEGORY_API);
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const result = await res.json();
                categoriesData = result.data;
                const mainSelect = document.getElementById("mainCategorySelect");
                mainSelect.innerHTML = '<option value="">Select category</option>';
                categoriesData.categories.forEach(cat => {
                    const opt = document.createElement("option");
                    opt.value = cat.id;
                    opt.textContent = cat.name;
                    mainSelect.appendChild(opt);
                });
                mainSelect.disabled = categoriesData.categories.length === 0;
            } catch (err) {
                console.error("Category load error:", err);
            }
        }

        const mainSelect = document.getElementById("mainCategorySelect"),
            subSelect = document.getElementById("subCategorySelect"),
            subSubSelect = document.getElementById("subSubCategorySelect");

        mainSelect.addEventListener("change", () => {
            const mainId = mainSelect.value;
            subSelect.innerHTML = '<option value="">Select subcategory</option>';
            subSubSelect.innerHTML = '<option value="">Select sub-subcategory</option>';
            if (!mainId) { subSelect.disabled = true; subSubSelect.disabled = true; return; }
            const subs = categoriesData.subcategories.filter(s => s.parentId === mainId);
            subs.forEach(s => {
                const opt = document.createElement("option");
                opt.value = s.id;
                opt.textContent = s.name;
                subSelect.appendChild(opt);
            });
            subSelect.disabled = subs.length === 0;
            subSubSelect.disabled = true;
        });

        subSelect.addEventListener("change", () => {
            const subId = subSelect.value;
            subSubSelect.innerHTML = '<option value="">Select sub-subcategory</option>';
            if (!subId) { subSubSelect.disabled = true; return; }
            const subSubs = categoriesData.subSubcategories.filter(s => s.subParentId === subId);
            if (subSubs.length === 0) {
                subSubSelect.innerHTML = '<option value="">No sub-subcategory available</option>';
                subSubSelect.disabled = true;
                return;
            }
            subSubs.forEach(s => {
                const opt = document.createElement("option");
                opt.value = s.id;
                opt.textContent = s.name;
                subSubSelect.appendChild(opt);
            });
            subSubSelect.disabled = false;
        });

        loadCategoryHierarchy();

        // ═══════════ FORM ELEMENTS ═══════════
        const form = document.getElementById("productForm"),
            submitBtn = document.getElementById("submitBtn");
        const productNameInput = document.getElementById("prodName"),
            skuInput = document.getElementById("sku"),
            brandInput = document.getElementById("brand"),
            modelInput = document.getElementById("model");
        const categorySelect = document.getElementById("mainCategorySelect"),
            sizeSelect = document.getElementById("sizeSelect"),
            priceInput = document.getElementById("price"),
            comparePriceInput = document.getElementById("comparePrice"),
            costPriceInput = document.getElementById("costPrice"),
            offerPercentInput = document.getElementById("offerPercent"),
            stockQuantityInput = document.getElementById("stock"),
            lowStockThresholdInput = document.getElementById("lowStockThreshold"),
            barcodeInput = document.getElementById("barcode"),
            shortDescriptionInput = document.getElementById("shortDesc"),
            fullDescriptionInput = document.getElementById("fullDesc"),
            shippingClassSelect = document.getElementById("shippingClassSelect"),
            freeShippingSelect = document.getElementById("freeShippingSelect"),
            lengthInput = document.getElementById("length"),
            widthInput = document.getElementById("width"),
            heightInput = document.getElementById("height"),
            weightInput = document.getElementById("weight"),
            shippingCostInput = document.getElementById("shippingCost"),
            statusSelect = document.getElementById("statusSelect"),
            visibilitySelect = document.getElementById("visibilitySelect"),
            tagsInput = document.getElementById("tags"),
            internalNotesInput = document.getElementById("internalNotes"),
            specTitleInput = document.getElementById("specTitle"),
            designTitleInput = document.getElementById("designTitle"),
            performanceTitleInput = document.getElementById("performanceTitle"),
            additionalTitleInput = document.getElementById("additionalTitle");

        const PRODUCT_API = "http://localhost:3000/Admin/productForm",
            PRODUCT_EDIT = "http://localhost:3000/Admin/editproductForm";

        function getProductIdFromURL() {
            const parts = window.location.pathname.split("/").filter(Boolean);
            const last = parts[parts.length - 1];
            return last === "productForm" ? null : last;
        }

        function setValue(el, val = "") { if (el) el.value = val ?? ""; }

        async function setCategoryHierarchy(data) {
            if (!data.category) return;
            if (mainSelect.options.length <= 1) await new Promise(r => setTimeout(r, 500));
            mainSelect.value = data.category;
            mainSelect.dispatchEvent(new Event("change"));
            await new Promise(r => setTimeout(r, 400));
            if (data.subcategory) {
                subSelect.value = data.subcategory;
                subSelect.dispatchEvent(new Event("change"));
                await new Promise(r => setTimeout(r, 400));
                subSubSelect.value = data.sub_subcategory || "";
            } else {
                subSelect.value = "";
                subSubSelect.value = "";
                subSubSelect.disabled = true;
            }
        }

        function renderSpecs(containerId, data, keyName, valueName) {
            const container = document.getElementById(containerId);
            if (!container) return;
            container.innerHTML = "";
            if (!Array.isArray(data)) return;
            data.forEach(spec => {
                addSpecRow(containerId, keyName, valueName, "Key", "Value");
                const row = container.lastElementChild;
                row.querySelector(`[name="${keyName}"]`).value = spec.key || "";
                row.querySelector(`[name="${valueName}"]`).value = spec.value || "";
            });
        }

        function renderMainImage(mainImage) {
            if (!mainImage?.path) return;
            const url = `${BASE_URL}${mainImage.path}`;
            if (mainPreview) {
                mainPreview.innerHTML = "";
                const div = document.createElement("div");
                div.className = "preview-item";
                div.innerHTML = `
                    <img src="${url}" style="width:100%;height:100%;object-fit:cover" alt="main">
                    <span class="preview-label">Main</span>
                    <button type="button" class="remove-image">×</button>
                `;
                div.querySelector(".remove-image").onclick = () => {
                    div.remove();
                    mainImageInput.value = "";
                    mainFileNameSpan.textContent = "No file chosen";
                };
                mainPreview.appendChild(div);
                mainFileNameSpan.textContent = mainImage.filename || "Existing image";
            }
        }

        // ═══════════ LOAD PRODUCT FOR EDIT ═══════════
        async function loadProductForEdit() {
            const id = getProductIdFromURL();
            if (!id) {
                showModal("Create Mode — fill in all required fields", true);
                return;
            }
            showModal("Loading product data...", true);
            try {
                const res = await fetch(`${PRODUCT_API}/${id}`);
                const result = await res.json();
                if (!res.ok || !result?.data) throw new Error(result?.message || "Invalid product data");
                const data = result.data;

                setValue(productNameInput, data.productName);
                setValue(skuInput, data.sku);
                setValue(brandInput, data.brand);
                setValue(modelInput, data.model);

                const catId = (data.category && typeof data.category === 'object') ? data.category._id : (data.category || "");
                const subId = (data.subcategory && typeof data.subcategory === 'object') ? data.subcategory._id : (data.subcategory || "");
                const subSubId = (data.sub_subcategory && typeof data.sub_subcategory === 'object') ? data.sub_subcategory._id : (data.sub_subcategory || "");
                await setCategoryHierarchy({ category: catId, subcategory: subId, sub_subcategory: subSubId });

                setValue(sizeSelect, data.size);
                setValue(priceInput, data.price);
                setValue(comparePriceInput, data.comparePrice);
                setValue(costPriceInput, data.costPrice);
                setValue(offerPercentInput, data.offerPercent);
                setValue(stockQuantityInput, data.stockQuantity);
                setValue(lowStockThresholdInput, data.lowStockThreshold);
                setValue(barcodeInput, data.barcode);
                setValue(shortDescriptionInput, data.shortDescription);
                setValue(fullDescriptionInput, data.fullDescription);
                setValue(shippingClassSelect, data.shippingClass);
                setValue(freeShippingSelect, data.freeShipping ? "true" : "false");

                if (data.dimensions) {
                    setValue(lengthInput, data.dimensions.length);
                    setValue(widthInput, data.dimensions.width);
                    setValue(heightInput, data.dimensions.height);
                    setValue(weightInput, data.dimensions.weight);
                    setValue(shippingCostInput, data.dimensions.shippingCost);
                }
                if (data.delivery) {
                    setValue(minDayInput, data.delivery.minDays);
                    setValue(maxDayInput, data.delivery.maxDays);
                }
                setValue(statusSelect, data.status);
                setValue(visibilitySelect, data.visibility);
                tagsInput.value = Array.isArray(data.tags) ? data.tags.join(", ") : "";
                setValue(internalNotesInput, data.internalNotes);
                setValue(specTitleInput, data.specTitle);
                setValue(designTitleInput, data.designTitle);
                setValue(performanceTitleInput, data.performanceTitle);
                setValue(additionalTitleInput, data.additionalTitle);

                renderSpecs("keySpecsContainer", data.keySpecs || [], "keySpecs_keys[]", "keySpecs_values[]");
                renderSpecs("detailedSpecsContainer", data.detailedSpecs || [], "detailedSpecs_keys[]", "detailedSpecs_values[]");
                renderSpecs("designSpecsContainer", data.designSpecs || [], "designSpecs_keys[]", "designSpecs_values[]");
                renderSpecs("perfSpecsContainer", data.perfSpecs || [], "perfSpecs_keys[]", "perfSpecs_values[]");
                renderSpecs("additionalSpecsContainer", data.additionalSpecs || [], "additionalSpecs_keys[]", "additionalSpecs_values[]");

                renderMainImage(data.mainImage);
                existingImages = data.additionalImages || [];
                renderAdditionalImages();
                existingVideos = data.productVideos || [];
                renderVideosUI();

                const vidLinkContainer = document.getElementById("videoLinksContainer");
                if (vidLinkContainer && Array.isArray(data.videoLinks)) {
                    vidLinkContainer.innerHTML = "";
                    data.videoLinks.forEach(link => {
                        addVideoLinkRow();
                        vidLinkContainer.lastElementChild.querySelector("input").value = link;
                    });
                }
                updateDeliveryCounter();
                showModal("Product loaded successfully", true);
            } catch (err) {
                console.error(err);
                showModal(err.message || "Failed to load product", false);
            }
        }
        loadProductForEdit();

        // ═══════════ FORM SUBMISSION ═══════════
        form?.addEventListener("submit", async function(e) {
            e.preventDefault();
            clearErrors();
            const formData = new FormData();
            let hasError = false,
                firstError = null;
            const productId = getProductIdFromURL(),
                isEdit = !!productId;

            const setError = (el, msg) => { if (!hasError) firstError = el; highlightError(el, msg); hasError = true; };
            const append = (k, v) => { if (v !== undefined && v !== null && v !== "") formData.append(k, v); };
            const safeParse = (v, d = 0) => { const n = parseFloat(v); return isNaN(n) ? d : n; };
            const safeParseInt = (v, d = 0) => { const n = parseInt(v); return isNaN(n) ? d : n; };

            const pName = productNameInput?.value.trim();
            if (!pName) setError(productNameInput, "Product name is required");
            else if (pName.length < 3 || pName.length > 100) setError(productNameInput, "Must be 3-100 characters");
            else append("productName", pName);

            const sku = skuInput?.value.trim();
            if (!sku) setError(skuInput, "SKU is required");
            else if (sku.length < 3 || sku.length > 60) setError(skuInput, "Must be 3-60 characters");
            else append("sku", sku);

            const brand = brandInput?.value.trim();
            if (!brand) setError(brandInput, "Brand is required");
            else if (brand.length < 2 || brand.length > 60) setError(brandInput, "Must be 2-60 characters");
            else append("brand", brand);

            const model = modelInput?.value.trim();
            if (!model) setError(modelInput, "Model is required");
            else if (model.length < 1 || model.length > 60) setError(modelInput, "Must be 1-60 characters");
            else append("model", model);

            if (!categorySelect.value) setError(categorySelect, "Category is required");
            append("category", categorySelect.value);
            if (subSelect.value) append("subcategory", subSelect.value);
            if (subSubSelect.value) append("sub_subcategory", subSubSelect.value);

            const size = sizeSelect?.value;
            if (size && !["S", "M", "L", "XL", "NONE"].includes(size.toUpperCase())) setError(sizeSelect, "Invalid size");
            else append("size", size?.toUpperCase());

            const price = safeParse(priceInput?.value, NaN);
            if (isNaN(price) || price < 0) setError(priceInput, "Must be a non-negative number");
            else append("price", price);

            const cp = safeParse(comparePriceInput?.value, NaN);
            if (!isNaN(cp) && cp >= 0) append("comparePrice", cp);
            const cost = safeParse(costPriceInput?.value, NaN);
            if (!isNaN(cost) && cost >= 0) append("costPrice", cost);
            const offer = safeParse(offerPercentInput?.value, NaN);
            if (!isNaN(offer)) {
                if (offer < 0 || offer > 100) setError(offerPercentInput, "Must be 0-100");
                else append("offerPercent", offer);
            }

            const stock = safeParseInt(stockQuantityInput?.value, NaN);
            if (isNaN(stock) || stock < 0) setError(stockQuantityInput, "Must be a non-negative integer");
            else append("stockQuantity", stock);

            const low = safeParseInt(lowStockThresholdInput?.value, NaN);
            if (!isNaN(low) && low >= 0) append("lowStockThreshold", low);
            else if (lowStockThresholdInput?.value && isNaN(low)) setError(lowStockThresholdInput, "Must be an integer");

            const barcode = barcodeInput?.value.trim();
            if (barcode) {
                if (barcode.length < 3 || barcode.length > 60) setError(barcodeInput, "Must be 3-60 characters");
                else append("barcode", barcode);
            }

            const short = shortDescriptionInput?.value.trim();
            if (!short) setError(shortDescriptionInput, "Short description is required");
            else if (short.length < 3 || short.length > 300) setError(shortDescriptionInput, "Must be 3-300 characters");
            else append("shortDescription", short);

            const full = fullDescriptionInput?.value.trim();
            if (!full) setError(fullDescriptionInput, "Full description is required");
            else if (full.length < 3 || full.length > 2000) setError(fullDescriptionInput, "Must be 3-2000 characters");
            else append("fullDescription", full);

            append("shippingClass", shippingClassSelect?.value || "Standard");
            append("freeShipping", freeShippingSelect?.value === "true");

            const len = safeParse(lengthInput?.value, NaN);
            if (!isNaN(len) && len >= 0) append("length", len);
            else if (lengthInput?.value && len < 0) setError(lengthInput, "Must be ≥ 0");
            const wid = safeParse(widthInput?.value, NaN);
            if (!isNaN(wid) && wid >= 0) append("width", wid);
            else if (widthInput?.value && wid < 0) setError(widthInput, "Must be ≥ 0");
            const hei = safeParse(heightInput?.value, NaN);
            if (!isNaN(hei) && hei >= 0) append("height", hei);
            else if (heightInput?.value && hei < 0) setError(heightInput, "Must be ≥ 0");
            const wei = safeParse(weightInput?.value, NaN);
            if (!isNaN(wei) && wei >= 0) append("weight", wei);
            else if (weightInput?.value && wei < 0) setError(weightInput, "Must be ≥ 0");
            const shipC = safeParse(shippingCostInput?.value, NaN);
            if (!isNaN(shipC) && shipC >= 0) append("shippingCost", shipC);

            const minD = safeParseInt(minDayInput?.value, NaN),
                maxD = safeParseInt(maxDayInput?.value, NaN);
            if (!isNaN(minD)) {
                if (minD < 0 || minD > 365) setError(minDayInput, "Must be 0-365");
                else append("minDay", minD);
            }
            if (!isNaN(maxD)) {
                if (maxD < 0 || maxD > 365) setError(maxDayInput, "Must be 0-365");
                else append("maxDay", maxD);
            }
            if (!isNaN(minD) && !isNaN(maxD) && minD > maxD) {
                setError(minDayInput, "Min > Max");
                setError(maxDayInput, "Max < Min");
            }

            const status = statusSelect?.value;
            if (status && !["draft", "active", "archived"].includes(status)) setError(statusSelect, "Invalid status");
            else append("status", status || "draft");

            const vis = visibilitySelect?.value;
            if (vis && !["visible", "hidden"].includes(vis)) setError(visibilitySelect, "Invalid visibility");
            else append("visibility", vis || "visible");

            const tags = tagsInput?.value.trim();
            if (tags && tags.length > 200) setError(tagsInput, "Must be ≤ 200 characters");
            else append("tags", tags || "");

            const notes = internalNotesInput?.value.trim();
            if (notes && notes.length > 500) setError(internalNotesInput, "Must be ≤ 500 characters");
            else append("internalNotes", notes || "");

            [specTitleInput, designTitleInput, performanceTitleInput, additionalTitleInput].forEach(el => {
                const v = el?.value.trim();
                if (v) {
                    if (v.length < 3 || v.length > 100) setError(el, "Must be 3-100 characters");
                    else append(el.name, v);
                }
            });

            append("keySpecs", JSON.stringify(collectSpecifications("keySpecsContainer", "keySpecs_keys[]", "keySpecs_values[]")));
            append("detailedSpecs", JSON.stringify(collectSpecifications("detailedSpecsContainer", "detailedSpecs_keys[]", "detailedSpecs_values[]")));
            append("designSpecs", JSON.stringify(collectSpecifications("designSpecsContainer", "designSpecs_keys[]", "designSpecs_values[]")));
            append("perfSpecs", JSON.stringify(collectSpecifications("perfSpecsContainer", "perfSpecs_keys[]", "perfSpecs_values[]")));
            append("additionalSpecs", JSON.stringify(collectSpecifications("additionalSpecsContainer", "additionalSpecs_keys[]", "additionalSpecs_values[]")));
            append("videoLinks", JSON.stringify(collectVideoLinks()));

            const mainFile = mainImageInput?.files?.[0];
            const hasPreviewImg = !!mainPreview?.querySelector('img');
            if (!mainFile && !hasPreviewImg && !isEdit) {
                showModal("Main image is required", false);
                hasError = true;
            }
            if (mainFile) {
                if (!mainFile.type.startsWith("image/")) { showModal("Invalid main image format", false); hasError = true; }
                if (mainFile.size > MAX_IMG_SIZE) { showModal("Main image exceeds 5MB", false); hasError = true; }
                if (!hasError) formData.append("mainImage", mainFile);
            }

            if (isEdit) {
                if (existingImages.length) formData.append("existingImages", JSON.stringify(existingImages));
                if (removedImages.length) formData.append("removedImages", JSON.stringify(removedImages.map(i => i.filename)));
            }
            selectedImages.forEach(f => {
                if (f.size > MAX_IMG_SIZE) { showModal(`${f.name} exceeds 5MB`, false); hasError = true; }
                if (!f.type.startsWith("image/")) { showModal(`${f.name} is not a valid image`, false); hasError = true; }
            });
            if (!hasError) selectedImages.forEach(f => formData.append("additionalImages", f));

            if (isEdit) {
                if (existingVideos.length) formData.append("existingVideos", JSON.stringify(existingVideos));
                if (removedVideos.length) formData.append("removedVideos", JSON.stringify(removedVideos));
            }
            selectedVideos.forEach(f => {
                if (f.size > MAX_VIDEO_SIZE) { showModal(`${f.name} exceeds 200MB`, false); hasError = true; }
                if (!f.type.startsWith("video/")) { showModal(`${f.name} is not a valid video`, false); hasError = true; }
            });
            if (!hasError) selectedVideos.forEach(f => formData.append("productVideos", f));

            if (hasError) {
                if (firstError) firstError.focus();
                showModal("Please fix the highlighted errors", false);
                return;
            }

            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
            submitBtn.disabled = true;
            try {
                const url = isEdit ? `${PRODUCT_EDIT}/${productId}` : PRODUCT_API;
                const method = isEdit ? "PUT" : "POST";
                const resp = await fetch(url, { method, body: formData });
                const data = await resp.json();
                if (!resp.ok) {
                    if (data.errors) data.errors.forEach(e => showModal(e, false));
                    else showModal(data.message || "An error occurred", false);
                    return;
                }
                showModal(isEdit ? "Product updated successfully!" : "Product created successfully!", true);
                if (!isEdit) {
                    setTimeout(() => {
                        form.reset();
                        selectedImages = [];
                        selectedVideos = [];
                        mainPreview.innerHTML = "";
                        additionalPreview.innerHTML = "";
                        videosPreview.innerHTML = "";
                        mainFileNameSpan.textContent = "No file chosen";
                        additionalFileName.textContent = "No images selected";
                        videosFileName.textContent = "No files chosen";
                        if (deliveryCounter) deliveryCounter.style.display = "none";
                        document.querySelectorAll(".specification-row").forEach(row => {
                            if (row.closest("#keySpecsContainer") && row !== document.querySelector("#keySpecsContainer .specification-row"))
                                row.remove();
                        });
                        ["keySpecsContainer", "detailedSpecsContainer", "designSpecsContainer", "perfSpecsContainer", "additionalSpecsContainer"].forEach(cid => {
                            const c = document.getElementById(cid);
                            if (c) {
                                c.innerHTML = `
                                    <div class="specification-row">
                                        <div class="spec-input"><input type="text" name="${cid === 'keySpecsContainer' ? 'keySpecs_keys[]' : cid === 'detailedSpecsContainer' ? 'detailedSpecs_keys[]' : cid === 'designSpecsContainer' ? 'designSpecs_keys[]' : cid === 'perfSpecsContainer' ? 'perfSpecs_keys[]' : 'additionalSpecs_keys[]'}" class="form-control" placeholder="${cid === 'keySpecsContainer' ? 'Spec name' : cid === 'detailedSpecsContainer' ? 'Category' : cid === 'designSpecsContainer' ? 'Design feature' : cid === 'perfSpecsContainer' ? 'Metric' : 'Feature'}"></div>
                                        <div class="spec-input"><input type="text" name="${cid === 'keySpecsContainer' ? 'keySpecs_values[]' : cid === 'detailedSpecsContainer' ? 'detailedSpecs_values[]' : cid === 'designSpecsContainer' ? 'designSpecs_values[]' : cid === 'perfSpecsContainer' ? 'perfSpecs_values[]' : 'additionalSpecs_values[]'}" class="form-control" placeholder="Value"></div>
                                        <button type="button" class="btn-small btn-danger removeRowBtn">Remove</button>
                                    </div>
                                `;
                                attachRemove(c.querySelector(".removeRowBtn"));
                            }
                        });
                    }, 1000);
                }
            } catch (err) {
                console.error(err);
                showModal("Server error — please try again", false);
            } finally {
                submitBtn.innerHTML = "Submit Product";
                submitBtn.disabled = false;
            }
        });

        setTimeout(() => productNameInput?.focus(), 150);
    </script>
</body>
</html>