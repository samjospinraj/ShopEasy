<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShopMaster · Admin Products 2026</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'SF Pro Display', 'Inter', Roboto, system-ui, sans-serif;
        }

        :root {
            --bg-deep: #060b1f;
            --bg-card: rgba(10, 16, 36, 0.65);
            --bg-card-hover: rgba(14, 22, 45, 0.82);
            --bg-sidebar: rgba(7, 11, 28, 0.82);
            --bg-header: rgba(9, 14, 32, 0.7);
            --glass-blur: 20px;
            --glass-blur-light: 12px;
            --primary: #4dabf7;
            --primary-glow: #339af0;
            --accent-cyan: #38bdf8;
            --accent-teal: #2dd4bf;
            --accent-purple: #a78bfa;
            --accent-violet: #8b5cf6;
            --accent-green: #34d399;
            --accent-orange: #fb923c;
            --accent-red: #f87171;
            --accent-pink: #f472b6;
            --text-primary: #e8ecf4;
            --text-secondary: #b0bdd0;
            --text-muted: #7b8ca6;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(77, 171, 247, 0.3);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.45), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-glow: 0 0 40px rgba(77, 171, 247, 0.18), 0 0 80px rgba(77, 171, 247, 0.06);
            --shadow-glow-purple: 0 0 40px rgba(139, 92, 246, 0.18), 0 0 80px rgba(139, 92, 246, 0.06);
            --radius-xl: 22px;
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-smooth: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            background: radial-gradient(ellipse at 20% 20%, #0b1430 0%, #060b1f 45%, #04091a 70%, #020617 100%);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
        }

        #nuranCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        .sidebar {
            width: 280px;
            background: var(--bg-sidebar);
            backdrop-filter: blur(26px);
            -webkit-backdrop-filter: blur(26px);
            color: var(--text-primary);
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            border-right: 1px solid var(--border-subtle);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        .sidebar-header {
            padding: 0 20px 18px 20px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo-text {
            font-size: 1.6rem;
            font-weight: 700;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .logo-subtext {
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }
        .toggle-sidebar {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 36px;
            height: 36px;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
            font-size: 1rem;
        }
        .toggle-sidebar:hover {
            background: rgba(77, 171, 247, 0.15);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.25);
        }
        .sidebar-menu {
            flex: 1;
            padding: 20px 0;
        }
        .menu-item {
            display: flex;
            align-items: center;
            padding: 13px 20px;
            margin: 3px 10px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition-fast);
            border-radius: 10px;
            cursor: pointer;
            font-weight: 450;
            border: 1px solid transparent;
        }
        .menu-item:hover {
            background: rgba(77, 171, 247, 0.08);
            color: var(--text-primary);
            border-color: rgba(77, 171, 247, 0.2);
        }
        .menu-item.active-menu {
            background: rgba(77, 171, 247, 0.13);
            color: #fff;
            border-color: rgba(77, 171, 247, 0.35);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.15);
            position: relative;
        }
        .menu-item.active-menu::before {
            content: '';
            position: absolute;
            left: -2px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 22px;
            border-radius: 0 4px 4px 0;
            background: var(--accent-cyan);
            box-shadow: 0 0 14px var(--accent-cyan);
        }
        .menu-item i {
            width: 24px;
            font-size: 1.15rem;
            margin-right: 14px;
            text-align: center;
        }
        .menu-text {
            font-size: 0.95rem;
        }

        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 22px 30px;
            transition: margin-left 0.35s ease;
            width: 100%;
            position: relative;
            z-index: 1;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-header);
            backdrop-filter: blur(22px);
            -webkit-backdrop-filter: blur(22px);
            padding: 14px 26px;
            border-radius: 50px;
            box-shadow: var(--shadow-card);
            margin-bottom: 28px;
            border: 1px solid var(--border-subtle);
            flex-wrap: wrap;
            gap: 14px;
            position: relative;
            z-index: 2;
        }
        .menu-toggle {
            display: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 44px;
            height: 44px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1.2rem;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
        }
        .menu-toggle:hover {
            border-color: var(--border-glow);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.2);
            color: var(--accent-cyan);
        }
        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            padding: 8px 20px;
            width: min(400px, 100%);
            border: 1px solid var(--border-subtle);
            transition: var(--transition-fast);
        }
        .search-bar:focus-within {
            border-color: var(--border-glow);
            box-shadow: 0 0 20px rgba(77, 171, 247, 0.2);
            background: rgba(255, 255, 255, 0.05);
        }
        .search-bar input {
            border: none;
            background: transparent;
            padding: 8px 10px;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
            color: var(--text-primary);
        }
        .search-bar input::placeholder {
            color: var(--text-muted);
        }
        .search-bar i {
            color: var(--text-muted);
        }
        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .notification-btn {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-subtle);
            font-size: 1.15rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 10px 12px;
            border-radius: 50%;
            transition: var(--transition-fast);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .notification-btn:hover {
            background: rgba(77, 171, 247, 0.12);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.2);
        }
        .notification-badge {
            position: absolute;
            top: 2px;
            right: 3px;
            background: var(--accent-red);
            color: #fff;
            font-size: 0.6rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            box-shadow: 0 0 10px rgba(248, 113, 113, 0.5);
            animation: pulseBadge 2s ease-in-out infinite;
        }
        @keyframes pulseBadge {
            0%,
            100% {
                box-shadow: 0 0 8px rgba(248, 113, 113, 0.5);
            }
            50% {
                box-shadow: 0 0 20px rgba(248, 113, 113, 0.8), 0 0 30px rgba(248, 113, 113, 0.3);
            }
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 5px 18px 5px 8px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            border: 1px solid var(--border-subtle);
            cursor: pointer;
            transition: var(--transition-fast);
        }
        .user-info:hover {
            border-color: var(--border-glow);
            box-shadow: 0 0 16px rgba(77, 171, 247, 0.15);
        }
        .user-info img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid rgba(77, 171, 247, 0.5);
            object-fit: cover;
            box-shadow: 0 0 12px rgba(77, 171, 247, 0.3);
        }
        .user-details h4 {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        .user-details p {
            font-size: 0.7rem;
            color: var(--text-muted);
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header h2 {
            font-size: 1.9rem;
            font-weight: 700;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 12px;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .view-toggle {
            display: flex;
            gap: 6px;
            background: rgba(255, 255, 255, 0.04);
            padding: 5px;
            border-radius: 48px;
            border: 1px solid var(--border-subtle);
            backdrop-filter: blur(8px);
        }
        .view-btn {
            border: none;
            padding: 10px 22px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            background: transparent;
            color: var(--text-secondary);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition-fast);
        }
        .view-btn.active-view {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: #fff;
            box-shadow: 0 4px 16px rgba(77, 171, 247, 0.3);
        }
        .add-product-btn {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.25s ease;
            box-shadow: 0 4px 20px rgba(77, 171, 247, 0.35);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }
        .add-product-btn:hover {
            transform: translateY(-3px);
            background: linear-gradient(135deg, #5bb8ff, #3a8af0);
            box-shadow: 0 8px 28px rgba(77, 171, 247, 0.45);
        }

        .filter-container {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            -webkit-backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 22px 26px;
            margin-bottom: 28px;
            border: 1px solid var(--border-subtle);
            display: flex;
            flex-wrap: wrap;
            align-items: flex-end;
            gap: 24px;
            transition: var(--transition-smooth);
        }
        .filter-container:hover {
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }
        .filter-group {
            display: flex;
            flex-direction: column;
            min-width: 150px;
        }
        .filter-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 6px;
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }
        .filter-select,
        .filter-input {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            border-radius: 40px;
            padding: 11px 16px;
            font-size: 0.9rem;
            color: var(--text-primary);
            outline: none;
            transition: var(--transition-fast);
            cursor: pointer;
        }
        /* 👇 Styled options for dark theme */
        .filter-select option {
            background-color: #0f1829;
            color: #e0e7f0;
        }
        .filter-select option:checked {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: white;
        }
        .filter-select:hover,
        .filter-select:focus {
            border-color: var(--border-glow);
            box-shadow: 0 0 12px rgba(77, 171, 247, 0.12);
        }
        .price-range {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .price-range input {
            width: 100px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            border-radius: 40px;
            padding: 11px 14px;
            font-size: 0.9rem;
            color: var(--text-primary);
            outline: none;
        }
        .price-range input:focus {
            border-color: var(--border-glow);
        }
        .apply-filter-btn {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            border: none;
            color: #fff;
            padding: 11px 28px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: var(--transition-fast);
            box-shadow: 0 4px 18px rgba(77, 171, 247, 0.3);
        }
        .apply-filter-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(77, 171, 247, 0.4);
        }
        .clear-filter {
            background: transparent;
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            padding: 11px 22px;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition-fast);
        }
        .clear-filter:hover {
            border-color: var(--accent-red);
            color: var(--accent-red);
            box-shadow: 0 0 16px rgba(248, 113, 113, 0.2);
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 26px;
            margin-bottom: 36px;
            position: relative;
            z-index: 1;
        }
        .product-card {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            -webkit-backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 20px 16px;
            border: 1px solid var(--border-subtle);
            transition: var(--transition-smooth);
            display: flex;
            flex-direction: column;
            position: relative;
            cursor: pointer;
            overflow: hidden;
        }
        .product-card::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: var(--radius-xl);
            opacity: 0;
            transition: opacity 0.4s ease;
            background: radial-gradient(circle at 50% 0%, rgba(77, 171, 247, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }
        .product-card:hover::after {
            opacity: 1;
        }
        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-glow);
            border-color: var(--border-glow);
            background: var(--bg-card-hover);
        }
        .product-badge {
            position: absolute;
            top: 14px;
            right: 16px;
            background: linear-gradient(135deg, #fb923c, #f97316);
            color: #fff;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 5px 12px;
            border-radius: 30px;
            z-index: 2;
            letter-spacing: 0.3px;
            box-shadow: 0 2px 10px rgba(251, 146, 60, 0.35);
        }
        .product-img {
            width: 100%;
            height: 160px;
            background: rgba(77, 171, 247, 0.06);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.8rem;
            color: var(--accent-cyan);
            margin-bottom: 14px;
            overflow: hidden;
            border: 1px solid var(--border-subtle);
        }
        .product-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 18px;
        }
        .product-info h4 {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 5px;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .product-category {
            font-size: 0.78rem;
            color: var(--accent-cyan);
            background: rgba(56, 189, 248, 0.1);
            display: inline-block;
            padding: 4px 12px;
            border-radius: 30px;
            margin: 8px 0 10px;
            border: 1px solid rgba(56, 189, 248, 0.2);
        }
        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }
        .product-price {
            font-size: 1.45rem;
            font-weight: 700;
            color: var(--accent-cyan);
            letter-spacing: -0.3px;
        }
        .product-stock {
            font-size: 0.8rem;
            background: rgba(52, 211, 153, 0.1);
            padding: 5px 10px;
            border-radius: 30px;
            color: var(--accent-green);
            font-weight: 600;
            border: 1px solid rgba(52, 211, 153, 0.25);
        }
        .low-stock {
            background: rgba(248, 113, 113, 0.1);
            color: var(--accent-red);
            border-color: rgba(248, 113, 113, 0.25);
        }
        .card-actions {
            display: flex;
            gap: 8px;
            margin-top: 14px;
            border-top: 1px solid var(--border-subtle);
            padding-top: 14px;
        }
        .card-action-btn {
            flex: 1;
            border: 1px solid var(--border-subtle);
            background: rgba(255, 255, 255, 0.03);
            padding: 8px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.78rem;
            cursor: pointer;
            transition: var(--transition-fast);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            color: var(--text-secondary);
        }
        .card-action-btn:hover {
            background: rgba(77, 171, 247, 0.15);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 14px rgba(56, 189, 248, 0.18);
        }

        .table-view {
            background: var(--bg-card);
            backdrop-filter: blur(var(--glass-blur-light));
            -webkit-backdrop-filter: blur(var(--glass-blur-light));
            border-radius: var(--radius-xl);
            padding: 20px;
            border: 1px solid var(--border-subtle);
            overflow-x: auto;
            margin-bottom: 36px;
            transition: var(--transition-smooth);
        }
        .table-view:hover {
            border-color: var(--border-glow);
            box-shadow: var(--shadow-glow);
        }
        .table-view table {
            width: 100%;
            border-collapse: collapse;
            min-width: 700px;
        }
        .table-view th {
            text-align: left;
            padding: 14px 10px;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--border-subtle);
        }
        .table-view td {
            padding: 14px 10px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            color: var(--text-secondary);
            font-size: 0.88rem;
        }
        tr:hover td {
            background: rgba(255, 255, 255, 0.02);
        }
        tr:last-child td {
            border: none;
        }
        .stock-indicator {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .stock-high {
            background: rgba(52, 211, 153, 0.12);
            color: #34d399;
            border: 1px solid rgba(52, 211, 153, 0.3);
        }
        .stock-medium {
            background: rgba(251, 191, 36, 0.12);
            color: #fbbf24;
            border: 1px solid rgba(251, 191, 36, 0.3);
        }
        .stock-low {
            background: rgba(248, 113, 113, 0.12);
            color: #f87171;
            border: 1px solid rgba(248, 113, 113, 0.3);
        }
        .table-actions button {
            background: transparent;
            border: none;
            font-size: 1.05rem;
            margin: 0 5px;
            cursor: pointer;
            color: var(--text-muted);
            transition: var(--transition-fast);
        }
        .table-actions button:hover {
            color: var(--accent-cyan);
            text-shadow: 0 0 8px rgba(56, 189, 248, 0.4);
        }

        .hidden {
            display: none;
        }
        .notification-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(14, 22, 45, 0.92);
            backdrop-filter: blur(22px);
            -webkit-backdrop-filter: blur(22px);
            border-left: 4px solid var(--accent-cyan);
            padding: 15px 22px;
            border-radius: 16px;
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5), 0 0 20px rgba(56, 189, 248, 0.2);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
            color: var(--text-primary);
            animation: slideInToast 0.3s ease;
        }
        @keyframes slideInToast {
            from {
                opacity: 0;
                transform: translateX(50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        .loader {
            text-align: center;
            padding: 60px;
            font-size: 1.2rem;
            color: var(--accent-cyan);
        }

        @media (max-width: 992px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.active {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
            .menu-toggle {
                display: flex;
            }
        }
        @media (max-width: 680px) {
            .main-content {
                padding: 14px;
            }
            .filter-container {
                flex-direction: column;
                align-items: stretch;
            }
            .products-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <canvas id="nuranCanvas"></canvas>

    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div>
                <div class="logo-text">ShopMaster</div>
                <div class="logo-subtext">admin · 2026</div>
            </div>
            <button class="toggle-sidebar" id="toggleSidebar">
                <i class="fas fa-chevron-left"></i>
            </button>
        </div>
        <div class="sidebar-menu">
            <a href="/Admin/dashboard" class="menu-item"><i class="fas fa-tachometer-alt"></i><span class="menu-text">Dashboard</span></a>
            <a href="/Admin/product" class="menu-item active-menu"><i class="fas fa-box"></i><span class="menu-text">Products</span></a>
            <a href="/Admin/category" class="menu-item"><i class="fas fa-tags"></i><span class="menu-text">Categories</span></a>
            <a href="/Admin/order" class="menu-item"><i class="fas fa-shopping-cart"></i><span class="menu-text">Orders</span></a>
            <a href="/Admin/customer" class="menu-item"><i class="fas fa-users"></i><span class="menu-text">Customers</span></a>
            <a href="/Admin/review" class="menu-item "><i class="fas fa-star"></i> Reviews</a>
            <a href="/Admin/analytics" class="menu-item"><i class="fas fa-chart-line"></i><span class="menu-text">Analytics</span></a>
            <a href="/Admin/profile" class="menu-item"><i class="fas fa-id-badge"></i><span class="menu-text">Profile</span></a>
            <a href="/Admin/setting" class="menu-item"><i class="fas fa-cog"></i><span class="menu-text">Settings</span></a>
        </div>
    </div>

    <div class="main-content" id="mainContent">
        <div class="header">
            <button class="menu-toggle" id="menuToggle">
                <i class="fas fa-bars"></i>
            </button>
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search products by name..." />
            </div>
            <div class="header-actions">
                <button class="notification-btn">
                    <i class="fas fa-bell"></i><span class="notification-badge">5</span>
                </button>
                <div class="user-info">
                    <img src="https://ui-avatars.com/api/?name=Admin+Master&background=4dabf7&color=fff&bold=true&size=42" alt="admin" />
                    <div class="user-details">
                        <h4>Alex Master</h4>
                        <p>Super Admin</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="page-header">
            <h2><i class="fas fa-box-open" style="color:var(--accent-cyan);"></i> Products</h2>
            <div class="view-toggle">
                <button class="view-btn active-view" id="viewCardsBtn">
                    <i class="fas fa-th-large"></i> Cards
                </button>
                <button class="view-btn" id="viewTableBtn">
                    <i class="fas fa-table"></i> Table
                </button>
            </div>
            <button class="add-product-btn" id="addProductBtn">
                <i class="fas fa-plus"></i> Add Product
            </button>
        </div>

        <div class="filter-container">
            <div class="filter-group">
                <label><i class="fas fa-filter"></i> Category</label>
                <select class="filter-select" id="categoryFilter">
                    <option value="all">All categories</option>
                </select>
            </div>
            <div class="filter-group">
                <label><i class="fas fa-tag"></i> Price range</label>
                <div class="price-range">
                    <input type="number" id="minPrice" placeholder="Min ₹" value="" />
                    <span style="color:var(--text-muted);">—</span>
                    <input type="number" id="maxPrice" placeholder="Max ₹" value="" />
                </div>
            </div>
            <div class="filter-group">
                <label><i class="fas fa-cubes"></i> Stock status</label>
                <select class="filter-select" id="stockFilter">
                    <option value="all">All</option>
                    <option value="high">High (≥50)</option>
                    <option value="medium">Medium (20–49)</option>
                    <option value="low">Low (≤19)</option>
                </select>
            </div>
            <button class="apply-filter-btn" id="applyFilterBtn">
                <i class="fas fa-sliders-h"></i> Apply filters
            </button>
            <button class="clear-filter" id="clearFilterBtn">Clear</button>
        </div>

        <div id="cardsView" class="products-grid"></div>
        <div id="tableView" class="table-view hidden">
            <table>
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody"></tbody>
            </table>
        </div>
        <p style="text-align: center; color: var(--text-muted); margin-top: 20px; font-size: 0.85rem;">
            <i class="fas fa-sync-alt"></i> Live data from backend API · 2026
        </p>
    </div>

    <script>
        (function() {
            // ═══════════ NURAN NEURAL BACKGROUND ═══════════
            const nuranCanvas = document.getElementById('nuranCanvas');
            const ctx = nuranCanvas.getContext('2d');
            let particles = [];
            let mouseX = -999,
                mouseY = -999,
                targetMouseX = -999,
                targetMouseY = -999;
            const SPLATTER_RADIUS = 190;
            const CONNECTION_DIST = 140;
            const PARTICLE_COUNT = window.innerWidth < 768 ? 80 : 140;
            const MAX_FORCE = 4.5;
            const DAMPING = 0.94;

            function resizeCanvas() {
                nuranCanvas.width = window.innerWidth;
                nuranCanvas.height = window.innerHeight;
            }
            resizeCanvas();
            window.addEventListener('resize', () => {
                resizeCanvas();
                const newCount = window.innerWidth < 768 ? 80 : 140;
                while (particles.length < newCount) particles.push(createParticle());
                while (particles.length > newCount) particles.pop();
            });

            function createParticle() {
                const colors = [
                    'rgba(77,171,247,', 'rgba(56,189,248,', 'rgba(167,139,250,',
                    'rgba(139,92,246,', 'rgba(45,212,191,', 'rgba(96,165,250,',
                    'rgba(192,132,252,', 'rgba(52,211,153,',
                ];
                const color = colors[Math.floor(Math.random() * colors.length)];
                return {
                    x: Math.random() * nuranCanvas.width,
                    y: Math.random() * nuranCanvas.height,
                    vx: (Math.random() - 0.5) * 0.7,
                    vy: (Math.random() - 0.5) * 0.7,
                    size: 1.8 + Math.random() * 3.5,
                    color: color,
                    glowAlpha: 0.5 + Math.random() * 0.5,
                    pulsePhase: Math.random() * Math.PI * 2,
                    pulseSpeed: 0.008 + Math.random() * 0.025,
                    baseSize: 1.8 + Math.random() * 3.5,
                };
            }
            for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(createParticle());

            document.addEventListener('mousemove', (e) => { targetMouseX = e.clientX;
                targetMouseY = e.clientY; });
            document.addEventListener('mouseleave', () => { targetMouseX = -999;
                targetMouseY = -999; });
            document.addEventListener('touchmove', (e) => {
                if (e.touches.length > 0) { targetMouseX = e.touches[0].clientX;
                    targetMouseY = e.touches[0].clientY; }
            }, { passive: true });
            document.addEventListener('touchend', () => { targetMouseX = -999;
                targetMouseY = -999; });

            function animateNuran(timestamp) {
                mouseX += (targetMouseX - mouseX) * 0.18;
                mouseY += (targetMouseY - mouseY) * 0.18;
                ctx.clearRect(0, 0, nuranCanvas.width, nuranCanvas.height);
                const time = timestamp * 0.001;
                for (let i = 0; i < particles.length; i++) {
                    const p = particles[i];
                    p.vx += (Math.sin(time * 0.7 + p.pulsePhase) * 0.025);
                    p.vy += (Math.cos(time * 0.6 + p.pulsePhase + 1.3) * 0.025);
                    if (mouseX > -500 && mouseY > -500) {
                        const dx = p.x - mouseX;
                        const dy = p.y - mouseY;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < SPLATTER_RADIUS && dist > 0.5) {
                            const force = (1 - dist / SPLATTER_RADIUS) * MAX_FORCE;
                            p.vx += (dx / dist) * force;
                            p.vy += (dy / dist) * force;
                            p.glowAlpha = Math.min(1, p.glowAlpha + 0.06);
                        }
                    }
                    p.x += p.vx;
                    p.y += p.vy;
                    p.vx *= DAMPING;
                    p.vy *= DAMPING;
                    const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
                    if (speed > 6) { p.vx = (p.vx / speed) * 6;
                        p.vy = (p.vy / speed) * 6; }
                    if (p.x < -30) p.x = nuranCanvas.width + 30;
                    if (p.x > nuranCanvas.width + 30) p.x = -30;
                    if (p.y < -30) p.y = nuranCanvas.height + 30;
                    if (p.y > nuranCanvas.height + 30) p.y = -30;
                    p.size = p.baseSize + Math.sin(time * p.pulseSpeed * 10 + p.pulsePhase) * 0.7;
                    p.glowAlpha += (0.6 - p.glowAlpha) * 0.03;
                }
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x;
                        const dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < CONNECTION_DIST) {
                            const alpha = (1 - dist / CONNECTION_DIST) * 0.28;
                            const pulse = Math.sin(timestamp * 0.003 + i * 0.4 + j * 0.3) * 0.5 + 0.5;
                            ctx.beginPath();
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.strokeStyle = `rgba(120,170,230,${alpha * (0.5 + pulse * 0.5)})`;
                            ctx.lineWidth = 0.6;
                            ctx.stroke();
                        }
                    }
                }
                for (const p of particles) {
                    const glowGrad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * 3.5);
                    glowGrad.addColorStop(0, p.color + (p.glowAlpha * 0.7) + ')');
                    glowGrad.addColorStop(0.35, p.color + (p.glowAlpha * 0.25) + ')');
                    glowGrad.addColorStop(1, p.color + '0)');
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * 3.5, 0, Math.PI * 2);
                    ctx.fillStyle = glowGrad;
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * 0.65, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255,255,255,${0.7 + p.glowAlpha * 0.3})`;
                    ctx.fill();
                }
                if (mouseX > -500 && mouseY > -500) {
                    const mouseGlow = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, SPLATTER_RADIUS *
                    0.7);
                    mouseGlow.addColorStop(0, 'rgba(120,180,240,0.08)');
                    mouseGlow.addColorStop(0.5, 'rgba(100,150,220,0.03)');
                    mouseGlow.addColorStop(1, 'rgba(0,0,0,0)');
                    ctx.beginPath();
                    ctx.arc(mouseX, mouseY, SPLATTER_RADIUS * 0.7, 0, Math.PI * 2);
                    ctx.fillStyle = mouseGlow;
                    ctx.fill();
                }
                requestAnimationFrame(animateNuran);
            }
            requestAnimationFrame(animateNuran);
            console.log('🧠 Nuran neural background active · Products page');

            // ═══════════ PRODUCT MANAGEMENT LOGIC ═══════════
            const BASE_URL = "http://localhost:3000";
            const CATEGORY_URL = `${BASE_URL}/Admin/categories`;
            const PRODUCT_URL = `${BASE_URL}/Admin/allproduct`;
            const DELETED_URL = `${BASE_URL}/Admin/deletedproduct`;

            let allProducts = [];
            let allCategories = [];

            const cardsContainer = document.getElementById("cardsView");
            const tableBody = document.getElementById("tableBody");
            const categoryFilterSelect = document.getElementById("categoryFilter");
            const searchInput = document.getElementById("searchInput");
            const minPriceInput = document.getElementById("minPrice");
            const maxPriceInput = document.getElementById("maxPrice");
            const stockFilterSelect = document.getElementById("stockFilter");
            const applyBtn = document.getElementById("applyFilterBtn");
            const clearBtn = document.getElementById("clearFilterBtn");
            const viewCardsBtn = document.getElementById("viewCardsBtn");
            const viewTableBtn = document.getElementById("viewTableBtn");
            const cardsViewDiv = document.getElementById("cardsView");
            const tableViewDiv = document.getElementById("tableView");

            function showToast(message, icon = "info-circle") {
                const old = document.querySelector('.notification-toast');
                if (old) old.remove();
                const toast = document.createElement("div");
                toast.className = "notification-toast";
                toast.innerHTML =
                    `<i class="fas fa-${icon}" style="color:var(--accent-cyan);font-size:1.3rem;"></i><span>${message}</span>`;
                document.body.appendChild(toast);
                setTimeout(() => {
                    toast.style.opacity = "0";
                    toast.style.transform = "translateX(50px)";
                    toast.style.transition = "all 0.35s ease";
                    setTimeout(() => toast.remove(), 350);
                }, 2400);
            }

            async function fetchCategories() {
                try {
                    const res = await fetch(CATEGORY_URL);
                    if (!res.ok) throw new Error("Failed to fetch categories");
                    const data = await res.json();
                    allCategories = Array.isArray(data) ? data : [];
                    populateCategoryFilter();
                } catch (error) {
                    console.error("Category fetch error:", error);
                    showToast("Could not load categories", "exclamation-triangle");
                    allCategories = ["Electronics", "Sports", "Kitchen", "Fashion"];
                    populateCategoryFilter();
                }
            }

            function populateCategoryFilter() {
                categoryFilterSelect.innerHTML = '<option value="all">All categories</option>';
                const categories = Array.isArray(allCategories) ? allCategories : [];
                categories.forEach((cat) => {
                    const name = typeof cat === "string" ? cat : cat.categoryName || cat.name;
                    if (!name) return;
                    const option = document.createElement("option");
                    option.value = name;
                    option.textContent = name;
                    categoryFilterSelect.appendChild(option);
                });
            }

            function getProductImageUrl(product) {
                if (product.mainImage && product.mainImage.path) return `${BASE_URL}${product.mainImage.path}`;
                if (product.image && typeof product.image === "string") {
                    if (product.image.startsWith("http")) return product.image;
                    return `${BASE_URL}${product.image}`;
                }
                if (product.images && Array.isArray(product.images) && product.images.length > 0) {
                    const firstImg = product.images[0];
                    if (typeof firstImg === "string") {
                        if (firstImg.startsWith("http")) return firstImg;
                        return `${BASE_URL}${firstImg}`;
                    }
                    if (firstImg && firstImg.path) return `${BASE_URL}${firstImg.path}`;
                }
                return null;
            }

            async function fetchProducts() {
                try {
                    cardsContainer.innerHTML =
                        '<div class="loader"><i class="fas fa-spinner fa-pulse"></i> Loading products...</div>';
                    tableBody.innerHTML = '<tr><td colspan="8" class="loader">Loading...</td></tr>';
                    const res = await fetch(PRODUCT_URL);
                    if (!res.ok) throw new Error(`HTTP ${res.status}`);
                    const response = await res.json();
                    allProducts = Array.isArray(response) ? response : Array.isArray(response?.data) ? response.data :
                    [];
                    renderCurrentView();
                    showToast(`${allProducts.length} products loaded`, "check-circle");
                } catch (error) {
                    console.error("Product fetch error:", error);
                    cardsContainer.innerHTML =
                        '<div class="loader" style="color:var(--accent-red);"><i class="fas fa-exclamation-triangle"></i> Failed to load products.</div>';
                    tableBody.innerHTML = '<tr><td colspan="8">Error loading products</td></tr>';
                    showToast("Backend connection failed", "times-circle");
                }
            }

            function getFilteredProducts() {
                const category = categoryFilterSelect.value;
                const searchTerm = searchInput.value.trim().toLowerCase();
                const min = parseFloat(minPriceInput.value) || 0;
                const max = parseFloat(maxPriceInput.value) || Infinity;
                const stockStatus = stockFilterSelect.value;
                return allProducts.filter((prod) => {
                    let prodCategory = "";
                    if (typeof prod.category === "object" && prod.category !== null) {
                        prodCategory = prod.category.categoryName || prod.category.name || "";
                    } else {
                        prodCategory = prod.category || "";
                    }
                    const catMatch = category === "all" || prodCategory === category;
                    const searchMatch = searchTerm === "" || (prod.productName || "").toLowerCase().includes(
                        searchTerm);
                    const price = Number(prod.price) || 0;
                    const priceMatch = price >= min && price <= max;
                    const stock = Number(prod.stockQuantity) || 0;
                    let stockMatch = true;
                    if (stockStatus === "high") stockMatch = stock >= 50;
                    else if (stockStatus === "medium") stockMatch = stock >= 20 && stock <= 49;
                    else if (stockStatus === "low") stockMatch = stock <= 19;
                    return catMatch && searchMatch && priceMatch && stockMatch;
                });
            }

            function renderCards(products) {
                if (!products.length) {
                    cardsContainer.innerHTML =
                        '<div style="text-align:center; padding:60px; background:var(--bg-card); border-radius:var(--radius-xl); border:1px solid var(--border-subtle); color:var(--text-muted);">No products match the filters</div>';
                    return;
                }
                cardsContainer.innerHTML = products.map(prod => {
                    const id = prod._id || prod.id;
                    let category = "";
                    if (typeof prod.category === "object" && prod.category !== null) {
                        category = prod.category.categoryName || "Uncategorized";
                    } else {
                        category = prod.category || "Uncategorized";
                    }
                    const price = Number(prod.price) || 0;
                    const stock = Number(prod.stockQuantity) || 0;
                    const name = escapeHtml(prod.productName || "Unnamed");
                    const imageUrl = getProductImageUrl(prod);
                    return `
                        <div class="product-card" data-id="${id}" data-category="${category}" data-price="${price}" data-stock="${stock}">
                            ${prod.isBestseller ? '<span class="product-badge">Bestseller</span>' : (prod.isNew ? '<span class="product-badge">New</span>' : "")}
                            <div class="product-img">
                                ${imageUrl ? `<img src="${imageUrl}" alt="${name}" onerror="this.parentElement.innerHTML='<i class=\'fas fa-cube\'></i>'">` : `<i class="fas fa-cube"></i>`}
                            </div>
                            <div class="product-info">
                                <h4 title="${name}">${name}</h4>
                                <span class="product-category">${category}</span>
                                <div class="product-footer">
                                    <span class="product-price">₹${formatPrice(price)}</span>
                                    <span class="product-stock ${stock <= 19 ? 'low-stock' : ''}">${stock} in stock</span>
                                </div>
                            </div>
                            <div class="card-actions">
                                <button class="card-action-btn edit-card" data-id="${id}"><i class="fas fa-edit"></i> Edit</button>
                                <button class="card-action-btn view-card" data-id="${id}"><i class="fas fa-eye"></i> View</button>
                                <button class="card-action-btn deleted-card" data-id="${id}"><i class="fas fa-trash"></i> Delete</button>
                            </div>
                        </div>
                    `;
                }).join("");
                attachCardEvents();
            }

            function renderTable(products) {
                if (!products.length) {
                    tableBody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-muted);">No products found</td></tr>';
                    return;
                }
                tableBody.innerHTML = products.map(prod => {
                    const id = prod._id || prod.id;
                    let category = "";
                    if (typeof prod.category === "object" && prod.category !== null) {
                        category = prod.category.categoryName || "-";
                    } else {
                        category = prod.category || "-";
                    }
                    const stock = Number(prod.stockQuantity) || 0;
                    const price = Number(prod.price) || 0;
                    const name = escapeHtml(prod.productName || "");
                    const imageUrl = getProductImageUrl(prod);
                    const stockStatusText = stock >= 50 ? "high" : (stock >= 20 ? "medium" : "low");
                    return `
                        <tr data-id="${id}">
                            <td style="width:60px;">
                                ${imageUrl ? `<img src="${imageUrl}" alt="${name}" style="width:50px;height:50px;object-fit:cover;border-radius:8px;" onerror="this.style.display='none'">` : '<i class="fas fa-cube" style="font-size:22px;color:var(--text-muted);"></i>'}
                            </td>
                            <td><strong>${name}</strong></td>
                            <td>${category}</td>
                            <td>₹${formatPrice(price)}</td>
                            <td>${stock}</td>
                            <td><span class="stock-indicator stock-${stockStatusText}">${stockStatusText}</span></td>
                            <td class="table-actions">
                                <button class="table-edit" data-id="${id}" title="Edit"><i class="fas fa-edit"></i></button>
                                <button class="table-view" data-id="${id}" title="View"><i class="fas fa-eye"></i></button>
                                <button class="table-deleted" data-id="${id}" title="Delete"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                    `;
                }).join("");
                attachTableEvents();
            }

            function renderCurrentView() {
                const filtered = getFilteredProducts();
                const isCardsActive = !cardsViewDiv.classList.contains("hidden");
                if (isCardsActive) renderCards(filtered);
                else renderTable(filtered);
            }

            function attachCardEvents() {
                document.querySelectorAll(".edit-card").forEach((btn) => {
                    btn.addEventListener("click", (e) => {
                        e.stopPropagation();
                        window.location.href = `/Admin/editproductForm/${btn.dataset.id}`;
                    });
                });
                document.querySelectorAll(".view-card").forEach((btn) => {
                    btn.addEventListener("click", (e) => {
                        e.stopPropagation();
                        window.location.href = `/Admin/singleProduct/${btn.dataset.id}`;
                    });
                });
                document.querySelectorAll(".deleted-card").forEach((card) => {
                    card.addEventListener("click", async (e) => {
                        e.stopPropagation();
                        const id = card.dataset.id;
                        try {
                            const response = await fetch(`${DELETED_URL}/${id}`, { method: "DELETE",
                                headers: { "Content-Type": "application/json" } });
                            if (!response.ok) throw new Error("Delete failed");
                            showToast('Deleted successfully', 'check-circle');
                            setTimeout(() => location.reload(), 1000);
                        } catch (error) {
                            console.error(error);
                            showToast("Delete failed", "times-circle");
                        }
                    });
                });
            }

            function attachTableEvents() {
                document.querySelectorAll(".table-edit").forEach((btn) => {
                    btn.addEventListener("click", (e) => {
                        e.stopPropagation();
                        window.location.href = `/Admin/editproductForm/${btn.dataset.id}`;
                    });
                });
                document.querySelectorAll(".table-view").forEach((btn) => {
                    btn.addEventListener("click", (e) => {
                        e.stopPropagation();
                        window.location.href = `/Admin/singleProduct/${btn.dataset.id}`;
                    });
                });
                document.querySelectorAll(".table-deleted").forEach((card) => {
                    card.addEventListener("click", async (e) => {
                        e.stopPropagation();
                        const id = card.dataset.id;
                        try {
                            const response = await fetch(`${DELETED_URL}/${id}`, { method: "DELETE",
                                headers: { "Content-Type": "application/json" } });
                            if (!response.ok) throw new Error("Delete failed");
                            showToast('Deleted successfully', 'check-circle');
                            setTimeout(() => location.reload(), 1000);
                        } catch (error) {
                            console.error(error);
                            showToast("Delete failed", "times-circle");
                        }
                    });
                });
            }

            function formatPrice(price) {
                if (price === undefined || price === null) return "0.00";
                return Number(price).toFixed(2);
            }

            function escapeHtml(str) {
                if (!str) return "";
                return str.replace(/[&<>]/g, function(m) {
                    if (m === "&") return "&amp;";
                    if (m === "<") return "&lt;";
                    if (m === ">") return "&gt;";
                    return m;
                });
            }

            function setActiveView(view) {
                if (view === "cards") {
                    cardsViewDiv.classList.remove("hidden");
                    tableViewDiv.classList.add("hidden");
                    viewCardsBtn.classList.add("active-view");
                    viewTableBtn.classList.remove("active-view");
                    renderCards(getFilteredProducts());
                } else {
                    cardsViewDiv.classList.add("hidden");
                    tableViewDiv.classList.remove("hidden");
                    viewTableBtn.classList.add("active-view");
                    viewCardsBtn.classList.remove("active-view");
                    renderTable(getFilteredProducts());
                }
            }

            viewCardsBtn.addEventListener("click", () => setActiveView("cards"));
            viewTableBtn.addEventListener("click", () => setActiveView("table"));
            applyBtn.addEventListener("click", () => { renderCurrentView();
                showToast("Filters applied", "sliders-h"); });
            clearBtn.addEventListener("click", () => {
                categoryFilterSelect.value = "all";
                minPriceInput.value = "";
                maxPriceInput.value = "";
                stockFilterSelect.value = "all";
                searchInput.value = "";
                renderCurrentView();
                showToast("Filters cleared", "times-circle");
            });
            searchInput.addEventListener("input", () => renderCurrentView());

            const sidebar = document.getElementById("sidebar");
            const menuToggle = document.getElementById("menuToggle");
            const toggleSidebarBtn = document.getElementById("toggleSidebar");

            function toggleSidebarFunc() { sidebar.classList.toggle("active"); }
            if (menuToggle) menuToggle.addEventListener("click", toggleSidebarFunc);
            if (toggleSidebarBtn) toggleSidebarBtn.addEventListener("click", toggleSidebarFunc);

            document.getElementById("addProductBtn")?.addEventListener("click", () => {
                showToast("Redirect to add product form", "plus-circle");
                setTimeout(() => { window.location.href = '/admin/productForm'; }, 800);
            });

            document.querySelector(".user-info")?.addEventListener("click", () => showToast("User profile menu",
                "user"));

            fetchCategories().then(() => fetchProducts());
        })();
    </script>
</body>
</html>