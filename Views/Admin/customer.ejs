    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // ═══════════ NURAN PARTICLE BACKGROUND ═══════════
            const canvas = document.getElementById('nuranCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouseX = -999, mouseY = -999, targetMouseX = -999, targetMouseY = -999;
            const SPLATTER_RADIUS = 190, CONNECTION_DIST = 140, PARTICLE_COUNT = window.innerWidth < 768 ? 80 : 140;
            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            resize(); window.addEventListener('resize', () => { resize(); const nc = window.innerWidth<768?80:140; while(particles.length<nc) particles.push(createParticle()); while(particles.length>nc) particles.pop(); });
            function createParticle() {
                const cols = ['rgba(77,171,247,','rgba(56,189,248,','rgba(167,139,250,','rgba(139,92,246,','rgba(45,212,191,','rgba(96,165,250,','rgba(192,132,252,','rgba(52,211,153,'];
                const c = cols[Math.floor(Math.random()*cols.length)];
                return { x:Math.random()*canvas.width, y:Math.random()*canvas.height, vx:(Math.random()-0.5)*0.7, vy:(Math.random()-0.5)*0.7, size:1.8+Math.random()*3.5, color:c, glowAlpha:0.5+Math.random()*0.5, pulsePhase:Math.random()*Math.PI*2, pulseSpeed:0.008+Math.random()*0.025, baseSize:1.8+Math.random()*3.5 };
            }
            for(let i=0;i<PARTICLE_COUNT;i++) particles.push(createParticle());
            document.addEventListener('mousemove',e=>{ targetMouseX=e.clientX; targetMouseY=e.clientY; });
            document.addEventListener('mouseleave',()=>{ targetMouseX=-999; targetMouseY=-999; });
            document.addEventListener('touchmove',e=>{ if(e.touches.length>0){ targetMouseX=e.touches[0].clientX; targetMouseY=e.touches[0].clientY; } },{passive:true});
            document.addEventListener('touchend',()=>{ targetMouseX=-999; targetMouseY=-999; });
            function animate(ts) {
                mouseX+=(targetMouseX-mouseX)*0.18; mouseY+=(targetMouseY-mouseY)*0.18;
                ctx.clearRect(0,0,canvas.width,canvas.height);
                const time=ts*0.001;
                for(let p of particles) {
                    p.vx+=Math.sin(time*0.7+p.pulsePhase)*0.025; p.vy+=Math.cos(time*0.6+p.pulsePhase+1.3)*0.025;
                    if(mouseX>-500&&mouseY>-500){ const dx=p.x-mouseX,dy=p.y-mouseY,dist=Math.sqrt(dx*dx+dy*dy); if(dist<SPLATTER_RADIUS&&dist>0.5){ const force=(1-dist/SPLATTER_RADIUS)*4.5; p.vx+=(dx/dist)*force; p.vy+=(dy/dist)*force; p.glowAlpha=Math.min(1,p.glowAlpha+0.06); } }
                    p.x+=p.vx; p.y+=p.vy; p.vx*=0.94; p.vy*=0.94;
                    const sp=Math.sqrt(p.vx*p.vx+p.vy*p.vy); if(sp>6){ p.vx=(p.vx/sp)*6; p.vy=(p.vy/sp)*6; }
                    if(p.x<-30)p.x=canvas.width+30; if(p.x>canvas.width+30)p.x=-30; if(p.y<-30)p.y=canvas.height+30; if(p.y>canvas.height+30)p.y=-30;
                    p.size=p.baseSize+Math.sin(time*p.pulseSpeed*10+p.pulsePhase)*0.7;
                    p.glowAlpha+=(0.6-p.glowAlpha)*0.03;
                }
                for(let i=0;i<particles.length;i++) for(let j=i+1;j<particles.length;j++) {
                    const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,dist=Math.sqrt(dx*dx+dy*dy);
                    if(dist<CONNECTION_DIST){ const alpha=(1-dist/CONNECTION_DIST)*0.28, pulse=Math.sin(ts*0.003+i*0.4+j*0.3)*0.5+0.5; ctx.beginPath(); ctx.moveTo(particles[i].x,particles[i].y); ctx.lineTo(particles[j].x,particles[j].y); ctx.strokeStyle=`rgba(120,170,230,${alpha*(0.5+pulse*0.5)})`; ctx.lineWidth=0.6; ctx.stroke(); }
                }
                for(let p of particles) {
                    const grad=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.size*3.5);
                    grad.addColorStop(0,p.color+(p.glowAlpha*0.7)+')'); grad.addColorStop(0.35,p.color+(p.glowAlpha*0.25)+')'); grad.addColorStop(1,p.color+'0)');
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.size*3.5,0,Math.PI*2); ctx.fillStyle=grad; ctx.fill();
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.size*0.65,0,Math.PI*2); ctx.fillStyle=`rgba(255,255,255,${0.7+p.glowAlpha*0.3})`; ctx.fill();
                }
                if(mouseX>-500&&mouseY>-500){ const mg=ctx.createRadialGradient(mouseX,mouseY,0,mouseX,mouseY,SPLATTER_RADIUS*0.7); mg.addColorStop(0,'rgba(120,180,240,0.08)'); mg.addColorStop(0.5,'rgba(100,150,220,0.03)'); mg.addColorStop(1,'rgba(0,0,0,0)'); ctx.beginPath(); ctx.arc(mouseX,mouseY,SPLATTER_RADIUS*0.7,0,Math.PI*2); ctx.fillStyle=mg; ctx.fill(); }
                requestAnimationFrame(animate);
            }
            requestAnimationFrame(animate);

            // ═══════════ SIDEBAR TOGGLE ═══════════
            const sidebar = document.getElementById('sidebar');
            const mobileToggle = document.getElementById('mobileMenuToggle');
            const toggleSidebarBtn = document.getElementById('toggleSidebarBtn');
            function toggleSidebar() { sidebar.classList.toggle('active'); }
            mobileToggle?.addEventListener('click', toggleSidebar);
            toggleSidebarBtn?.addEventListener('click', () => { if(window.innerWidth<=992) sidebar.classList.toggle('active'); });

            // ═══════════ MODAL POPUP 2026 ═══════════
            function showModal(message, isSuccess = true) {
                const existing = document.querySelector('.modal-overlay');
                if(existing) existing.remove();
                const overlay = document.createElement('div');
                overlay.className = 'modal-overlay';
                const iconClass = isSuccess ? 'fa-check-circle' : 'fa-exclamation-triangle';
                const iconColor = isSuccess ? 'var(--accent-green)' : 'var(--accent-red)';
                overlay.innerHTML = `
                    <div class="modal-content">
                        <div class="modal-icon" style="color: ${iconColor};"><i class="fas ${iconClass}"></i></div>
                        <div class="modal-message">${message}</div>
                        <button class="modal-btn">OK</button>
                    </div>
                `;
                document.body.appendChild(overlay);
                const closeModal = () => {
                    overlay.style.opacity = '0';
                    overlay.style.transition = 'opacity 0.2s';
                    setTimeout(() => overlay.remove(), 200);
                };
                overlay.querySelector('.modal-btn').addEventListener('click', closeModal);
                overlay.addEventListener('click', (e) => { if(e.target === overlay) closeModal(); });
                setTimeout(closeModal, 3500);
            }

            // ═══════════ DATA & STATE ═══════════
            let allCustomers = [];
            let currentView = 'cards';
            let countData = null;

            const cardsView = document.getElementById('cardsView');
            const tableView = document.getElementById('tableView');
            const countsView = document.getElementById('countsView');
            const filterContainer = document.getElementById('filterContainer');
            const viewCardsBtn = document.getElementById('viewCardsBtn');
            const viewTableBtn = document.getElementById('viewTableBtn');
            const viewCountsBtn = document.getElementById('viewCountsBtn');
            const searchInput = document.getElementById('searchInput');
            const statusFilter = document.getElementById('statusFilter');
            const locationFilter = document.getElementById('locationFilter');
            const minOrdersInput = document.getElementById('minOrders');
            const applyFilterBtn = document.getElementById('applyFilterBtn');
            const clearFilterBtn = document.getElementById('clearFilterBtn');

            // Fetch customer stats (block/unblock counts)
            async function fetchStats() {
                try {
                    const res = await fetch('/admin/customers/blocks');
                    if(!res.ok) throw new Error('Failed');
                    const data = await res.json();
                    if(data.success) {
                        document.getElementById('totalCustomers').textContent = data.data.totalCustomers;
                        document.getElementById('activeCustomers').textContent = data.data.unblocked;
                        document.getElementById('blockedCustomers').textContent = data.data.blocked;
                    }
                } catch(err) {
                    console.error('Stats error:', err);
                }
            }

            // Fetch all customers
            async function fetchCustomers() {
                try {
                    const response = await fetch('/admin/customers');
                    if (!response.ok) throw new Error(`Server responded with ${response.status}`);
                    const result = await response.json();
                    if (!result.success || !Array.isArray(result.customers)) {
                        throw new Error('Invalid API response format');
                    }
                    return result.customers;
                } catch (error) {
                    console.error('Failed to fetch customers:', error);
                    showModal('Could not load customers. Using demo data.', false);
                    return [
                        { _id: '1', name: 'Emily Clark', email: 'emily.c@example.com', address: 'New York', joinedAt: '2021-02-15', isVerified: true, orderCount: 24, totalOrdersAmount: 1240, isBlocked: false, image: null },
                        { _id: '2', name: 'Michael Chen', email: 'm.chen@example.com', address: 'Los Angeles', joinedAt: '2019-11-03', isVerified: true, orderCount: 56, totalOrdersAmount: 5430, isBlocked: false, image: null },
                        { _id: '3', name: 'Sarah O\'Connor', email: 's.oconnor@example.com', address: 'Chicago', joinedAt: '2023-07-19', isVerified: false, orderCount: 3, totalOrdersAmount: 129, isBlocked: true, image: null },
                        { _id: '4', name: 'James Rodriguez', email: 'j.rod@example.com', address: 'Miami', joinedAt: '2022-09-10', isVerified: true, orderCount: 17, totalOrdersAmount: 890, isBlocked: false, image: null }
                    ];
                }
            }

            // Fetch customer counts
            async function fetchCounts() {
                try {
                    const res = await fetch('/admin/customers/count');
                    if(!res.ok) throw new Error('Failed to fetch counts');
                    const result = await res.json();
                    if(result.success) {
                        countData = result.data;
                        renderCounts();
                    } else {
                        showModal('Could not load count data.', false);
                    }
                } catch(err) {
                    console.error('Counts error:', err);
                    showModal('Error loading customer counts.', false);
                }
            }

            function normalizeCustomer(raw) {
                const name = raw.name || 'Unknown';
                const location = raw.address || '--';
                const joinDate = raw.joinedAt ? new Date(raw.joinedAt).toLocaleDateString('en-US', { month: '2-digit', year: 'numeric' }) : '--';
                const orders = typeof raw.orderCount === 'number' ? raw.orderCount : 0;
                const spent = typeof raw.totalOrdersAmount === 'number' ? raw.totalOrdersAmount : 0;
                const isBlocked = raw.isBlocked || false;
                const verified = raw.isVerified || false;
                let status = isBlocked ? 'blocked' : (verified ? 'active' : 'inactive');
                let avatar = null;
                if (raw.image && raw.image.filename) {
                    avatar = `/Uploads/Profile/${raw.image.filename}`;
                }
                return {
                    id: raw._id,
                    name,
                    email: raw.email || '',
                    location,
                    joinDate,
                    orders,
                    spent,
                    status,
                    isBlocked,
                    isVerified: verified,
                    avatar
                };
            }

            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // Render functions for list
            function renderCard(customer) {
                let badgeText = customer.status.toUpperCase();
                let badgeClass = 'badge-active';
                if (customer.status === 'blocked') badgeClass = 'badge-blocked';
                else if (customer.status === 'inactive') badgeClass = 'badge-inactive';
                const avatarUrl = customer.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(customer.name)}&background=${customer.isBlocked ? '9ca3af' : '2c6de9'}&color=fff&size=80`;
                const spentFormatted = `$${customer.spent.toLocaleString()}`;
                const blockBtnText = customer.isBlocked ? 'Unblock' : 'Block';
                const blockBtnClass = customer.isBlocked ? 'unblock-btn' : 'block-btn';

                return `
                <div class="customer-card" data-id="${customer.id}" data-status="${customer.status}" data-location="${escapeHtml(customer.location)}" data-orders="${customer.orders}" data-blocked="${customer.isBlocked}">
                    <span class="customer-badge ${badgeClass}">${badgeText}</span>
                    <div class="customer-avatar"><img src="${avatarUrl}" alt="${escapeHtml(customer.name)}"></div>
                    <div class="customer-info">
                        <h4>${escapeHtml(customer.name)}</h4>
                        <div class="customer-email">${escapeHtml(customer.email)}</div>
                        <div class="customer-detail-row">
                            <span><i class="fas fa-map-marker-alt"></i> ${escapeHtml(customer.location)}</span>
                            <span><i class="fas fa-calendar-alt"></i> ${customer.joinDate}</span>
                        </div>
                        <span class="customer-orders"><i class="fas fa-shopping-bag"></i> ${customer.orders} orders</span>
                    </div>
                    <div class="customer-footer">
                        <span>${spentFormatted} spent</span>
                        <span class="footer-status">${customer.status.charAt(0).toUpperCase() + customer.status.slice(1)}</span>
                    </div>
                    <div class="card-actions">
                        <button class="card-action-btn toggle-block-card ${blockBtnClass}" data-id="${customer.id}" data-blocked="${customer.isBlocked}">
                            <i class="fas fa-${customer.isBlocked ? 'unlock' : 'lock'}"></i> ${blockBtnText}
                        </button>
                        <button class="card-action-btn view-card" data-id="${customer.id}">
                            <i class="fas fa-eye"></i> View
                        </button>
                    </div>
                </div>`;
            }

            function renderTableRow(customer) {
                let statusClass = 'status-active';
                let statusText = 'Active';
                if (customer.status === 'blocked') { statusClass = 'status-blocked-table'; statusText = 'Blocked'; }
                else if (customer.status === 'inactive') { statusClass = 'status-inactive-table'; statusText = 'Inactive'; }
                const avatarUrl = customer.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(customer.name)}&background=${customer.isBlocked ? '9ca3af' : '2c6de9'}&color=fff&size=42`;
                const blockBtnText = customer.isBlocked ? 'Unblock' : 'Block';

                return `
                <tr data-id="${customer.id}" data-status="${customer.status}" data-location="${escapeHtml(customer.location)}" data-orders="${customer.orders}" data-blocked="${customer.isBlocked}">
                    <td>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div class="table-avatar"><img src="${avatarUrl}" style="width:42px;height:42px;border-radius:50%"></div>
                            ${escapeHtml(customer.name)}
                        </div>
                    </td>
                    <td>${escapeHtml(customer.email)}</td>
                    <td>${escapeHtml(customer.location)}</td>
                    <td>${customer.orders}</td>
                    <td>$${customer.spent.toLocaleString()}</td>
                    <td><span class="status-indicator ${statusClass}">${statusText}</span></td>
                    <td class="table-actions">
                        <button class="toggle-block-table btn btn-sm ${customer.isBlocked ? 'btn-outline-success' : 'btn-outline-danger'}" data-id="${customer.id}" data-blocked="${customer.isBlocked}">${blockBtnText}</button>
                        <button class="view-table btn btn-sm btn-outline-light ms-1"><i class="fas fa-eye"></i></button>
                    </td>
                </tr>`;
            }

            function renderAll(customers) {
                cardsView.innerHTML = '';
                const tbody = tableView.querySelector('tbody');
                tbody.innerHTML = '';

                if (customers.length === 0) {
                    cardsView.innerHTML = '<div class="text-center py-5 w-100"><i class="fas fa-user-slash fa-2x text-muted"></i><p>No customers found.</p></div>';
                    tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4">No customers to display.</td></tr>';
                    return;
                }

                const cardsHTML = customers.map(c => renderCard(c)).join('');
                cardsView.innerHTML = cardsHTML;

                const rowsHTML = customers.map(c => renderTableRow(c)).join('');
                tbody.innerHTML = rowsHTML;
            }

            // Block/Unblock handler – now correctly uses isVerified
            async function toggleCustomerBlock(customerId, currentlyBlocked) {
                const endpoint = currentlyBlocked ?
                    `/admin/customer/unblock/${customerId}` :
                    `/admin/customer/block/${customerId}`;
                try {
                    const response = await fetch(endpoint, { method: 'PUT' });
                    const data = await response.json();
                    if (!data.success) throw new Error(data.message || 'Operation failed');
                    const customer = allCustomers.find(c => c.id === customerId);
                    if (customer) {
                        customer.isBlocked = !currentlyBlocked;
                        // Determine new status based on isVerified (stored in customer object)
                        customer.status = customer.isBlocked ? 'blocked' : (customer.isVerified ? 'active' : 'inactive');
                        updateCustomerElement(customer);
                    }
                    showModal(data.message, true);
                    fetchStats();
                } catch (error) {
                    console.error(error);
                    showModal(error.message, false);
                }
            }

            function updateCustomerElement(customer) {
                // Update card
                const card = document.querySelector(`.customer-card[data-id="${customer.id}"]`);
                if (card) {
                    // Update badge
                    const badge = card.querySelector('.customer-badge');
                    badge.textContent = customer.status.toUpperCase();
                    badge.className = 'customer-badge';
                    if (customer.status === 'blocked') badge.classList.add('badge-blocked');
                    else if (customer.status === 'inactive') badge.classList.add('badge-inactive');
                    else badge.classList.add('badge-active');
                    card.dataset.status = customer.status;
                    card.dataset.blocked = customer.isBlocked;

                    // Update footer status text
                    const footerStatus = card.querySelector('.footer-status');
                    if (footerStatus) {
                        footerStatus.textContent = customer.status.charAt(0).toUpperCase() + customer.status.slice(1);
                    }

                    // Update block button
                    const blockBtn = card.querySelector('.toggle-block-card');
                    const newBlocked = customer.isBlocked;
                    blockBtn.dataset.blocked = newBlocked;
                    blockBtn.innerHTML = `<i class="fas fa-${newBlocked ? 'unlock' : 'lock'}"></i> ${newBlocked ? 'Unblock' : 'Block'}`;
                    blockBtn.className = `card-action-btn toggle-block-card ${newBlocked ? 'unblock-btn' : 'block-btn'}`;
                }

                // Update table row
                const row = document.querySelector(`#tableView tbody tr[data-id="${customer.id}"]`);
                if (row) {
                    const statusCell = row.querySelector('.status-indicator');
                    if (statusCell) {
                        let cls = 'status-active';
                        let txt = 'Active';
                        if (customer.status === 'blocked') { cls = 'status-blocked-table'; txt = 'Blocked'; }
                        else if (customer.status === 'inactive') { cls = 'status-inactive-table'; txt = 'Inactive'; }
                        statusCell.textContent = txt;
                        statusCell.className = `status-indicator ${cls}`;
                    }
                    const blockBtn = row.querySelector('.toggle-block-table');
                    if (blockBtn) {
                        blockBtn.textContent = customer.isBlocked ? 'Unblock' : 'Block';
                        blockBtn.dataset.blocked = customer.isBlocked;
                        blockBtn.className = `btn btn-sm ${customer.isBlocked ? 'btn-outline-success' : 'btn-outline-danger'} toggle-block-table`;
                    }
                    row.dataset.status = customer.status;
                    row.dataset.blocked = customer.isBlocked;
                }
            }

            // Filtering
            function getFilteredCustomers() {
                const statusVal = statusFilter.value;
                const locationVal = locationFilter.value;
                const minOrders = parseInt(minOrdersInput.value, 10) || 0;
                const searchTerm = searchInput.value.trim().toLowerCase();
                return allCustomers.filter(customer => {
                    if (statusVal !== 'all' && customer.status !== statusVal) return false;
                    if (locationVal !== 'all' && customer.location !== locationVal) return false;
                    if (customer.orders < minOrders) return false;
                    if (searchTerm) {
                        return customer.name.toLowerCase().includes(searchTerm) || customer.email.toLowerCase().includes(searchTerm);
                    }
                    return true;
                });
            }

            function applyFilters() {
                const filtered = getFilteredCustomers();
                const visibleIds = new Set(filtered.map(c => c.id));
                document.querySelectorAll('#cardsView .customer-card').forEach(card => {
                    card.style.display = visibleIds.has(card.dataset.id) ? '' : 'none';
                });
                document.querySelectorAll('#tableView tbody tr').forEach(row => {
                    if (row.dataset.id) row.style.display = visibleIds.has(row.dataset.id) ? '' : 'none';
                });
            }

            function clearFilters() {
                statusFilter.value = 'all';
                locationFilter.value = 'all';
                minOrdersInput.value = '';
                searchInput.value = '';
                document.querySelectorAll('#cardsView .customer-card, #tableView tbody tr').forEach(el => el.style.display = '');
            }

            // View toggle (Cards/Table/Counts)
            function setView(view) {
                currentView = view;
                [cardsView, tableView, countsView].forEach(el => el.classList.add('d-none'));
                viewCardsBtn.classList.remove('active-view');
                viewTableBtn.classList.remove('active-view');
                viewCountsBtn.classList.remove('active-view');
                if (view === 'cards') {
                    cardsView.classList.remove('d-none');
                    viewCardsBtn.classList.add('active-view');
                    filterContainer.style.display = 'flex';
                } else if (view === 'table') {
                    tableView.classList.remove('d-none');
                    viewTableBtn.classList.add('active-view');
                    filterContainer.style.display = 'flex';
                } else if (view === 'counts') {
                    countsView.classList.remove('d-none');
                    viewCountsBtn.classList.add('active-view');
                    filterContainer.style.display = 'none';
                    if (!countData) fetchCounts();
                }
            }

            // Render count tables & cards
            function renderCounts() {
                if (!countData) return;
                const { yearly, monthly, weekly, daily } = countData;

                const mapReduce = (arr, keyFunc, labelFunc) => {
                    const map = new Map();
                    arr.forEach(item => {
                        const period = keyFunc(item._id);
                        const isBlocked = item._id.isBlocked;
                        const count = item.count;
                        if (!map.has(period)) {
                            map.set(period, { active: 0, blocked: 0 });
                        }
                        if (isBlocked) {
                            map.get(period).blocked += count;
                        } else {
                            map.get(period).active += count;
                        }
                    });
                    return Array.from(map, ([period, counts]) => ({
                        periodLabel: labelFunc(period),
                        ...counts,
                        total: counts.active + counts.blocked
                    }));
                };

                function renderCards(data, containerId, cardFormat) {
                    const container = document.getElementById(containerId);
                    container.innerHTML = data.map(r => {
                        const periodDisplay = cardFormat(r);
                        return `
                        <div class="count-card">
                            <div class="period">${periodDisplay}</div>
                            <div class="d-flex gap-3">
                                <div><span class="label">Active</span><div class="value">${r.active}</div></div>
                                <div><span class="label">Blocked</span><div class="value">${r.blocked}</div></div>
                                <div><span class="label">Total</span><div class="value">${r.total}</div></div>
                            </div>
                        </div>`;
                    }).join('');
                }

                // Yearly data
                const yearlyProcessed = mapReduce(yearly, id => id.year, p => p.toString()).sort((a,b) => a.periodLabel - b.periodLabel);
                document.getElementById('yearlyTable').innerHTML = yearlyProcessed.map(r => `
                    <tr><td>${r.periodLabel}</td><td>${r.active}</td><td>${r.blocked}</td><td>${r.total}</td></tr>
                `).join('') || '<tr><td colspan="4">No data</td></tr>';
                renderCards(yearlyProcessed, 'yearlyCards', r => `Year ${r.periodLabel}`);

                // Monthly data
                const monthlyProcessed = mapReduce(monthly, id => `${id.year}-${String(id.month).padStart(2,'0')}`, p => p)
                    .sort((a,b) => a.periodLabel.localeCompare(b.periodLabel));
                document.getElementById('monthlyTable').innerHTML = monthlyProcessed.map(r => {
                    const [year, month] = r.periodLabel.split('-');
                    return `<tr><td>${year}</td><td>${month}</td><td>${r.active}</td><td>${r.blocked}</td><td>${r.total}</td></tr>`;
                }).join('') || '<tr><td colspan="5">No data</td></tr>';
                renderCards(monthlyProcessed, 'monthlyCards', r => r.periodLabel.replace('-', ' Month '));

                // Weekly data
                const weeklyProcessed = mapReduce(weekly, id => `${id.year}-W${String(id.week).padStart(2,'0')}`, p => p)
                    .sort((a,b) => a.periodLabel.localeCompare(b.periodLabel));
                document.getElementById('weeklyTable').innerHTML = weeklyProcessed.map(r => {
                    const [year, week] = r.periodLabel.split('-');
                    return `<tr><td>${year}</td><td>${week}</td><td>${r.active}</td><td>${r.blocked}</td><td>${r.total}</td></tr>`;
                }).join('') || '<tr><td colspan="5">No data</td></tr>';
                renderCards(weeklyProcessed, 'weeklyCards', r => r.periodLabel);

                // Daily data
                const dailyProcessed = mapReduce(daily, id => `${id.year}-${String(id.month).padStart(2,'0')}-${String(id.day).padStart(2,'0')}`, p => p)
                    .sort((a,b) => a.periodLabel.localeCompare(b.periodLabel));
                document.getElementById('dailyTable').innerHTML = dailyProcessed.map(r => {
                    const dateStr = new Date(r.periodLabel).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
                    return `<tr><td>${dateStr}</td><td>${r.active}</td><td>${r.blocked}</td><td>${r.total}</td></tr>`;
                }).join('') || '<tr><td colspan="4">No data</td></tr>';
                renderCards(dailyProcessed, 'dailyCards', r => new Date(r.periodLabel).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }));
            }

            // Event listeners for views
            viewCardsBtn.addEventListener('click', () => setView('cards'));
            viewTableBtn.addEventListener('click', () => setView('table'));
            viewCountsBtn.addEventListener('click', () => setView('counts'));
            applyFilterBtn.addEventListener('click', applyFilters);
            clearFilterBtn.addEventListener('click', clearFilters);
            searchInput.addEventListener('input', () => { setTimeout(applyFilters, 300); });

            // Delegation for block/unblock and view actions
            cardsView.addEventListener('click', (e) => {
                const blockBtn = e.target.closest('.toggle-block-card');
                if (blockBtn) {
                    e.stopPropagation();
                    const customerId = blockBtn.dataset.id;
                    const currentlyBlocked = blockBtn.dataset.blocked === 'true';
                    toggleCustomerBlock(customerId, currentlyBlocked);
                    return;
                }
                const viewBtn = e.target.closest('.view-card');
                if (viewBtn) {
                    e.stopPropagation();
                    window.location.href = `/admin/customerDetails/${viewBtn.dataset.id}`;
                }
            });

            tableView.addEventListener('click', (e) => {
                const blockBtn = e.target.closest('.toggle-block-table');
                if (blockBtn) {
                    e.stopPropagation();
                    const customerId = blockBtn.dataset.id;
                    const currentlyBlocked = blockBtn.dataset.blocked === 'true';
                    toggleCustomerBlock(customerId, currentlyBlocked);
                    return;
                }
                const viewBtn = e.target.closest('.view-table');
                if (viewBtn) {
                    e.stopPropagation();
                    const row = viewBtn.closest('tr');
                    if (row && row.dataset.id) {
                        window.location.href = `/admin/customerDetails/${row.dataset.id}`;
                    }
                }
            });

            // Update location dropdown from data
            function updateLocationDropdown(customers) {
                const cities = [...new Set(customers.map(c => c.location).filter(Boolean))].sort();
                locationFilter.innerHTML = '<option value="all">All cities</option>';
                cities.forEach(city => {
                    const option = document.createElement('option');
                    option.value = city;
                    option.textContent = city;
                    locationFilter.appendChild(option);
                });
            }

            // Initialize
            async function init() {
                await fetchStats();
                const rawData = await fetchCustomers();
                allCustomers = rawData.map(normalizeCustomer);
                updateLocationDropdown(allCustomers);
                renderAll(allCustomers);
                // Prefetch counts
                fetchCounts();
            }
            init();
        })();
    </script>
</body>
</html>