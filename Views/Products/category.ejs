        }

        .modal-premium .btn-modal-action {
            padding: 10px 28px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .modal-premium .btn-modal-primary {
            background: var(--gradient-1);
