<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>ShopMaster · Orders 2026</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --bg-deep: #060b1f;
            --bg-card: rgba(10, 16, 36, 0.65);
            --bg-sidebar: rgba(7, 11, 28, 0.82);
            --bg-header: rgba(9, 14, 32, 0.7);
            --primary: #4dabf7;
            --primary-glow: #339af0;
            --accent-cyan: #38bdf8;
            --accent-green: #34d399;
            --accent-red: #f87171;
            --accent-orange: #fb923c;
            --text-primary: #e8ecf4;
            --text-secondary: #b0bdd0;
            --text-muted: #7b8ca6;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(77, 171, 247, 0.3);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.45), 0 1px 0 rgba(255, 255, 255, 0.04) inset;
            --shadow-glow: 0 0 40px rgba(77, 171, 247, 0.18);
            --radius-xl: 22px;
            --radius-lg: 16px;
            --radius-md: 12px;
            --transition: all 0.3s ease;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }
        body {
            background: radial-gradient(ellipse at 20% 20%, #0b1430 0%, #060b1f 45%, #04091a 70%, #020617 100%);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
            display: flex;
        }
        #nuranCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }
        .sidebar {
            width: 280px;
            background: var(--bg-sidebar);
            backdrop-filter: blur(26px);
            -webkit-backdrop-filter: blur(26px);
            color: var(--text-primary);
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            border-right: 1px solid var(--border-subtle);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        .sidebar-header {
            padding: 0 20px 18px 20px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo-text {
            font-size: 1.6rem;
            font-weight: 700;
            background: linear-gradient(135deg, #e8ecf4 0%, #a0c8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .logo-subtext {
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }
        .toggle-sidebar {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 36px;
            height: 36px;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            font-size: 1rem;
        }
        .toggle-sidebar:hover {
            background: rgba(77, 171, 247, 0.15);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.25);
        }
        .sidebar-menu {
            flex: 1;
            padding: 20px 0;
        }
        .menu-item {
            display: flex;
            align-items: center;
            padding: 13px 20px;
            margin: 3px 10px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            border-radius: 10px;
            cursor: pointer;
            font-weight: 450;
            border: 1px solid transparent;
        }
        .menu-item:hover {
            background: rgba(77, 171, 247, 0.08);
            color: var(--text-primary);
            border-color: rgba(77, 171, 247, 0.2);
        }
        .menu-item.active-menu {
            background: rgba(77, 171, 247, 0.13);
            color: #fff;
            border-color: rgba(77, 171, 247, 0.35);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.15);
            position: relative;
        }
        .menu-item.active-menu::before {
            content: '';
            position: absolute;
            left: -2px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 22px;
            border-radius: 0 4px 4px 0;
            background: var(--accent-cyan);
            box-shadow: 0 0 14px var(--accent-cyan);
        }
        .menu-item i {
            width: 24px;
            font-size: 1.15rem;
            margin-right: 14px;
            text-align: center;
        }
        .menu-text {
            font-size: 0.95rem;
        }
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 22px 30px;
            transition: margin-left 0.35s ease;
            width: 100%;
            position: relative;
            z-index: 1;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-header);
            backdrop-filter: blur(22px);
            -webkit-backdrop-filter: blur(22px);
            padding: 14px 26px;
            border-radius: 50px;
            box-shadow: var(--shadow-card);
            margin-bottom: 28px;
            border: 1px solid var(--border-subtle);
            flex-wrap: wrap;
            gap: 14px;
        }
        .menu-toggle {
            display: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            width: 44px;
            height: 44px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1.2rem;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
        }
        .menu-toggle:hover {
            border-color: var(--border-glow);
            box-shadow: 0 0 18px rgba(56, 189, 248, 0.2);
            color: var(--accent-cyan);
        }
        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            padding: 8px 20px;
            width: min(400px, 100%);
            border: 1px solid var(--border-subtle);
            transition: var(--transition);
        }
        .search-bar:focus-within {
            border-color: var(--border-glow);
            box-shadow: 0 0 14px rgba(77, 171, 247, 0.15);
        }
        .search-bar input {
            border: none;
            background: transparent;
            padding: 8px 10px;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
            color: var(--text-primary);
        }
        .search-bar input::placeholder {
            color: var(--text-muted);
        }
        .search-bar i {
            color: var(--text-muted);
        }
        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .notification-btn {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-subtle);
            font-size: 1.15rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 10px 12px;
            border-radius: 50%;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .notification-btn:hover {
            background: rgba(77, 171, 247, 0.12);
            border-color: var(--border-glow);
            color: var(--accent-cyan);
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.2);
        }
        .notification-badge {
            position: absolute;
            top: 2px;
            right: 3px;
            background: var(--accent-red);
            color: #fff;
            font-size: 0.6rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 5px 18px 5px 8px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            border: 1px solid var(--border-subtle);
            cursor: pointer;
        }
        .user-info img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid rgba(77, 171, 247, 0.5);
            object-fit: cover;
        }
        .user-details h4 {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }
        .user-details p {
            font-size: 0.7rem;
            color: var(--text-muted);
            margin: 0;
        }
        .revenue-summary {
            display: flex;
            gap: 20px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .revenue-card {
            flex: 1 1 200px;
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: var(--radius-xl);
            padding: 20px;
            border: 1px solid var(--border-subtle);
            box-shadow: var(--shadow-card);
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .revenue-card i {
            font-size: 2rem;
            color: var(--accent-cyan);
        }
        .revenue-info h5 {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 4px;
        }
        .revenue-info .revenue-value {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text-primary);
        }
        .page-controls {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }
        .page-controls h2 {
            font-size: 1.8rem;
            color: var(--text-primary);
            white-space: nowrap;
        }
        .filter-section {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
            max-width: 100%;
        }
        .filter-row {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
            width: 100%;
            max-width: 100%;
        }
        .filter-dropdown {
            position: relative;
            display: inline-block;
            max-width: 100%;
        }
        .filter-btn {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            box-shadow: var(--shadow-card);
            transition: var(--transition);
            color: var(--text-primary);
            white-space: nowrap;
            width: auto;
            max-width: 100%;
        }
        .filter-btn:hover {
            border-color: var(--border-glow);
            background: rgba(77, 171, 247, 0.08);
        }
        .filter-btn i {
            color: var(--primary);
        }
        .filter-badge {
            background: var(--bg-card);
            padding: 8px 20px;
            border-radius: 40px;
            border: 1px solid var(--border-subtle);
            box-shadow: var(--shadow-card);
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-primary);
            white-space: nowrap;
            width: auto;
            max-width: 100%;
        }
        .filter-badge i {
            color: var(--primary);
        }
        .filter-menu {
            position: absolute;
            top: 55px;
            right: 0;
            background: rgba(10, 16, 36, 0.95);
            backdrop-filter: blur(16px);
            border-radius: 20px;
            box-shadow: 0 20px 35px rgba(0, 0, 0, 0.5);
            width: 240px;
            padding: 16px 0;
            z-index: 100;
            border: 1px solid var(--border-subtle);
            display: none;
        }
        .filter-menu.show {
            display: block;
        }
        .filter-menu-item {
            padding: 12px 22px;
            display: flex;
            align-items: center;
            gap: 14px;
            cursor: pointer;
            transition: 0.2s;
            color: var(--text-secondary);
        }
        .filter-menu-item:hover {
            background: rgba(77, 171, 247, 0.1);
            color: var(--text-primary);
        }
        .filter-menu-item i {
            width: 20px;
        }
        .active-filter-tag {
            background: rgba(77, 171, 247, 0.1);
            padding: 5px 15px;
            border-radius: 40px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--accent-cyan);
            font-size: 0.85rem;
            font-weight: 500;
            flex-wrap: wrap;
            max-width: 100%;
            white-space: nowrap;
            width: auto;
        }
        .clear-filter {
            cursor: pointer;
            margin-left: 6px;
            color: var(--accent-red);
        }
        .filter-input-group {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 40px;
            padding: 6px 16px;
            box-shadow: var(--shadow-card);
            transition: var(--transition);
            width: auto;
            max-width: 100%;
        }
        .filter-input-group:focus-within {
            border-color: var(--border-glow);
            box-shadow: 0 0 14px rgba(77, 171, 247, 0.15);
        }
        .filter-input-group input {
            border: none;
            background: transparent;
            outline: none;
            font-size: 0.9rem;
            padding: 4px 4px;
            color: var(--text-primary);
            width: 100%;
            min-width: 80px;
        }
        .filter-input-group input[type="date"] {
            width: auto;
            min-width: 110px;
        }
        .date-separator {
            color: var(--text-muted);
            font-weight: 500;
            margin: 0 4px;
        }
        .view-toggle {
            display: flex;
            gap: 6px;
            background: var(--bg-card);
            padding: 6px;
            border-radius: 50px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-subtle);
            white-space: nowrap;
        }
        .view-btn {
            border: none;
            background: transparent;
            padding: 10px 22px;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            color: var(--text-secondary);
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .view-btn.active-view {
            background: var(--primary);
            color: #fff;
        }
        .table-wrapper {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: var(--radius-xl);
            padding: 20px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-subtle);
            overflow-x: auto;
            transition: var(--transition);
        }
        .table-wrapper.hidden {
            display: none;
        }
        .orders-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1000px;
            color: var(--text-primary);
        }
        .orders-table th {
            text-align: left;
            padding: 16px 12px;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid var(--border-subtle);
        }
        .orders-table td {
            padding: 16px 12px;
            border-bottom: 1px solid var(--border-subtle);
            cursor: pointer;
            transition: background 0.15s;
            vertical-align: middle;
        }
        .orders-table tbody tr:hover td {
            background: rgba(77, 171, 247, 0.06);
        }
        .status {
            padding: 5px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            white-space: nowrap;
        }
        .status-completed,
        .status-delivered {
            background: rgba(52, 211, 153, 0.15);
            color: var(--accent-green);
            border: 1px solid rgba(52, 211, 153, 0.3);
        }
        .status-confirmed {
            background: rgba(56, 189, 248, 0.15);
            color: var(--accent-cyan);
            border: 1px solid rgba(56, 189, 248, 0.3);
        }
        .status-processing,
        .status-shipped,
        .status-packed,
        .status-out_for_delivery {
            background: rgba(251, 146, 60, 0.15);
            color: var(--accent-orange);
            border: 1px solid rgba(251, 146, 60, 0.3);
        }
        .status-pending {
            background: rgba(248, 113, 113, 0.15);
            color: var(--accent-red);
            border: 1px solid rgba(248, 113, 113, 0.3);
        }
        .status-cancelled,
        .status-deliveryFailed {
            background: rgba(239, 68, 68, 0.1);
            color: #991b1b;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }
        .status-return_requested {
            background: rgba(251, 191, 36, 0.15);
            color: #f59e0b;
            border: 2px solid #f59e0b;
            animation: pulse-border 2s infinite;
        }
        .status-return_approved {
            background: rgba(52, 211, 153, 0.1);
            color: var(--accent-green);
            border: 1px solid rgba(52, 211, 153, 0.3);
        }
        .status-returned {
            background: rgba(16, 185, 129, 0.15);
            color: var(--accent-green);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        .status-return_expired {
            background: rgba(239, 68, 68, 0.15);
            color: var(--accent-red);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .status-return_rejected {
            background: rgba(107, 114, 128, 0.15);
            color: #9ca3af;
            border: 1px solid rgba(107, 114, 128, 0.3);
        }
        .payment-online {
            background: rgba(77, 171, 247, 0.15);
            color: var(--accent-cyan);
            border: 1px solid rgba(77, 171, 247, 0.35);
            padding: 5px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            white-space: nowrap;
        }
        .payment-cod {
            background: rgba(251, 191, 36, 0.12);
            color: #f59e0b;
            border: 1px solid rgba(251, 191, 36, 0.3);
            padding: 5px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            white-space: nowrap;
        }
        .razorpay-cell {
            font-family: 'Courier New', monospace;
            font-size: 0.78rem;
            color: var(--text-secondary);
            max-width: 160px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            cursor: pointer;
            transition: var(--transition);
        }
        .razorpay-cell:hover {
            color: var(--accent-cyan);
        }
        @keyframes pulse-border {
            0%, 100% {
                border-color: #f59e0b;
                box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.35);
            }
            50% {
                border-color: #d97706;
                box-shadow: 0 0 0 8px rgba(245, 158, 11, 0);
            }
        }
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
            transition: var(--transition);
        }
        .cards-grid.hidden {
            display: none;
        }
        .order-card {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: var(--radius-xl);
            padding: 20px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-subtle);
            transition: var(--transition);
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 14px;
            position: relative;
            overflow: hidden;
        }
        .order-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-glow);
            border-color: var(--border-glow);
        }
        .order-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(90deg, var(--primary), var(--accent-cyan));
        }
        .card-header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        .order-id {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--accent-cyan);
            background: rgba(77, 171, 247, 0.15);
            padding: 4px 14px;
            border-radius: 40px;
            letter-spacing: 0.3px;
        }
        .status-badges {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .customer-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 5px 0;
        }
        .customer-avatar {
            width: 42px;
            height: 42px;
            background: rgba(77, 171, 247, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-cyan);
            font-weight: bold;
            font-size: 1.1rem;
            border: 2px solid var(--border-glow);
        }
        .customer-info h4 {
            font-size: 1rem;
            color: var(--text-primary);
        }
        .customer-info p {
            font-size: 0.8rem;
            color: var(--text-muted);
        }
        .order-detail-row {
            display: flex;
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.03);
            padding: 14px 16px;
            border-radius: 20px;
            margin: 6px 0;
        }
        .detail-item {
            text-align: center;
        }
        .detail-label {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
        }
        .detail-value {
            font-weight: 700;
            font-size: 1rem;
            color: var(--text-primary);
        }
        .products-preview {
            font-size: 0.85rem;
            color: var(--text-secondary);
            background: rgba(77, 171, 247, 0.05);
            padding: 10px 16px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .products-preview i {
            color: var(--primary);
        }
        .preview-image {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid var(--border-subtle);
        }
        .approval-row {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(245, 158, 11, 0.1);
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #f59e0b;
            border-left: 4px solid #f59e0b;
        }
        .approval-row i {
            color: #f59e0b;
        }
        .payment-info-row {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(77, 171, 247, 0.06);
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
            border-left: 4px solid var(--accent-cyan);
            flex-wrap: wrap;
        }
        .payment-info-row i {
            color: var(--accent-cyan);
        }
        .razorpay-detail {
            font-family: 'Courier New', monospace;
            font-size: 0.72rem;
            color: var(--text-secondary);
            background: rgba(255, 255, 255, 0.03);
            padding: 3px 10px;
            border-radius: 10px;
            white-space: nowrap;
        }
        .countdown-timer-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.02);
            padding: 6px 12px;
            border-radius: 12px;
            border: 2px solid rgba(245, 158, 11, 0.3);
            font-weight: 600;
            flex-shrink: 0;
            justify-content: center;
            margin-top: 4px;
            width: 100%;
            box-sizing: border-box;
        }
        .countdown-timer-wrap.urgent {
            border-color: #f97316;
            background: rgba(249, 115, 22, 0.1);
            animation: urgent-pulse 1s infinite;
        }
        .countdown-timer-wrap.expired-timer {
            border-color: var(--accent-red);
            background: rgba(248, 113, 113, 0.05);
        }
        .timer-text {
            font-size: 1rem;
            font-variant-numeric: tabular-nums;
            font-family: 'Courier New', monospace;
            letter-spacing: 1px;
            color: #f59e0b;
        }
        .timer-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: #a16207;
            letter-spacing: 0.5px;
        }
        .urgent .timer-text {
            color: #f97316;
        }
        .expired-timer .timer-text {
            color: var(--accent-red);
        }
        @keyframes urgent-pulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.4);
            }
            50% {
                box-shadow: 0 0 0 10px rgba(249, 115, 22, 0);
            }
        }
        .card-footer {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            border-top: 1px solid var(--border-subtle);
            padding-top: 12px;
            margin-top: 4px;
        }
        .btn {
            padding: 8px 18px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-primary {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            color: white;
        }
        .btn-outline {
            background: transparent;
            border: 2px solid var(--border-glow);
            color: var(--text-secondary);
        }
        .btn:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
        }
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeInOverlay 0.25s ease;
        }
        .modal-content {
            background: linear-gradient(145deg, rgba(18, 28, 52, 0.95), rgba(10, 18, 40, 0.95));
            backdrop-filter: blur(16px);
            border: 1px solid var(--border-glow);
            border-radius: 24px;
            padding: 32px 36px;
            max-width: 420px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6), 0 0 30px rgba(77, 171, 247, 0.3);
            animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .modal-icon {
            font-size: 3rem;
            margin-bottom: 16px;
        }
        .modal-message {
            font-size: 1.15rem;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 24px;
            line-height: 1.5;
        }
        .modal-btn {
            background: linear-gradient(135deg, #4dabf7, #339af0);
            border: none;
            padding: 12px 32px;
            border-radius: 40px;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 4px 12px rgba(77, 171, 247, 0.3);
        }
        .modal-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(77, 171, 247, 0.4);
        }
        @keyframes fadeInOverlay { from { opacity: 0; } to { opacity: 1; } }
        @keyframes scaleIn { 0% { transform: scale(0.7); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }

        /* RESPONSIVE */
        @media (max-width: 1200px) { .cards-grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); } .orders-table { min-width: 900px; } }
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); } .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 16px; } .menu-toggle { display: flex; }
            .header { flex-direction: column; align-items: stretch; }
            .search-bar { width: 100%; } .header-actions { justify-content: flex-end; }
            .page-controls { flex-direction: column; align-items: stretch; }
            .filter-section { flex-direction: column; align-items: stretch; gap: 10px; width: 100%; }
            .filter-row { flex-direction: column; align-items: stretch; gap: 10px; width: 100%; }
            .filter-dropdown, .filter-btn, .filter-input-group, .filter-badge, .active-filter-tag { width: 100%; max-width: 100%; }
            .filter-btn { justify-content: space-between; }
            .filter-input-group { width: 100%; }
            .filter-input-group input[type="date"] { width: auto; min-width: 0; flex: 1 1 auto; }
            .view-toggle { align-self: flex-end; }
            .revenue-card { flex: 1 1 150px; }
        }
        @media (max-width: 768px) { .cards-grid { grid-template-columns: 1fr; } .page-controls h2 { font-size: 1.5rem; } .active-filter-tag { white-space: normal; } }
        @media (max-width: 480px) {
            .filter-input-group.date-range-group { flex-direction: column; align-items: flex-start; }
            .filter-input-group.date-range-group input[type="date"] { width: 100%; min-width: auto; }
            .filter-input-group.date-range-group .date-separator { display: none; }
            .view-btn { padding: 8px 14px; font-size: 0.8rem; }
            .filter-btn { padding: 8px 16px; font-size: 0.85rem; }
            .filter-input-group input { font-size: 0.8rem; }
            .order-card { padding: 16px; }
            .card-footer { flex-direction: column; align-items: stretch; } .btn { justify-content: center; }
        }
    </style>
</head>
<body>
    <canvas id="nuranCanvas"></canvas>

    <!-- SIDEBAR -->
