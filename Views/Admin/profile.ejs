                    <div class="pref-item"><div><div class="pref-title">Email notifications</div><div class="pref-desc">Order updates, alerts, newsletters</div></div><div class="toggle-switch active" id="toggleEmailNotif"></div></div>
                    <div class="pref-item"><div><div class="pref-title">Session timeout</div><div class="pref-desc">Auto‑logout after 30 min</div></div><div class="toggle-switch" id="toggleTimeout"></div></div>
